surface.md","reason":"document analyzer seam + [metrics] extra + external CLIs"},{"path":"docs/user-guide.md","reason":"document [code_health] config keys, tool prereqs, Unavailable fallback"},{"path":"AGENTS.md","reason":"update the one-line metrics pointer if description changed"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","839b-f6d2-7e1a-4051"],["relates_to","0734-ceae-be55-4fa7"]],"parent_id":"839b-f6d2-7e1a-4051","parent_status_uuid":"c14d7e5e-a2b7-42ae-9ce6-4e800d42df77","plan_review_phase":"execution","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":["metrics","code-health"],"ticket_id":"a9dd-041f-de89-48c5","ticket_type":"task","title":"Docs: the [metrics] extra, [code_health] config, adapter set, and the fallback contract","verify_commands":[]},"source_event_uuids":["c0a65224-420a-488a-955a-72152f2e2fd9","2699fcf6-61d4-4706-b914-6a110df816e3","21f15d92-b7b1-4fe7-88fb-d298d88683c6","c2a25993-9240-4469-82a8-e456290a8587","5c98b6aa-e0c6-48af-9acf-640ffbc2fe79","8284b393-c5e2-414a-b354-abfc9759d007","0ba326de-af15-40fb-bbc3-375b79ce5f55","c7de7be6-fed8-4280-a3f8-a9b58b65aa0b","50b655d1-7efa-4eaa-abcc-e937e48b68b9","731cdf6c-b082-49fb-a4f9-1c32f5e58e84","c14d7e5e-a2b7-42ae-9ce6-4e800d42df77","f92a838a-b642-4b43-b079-cfec984b22cb","f3acfff6-c3d5-4be8-9e25-f9f1ba82994c"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784873945980326002,"uuid":"265c2cd0-c6ad-42d6-ad26-82004a721b7c"}