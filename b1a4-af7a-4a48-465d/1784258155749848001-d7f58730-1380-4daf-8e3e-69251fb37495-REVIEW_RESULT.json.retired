{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","author_sig":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","data":{"coaching":[{"coaching":"Pin down sidecar round selection for join and has_strong_finding with a concrete worked example.","decision":"block","finding_refs":["f2128916167e029d4","fd2f3ae3b4399c920","f90dc2241c9567ff7"],"move_id":"6","move_name":"specification by example","subject":"sidecar round selection for join and has_strong_finding"},{"coaching":"Plan how empty-join harness behavior under no-sidecar corpus will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f0fb3d1a61f2c6a88"],"move_id":"9","move_name":"plan the verification","subject":"empty-join harness behavior under no-sidecar corpus"},{"coaching":"Pin down sample_counts sub-field schema and semantics with a concrete worked example.","decision":"advisory","finding_refs":["f0dd45ec0a4954fa1","f9e361c0892426c93","fb65cdb948fc2c753","f1d942fd87cef78c3"],"move_id":"6","move_name":"specification by example","subject":"sample_counts sub-field schema and semantics"},{"coaching":"Weigh at least one structural alternative for adverse-edit definition alignment with miner constants.","decision":"advisory","finding_refs":["fdabaaf22fda7df7c"],"move_id":"5","move_name":"weigh alternatives","subject":"adverse-edit definition alignment with miner constants"},{"coaching":"Realign blocking-FP proxy ground truth divergence from parent epic to the parent's plan — the parent wins on conflict; if the parent is genuinely wrong, update the PARENT first (which forces its re-review), never silently diverge the leaf.","decision":"advisory","finding_refs":["f10b6f4cf303f16af"],"move_id":"13","move_name":"realign to parent plan","subject":"blocking-FP proxy ground truth divergence from parent epic"},{"coaching":"Pin down subprocess failure handling and fallback behavior with a concrete worked example.","decision":"advisory","finding_refs":["f65290b286d88d203","f3495b2035b0f86c4"],"move_id":"6","move_name":"specification by example","subject":"subprocess failure handling and fallback behavior"},{"coaching":"Plan how no-refresh flag acceptance criteria coverage will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f17b050fa8a019b75"],"move_id":"9","move_name":"plan the verification","subject":"no-refresh flag acceptance criteria coverage"},{"coaching":"Plan how rounds_per_ticket metric verification in AC will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f08fe39cbb523c2cf"],"move_id":"9","move_name":"plan the verification","subject":"rounds_per_ticket metric verification in AC"},{"coaching":"Test the riskiest assumption behind hardcoded priority floor vs. imported constant drift risk first.","decision":"advisory","finding_refs":["f1335f33c53728ba0"],"move_id":"4","move_name":"riskiest-assumption test","subject":"hardcoded priority floor vs. imported constant drift risk"},{"coaching":"Pin down atomic write contract for gate_eval_metrics.json with a concrete worked example.","decision":"advisory","finding_refs":["fff83bf1cc3f79dc2"],"move_id":"6","move_name":"specification by example","subject":"atomic write contract for gate_eval_metrics.json"},{"coaching":"Test the riskiest assumption behind emission-order stability assumption in window slicing first.","decision":"advisory","finding_refs":["f294ad309e75baa98"],"move_id":"4","move_name":"riskiest-assumption test","subject":"emission-order stability assumption in window slicing"},{"coaching":"Weigh at least one structural alternative for atomic-write helper duplication across harness files.","decision":"advisory","finding_refs":["f10cc015ecf96aea0"],"move_id":"5","move_name":"weigh alternatives","subject":"atomic-write helper duplication across harness files"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":8,"blocking":3,"dropped":11,"indeterminate":0},"det":{"P1":{"ac_items":5,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","probed":6,"ran":true,"references":6,"resolved":2,"status":"pass","unresolved_or_abstained":4},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":5,"blocking":false,"desc_chars":9631,"file_impact":2,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":5,"blocking":false,"name":"ac-quality","ran":true,"status":"fail","verify_commands_linted":72,"verify_lint_abstained":70},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":2425,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":2,"name":"file-impact-coverage","ran":true,"status":"pass"}},"floored_criteria":["E1","E4","T1","T5b","T5e","T8","T9"],"floored_finding_ids":["f65290b286d88d203","f3495b2035b0f86c4","f17b050fa8a019b75","f08fe39cbb523c2cf","f1335f33c53728ba0","fff83bf1cc3f79dc2","f294ad309e75baa98","f10cc015ecf96aea0"],"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":446.3,"llm_calls":28,"llm_ms":717645.8,"total_ms":718217.8,"verify_requests":18},"narrowed":true,"remediation":{"baseline":"sidecar","eligible":true,"reasons":{"code_unchanged":true,"plan_changed":true,"registry_unchanged":true,"sidecar_baseline":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","G5","T2","T4","T5b","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Clarify in the 'Per-criterion trailing metrics' section whether the per-criterion finding enumeration uses only the LATEST REVIEW_RESULT payload per ticket (via `latest_review_result`) or all historical payloads (via `all_review_results`), and document the rationale (e.g., 'latest payload captures the final review state before claim').","cohort":["G1G2"],"criteria":["G1G2"],"decision":"block","drop_reason":null,"evidence":["Plan: 'reads each reviewed ticket's persisted REVIEW_RESULT sidecars via rebar.llm.plan_review.sidecar.all_review_results'","Plan: 'joining each REVIEW_RESULT finding to its ticket's outcome row by ticket_id'","sidecar.py:164: all_review_results returns list[dict] — ALL retained payloads, newest→oldest, not just the latest","A ticket with review_round_count=3 would have up to 3 payloads; enumerating findings from all three could count the same criterion's finding 3 times"],"finding":"The plan instructs the harness to read 'each reviewed ticket's persisted REVIEW_RESULT sidecars via rebar.llm.plan_review.sidecar.all_review_results' and join 'each REVIEW_RESULT finding to its ticket's outcome row by ticket_id' for per-criterion metrics, but `all_review_results` returns ALL historical review payloads for a ticket (newest→oldest), not just the latest. The plan does not specify which payload(s) feed the per-criterion finding enumeration: using all payloads double-counts findings that appear in multiple rounds (inflating denominators); using only the latest omits findings from earlier rounds that may have triggered the review outcome. This under-specification is load-bearing for the correctness of blocking_fp_proxy and advisory_application_rate.","group_criteria":null,"group_id":null,"id":"f2128916167e029d4","impact":1.0,"is_primary":null,"location":"What section — 'Per-criterion trailing metrics (FINDING-level)' / Scope bullet for gate_eval_instrumentation.py","norm_id":"ncee964c928a39e72","priority":1.0,"reason":"high-priority+criterion-opted-in","scenarios":["Harness enumerates findings from all historical payloads: a ticket reviewed 3 times with the same blocking G1G2 finding each round contributes 3 denominator entries to blocking_fp_proxy(G1G2), inflating the metric","Harness uses only the latest payload (reasonable default): consistent with 'the current review verdict' but not documented, so implementers may disagree"],"severity":"critical","suggested_fix":"Use `latest_review_result` (not `all_review_results`) for the per-criterion metrics join — it returns the single most-recent payload, avoiding double-counting. Reserve `all_review_results` if a future metric explicitly tracks per-round history. Update the Scope bullet to read: 'reads each reviewed ticket's latest persisted REVIEW_RESULT sidecar via rebar.llm.plan_review.sidecar.latest_review_result'.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"high"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Specify which sidecar round(s) contribute findings to the `blocking_fp_proxy` and `advisory_application_rate` denominators — state explicitly whether the job uses only the latest retained round (`all_review_results(...)[0]` equivalent) or all retained rounds, and document the rationale (latest-only is the natural choice since it represents the gate's final judgment on that ticket).","cohort":["G6"],"criteria":["G6"],"decision":"block","drop_reason":null,"evidence":["Plan says: 'joining each REVIEW_RESULT finding to its ticket's outcome row by ticket_id, for each criterion C'","`all_review_results` (sidecar.py:164) returns ALL retained sidecar payloads newest→oldest, not just the latest","Corpus shows tickets with high review_round_count (e.g., review_round_count=20 for c9d8-eeb2), so multi-round inflation is a real scenario","ABSENCE: the plan never states 'latest round only' or 'all retained rounds' for the denominator computation"],"finding":"The per-criterion metrics computation joins 'each REVIEW_RESULT finding to its ticket's outcome row' using `all_review_results`, which returns ALL retained sidecar rounds (newest→oldest, up to the 50-per-ticket cap). The plan does not specify which round(s) contribute findings to the blocking_fp_proxy and advisory_application_rate denominators. Using all rounds inflates denominators non-linearly for high-round-count tickets (e.g., corpus shows tickets with 20 rounds), while using only the latest round would exclude earlier blocking findings that were cleared in subsequent rounds and wouldn't appear in the final sidecar. This ambiguity makes the metric definition insufficiently reproducible — two implementers will produce different denominators.","group_criteria":null,"group_id":null,"id":"fd2f3ae3b4399c920","impact":1.0,"is_primary":null,"location":"## What — 'Per-criterion trailing metrics (FINDING-level)' section; Scope — `gate_eval_instrumentation.py`","norm_id":"n930f33039428507a","priority":1.0,"reason":"high-priority+criterion-opted-in","scenarios":["A ticket reviewed 10 times with the same G6 blocking finding each round contributes 10 entries to the G6 blocking_fp_proxy denominator if all rounds are used, making a single ticket's outcome disproportionately weight the metric.","Two implementers produce different blocking_fp_proxy values for the same corpus because one uses latest-only and the other uses all-retained-rounds."],"severity":"critical","suggested_fix":"Add to the metrics spec: 'For each ticket, only the most-recent retained REVIEW_RESULT sidecar payload (`all_review_results(ticket_id)[0]`) contributes findings to the denominators; earlier rounds are not double-counted. Rationale: the most-recent review reflects the gate's final judgment after all author revisions.'","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"high"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify explicitly in the `has_strong_finding` definition whether the existential quantifier ranges over the LATEST review round only (e.g. 'latest `all_review_results()[0]`') or over ALL persisted rounds — and confirm the chosen interpretation reproduces the stated 7/8 frozen label agreement.","cohort":["T8"],"criteria":["T8"],"decision":"block","drop_reason":null,"evidence":["Plan: 'reads each reviewed ticket's persisted REVIEW_RESULT sidecars via rebar.llm.plan_review.sidecar.all_review_results'","tests/unit/test_audit_read.py:191: `test_all_review_results_returns_full_history_newest_first` — confirmed newest-first multi-round return","Plan's has_strong_finding definition: '∃ a surfaced sidecar finding with decision ∈ {block, advisory} AND priority >= 0.5 AND severity ∈ {critical, major}' — the ∃ quantifier is ambiguous about which round(s) the existential ranges over","The classifier uses has_strong_finding in C3, which already requires had_persisted_review — leaving the multi-round question unresolved"],"finding":"The plan specifies that `has_strong_finding` reads sidecar findings 'via `rebar.llm.plan_review.sidecar.all_review_results`', but `all_review_results` returns ALL persisted review rounds (newest-first, up to the sidecar's on-disk retention cap), not just the latest. The plan never specifies whether the `has_strong_finding` predicate should be evaluated over the latest round only, or over ANY round across all persisted sidecars. This ambiguity is structurally load-bearing: a ticket with a strong finding in round 1 that was remediated by round 2 would fire the predicate differently under the two interpretations.","group_criteria":null,"group_id":null,"id":"f90dc2241c9567ff7","impact":0.8,"is_primary":null,"location":"'What' section — Outcome classifier, `has_strong_finding` definition; cross-referenced with sidecar.py:164 (`all_review_results`)","norm_id":"n8263ec6ef3d092d1","priority":0.8,"reason":"high-priority+criterion-opted-in","scenarios":["A ticket with 2 review rounds: round 1 had a strong blocking finding, round 2 (post-remediation) has only minor advisories. 'Scan all rounds' → has_strong_finding = True → UNKNOWABLE; 'Scan latest only' → has_strong_finding = False → MISSED. The two interpretations disagree on the frozen label for a CAUGHT case."],"severity":"critical","suggested_fix":"Add to the `has_strong_finding` definition: 'evaluated over the MOST RECENT persisted sidecar only (`all_review_results(ticket_id)[0]`), since a remediation re-review producing only minor findings confirms the prior strong finding was addressed.'","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"high"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify the `--emit` behavior when the corpus–sidecar join yields zero matching rows: either exit non-zero with a clear diagnostic (e.g., 'No tickets with persisted reviews found; commit sidecars or use --no-refresh') or document that the committed corpus and sidecars must be present for `--emit` to satisfy the AC.","cohort":["T5b","T6","T9"],"criteria":["T6"],"decision":"advisory","drop_reason":null,"evidence":["'a non-trivial object with ≥1 criterion whose blocking_fp_proxy and advisory_application_rate are numeric … NOT satisfiable by {}, all-null values, or all-zero sample counts'","No fallback or error path specified for the case where the join yields zero rows","The plan restricts classifier application to tickets with `had_persisted_review AND post_claim_signal` — on a fresh clone with no sidecars, this set is empty"],"finding":"The plan does not specify harness behavior when `--emit` (or `--verify-repro`) is run but the corpus contains no tickets with persisted `REVIEW_RESULT` sidecars — i.e., the join between corpus rows and sidecars produces zero matching rows. The AC for `--emit` requires ≥1 criterion with numeric `blocking_fp_proxy` and positive `sample_counts`, but if the join is empty the harness cannot satisfy this AC; the plan is silent on what the harness should do (exit non-zero, emit a warning, emit an empty object).","group_criteria":null,"group_id":null,"id":"f0fb3d1a61f2c6a88","impact":0.85,"is_primary":null,"location":"AC for `--emit`; What section — 'Per-criterion trailing metrics'","norm_id":"nd1b2ca9c6bdac74b","priority":0.7438,"reason":"default-advisory","scenarios":["Fresh clone or CI environment where sidecars have not been committed → join produces zero rows → `--emit` outputs `{}` or all-null metrics → AC assertion fails with a cryptic Python AssertionError","Corpus refresh drops previously reviewed tickets → sample counts drop to zero mid-window → harness behavior undefined"],"severity":"critical","suggested_fix":"","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"low","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Define the `sample_counts` sub-field schema in the What section's per-criterion metrics definition — specify what keys it contains (e.g. `{blocking_total, advisory_total, window_tickets}`) and what each counts, so the AC2 assertion enforces a meaningful contract rather than any positive-sum dict.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["AC2 proving command: `isinstance(v.get('sample_counts'),dict) and sum(v['sample_counts'].values())>0`","The What section defines three metrics (blocking_fp_proxy, advisory_application_rate, rounds_per_ticket) but never names `sample_counts` as a sub-field of the per-criterion output object or defines its keys","Search for 'sample_counts' in docs/experiments/plan-review-gate/ returns zero results — field is not defined anywhere in existing harness docs"],"finding":"The `sample_counts` field is mandated by the AC2 proving command (`isinstance(v.get('sample_counts'), dict) and sum(v['sample_counts'].values()) > 0`) but its internal sub-field schema — what keys the dict contains and what each counts — is never defined anywhere in the plan (not in the What section's metric definitions, not in Scope, not in any other AC). An implementer cannot know whether `sample_counts` holds per-decision-type counts, per-ticket counts, or something else.","group_criteria":null,"group_id":null,"id":"f0dd45ec0a4954fa1","impact":0.67,"is_primary":null,"location":"Acceptance Criteria AC2 (--emit proving command) and 'What' section, Per-criterion trailing metrics","norm_id":"n087cd7138b9d8c89","priority":0.67,"reason":"default-advisory","scenarios":["Implementer creates an output object with a `sample_counts` dict keyed by something reasonable (e.g. {'blocking': N}) but the AC's `sum(v['sample_counts'].values()) > 0` passes trivially with any single non-zero key — no contract is enforced beyond 'some positive integer exists'.","Two implementers produce incompatible `sample_counts` schemas (one uses counts of findings, the other counts of tickets) — both pass the AC but compute different denominators, making the metric output non-comparable across runs."],"severity":"major","suggested_fix":"In the 'What' section under 'Per-criterion trailing metrics', add: '`sample_counts` is a dict with at minimum the keys `{\"blocking_total\": <int>, \"advisory_total\": <int>}` — the raw denominators for `blocking_fp_proxy` and `advisory_application_rate` respectively — so the AC's non-triviality assertion is falsifiable by a real implementation gap.'","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The `sample_counts` block is required in every per-criterion metric output by AC2's proving command (`assert ... 'sample_counts' in v`), but its internal schema — what sub-fields it contains and their semantics — is never defined anywhere in the plan. An implementer cannot determine whether `sample_counts` should hold raw integer counts of blocking/advisory/total findings, ticket counts, or something else.","group_criteria":null,"group_id":null,"id":"f9e361c0892426c93","impact":0.67,"is_primary":null,"location":"Acceptance Criteria, AC2 — `--emit` proving command; 'Per-criterion trailing metrics' section in What","norm_id":"nef8ec01ee85c2504","priority":0.67,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"Add to the 'Per-criterion trailing metrics' section: `sample_counts` = `{blocking_total: int, advisory_total: int, fp_proxy_numerator: int, advisory_adverse_numerator: int}` — the raw counts the two rate metrics are derived from.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The `sample_counts` block is required by the AC but its internal schema (sub-fields and their semantics) is never defined anywhere in the plan.","group_criteria":null,"group_id":null,"id":"fb65cdb948fc2c753","impact":0.67,"is_primary":null,"location":"Acceptance Criteria — `--emit` AC: '≥1 criterion carrying all three of `blocking_fp_proxy`, `advisory_application_rate`, and a `sample_counts` block'","norm_id":"nb39234c7c9f4a368","priority":0.67,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"Add to the 'Per-criterion trailing metrics' section: '`sample_counts` is `{\"n_blocking\": <denominator of blocking_fp_proxy>, \"n_advisory\": <denominator of advisory_application_rate>, \"n_fp_proxy_hits\": <numerator of blocking_fp_proxy>, \"window_rows\": <actual N used>}`.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Reconcile the plan's 'adverse post-claim edit' vocabulary with the miner's `_SUBSTANTIVE_CLASSES` — either explicitly extend the adverse set to include `premise-invalidated`, `scope-reduction`, and `approach-change`, or document the deliberate exclusion and why those classes are not considered adverse for the metric.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Plan: 'adverse post-claim edit is defined once: post_claim_edit_class ∈ {plan-authored-post-claim, ac-strengthened, substantive-unclassified}'","mine_outcome_corpus.py:419-427: _SUBSTANTIVE_CLASSES = {'plan-authored-post-claim', 'premise-invalidated', 'scope-reduction', 'approach-change', 'ac-strengthened', 'operator-attested-retag', 'substantive-unclassified'}","runs/README.md:83-85 notes 'The semantic §5.2 classes (premise-invalidated / scope-reduction / approach-change) are not fabricated by the miner — they land here for the adjudication pass' — meaning they CAN appear in the corpus","The plan's adverse set omits operator-attested-retag (handled by C1) and the three semantic classes — but no rule says what to do when a ticket has post_claim_edit_class == 'premise-invalidated'"],"finding":"The plan's 'adverse post-claim edit' definition (`post_claim_edit_class ∈ {plan-authored-post-claim, ac-strengthened, substantive-unclassified}`) is materially narrower than the miner's `_SUBSTANTIVE_CLASSES` set (which also includes `premise-invalidated`, `scope-reduction`, `approach-change`, and `operator-attested-retag`). The `advisory_application_rate` metric uses 'adverse post-claim edit' as its join predicate, but the vocabulary that the miner actually emits for those three semantic classes differs from the plan's closed set — and the plan provides no rule for handling these 'extra' substantive classes.","group_criteria":null,"group_id":null,"id":"fdabaaf22fda7df7c","impact":0.67,"is_primary":null,"location":"'What' section — 'adverse post-claim edit' definition; cross-referenced at mine_outcome_corpus.py:419-427","norm_id":"n4c179ca9432aca66","priority":0.5025,"reason":"default-advisory","scenarios":["A ticket with `post_claim_edit_class == 'premise-invalidated'` exists in the corpus — an implementer applying the plan's 'adverse' definition will not count it as adverse, silently under-counting advisory_application_rate.","A future miner run produces rows with 'scope-reduction' or 'approach-change' (the miner's code supports them); the harness silently ignores them as non-adverse."],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Define `sample_counts` in the 'What' section's metric definitions: specify what keys it contains (e.g., `{\"blocking\": N, \"advisory\": M}`), how it is populated, and what 'positive total' means in context.","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["AC proving command: `v.get('sample_counts'),dict) and sum(v['sample_counts'].values())>0`","'What' section defines: `blocking_fp_proxy(C)`, `advisory_application_rate(C)`, `rounds_per_ticket` — `sample_counts` is absent from all metric definitions"],"finding":"The AC proving command for `--emit` asserts that `sample_counts` is a non-empty dict with a positive total, but `sample_counts` is never defined as a field in the 'What' section's metric definitions (which define only `blocking_fp_proxy`, `advisory_application_rate`, and `rounds_per_ticket`). An implementer cannot infer the schema of `sample_counts` from the plan body.","group_criteria":null,"group_id":null,"id":"f1d942fd87cef78c3","impact":0.536,"is_primary":null,"location":"AC for `--emit` (proving command) vs. 'What' section per-criterion trailing metrics","norm_id":"n995417dc4033bdf4","priority":0.469,"reason":"default-advisory","scenarios":["Implementer writes the metrics JSON without a `sample_counts` key (because it isn't specified), causing the AC proving command to fail on a technicality.","Implementer guesses different schemas for `sample_counts` (e.g., per-decision-type counts vs. per-ticket counts), producing an output that satisfies the AC mechanically but doesn't match reviewer intent."],"severity":"major","suggested_fix":"Add to the per-criterion metrics block in 'What': \"`sample_counts` is a dict of `{decision_type: count}` (e.g., `{\"blocking\": 3, \"advisory\": 7}`) recording how many findings of each type the criterion emitted in the window, so that `blocking_fp_proxy` and `advisory_application_rate` denominators are auditable.\"","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Resolve the blocking-FP proxy measurement conflict: either update the parent epic's Success Criteria to reflect the E1 adjudication corpus descope (replacing 'E1's committed finding-adjudication ground-truth corpus' with the force-close/reopen signal), then re-review the parent, before closing this leaf — or realign the leaf's proxy definition back to E1 adjudication labels as the parent specifies.","cohort":["G7"],"criteria":["G7"],"decision":"advisory","drop_reason":null,"evidence":["Parent SC: 'the blocking-FP proxy for a criterion is the fraction of that criterion's BLOCKING findings … subsequently adjudicated false-positive / not-block-worthy — measured by R7's instrumentation against E1's committed finding-adjudication ground-truth corpus'","Leaf What: 'The automatic proxy for \"adjudicated not-block-worthy\" is force_close OR reopen_count > 0' and 'The earlier (no adverse post-claim edit) disjunct is removed'","Leaf comment: 'the independent human-adjudicated gold set is parked as idea e59d-c078-724d-46e5' — acknowledges the E1 adjudication corpus was descoped, but the parent SC still references it as the measurement target","Per G7: parent wins on conflict; the leaf may not silently redefine a parent deliverable without first updating the parent"],"finding":"The leaf redefines the blocking-FP proxy measurement ground from E1's committed finding-adjudication corpus (as specified in the parent's Success Criteria) to a purely event-based signal (`force_close OR reopen_count > 0`), directly contradicting the parent's authoritative definition.","group_criteria":null,"group_id":null,"id":"f10b6f4cf303f16af","impact":0.67,"is_primary":null,"location":"Leaf What section ('blocking_fp_proxy(C)') vs. parent Success Criteria ('measured by R7's instrumentation against E1's committed finding-adjudication ground-truth corpus')","norm_id":"n504f4380246fb661","priority":0.4606,"reason":"default-advisory","scenarios":["An implementer reading only the parent's SC will expect the proxy to be measured against E1's adjudication labels; an implementer reading the leaf will build a force-close/reopen signal instead — these are incompatible.","If the parent SC is authoritative, the leaf's metric computation is out of scope and contradicts the contract; if the leaf's approach is correct (E1 adjudication corpus was validly descoped), the parent SC must be updated first."],"severity":"major","suggested_fix":"Update the parent epic's Success Criteria to replace 'measured by R7's instrumentation against E1's committed finding-adjudication ground-truth corpus' with 'measured by R7's instrumentation using force_close OR reopen_count > 0 as the not-block-worthy proxy (E1 adjudication corpus descoped; see E1 comment 2026-07-16)'. This re-opens the parent's plan-review attestation, which must be re-reviewed before the leaf can close.","tier":"LLM","validity":0.6875,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"insufficient","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"insufficient","impact_follows_necessarily":"insufficient","is_verifiable":"yes","no_existing_mitigation":"insufficient","no_viable_alternative_explanation":"insufficient","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"insufficient"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"medium","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":null,"blocking_enabled":null,"checklist_item":"","cohort":null,"criteria":["P6"],"decision":"advisory","drop_reason":null,"evidence":["vague/subjective terms present: clean"],"finding":"Acceptance-criteria / definition-of-done quality issues.","group_criteria":null,"group_id":null,"id":"f607dd457c67f9209","impact":0.4,"is_primary":null,"location":"","norm_id":"ned06ebc801a522e3","priority":0.4,"reason":null,"scenarios":[],"severity":"minor","suggested_fix":"Split compound criteria, replace subjective terms with observable outcomes, and state how each is verified.","tier":"DET","validity":1.0,"verification":null},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Reconcile the `--emit` AC's proving command with the metric definitions: either (a) specify that null/NaN is the correct value when a criterion has no findings of a given type and relax the `isinstance(...,(int,float))` check to allow null for one of the two fields, OR (b) assert in the 'What' section that the corpus is known to contain at least one criterion with both blocking and advisory findings so the joint-numeric requirement is satisfiable.","cohort":["COH","E1","T4"],"criteria":["COH"],"decision":"dropped","drop_reason":null,"evidence":["'What': `blocking_fp_proxy(C)` = fraction of C's *blocking* findings …; `advisory_application_rate(C)` = fraction of C's *advisory* findings …","AC proving command: `any(isinstance(v.get('blocking_fp_proxy'),(int,float)) and isinstance(v.get('advisory_application_rate'),(int,float)) …`","No section states that any criterion is guaranteed to emit both blocking and advisory findings in the corpus."],"finding":"The AC for `--emit` requires ≥1 criterion with BOTH `blocking_fp_proxy` AND `advisory_application_rate` simultaneously numeric, but the 'What' section defines each as computed only over findings of its respective decision type — a criterion with only blocking findings (no advisory) would have a null `advisory_application_rate`, and vice versa. No section reconciles whether any criterion is guaranteed to have both types in the corpus.","group_criteria":null,"group_id":null,"id":"f2d19ad75db914ecb","impact":0.264,"is_primary":null,"location":"'What' section (per-criterion metric definitions) vs. AC for `--emit` (proving command)","norm_id":"nb5c9513052974373","priority":0.099,"reason":"low-validity","scenarios":["All criteria in the corpus happen to be either blocking-only or advisory-only; the AC proving command fails even though the implementation is correct.","Implementer forces both fields to 0.0 when no findings of that type exist, satisfying the AC mechanically but producing misleading metrics (0.0 ≠ undefined)."],"severity":"minor","suggested_fix":"Change the AC proving command to `any((v.get('blocking_fp_proxy') is not None or v.get('advisory_application_rate') is not None) and isinstance(v.get('sample_counts'),dict) and sum(v['sample_counts'].values())>0 for v in d.values())` and document that individual fields are null when a criterion has no findings of that decision type in the window.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Document the join's missing-key behavior: specify whether tickets present in sidecars but absent from the windowed corpus are silently skipped (recommended, with a logged warning count), and whether tickets in the windowed corpus with no on-disk sidecar are excluded from metric denominators (expected behavior since they have no findings to join).","cohort":["G6"],"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":["Plan: '--window N bounds the corpus to the last N rows in the miner's deterministic emission order'","Plan: 'joining each REVIEW_RESULT finding to its ticket's outcome row by ticket_id' — join direction implies corpus is the authoritative set","The corpus is refreshed from git-object walk; sidecars live on disk — these can diverge between miner runs","ABSENCE: no mention of what happens when sidecar exists for a ticket outside the N-row window, or when a corpus row has no matching on-disk sidecar"],"finding":"The `--window N` flag 'bounds the corpus to the last N rows in the miner's deterministic emission order.' The metrics join flows corpus-row → sidecar-findings: the corpus is the filtering side, and sidecars are joined in. The plan does not specify the join behavior when a ticket's sidecar exists on disk but its corpus row falls outside the N-row window (its findings would be silently excluded from the metric), OR when a ticket appears in the windowed corpus but has no on-disk sidecar (its outcome contributes no denominator mass). The asymmetry between corpus-windowing and sidecar-availability is not documented, leaving an unaddressed edge case: newly-reviewed tickets not yet in the refreshed corpus (between miner runs) could cause their sidecar findings to vanish from metrics without any warning.","group_criteria":null,"group_id":null,"id":"fc030a73edff617a1","impact":0.33,"is_primary":null,"location":"## What — '`--window N`' paragraph; AC — `--emit` proving command","norm_id":"nb03496d5fd1912d4","priority":0.1237,"reason":"low-validity","scenarios":["With --window 50 on a 628-row corpus, the 578 older tickets' sidecar findings are silently dropped from metrics, regardless of whether they represent recent gate activity (emission order ≠ chronological order, as the plan itself admits).","Between a --no-refresh run and a fresh run, tickets reviewed after the corpus was last written have sidecars but no corpus rows, so their blocking findings don't appear in blocking_fp_proxy at all."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"insufficient","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E6","F1"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"AC2's proving command checks only that the three metric *keys are present* in at least one criterion's dict, but it does NOT verify non-null/non-trivial values. An implementation that emits `{'some_criterion': {'blocking_fp_proxy': null, 'advisory_application_rate': null, 'sample_counts': {}}}` would satisfy `all(k in v for k in (...))` (key-presence check) yet the criterion explicitly states it is 'NOT satisfiable by `{}`/all-null'. The proving command therefore does not prove the non-triviality property it claims to enforce.","group_criteria":null,"group_id":null,"id":"f02bce4ba49b8794c","impact":0.0,"is_primary":null,"location":"Acceptance Criteria — AC2 proving command (the Python one-liner after `--emit &&`)","norm_id":"n1e49d1d40cec493d","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"Replace the assertion in the proving command with:\n```\nassert d and any(\n    all(k in v for k in ('blocking_fp_proxy','advisory_application_rate','sample_counts'))\n    and (v.get('blocking_fp_proxy') is not None or v.get('advisory_application_rate') is not None)\n    for v in d.values()\n)\n```\nThis ensures at least one criterion has both the required keys AND at least one non-null metric value, matching the 'NOT satisfiable by `{}`/all-null' claim.","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a specified error-handling rule for subprocess failure to the 'Corpus acquisition' section: at minimum, state whether a non-zero miner exit should (a) re-raise/abort with a clear error message, (b) automatically fall back to the committed corpus (as `--no-refresh` does), or (c) emit a warning and continue with whatever JSONL exists on disk.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":"novelty","evidence":["Plan: 'The job refreshes the outcome corpus by invoking mine_outcome_corpus.py as a subprocess … then reads that JSONL'","Plan acknowledges `mine_outcome_corpus.py:381` calls sys.exit() on floor-check failure as the motivation for subprocess invocation","No fallback path is specified for subprocess exit != 0","The `--no-refresh` flag is described as the offline/CI path but is not specified as the automatic fallback when refresh fails"],"finding":"The plan specifies that the job invokes `mine_outcome_corpus.py` as a subprocess but defines no fallback or error-handling for subprocess failure (non-zero exit code, timeout, miner floor-check assertion, or missing output file). The miner calls `sys.exit()` on floor-check failure (`mine_outcome_corpus.py:381`), which would produce a non-zero return code — but the plan says nothing about what the harness should do in that case (abort, fall back to committed corpus, emit a warning, etc.).","group_criteria":null,"group_id":null,"id":"f65290b286d88d203","impact":0.536,"is_primary":null,"location":"'What' section — Corpus acquisition (subprocess, not import)","norm_id":"n0294de5b75c40fed","priority":0.335,"reason":"default-advisory","scenarios":["The miner subprocess exits non-zero (e.g. corpus has fewer than REVIEWED_FLOOR tickets after a store reset). The harness has no specified behavior — it may silently read a stale or empty corpus file, or crash with an unhandled exception.","In CI, the miner requires git history access that is unavailable; the subprocess fails; the harness produces no metrics output and the `--emit` AC is unsatisfiable."],"severity":"major","suggested_fix":"Add: 'If the subprocess exits non-zero, the job aborts with a descriptive error message citing the miner's exit code and stderr; it does NOT silently fall back to a stale corpus. Use `--no-refresh` explicitly for offline/CI runs.'","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify subprocess error handling: check return code, capture stderr, and either abort with a clear diagnostic message or fall back to `--no-refresh` behavior when the miner subprocess returns non-zero or times out.","cohort":["T5b","T6","T9"],"criteria":["T5b"],"decision":"advisory","drop_reason":"novelty","evidence":["'The job refreshes the outcome corpus by invoking mine_outcome_corpus.py as a subprocess … then reads that JSONL'","No mention of checking subprocess return code, capturing stderr, setting a timeout, or falling back gracefully on non-zero exit","'mine_outcome_corpus.py:381 … sys.exit() on floor-check failure' is cited as motivating subprocess use, but the plan does not specify how the caller handles that exit"],"finding":"The plan specifies that `gate_eval_instrumentation.py` invokes `mine_outcome_corpus.py` as a subprocess but documents no error handling when that subprocess fails (non-zero exit, timeout, or miner floor-check rejection). The `--no-refresh` fallback requires the user to proactively choose it; an unhandled subprocess failure could crash the harness with an opaque traceback or silently continue with a stale/empty corpus, producing misleading metrics.","group_criteria":null,"group_id":null,"id":"f3495b2035b0f86c4","impact":0.264,"is_primary":null,"location":"What section — 'Corpus acquisition (subprocess, not import)'","norm_id":"n5ecc21faa03cae95","priority":0.165,"reason":"default-advisory","scenarios":["Miner floor-check fails on a fresh clone with insufficient corpus rows → subprocess exits non-zero → harness crashes without a user-actionable message","CI environment blocks subprocess spawning → silent failure producing empty corpus → `--emit` writes all-null metrics without warning"],"severity":"minor","suggested_fix":"After `subprocess.run([...])`, check `result.returncode != 0` and raise a clear `RuntimeError(f'Corpus refresh failed (exit {result.returncode}): {result.stderr}')`, or add a `--refresh-timeout` with a fallback to the committed corpus.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an AC (or extend an existing AC) that verifies `--no-refresh` skips corpus regeneration — e.g., assert `mine_outcome_corpus.py` is NOT invoked as a subprocess when `--no-refresh` is passed (check via mock or absence of side-effect).","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":"novelty","evidence":["Scope: CLI flags listed include `--no-refresh`","'What': 'A `--no-refresh` flag skips regeneration and reads the committed corpus (offline / CI use).'","ACs cover only `--verify-repro`, `--emit`, `--window N`, and `pytest` — `--no-refresh` has no corresponding criterion."],"finding":"The `--no-refresh` CLI flag is described in both the 'What' section and the Scope as a deliverable with defined behavior (\"skips regeneration and reads the committed corpus (offline / CI use)\"), but no AC covers or verifies it — it is an uncovered deliverable.","group_criteria":null,"group_id":null,"id":"f17b050fa8a019b75","impact":0.0,"is_primary":null,"location":"'What' section (corpus acquisition paragraph) and Scope vs. Acceptance Criteria","norm_id":"ndafcffa6705dba82","priority":0.0,"reason":"default-advisory","scenarios":["Implementer omits `--no-refresh` entirely; no AC catches the omission.","CI usage documented as relying on `--no-refresh` silently breaks when the flag isn't implemented."],"severity":"none","suggested_fix":"","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add `rounds_per_ticket` to the `--emit` AC's proving command (or README documentation sentinel check) so the emitted JSON's presence and non-triviality of this distribution field is verified.","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":"novelty","evidence":["'What': '**rounds_per_ticket** = the `review_round_count` distribution over the window.'","AC proving command checks only: `blocking_fp_proxy`, `advisory_application_rate`, `sample_counts` — no mention of `rounds_per_ticket`."],"finding":"The `rounds_per_ticket` metric is listed as a per-criterion trailing metric in the 'What' section, but no AC verifies it is present or populated in the emitted output — the `--emit` AC proving command only checks `blocking_fp_proxy` and `advisory_application_rate`.","group_criteria":null,"group_id":null,"id":"f08fe39cbb523c2cf","impact":0.0,"is_primary":null,"location":"'What' section (per-criterion trailing metrics) vs. AC for `--emit`","norm_id":"n770b5b73431320b9","priority":0.0,"reason":"default-advisory","scenarios":["Implementer omits `rounds_per_ticket` from the emitted JSON; the AC passes anyway.","The field is emitted but with wrong semantics (e.g., mean instead of distribution); no AC catches it."],"severity":"none","suggested_fix":"","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Direct `gate_eval_instrumentation.py` to import `RECALL_MIN_PRIORITY` from `rebar.llm.plan_review.sidecar` (or the canonical constant location) rather than hardcoding `0.5`, so the `has_strong_finding` predicate always tracks the live gate's threshold.","cohort":["T2","T5e","T7"],"criteria":["T5e"],"decision":"advisory","drop_reason":"novelty","evidence":["\"The 0.5 floor is the codebase's own `RECALL_MIN_PRIORITY` (`src/rebar/llm/plan_review/sidecar.py:299`)\" — plan names the source constant but does not direct an import or reference to it in the harness implementation","The harness lives in `docs/experiments/plan-review-gate/harnesses/` — a non-package directory — but `src/rebar/` is importable on the project path (the harness already imports `rebar.llm.plan_review.sidecar.all_review_results`), so importing the constant is feasible"],"finding":"The `has_strong_finding` predicate hardcodes the numeric value `0.5` for the priority floor, citing it as the codebase's own `RECALL_MIN_PRIORITY` constant (`src/rebar/llm/plan_review/sidecar.py:299`), but the plan does not direct the harness to import or reference that constant — it embeds the literal value. If `RECALL_MIN_PRIORITY` is later recalibrated, the harness silently diverges and the classifier's `has_strong_finding` gate computes against a stale threshold with no warning.","group_criteria":null,"group_id":null,"id":"f1335f33c53728ba0","impact":0.0,"is_primary":null,"location":"What section — `has_strong_finding` predicate definition; Scope section — `gate_eval_instrumentation.py`","norm_id":"n57d51d664670c75b","priority":0.0,"reason":"default-advisory","scenarios":["A future calibration raises `RECALL_MIN_PRIORITY` to 0.6; the harness keeps using 0.5; `has_strong_finding` flags more findings as strong than the live gate does, making the classifier's CAUGHT-vs-MISSED boundary inconsistent with actual gate behavior and inflating CAUGHT-BUT-IGNORED counts"],"severity":"none","suggested_fix":"In `gate_eval_instrumentation.py`, replace the literal `0.5` with `from rebar.llm.plan_review.sidecar import RECALL_MIN_PRIORITY` and use that symbol in the predicate. Add a one-line comment referencing the source location for traceability.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify that `--emit` writes atomically (write to a `.tmp` sibling file then `os.replace()` to the target) to prevent partial/corrupt output from concurrent or interrupted runs.","cohort":["T5b","T6","T9"],"criteria":["T5b","T9"],"decision":"advisory","drop_reason":"novelty","evidence":["'`--emit` writes per-criterion metrics to docs/experiments/plan-review-gate/runs/gate_eval_metrics.json'","No atomic-write protocol specified","The AC proving command does `json.load(open(...))` directly on the output file — a partial write would cause a JSON parse error rather than a graceful failure"],"finding":"The `--emit` write to `runs/gate_eval_metrics.json` is not described as atomic (e.g., write-to-tempfile-then-rename). An interrupted write (Ctrl-C, OOM kill, CI timeout) would leave a partial/corrupt JSON file that subsequent reads (including the AC proving command) would silently fail on or accept as valid.","group_criteria":null,"group_id":null,"id":"fff83bf1cc3f79dc2","impact":0.0,"is_primary":null,"location":"Scope section — `gate_eval_instrumentation.py`; AC for `--emit`","norm_id":"n59881ee7e888f4a0","priority":0.0,"reason":"default-advisory","scenarios":["CI job is killed mid-write → next CI run reads corrupt `gate_eval_metrics.json` → parse error cascades to test failure with no clear cause","Two concurrent `--emit` runs interleave writes → torn JSON output"],"severity":"none","suggested_fix":"Use `pathlib.Path.write_text(json.dumps(metrics, indent=2))` is not atomic; instead write to `gate_eval_metrics.json.tmp` then `os.replace('gate_eval_metrics.json.tmp', 'gate_eval_metrics.json')`.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Clarify in the plan (and README) that `--window N` selects the last N rows by alphabetical UUID sort (not chronological), and document what 'trailing' actually means in this context — or specify a different windowing key (e.g., last N by `review_round_count` or a corpus-line index) that better approximates recency.","cohort":["E4"],"criteria":["E4"],"decision":"advisory","drop_reason":"novelty","evidence":["Plan states: 'The corpus has no timestamp field; emission order is the stable proxy, documented as such — a strictly chronological window is future work needing a timestamp.'","mine_outcome_corpus.py line 379: `reviewed = sorted(tid for tid, tk in store.items() if review_round_count(tk) > 0)` — alphabetical UUID sort.","outcome_corpus.jsonl first rows: '003d-e6b0...', '0128-9a17...', '012e-bd01...' — lexicographic UUID order, not creation-time order.","UUIDs in this system are randomly generated (not UUIDv1/time-based), so lexicographic sort is effectively arbitrary with respect to ticket age."],"finding":"The plan asserts that `--window N` uses 'emission order' as a 'stable proxy' for chronological ordering of the outcome corpus, but `build_corpus()` in mine_outcome_corpus.py (line 379) sorts by `sorted(tid ...)` — alphabetical lexicographic sort of ticket UUID hex strings. UUID hex order has zero correlation with ticket creation time in this system (UUIDs are randomly generated, not time-based), so `--window N` does not capture the trailing-N most-recently-reviewed tickets in any temporal sense. The plan's own disclaimer ('a strictly chronological window is future work needing a timestamp') implicitly acknowledges the absence of temporal ordering, yet it still labels the alphabetical UUID sort a 'stable proxy' — which is a substantive overclaim that misleads implementors about what the metric window actually captures.","group_criteria":null,"group_id":null,"id":"f294ad309e75baa98","impact":0.0,"is_primary":null,"location":"What section, '--window N' paragraph: 'emission order is the stable proxy, documented as such'","norm_id":"n4279374223df65bb","priority":0.0,"reason":"default-advisory","scenarios":["An implementor using --window 50 believes they are computing metrics over the 50 most recently reviewed tickets, but actually gets an arbitrary alphabetical slice of ticket IDs — potentially mixing tickets from all time periods.","Alarm thresholds calibrated against a 'trailing window' expectation may fire or fail to fire unpredictably if the window does not capture recent activity."],"severity":"none","suggested_fix":"Replace 'emission order is the stable proxy' with 'corpus row order (alphabetical ticket UUID sort, NOT chronological)' in both the plan and the README, and note that the window is a reproducible but non-temporal slice until a timestamp field is added to the corpus schema.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Address the existing `_atomic_write_jsonl` duplication: the plan should explicitly state whether `gate_eval_instrumentation.py` will copy the helper a third time or reference a shared utility (e.g. a `harnesses/_util.py` module), so the implementer does not silently introduce a third divergent copy.","cohort":["T1"],"criteria":["T1"],"decision":"advisory","drop_reason":"novelty","evidence":["`mine_outcome_corpus.py:389` defines `def _atomic_write_jsonl(rows, path)` using tempfile.mkstemp + os.replace — 12-line identical implementation.","`build_adjudication_corpus.py:190` defines the same `_atomic_write_jsonl` — a second copy already present in the same directory.","The plan specifies `--emit` writes `gate_eval_metrics.json` but does not acknowledge the existing pattern or how it will be reused, implying a third private copy."],"finding":"The plan implicitly introduces a third copy of the `_atomic_write_jsonl` private helper (tempfile + os.replace pattern) in the new harness, when identical implementations already exist in `mine_outcome_corpus.py:389` and `build_adjudication_corpus.py:190` in the same `harnesses/` directory — repackaging a local pattern that has already been duplicated once.","group_criteria":null,"group_id":null,"id":"f10cc015ecf96aea0","impact":0.0,"is_primary":null,"location":"Scope — `docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py` (`--emit` write path)","norm_id":"nb84837f72626d6dd","priority":0.0,"reason":"default-advisory","scenarios":["Implementer writes a third copy of `_atomic_write_jsonl`, diverging from the existing two (e.g. missing the `finally` cleanup branch), introducing a subtle inconsistency.","Future changes to the atomic-write pattern (e.g. adding fsync) must be applied to three separate copies instead of one."],"severity":"none","suggested_fix":"Add a one-line note in Scope: 'reuses the `_atomic_write_jsonl` pattern from `mine_outcome_corpus.py` (copy verbatim or extract to a shared `harnesses/_util.py`)' so the implementer has explicit direction and the copy count stays intentional.","tier":"LLM","validity":0.5714,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"eb0554d0c0593393","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":446.3,"llm_calls":28,"llm_ms":717645.8,"total_ms":718217.8,"verify_requests":18},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"b1a4-af7a-4a48-465d","ticket_type":"story","verdict":"BLOCK","verified_at_sha":"43d1545237745f4666dcc13c81587c824251e51d"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784258155749848001,"uuid":"d7f58730-1380-4daf-8e3e-69251fb37495"}