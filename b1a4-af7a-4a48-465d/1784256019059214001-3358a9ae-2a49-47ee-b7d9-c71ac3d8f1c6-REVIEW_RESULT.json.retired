{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","author_sig":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","data":{"coaching":[{"coaching":"Pin down sample_counts block schema and sub-fields with a concrete worked example.","decision":"advisory","finding_refs":["fb65cdb948fc2c753"],"move_id":"6","move_name":"specification by example","subject":"sample_counts block schema and sub-fields"},{"coaching":"Plan how AC4 grep-based verification of new demotion content will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"block","finding_refs":["f8805931c92cc3c19","ff350769fe1a92243"],"move_id":"9","move_name":"plan the verification","subject":"AC4 grep-based verification of new demotion content"},{"coaching":"Pin down criteria_routing.json demotion operator workflow with a concrete worked example.","decision":"advisory","finding_refs":["f0cc74b4498e50bb0"],"move_id":"6","move_name":"specification by example","subject":"criteria_routing.json demotion operator workflow"},{"coaching":"Plan how AC2 ellipsis placeholder in proving command will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["ffec68666a30eaa6c"],"move_id":"9","move_name":"plan the verification","subject":"AC2 ellipsis placeholder in proving command"},{"coaching":"Pin down has_strong_finding quantifier scope across review rounds with a concrete worked example.","decision":"advisory","finding_refs":["f3e873446ef36bdf3"],"move_id":"6","move_name":"specification by example","subject":"has_strong_finding quantifier scope across review rounds"},{"coaching":"Plan how rounds_per_ticket absence from AC2 verification check will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["ff874ba1d4557ecf0"],"move_id":"9","move_name":"plan the verification","subject":"rounds_per_ticket absence from AC2 verification check"},{"coaching":"Pin down subprocess non-zero exit handling behavior with a concrete worked example.","decision":"advisory","finding_refs":["f6bb7cb7179b2d36d","f3363383b11edf6ff","f2f03b4077dc3003d"],"move_id":"6","move_name":"specification by example","subject":"subprocess non-zero exit handling behavior"},{"coaching":"Pin down atomic write guarantee for metrics JSON output with a concrete worked example.","decision":"advisory","finding_refs":["f78df8eee3ffdcb1a"],"move_id":"6","move_name":"specification by example","subject":"atomic write guarantee for metrics JSON output"},{"coaching":"Plan how unit test coverage of has_strong_finding extractor will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f15b3708df2996542"],"move_id":"9","move_name":"plan the verification","subject":"unit test coverage of has_strong_finding extractor"},{"coaching":"Run a quick pre-mortem on C3 UNKNOWABLE branch behavior on broader metrics corpus: how could this plan fail?","decision":"advisory","finding_refs":["faa2f4acf84fdda73"],"move_id":"3","move_name":"pre-mortem","subject":"C3 UNKNOWABLE branch behavior on broader metrics corpus"},{"coaching":"Realign live incremental mechanism versus batch job approach to the parent's plan — the parent wins on conflict; if the parent is genuinely wrong, update the PARENT first (which forces its re-review), never silently diverge the leaf.","decision":"advisory","finding_refs":["fc21341a65d82b6b2"],"move_id":"13","move_name":"realign to parent plan","subject":"live incremental mechanism versus batch job approach"},{"coaching":"Record an ADR for alarm and demotion playbook in production operational doc — it reads like a one-way door.","decision":"advisory","finding_refs":["fd948f2b516eb8463"],"move_id":"8","move_name":"ADR / one-way-door","subject":"alarm and demotion playbook in production operational doc"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":8,"blocking":1,"dropped":14,"indeterminate":0},"det":{"P1":{"ac_items":5,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","probed":6,"ran":true,"references":6,"resolved":2,"status":"pass","unresolved_or_abstained":4},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":5,"blocking":false,"desc_chars":9362,"file_impact":2,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":5,"blocking":false,"name":"ac-quality","ran":true,"status":"fail","verify_commands_linted":70,"verify_lint_abstained":69},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":2358,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":2,"name":"file-impact-coverage","ran":true,"status":"pass"}},"floored_criteria":["E1","E5","G6","G7","T5b","T8","T9"],"floored_finding_ids":["f3e873446ef36bdf3","ff874ba1d4557ecf0","f78df8eee3ffdcb1a","f15b3708df2996542","faa2f4acf84fdda73","f063c0a92a1bae6ff","fc21341a65d82b6b2","f913f71bf6b89e0af","fd948f2b516eb8463"],"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":531.1,"llm_calls":28,"llm_ms":574778.0,"total_ms":575637.2,"verify_requests":19},"narrowed":true,"remediation":{"baseline":"sidecar","eligible":true,"reasons":{"code_unchanged":true,"plan_changed":true,"registry_unchanged":true,"sidecar_baseline":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","G5","T2","T4","T5b","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G1G2"],"decision":"block","drop_reason":null,"evidence":[],"finding":"The AC4 proving command `grep -q 'T5e' docs/plan-review-gate.md` already passes on the current file (T5e is mentioned at line 142 in the calibration table) without any edit from this ticket — so the command cannot verify that the *new* alarm/demotion playbook content citing T5e demotion precedent was actually added.","group_criteria":null,"group_id":null,"id":"f8805931c92cc3c19","impact":1.0,"is_primary":null,"location":"Acceptance Criteria AC4 / docs/plan-review-gate.md","norm_id":"ncf4424636af4eba5","priority":1.0,"reason":"high-priority+criterion-opted-in","scenarios":[],"severity":"critical","suggested_fix":"Replace the T5e grep with a phrase that only appears in the new content, e.g.: `grep -q 'blocking_fp_proxy' docs/plan-review-gate.md && grep -q 'T5e' docs/plan-review-gate.md`","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"broken_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Replace the `grep -q \"T5e\"` clause in AC4 with a grep that anchors to a string that can ONLY appear after this change — e.g., `grep -q \"T5e.*demotion\" docs/plan-review-gate.md` or `grep -qP 'demot.*T5e|T5e.*demot' docs/plan-review-gate.md` — to avoid the pre-existing calibration-table match.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["Plan states: 'the `blocking_fp_proxy` token does NOT pre-exist in the doc, so it verifies the *new* alarm-rule content, not the incidental T5e mention already in the calibration table'","The same rationale is NOT applied to `grep -q \"T5e\"` — but T5e pre-exists, so that grep is a no-op check","VCDT #1: substring false-positive — grep matches pre-existing content, not the newly added demotion-precedent section"],"finding":"The AC4 proving command uses `grep -q \"T5e\" docs/plan-review-gate.md` to verify the new demotion-precedent content, but the plan itself acknowledges 'the incidental T5e mention already in the calibration table' — meaning T5e already appears in that file before any changes. The grep will always pass (pre-existing match), so it does NOT verify that the new alarm-rule T5e demotion-precedent text was actually added.","group_criteria":null,"group_id":null,"id":"ff350769fe1a92243","impact":1.0,"is_primary":null,"location":"Acceptance Criteria — AC4 proving command","norm_id":"nf7d1fe72061d4fc3","priority":1.0,"reason":"default-advisory","scenarios":["An implementer adds `blocking_fp_proxy` to the doc but forgets to add the T5e demotion-precedent sentence in the alarm/demotion playbook section; AC4 still passes because T5e already appears in the calibration table elsewhere"],"severity":"critical","suggested_fix":"Replace `grep -q \"T5e\" docs/plan-review-gate.md` with `grep -qE 'T5e.*(demot|precedent)|demotion.*T5e' docs/plan-review-gate.md` — this only matches when T5e appears alongside demotion language, which is the new content, not the old calibration-table row.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"broken_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Define the `sample_counts` sub-field vocabulary in the plan's Per-criterion metrics section (e.g., `{\"n_blocking_findings\": int, \"n_advisory_findings\": int, \"n_force_close_or_reopen\": int, \"window_rows\": int}`) so the AC's structural check is meaningful.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["The plan's 'Per-criterion trailing metrics' section defines formulas for blocking_fp_proxy(C) and advisory_application_rate(C) in detail, but 'sample_counts' appears only in the AC proving command as a third required key with no definition.","No definition of sample_counts sub-fields (e.g., n_blocking_findings, n_advisory_findings, n_force_close, n_reopen, window_size) appears anywhere in the plan.","An implementer reading only the plan cannot know whether sample_counts = {n_blocking: int, n_advisory: int} or {denominator_blocking: int, denominator_advisory: int, window_used: int} or some other structure — yet the AC asserts it as a structural requirement."],"finding":"The `sample_counts` block is required by the AC but its internal schema (sub-fields and their semantics) is never defined anywhere in the plan.","group_criteria":null,"group_id":null,"id":"fb65cdb948fc2c753","impact":0.67,"is_primary":null,"location":"Acceptance Criteria — `--emit` AC: '≥1 criterion carrying all three of `blocking_fp_proxy`, `advisory_application_rate`, and a `sample_counts` block'","norm_id":"nb39234c7c9f4a368","priority":0.5025,"reason":"default-advisory","scenarios":["The developer implementing --emit must guess what sub-fields to include in sample_counts; the AC's proving command only checks for key presence (not content), meaning any non-empty object passes the test regardless of what data it actually contains.","A downstream consumer of gate_eval_metrics.json (e.g., a future monitoring tool) will encounter an unstable schema if the implementer makes different choices than what was intended."],"severity":"major","suggested_fix":"Add to the 'Per-criterion trailing metrics' section: '`sample_counts` is `{\"n_blocking\": <denominator of blocking_fp_proxy>, \"n_advisory\": <denominator of advisory_application_rate>, \"n_fp_proxy_hits\": <numerator of blocking_fp_proxy>, \"window_rows\": <actual N used>}`.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add `tests/unit/test_threshold_recalibration.py` (specifically its `EXPECTED_ROUTING` pinned table) to the alarm/demotion playbook in `docs/plan-review-gate.md` as a required companion update whenever a criterion is demoted via `criteria_routing.json`.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["tests/unit/test_threshold_recalibration.py:33–71: EXPECTED_ROUTING is a pinned dict of all criteria with (block_threshold, default_posture) asserted by test_complete_routing_table_matches_expected()","Plan says: 'demote it from blocking to advisory via an ordinary criteria_routing.json edit (default_posture: \"advisory\")'","Plan does not list test_threshold_recalibration.py anywhere in Scope or playbook steps","The plan's own AC5 requires 'make lint && make typecheck && make test green' — a criteria_routing.json demotion without updating EXPECTED_ROUTING breaks this invariant"],"finding":"The alarm/demotion playbook in docs/plan-review-gate.md instructs an operator to edit src/rebar/llm/plan_review/criteria_routing.json (set default_posture: \"advisory\") when blocking_fp_proxy exceeds 10%, but does not enumerate tests/unit/test_threshold_recalibration.py as a mandatory companion update. That file pins the COMPLETE expected routing table (every criterion's block_threshold + default_posture, lines 33–71) and will fail make test on any criteria_routing.json demotion that is not mirrored in EXPECTED_ROUTING.","group_criteria":null,"group_id":null,"id":"f0cc74b4498e50bb0","impact":0.536,"is_primary":null,"location":"Scope / 'docs/plan-review-gate.md' bullet; Alarm/demotion rule section","norm_id":"nd086961233355ea6","priority":0.402,"reason":"default-advisory","scenarios":["Operator follows the documented playbook, edits criteria_routing.json to demote a criterion to advisory, but omits updating EXPECTED_ROUTING in test_threshold_recalibration.py — make test goes red, blocking the Gerrit landing.","A future reader of the playbook cannot find the test update step because it is not in the documented procedure."],"severity":"major","suggested_fix":"In the demotion playbook paragraph, append: 'Also update the `EXPECTED_ROUTING` dict in `tests/unit/test_threshold_recalibration.py` to reflect the new `(block_threshold, default_posture)` for the demoted criterion, or `make test` will fail on the pinned routing parity check.'","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"medium","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":null,"blocking_enabled":null,"checklist_item":"","cohort":null,"criteria":["P6"],"decision":"advisory","drop_reason":null,"evidence":["vague/subjective terms present: clean"],"finding":"Acceptance-criteria / definition-of-done quality issues.","group_criteria":null,"group_id":null,"id":"f607dd457c67f9209","impact":0.4,"is_primary":null,"location":"","norm_id":"ned06ebc801a522e3","priority":0.4,"reason":null,"scenarios":[],"severity":"minor","suggested_fix":"Split compound criteria, replace subjective terms with observable outcomes, and state how each is verified.","tier":"DET","validity":1.0,"verification":null},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Expand the `...` ellipsis in AC2's proving command to the full path `docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py` so the command is copy-pasteable without substitution.","cohort":["E2","E6","F1"],"criteria":["E6","E2"],"decision":"advisory","drop_reason":null,"evidence":["AC2 states: `python .../gate_eval_instrumentation.py --emit && python -c ...`","AC1 states the full path: `python docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py --verify-repro`","VCDT #3 analog: the abbreviated path could cause a literal execution failure if copy-pasted"],"finding":"AC2's proving command uses `...` as an ellipsis for the harness path (`python .../gate_eval_instrumentation.py --emit`), which is a placeholder rather than the full executable path. While the full path is inferable from AC1 and the Scope section, the command as written is not directly copy-pasteable without substitution.","group_criteria":null,"group_id":null,"id":"ffec68666a30eaa6c","impact":0.44,"is_primary":null,"location":"Acceptance Criteria — AC2 proving command","norm_id":"n0808cc447b105314","priority":0.22,"reason":"default-advisory","scenarios":["An automated CI harness or a literal-minded executing agent pastes the AC2 command verbatim and fails because `...` is not a valid path component"],"severity":"minor","suggested_fix":"Replace `python .../gate_eval_instrumentation.py --emit` with `python docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py --emit`.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify subprocess error-handling in the plan: on non-zero exit, the job should surface the miner's stderr, log a clear error, and either abort with a non-zero exit code or fall back to the committed corpus with an explicit warning (document which behavior is intended).","cohort":["T5b","T6","T9"],"criteria":["T5b"],"decision":"advisory","drop_reason":null,"evidence":["Plan says the miner 'atomically writes runs/outcome_corpus.jsonl' but specifies no handling for non-zero subprocess exit.","'--no-refresh flag skips regeneration' — this is an opt-in bypass, not an automatic fallback on failure.","No timeout, retry, or error-surface behavior is described for the subprocess call."],"finding":"The subprocess invocation of `mine_outcome_corpus.py` has no specified error-handling path: if the subprocess exits non-zero (e.g., miner floor-check failure, missing input files), the caller's behavior is undocumented — it may silently continue with a stale or absent corpus, or crash without a clear message.","group_criteria":null,"group_id":null,"id":"f6bb7cb7179b2d36d","impact":0.33,"is_primary":null,"location":"What § — 'Corpus acquisition (subprocess, not import)' / `gate_eval_instrumentation.py`","norm_id":"n30bf3fa8702855a5","priority":0.165,"reason":"default-advisory","scenarios":["Miner floor-check trips on a partial corpus during a CI `--emit` run; job silently reads a stale corpus from a prior run and emits misleading metrics.","Miner is missing a dependency and exits 1; job proceeds with whatever corpus is on disk without warning."],"severity":"minor","suggested_fix":"In the 'Corpus acquisition' section, add: 'If the subprocess exits non-zero, capture stderr, print a human-readable error, and exit non-zero (do not silently read a stale corpus). Operators should re-run with `--no-refresh` to use the committed corpus.'","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Specify the subprocess error-handling contract: on non-zero miner exit, the job should either (a) exit non-zero itself with the miner's stderr, or (b) fall back to the committed corpus with an explicit warning logged — and document which behavior is intended.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["'The job refreshes the outcome corpus by invoking mine_outcome_corpus.py as a subprocess… then reads that JSONL'","mine_outcome_corpus.py:381 calls sys.exit() on floor-check failure — the subprocess exits non-zero","No plan text specifies check=True, stderr capture, or a fallback on CalledProcessError","'A --no-refresh flag skips regeneration and reads the committed corpus (offline / CI use)' — defined as a deliberate choice, not as the automatic fallback on failure"],"finding":"The plan does not specify how `gate_eval_instrumentation.py` handles a non-zero exit from the `mine_outcome_corpus.py` subprocess. If the miner fails (floor-check fails, git objects missing, I/O error), the plan gives no instruction: the job could silently continue with a stale/empty corpus (if it catches the error and reads the committed JSONL) or crash with an unformatted traceback. The `--no-refresh` path is the documented offline fallback, but there is no specified behavior for refresh-attempted-but-failed.","group_criteria":null,"group_id":null,"id":"f3363383b11edf6ff","impact":0.33,"is_primary":null,"location":"What — Corpus acquisition (subprocess, not import)","norm_id":"n621aeaa066836f7f","priority":0.165,"reason":"default-advisory","scenarios":["CI runner has incomplete git objects; miner exits non-zero with floor-check message; gate_eval_instrumentation.py reads the stale committed corpus without warning and emits metrics against an out-of-date dataset","The subprocess call uses check=False (default in subprocess.run); miner fails silently; metrics are computed on a 0-row or prior-commit corpus"],"severity":"minor","suggested_fix":"Use subprocess.run(..., check=True) and catch CalledProcessError; on failure, emit a clear error (including the miner's stderr) and either re-raise (default) or fall back to the committed JSONL with a printed warning. Document the chosen behavior in the CLI --help.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a fallback specification for subprocess non-zero exit: e.g., 'if the subprocess exits non-zero, the job prints the miner's stderr, exits non-zero itself (propagating the error), and does NOT fall back to the committed corpus — use --no-refresh explicitly for offline use.'","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["mine_outcome_corpus.py:381 calls sys.exit() on floor-check failure, which will cause the subprocess to exit with a non-zero returncode.","The plan describes the --no-refresh flag as the mechanism for offline/CI use (skips regeneration, reads committed corpus), but says nothing about what the job should do when --no-refresh is NOT set and the subprocess fails.","No fallback, error-propagation rule, or abort-vs-continue decision is specified for the subprocess failure case."],"finding":"The plan does not specify what `gate_eval_instrumentation.py` should do when the `mine_outcome_corpus.py` subprocess exits non-zero (i.e., the miner's floor-check fails in a live refresh run).","group_criteria":null,"group_id":null,"id":"f2f03b4077dc3003d","impact":0.33,"is_primary":null,"location":"What section — 'Corpus acquisition (subprocess, not import)': 'The job refreshes the outcome corpus by invoking mine_outcome_corpus.py as a subprocess … then reads that JSONL.'","norm_id":"nc6def14021ef8ebd","priority":0.165,"reason":"default-advisory","scenarios":["In a CI environment without git objects (shallow clone), the miner fails with non-zero exit; gate_eval_instrumentation.py has no specified behavior — it might silently read the stale corpus, crash with an unhandled exception, or propagate the exit code.","An operator running the job without --no-refresh on a machine with gc'd objects gets an opaque failure with no documented recovery path."],"severity":"minor","suggested_fix":"In the 'Corpus acquisition' paragraph, add: 'If the subprocess exits non-zero, gate_eval_instrumentation.py must re-emit the miner's stderr and exit non-zero itself (CalledProcessError semantics); it must NOT silently fall back to the committed corpus.'","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an AC (or extend AC1/AC3) that verifies `--no-refresh` skips subprocess invocation and reads the existing corpus — e.g., assert the miner is not called when the flag is passed, or that `--verify-repro --no-refresh` exits non-zero only on corpus content failure rather than subprocess failure.","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"dropped","drop_reason":null,"evidence":["\"A `--no-refresh` flag skips regeneration and reads the committed corpus (offline / CI use)\" — What section","\"CLI flags `--verify-repro`, `--emit`, `--window N`, `--no-refresh`\" — Scope section","ABSENCE: no AC item references `--no-refresh`; the four ACs cover `--verify-repro`, `--emit`, `--window N`, and `pytest` only"],"finding":"The `--no-refresh` flag is a named CLI deliverable described in the What section and listed in Scope but has no Acceptance Criterion that verifies its behavior (e.g., that it skips subprocess invocation and reads the committed corpus).","group_criteria":null,"group_id":null,"id":"fa3ed7f6be43bb3fa","impact":0.0,"is_primary":null,"location":"Scope (CLI flags list) / What section ('A `--no-refresh` flag skips regeneration') / AC section (no entry)","norm_id":"n9aa839e618a520e8","priority":0.0,"reason":"low-validity","scenarios":["An implementer could omit `--no-refresh` or implement it incorrectly with no CI signal; CI offline runs that depend on this flag would silently fail or regenerate the corpus unexpectedly."],"severity":"none","suggested_fix":"Extend AC1 or add a new bullet: '`--verify-repro --no-refresh` reads `runs/outcome_corpus.jsonl` without invoking `mine_outcome_corpus.py` and still exits 0 when the committed corpus is present (proving command: `python .../gate_eval_instrumentation.py --verify-repro --no-refresh`).'\nExtend the pytest test to mock the subprocess and assert it is never called when `--no-refresh` is passed.","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Import `RECALL_MIN_PRIORITY` from `rebar.llm.plan_review.sidecar` (or expose it as a named constant from that module) rather than hardcoding `0.5` in the `has_strong_finding` predicate, so threshold changes propagate automatically.","cohort":["T2","T5e","T7"],"criteria":["T5e"],"decision":"dropped","drop_reason":null,"evidence":["Plan states: \"`has_strong_finding` (the exact 'substantive advisory' predicate): ∃ a surfaced sidecar finding with `decision ∈ {\"block\",\"advisory\"}` AND `priority >= 0.5` AND `severity ∈ {\"critical\",\"major\"}`. The 0.5 floor is the codebase's own `RECALL_MIN_PRIORITY` (`src/rebar/llm/plan_review/sidecar.py:299`)\"","Plan explicitly identifies the source constant but specifies the literal value in the predicate, not a reference to the constant"],"finding":"The `has_strong_finding` predicate hardcodes `priority >= 0.5` — the numeric value of `RECALL_MIN_PRIORITY` from `src/rebar/llm/plan_review/sidecar.py:299` — rather than importing that constant. If `RECALL_MIN_PRIORITY` is ever updated in the codebase, the harness will silently use a stale threshold and misclassify tickets without any warning.","group_criteria":null,"group_id":null,"id":"f726f4552d7e4d84b","impact":0.0,"is_primary":null,"location":"## What — `has_strong_finding` predicate definition; `docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py`","norm_id":"n3c18498e4be4bcf5","priority":0.0,"reason":"low-validity","scenarios":["RECALL_MIN_PRIORITY is adjusted during future calibration; the harness silently uses the old 0.5 floor and the classifier produces incorrect labels for months until someone notices the divergence"],"severity":"none","suggested_fix":"In `gate_eval_instrumentation.py`, add `from rebar.llm.plan_review.sidecar import RECALL_MIN_PRIORITY` and replace the literal `0.5` in the predicate with `RECALL_MIN_PRIORITY`. If a direct import is undesirable (e.g., to keep the harness dependency-light), document the coupling explicitly and add a comment `# Must match RECALL_MIN_PRIORITY in sidecar.py:299` with a TODO to sync on calibration changes.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a brief schema description (the three per-criterion keys: `blocking_fp_proxy`, `advisory_application_rate`, `sample_counts`, and their types/nullability) to the harnesses README under the metrics output section.","cohort":["T2","T5e","T7"],"criteria":["T7"],"decision":"dropped","drop_reason":null,"evidence":["AC2 states the proving command checks for `blocking_fp_proxy`, `advisory_application_rate`, and `sample_counts` keys, but the Scope entry for README.md lists 'classifier rules, the 4/8-vs-7/8 finding, the metric definitions + join key, cadence, and the metrics output path' — 'metric definitions' is listed but the per-key schema of the JSON output file is not explicitly called out as required README content","A future operator reading only the README would not know the exact shape of `gate_eval_metrics.json` without running the AC assertion"],"finding":"The `gate_eval_metrics.json` output schema (the keys each criterion entry carries) is verified by an AC inline assertion but is not explicitly listed in the harnesses README for future consumers/maintainers of the metrics file.","group_criteria":null,"group_id":null,"id":"f647944f302353cb6","impact":0.0,"is_primary":null,"location":"## Scope — `docs/experiments/plan-review-gate/README.md`; AC2 proving command","norm_id":"nd33a494a4dc8d7c8","priority":0.0,"reason":"veto:absence-refuted","scenarios":["A future team member wants to write a downstream consumer of `gate_eval_metrics.json`; without a schema in the README they must reverse-engineer it from the AC grep or the source code"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify the `--emit` behavior when the qualifying corpus is empty or yields all-null metrics: either (a) exit with a clear warning and skip writing (documented), or (b) emit a sentinel output that distinguishes 'no data yet' from 'computed zero' so the AC can be adjusted accordingly.","cohort":["T5b","T6","T9"],"criteria":["T6"],"decision":"dropped","drop_reason":null,"evidence":["AC states output must be non-trivial, but gives no guidance on what the tool should do or emit when the corpus genuinely has no qualifying rows (e.g., first deployment, no force-closes/reopens yet).","The classifier is applied ONLY to tickets with 'had_persisted_review AND a post-claim signal' — in early operation this intersection may be empty.","No error message, warning, or alternative output is specified for this empty-data case."],"finding":"The `--emit` path has no specified behavior when the joined dataset is legitimately empty (e.g., no tickets yet have both a persisted review AND a post-claim signal), yet the AC explicitly rejects `{}` / all-null output as non-satisfying — the plan does not resolve this contradiction for the early-deployment scenario.","group_criteria":null,"group_id":null,"id":"fd1fc89c8e91c2f58","impact":0.0,"is_primary":null,"location":"AC line: 'a non-trivial object with ≥1 criterion carrying all three of blocking_fp_proxy, advisory_application_rate, and a sample_counts block (NOT satisfiable by {}/all-null)'","norm_id":"n5241b13f61bfcfc3","priority":0.0,"reason":"veto:absence-refuted","scenarios":["First run after deployment: corpus has 628 rows but none have both a persisted review and a force-close/reopen; `--emit` produces `{}` and the AC verification assertion fires, making CI red for a legitimate state.","Operator runs `--emit --window 10` on a small window with no qualifying tickets — same result."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The `blocking_fp_proxy` formula's third disjunct — `(no adverse post-claim edit)` — is true for ~95%+ of corpus rows (the overwhelming majority have `post_claim_edit_class: 'none'`), making the entire `force_close OR reopen_count>0 OR (no adverse post-claim edit)` disjunction fire on virtually every blocking finding regardless of criterion quality. The metric would report near-100% FP-proxy for every criterion and be useless as a monitoring signal.","group_criteria":null,"group_id":null,"id":"f95c3ca451cbd9457","impact":0.0,"is_primary":null,"location":"## What — Per-criterion trailing metrics section: 'blocking_fp_proxy(C) = (# of C's blocking findings whose ticket was subsequently adjudicated not-block-worthy — proxied by `force_close OR reopen_count>0 OR (no adverse post-claim edit)`)'","norm_id":"n6152034bbb71d0d4","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"Redefine the proxy as `force_close OR reopen_count>0` (operational signals that the author had to work around the block), with 'no adverse post-claim edit' used as a *separate* `advisory_hit_rate`-style metric rather than folded into the FP proxy disjunction. If 'no adverse post-claim edit' is intended to mean 'the author didn't change anything, so the block may have been unnecessary,' it should be scoped to tickets where a review actually produced a blocking finding AND the ticket was closed without any author-side edit — expressed as a conjunction, not a disjunction: `(no adverse post-claim edit) AND (reopen_count == 0) AND (not force_close)` interpreted as 'ticket closed clean despite block' which would then be a separate metric track, not part of the FP proxy.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Clarify the sidecar scope for `has_strong_finding`: specify whether ∃ ranges over the LATEST round's surfaced findings only, or across ALL retained rounds — and document which choice was used in the 8-case investigation that produced the 7/8 repro result.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":"novelty","evidence":["sidecar.py provides both `latest_review_result` (single latest payload) and `all_review_results` (all retained payloads, newest-first); the plan says 'reads each reviewed ticket's persisted REVIEW_RESULT sidecars via rebar.llm.plan_review.sidecar.all_review_results' but then defines has_strong_finding with a bare ∃-quantifier.","For a C3 ticket (has_strong_finding=True, review_round_count=1), the scope does not matter. But for a ticket with review_round_count=2, round 1 might have a strong finding while round 2 (after plan revision) might not — the classifier outcome (UNKNOWABLE vs MISSED) depends entirely on which round's findings are searched.","The plan names `all_review_results` as the sidecar reader but does not resolve whether the predicate should be satisfied by ANY round or only the FINAL round."],"finding":"The `has_strong_finding` predicate is defined as '∃ a surfaced sidecar finding' but does not specify whether the ∃-quantifier ranges over ALL retained sidecar payloads for the ticket (all review rounds) or only the LATEST payload — an ambiguity that matters structurally because the classifier uses `review_round_count >= 2` as C2, implying multi-round tickets are the exact population where this choice is load-bearing.","group_criteria":null,"group_id":null,"id":"f3e873446ef36bdf3","impact":0.33,"is_primary":null,"location":"What section — has_strong_finding definition: '∃ a surfaced sidecar finding with decision ∈ {\"block\",\"advisory\"} AND priority >= 0.5 AND severity ∈ {\"critical\",\"major\"}'","norm_id":"nb9a1101d049037f1","priority":0.2063,"reason":"default-advisory","scenarios":["A ticket with a strong finding in round 1 but only weak findings in round 2 (because the author revised) — using all_review_results gives has_strong_finding=True (UNKNOWABLE); using only latest gives has_strong_finding=False (MISSED). The classifier emits different labels for the same ticket depending on implementation choice.","The 8 frozen test cases may not cover this ambiguity (the test asserts ≥6/8 agreement but does not enumerate which 2 are allowed to fail), so the golden test cannot detect a wrong implementation of this scoping rule."],"severity":"minor","suggested_fix":"Add to the has_strong_finding definition: 'The ∃-quantifier ranges over the LATEST retained REVIEW_RESULT payload only (i.e., `surfaced_findings(latest_review_result(ticket_id))`) — not across all rounds — because the classifier is predicting whether the gate *currently* has a strong signal, not whether it ever did.'","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Either add `rounds_per_ticket` to the AC2 proof command's key-check tuple, or clarify in the What section that it is a top-level (not per-criterion) field and add a separate assertion for it.","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":"novelty","evidence":["\"rounds_per_ticket = the review_round_count distribution over the window\" — What section, listed as the third of three per-criterion metrics","AC2 proof command: `assert d and any(all(k in v for k in ('blocking_fp_proxy','advisory_application_rate','sample_counts')) for v in d.values())` — `rounds_per_ticket` not checked","ABSENCE: no AC item references the `rounds_per_ticket` key or its presence in the output JSON"],"finding":"The `rounds_per_ticket` metric is described as a per-criterion trailing metric deliverable in the What section but is absent from the AC2 verification check, which only checks for `blocking_fp_proxy`, `advisory_application_rate`, and `sample_counts`.","group_criteria":null,"group_id":null,"id":"ff874ba1d4557ecf0","impact":0.33,"is_primary":null,"location":"What section ('rounds_per_ticket = the review_round_count distribution over the window') / AC2 proof command","norm_id":"n47f457a29b8628c5","priority":0.1886,"reason":"default-advisory","scenarios":["An implementer could omit `rounds_per_ticket` from `gate_eval_metrics.json` entirely with no CI signal; or place it at a different JSON level (window-level vs per-criterion), causing downstream consumers to fail."],"severity":"minor","suggested_fix":"If per-criterion: extend the AC2 key tuple to `('blocking_fp_proxy','advisory_application_rate','sample_counts','rounds_per_ticket')`. If window-level: add `assert 'rounds_per_ticket' in d` to the AC2 proof command and clarify its placement in the What section.","tier":"LLM","validity":0.5714,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify that `--emit` writes to a temporary file in the same directory and renames it atomically on success (e.g., `gate_eval_metrics.json.tmp` → `gate_eval_metrics.json`), ensuring the output is never in a partial state.","cohort":["T5b","T6","T9"],"criteria":["T5b","T9"],"decision":"advisory","drop_reason":"novelty","evidence":["Plan specifies the output path and format but says nothing about write atomicity or temp-file+rename.","AC verification command does `json.load(open(...))` immediately after `--emit` — a torn file causes this to fail with JSONDecodeError, not a clear message.","No concurrent-write protection is described; two CI jobs running `--emit` simultaneously can interleave writes."],"finding":"The `--emit` write to `runs/gate_eval_metrics.json` is not specified to be atomic (e.g., write to a temp file then rename); a process interruption mid-write leaves a corrupt JSON file that subsequent reads (including the AC verification command) will fail on with an opaque parse error.","group_criteria":null,"group_id":null,"id":"f78df8eee3ffdcb1a","impact":0.0,"is_primary":null,"location":"AC line: '--emit writes per-criterion metrics to runs/gate_eval_metrics.json' / Scope § `gate_eval_instrumentation.py`","norm_id":"n236c411df59b848a","priority":0.0,"reason":"default-advisory","scenarios":["SIGINT during a long `--emit` run leaves a half-written JSON file; next CI run's verification step fails with a cryptic parse error.","Two parallel CI jobs both run `--emit`; the file contains interleaved partial output from each."],"severity":"none","suggested_fix":"Add to the Scope section: 'The `--emit` write uses an atomic write pattern: serialize to `gate_eval_metrics.json.tmp`, then `os.replace()` to `gate_eval_metrics.json`, so the output file is never in a partial state.'","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add at least one `pytest`-collected unit test for `has_strong_finding(findings_list)` covering a true case (decision=block, priority≥0.5, severity=critical) and a false case (priority<0.5), so the extractor's field-parsing and threshold logic are CI-verified independently of the CLI proving command.","cohort":["E3","E5","G5"],"criteria":["E5"],"decision":"advisory","drop_reason":"novelty","evidence":["Plan scope: 'the `has_strong_finding` sidecar extractor' listed as an explicit deliverable","Test scope: 'a golden test importing the pure `classify` and asserting the 8 frozen `(cls, rounds, strong) → label` tuples' — `strong` is pre-supplied, extractor untested","Extractor uses `RECALL_MIN_PRIORITY` constant and severity conjunction — load-bearing for the 7/8 repro claim","--verify-repro is a manual proving command, not part of the `pytest` CI suite"],"finding":"The `has_strong_finding` sidecar extractor — a named deliverable in Scope with specific field references (`decision`, `priority >= RECALL_MIN_PRIORITY`, `severity ∈ {critical,major}`) — has no unit test in CI. The pytest AC only exercises `classify(post_claim_edit_class, review_round_count, has_strong_finding)` with a pre-supplied boolean, so the extractor's field-parsing and threshold logic are never verified by `make test`. The `--verify-repro` integration path exercises it, but that AC is a manual proving command, not a CI-collected test.","group_criteria":null,"group_id":null,"id":"f15b3708df2996542","impact":0.0,"is_primary":null,"location":"Scope: `has_strong_finding` sidecar extractor; AC: `python -m pytest tests/unit/test_gate_eval_classifier.py -q`","norm_id":"nafb1254fe04914d6","priority":0.0,"reason":"default-advisory","scenarios":["If the sidecar schema renames `priority` or the `decision` enum changes, the extractor silently returns wrong values; the unit test suite stays green because it never calls the extractor","The 7/8 repro claim rests on extractor correctness, but CI only validates the cascade logic, not the sidecar parsing"],"severity":"none","suggested_fix":"In `tests/unit/test_gate_eval_classifier.py`, add a small fixture of mock sidecar finding dicts and assert `has_strong_finding([...]) == True/False` for the boundary cases (at-floor priority, below-floor, wrong severity like 'minor', and the severity exclusion for high-priority-but-procedural findings).","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Clarify in the classifier spec and README how C3-labeled (UNKNOWABLE) tickets are handled in the trailing-metrics join — either exclude them from per-criterion counts (treating N/A consistently for both the 8-case validation and the operational window) or rename C3's output to something operationally meaningful (e.g. 'AMBIGUOUS') with a defined handling rule.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":"novelty","evidence":["Cascade: 'C3  has_strong_finding  → UNKNOWABLE'","The UNKNOWABLE label in §5 was a one-time human judgment ('the separating signal… does NOT carry the separating signal') for a single case; the corpus has no UNKNOWABLE field","The plan validates only '≥6/8 agreement' on the 8 frozen cases — it does not specify or bound how C3 behaves on the ~620 non-frozen corpus rows","Trailing metrics join: 'joining each REVIEW_RESULT finding to its ticket's outcome row' — UNKNOWABLE-labeled tickets contribute to per-criterion counts with an uninterpretable label"],"finding":"The cascade's C3 branch (has_strong_finding → UNKNOWABLE) fires on ALL tickets in the broader trailing-metrics corpus that survive the pre-filter and have a strong finding — not just the one frozen UNKNOWABLE case. In the full window of N=200+ rows, any ticket with `had_persisted_review AND post_claim_signal AND has_strong_finding` will be labeled UNKNOWABLE by the classifier, inflating the UNKNOWABLE bucket in the confusion table and making the operational output misleading for human reviewers inspecting the metrics.","group_criteria":null,"group_id":null,"id":"faa2f4acf84fdda73","impact":0.0,"is_primary":null,"location":"What — Outcome classifier cascade (C3 branch) and §Per-criterion trailing metrics","norm_id":"n23885b2793a3ac90","priority":0.0,"reason":"default-advisory","scenarios":["Operator runs --emit over a 200-row window; several tickets with strong findings but no C1/C2 signal are labeled UNKNOWABLE; the metrics output contains an UNKNOWABLE bucket that has no actionable meaning and no alarm threshold","--verify-repro passes (≥6/8 on frozen cases) while the broader metrics are populated with spurious UNKNOWABLE rows"],"severity":"none","suggested_fix":"Treat C3 tickets as N/A for metric computation (consistent with the 'applied ONLY to tickets with had_persisted_review AND a post-claim signal' pre-filter already excluding most rows); document that the UNKNOWABLE label is a validation artifact for the 8 frozen cases only, and the broader window's C3 outputs are excluded from metric numerators and denominators.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Resolve the LLM-vs-deterministic classifier conflict with the parent spec: either update `docs/research/task-decomposition-sota-2026.md §R7` to reflect the deterministic design (forcing parent re-review) before landing the leaf, or document in the leaf's scope statement that it is adopting the deterministic approach as a supersession of the parent's LLM method with an explicit cross-reference.","cohort":["G7"],"criteria":["G7"],"decision":"advisory","drop_reason":"novelty","evidence":["Parent spec (docs/research/task-decomposition-sota-2026.md §R7): 'classifying it MISSED / CAUGHT-BUT-IGNORED / UNKNOWABLE — initially by LLM with human spot-audit, using §5.2's rubric'","Leaf plan: 'The classifier is a first-match cascade' — explicitly deterministic, no LLM involvement","Leaf rationale: 'a classifier over the sidecar findings alone reaches only 4/8' — but this argues for a different LLM input, not for eliminating LLM entirely"],"finding":"The leaf replaces the parent's specified LLM-based classifier ('initially by LLM with human spot-audit, using §5.2's rubric') with a deterministic cascade, directly contradicting the parent's method specification. Per G7, the parent wins on conflicts; the leaf should either align to an LLM classifier or update the parent spec first.","group_criteria":null,"group_id":null,"id":"f063c0a92a1bae6ff","impact":0.0,"is_primary":null,"location":"What section — 'Outcome classifier (deterministic; the honest finding is that the sidecar findings do NOT carry the separating signal)'","norm_id":"n6147c228f859df30","priority":0.0,"reason":"default-advisory","scenarios":["A reviewer checking leaf-parent containment observes that the parent mandates an LLM classifier, while the leaf delivers a deterministic one — a direct method conflict the parent wins on.","If R1–R6 experiments expect an LLM-based gate-eval record as their substrate, a deterministic surrogate may not satisfy downstream consumers."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5714,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Either update the parent spec (`docs/research/task-decomposition-sota-2026.md §R7`) to explicitly scope to a batch-only harness over the outcome corpus (not a per-edit live append), or add to the leaf's scope a note explaining why the batch approach fulfils the parent's substrate intent and that the live-append mechanism is deferred.","cohort":["G7"],"criteria":["G7"],"decision":"advisory","drop_reason":"novelty","evidence":["Parent spec: 'on every material post-claim description edit, link the edit to the ticket's latest REVIEW_RESULT and append a gate-eval record (sidecar-style, reducer-ignored)' — implies a live, incremental record is written per edit event","Leaf scope: a re-runnable batch job that 'refreshes the outcome corpus by invoking mine_outcome_corpus.py as a subprocess, then reads that JSONL' — pure batch, no live append","Leaf explicitly states: 'No change to src/rebar/ behaviour' — confirming the live event-append path is absent"],"finding":"The parent spec describes a live/incremental mechanism ('on every material post-claim description edit, link the edit to the ticket's latest REVIEW_RESULT and append a gate-eval record (sidecar-style, reducer-ignored)'), but the leaf delivers only a batch harness over the static outcome corpus with no event-driven append of gate-eval records to the ticket store. The live-append mechanism is out of scope in the leaf without the parent being updated to reflect this narrowing.","group_criteria":null,"group_id":null,"id":"fc21341a65d82b6b2","impact":0.0,"is_primary":null,"location":"Scope section — 'docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py'","norm_id":"n1aca12a7f7fa1730","priority":0.0,"reason":"default-advisory","scenarios":["A future R1–R6 experiment joins on gate-eval records written per post-claim edit and finds none exist, because the leaf never appended them.","The parent's intent of a durable per-edit signal (linked to the causal REVIEW_RESULT) is lost if the job is only run ad-hoc or monthly over the snapshot corpus."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5714,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Confirm that the per-criterion trailing metrics (blocking_fp_proxy(C), advisory_application_rate(C), rounds_per_ticket per criterion) are within the parent's authorized scope — either cite a parent-level authorization, or update `docs/research/task-decomposition-sota-2026.md §R7` to include per-criterion metrics before landing this leaf.","cohort":["G7"],"criteria":["G7"],"decision":"advisory","drop_reason":"novelty","evidence":["Parent spec: 'Report monthly: post-claim material-edit rate (baseline 3.2%), miss rate among reviewed tickets (baseline 3/8), advisory-latency rate (baseline 4/8), blocking-FP proxy (blocked findings the author disputes or that vanish without plan change)' — four aggregate metrics, none per-criterion","Leaf: introduces finding-level per-criterion blocking_fp_proxy(C), advisory_application_rate(C), rounds_per_ticket distribution — a significantly expanded metrics layer not in the parent","Leaf AC: '--emit writes per-criterion metrics to gate_eval_metrics.json — a non-trivial object with ≥1 criterion carrying all three of blocking_fp_proxy, advisory_application_rate, and a sample_counts block'"],"finding":"The leaf introduces per-criterion trailing metrics (blocking_fp_proxy(C), advisory_application_rate(C), rounds_per_ticket) that go substantially beyond the four aggregate statistics the parent specifies (post-claim material-edit rate, miss rate, advisory-latency rate, blocking-FP proxy). These per-criterion metrics are a new deliverable the parent's scope does not authorize.","group_criteria":null,"group_id":null,"id":"f913f71bf6b89e0af","impact":0.0,"is_primary":null,"location":"What section — 'Per-criterion trailing metrics (FINDING-level, matching the parent epic's definition)'","norm_id":"n7593495f9fb7d6ba","priority":0.0,"reason":"default-advisory","scenarios":["The parent reviewer or epic owner did not authorize per-criterion metrics as part of R7; adding them in the leaf without parent authorization is scope creep that could affect downstream design decisions for R1–R6.","If the parent's four aggregate metrics are the agreed measurement contract for the epic, per-criterion variants are a design extension that needs explicit parent-level approval."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5714,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Either add the alarm/demotion playbook to the parent spec (`docs/research/task-decomposition-sota-2026.md §R7`) as an authorized deliverable before landing the leaf, or remove the `docs/plan-review-gate.md` demotion playbook from R7's scope and track it as a separate ticket.","cohort":["G7"],"criteria":["G7"],"decision":"advisory","drop_reason":"novelty","evidence":["Parent spec: 'Add a small offline job (not a gate change)' — explicitly constrains to a non-gate change","Parent spec: no mention of an alarm threshold, demotion rule, or playbook document","Leaf: 'docs/plan-review-gate.md — the alarm/demotion playbook (>10% blocking-FP rule, T5e precedent, operator response). The ONLY change outside docs/experiments/'"],"finding":"The leaf adds a formal alarm/demotion playbook to `docs/plan-review-gate.md` (a production operational document) — including a >10% blocking-FP alarm rule and operator demotion instructions. The parent R7 spec describes only an offline instrumentation job ('not a gate change') with no mention of a documented demotion playbook; this is a new deliverable the parent does not contain.","group_criteria":null,"group_id":null,"id":"fd948f2b516eb8463","impact":0.0,"is_primary":null,"location":"Scope section — 'docs/plan-review-gate.md — the alarm/demotion playbook (>10% blocking-FP rule, T5e precedent, operator response). The ONLY change outside docs/experiments/'","norm_id":"naf406d96b9f988da","priority":0.0,"reason":"default-advisory","scenarios":["The demotion playbook in docs/plan-review-gate.md becomes operational guidance that engineers act on; if the parent never authorized this operational doc change, it may conflict with other epic-level decisions about criteria governance.","A future reviewer of docs/plan-review-gate.md sees alarm/demotion rules sourced from R7 without tracing back to a parent-level authorization."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5714,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"3852f25498f6acb5","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":531.1,"llm_calls":28,"llm_ms":574778.0,"total_ms":575637.2,"verify_requests":19},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"b1a4-af7a-4a48-465d","ticket_type":"story","verdict":"BLOCK","verified_at_sha":"43d1545237745f4666dcc13c81587c824251e51d"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784256019059214001,"uuid":"3358a9ae-2a49-47ee-b7d9-c71ac3d8f1c6"}