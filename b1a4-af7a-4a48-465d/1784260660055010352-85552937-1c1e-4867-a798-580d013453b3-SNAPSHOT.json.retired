{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","data":{"compacted_at":1784260660055010352,"compiled_state":{"alias":"stenchful-retail-basenji","assignee":"","attestations":{"plan-review":{"algorithm":"sshsig","author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","envelope":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.opcert.v1+json\", \"signatures\": [{\"keyid\": \"ade0f2ef-51cc-45a2-bb97-c09846cd3df5\", \"sig\": \"\"}]}","head_sha":"47d6972c10ce4700eb7e2673f576d22f3308c152","key_id":null,"kind":"plan-review","manifest":["plan-review: PASS","ticket: b1a4-af7a-4a48-465d","material: d292170db13f1378","model: claude-sonnet-4-6","runner: pydantic_ai","blocking: 0","advisory: 9","rebar-version: 0.8.0 (47d6972c1)","regver: b293b9a55de591cc","verified-at-sha:cb0f8ec3b0641860ea6139431ccc63ca528c4732","dep absent docs/experiments/plan-review-gate/","dep f8582a65f833877bf78d3502459802829da75dc2348afa417870ffcf519a1a4f docs/plan-review-gate.md"],"material_fingerprint":"d292170db13f1378","merged_log_commit":"cb0f8ec3b0641860ea6139431ccc63ca528c4732","principal":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","signature":null,"signed_at":1784259525559983000}},"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","authorship":{"signed":13,"unsigned":3},"authorship_ledger":[{"content_hash":"a5b4937c1570b1fadd4f36140d7d8661900fd0a78c1d4f4cc95c62738eb078e0","event_uuid":"e764b8bc-6da0-49fc-bf53-3a1f5774831a","position":{"commit_sha":null,"position":"1784238660919555001-e764b8bc-6da0-49fc-bf53-3a1f5774831a"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"757183093420e1dd90c11cac39bbc8329b3c27a51683198e010d245e803f5f0c","event_uuid":"5ab33770-7b00-4715-be7a-016902bd20a2","position":{"commit_sha":null,"position":"1784238663375308001-5ab33770-7b00-4715-be7a-016902bd20a2"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"b3030c39b0ce27c2e20d90a91ca08c0827ca63860b9c54af8ec9a0874a0f9117","event_uuid":"528e363b-feb5-407d-9941-4719bc9f3e17","position":{"commit_sha":null,"position":"1784251411432704001-528e363b-feb5-407d-9941-4719bc9f3e17"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"8aed3d4372e83ce8a299e0a0d353741138a33ea2ba3187755db04b4fdf0235cd","event_uuid":"3ed28f0a-8e41-4361-b1d1-6e43793d7c57","position":{"commit_sha":null,"position":"1784252906888026001-3ed28f0a-8e41-4361-b1d1-6e43793d7c57"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"639a2185b6264c6b8e96fd5f2944cd9892f04a82ea97c93dc5b047ac5750d57d","event_uuid":"a26937a2-cbee-4c3d-b00f-dfaa7cf44170","position":{"commit_sha":null,"position":"1784253847483301001-a26937a2-cbee-4c3d-b00f-dfaa7cf44170"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"e81cf76144678eda8e99f6b728649512ead1734bbf7c2b74ace02b8499f90023","event_uuid":"bda67a7b-7b53-4206-bddc-dc32ef632616","position":{"commit_sha":null,"position":"1784255080026479001-bda67a7b-7b53-4206-bddc-dc32ef632616"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"67ac8be11602f4513f4f8d703dfc22628ca4d858f3eb4bcafd560faacb3ee707","event_uuid":"5531d09e-33ee-4be1-a519-d45b2fecdae2","position":{"commit_sha":null,"position":"1784256244066780001-5531d09e-33ee-4be1-a519-d45b2fecdae2"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"d519fd5c529da7d76d70da14246aecc9126d17b841d9c3a35e1192425d236699","event_uuid":"dc9abb9f-5b20-4ff6-9e14-e609d920fe53","position":{"commit_sha":null,"position":"1784257103517315001-dc9abb9f-5b20-4ff6-9e14-e609d920fe53"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"b9cb85cf29b1ef22dfb5503c7fc1a6110dbfd3d1eb61d5f3784435cddd8853ca","event_uuid":"51d717ac-5439-42c8-a2cb-aca9457becf9","position":{"commit_sha":null,"position":"1784258978255697001-51d717ac-5439-42c8-a2cb-aca9457becf9"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"ff7cdf00b19452f840df6e15bf4d405f6c34f37e990c7413886ac1b7f1f42427","event_uuid":"edcdf338-ce04-4e3d-b1aa-d438920fd1db","position":{"commit_sha":null,"position":"1784259525560266001-edcdf338-ce04-4e3d-b1aa-d438920fd1db"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"fb48614500a18e5a1c7fb5536254f4fb573d4d62ed2df9fb12ba47ff3e1a727e","event_uuid":"aa3209ef-3386-4868-a347-dac7200854fe","position":{"commit_sha":null,"position":"1784259676420451001-aa3209ef-3386-4868-a347-dac7200854fe"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"dc7696fe2f7052fab73288251d9375d2f71284e76693cac35fa597c250ff52ae","event_uuid":"b21ee9e7-53b9-418e-a1c2-c6704bb4cf56","position":{"commit_sha":null,"position":"1784259676634161001-b21ee9e7-53b9-418e-a1c2-c6704bb4cf56"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"af35994712180dadd0d5f75cbfc07515a8bfb4331e29e59673d20b742891d324","event_uuid":"ec2e6fbc-fab7-4271-8b20-880532606511","position":{"commit_sha":null,"position":"1784260660055010351-ec2e6fbc-fab7-4271-8b20-880532606511"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-212_agent","claim_remote_session":null,"claimed_session":"0598b281-0286-4b2c-891c-cc5b4c94ba24","comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"E1 DESCOPE NOTE (2026-07-16): E1's finding-adjudication TP/FP corpus was INVALIDATED (tool-less, plan-truncated labeling that doesn't match the whole-plan/code-grounded/agentic production gate; ~79 percent contaminated) and DESCOPED — the independent human-adjudicated gold set is parked as idea e59d-c078-724d-46e5. E1 still delivers the VALID outcome corpus + finding sample. This story (R7) uses the E1 OUTCOME-corpus classification method + the frozen §5.2 outcome labels. UNAFFECTED by the adjudication-corpus invalidation; proceed on the outcome corpus when resourced.","timestamp":1784238660919555001}],"created_at":1784143864014182001,"creation_channel":"unknown","deps":[{"link_uuid":"2da4438c-01a3-40e4-9080-8f517cd33c24","relation":"depends_on","target_id":"e95e-1543-cac7-47b9"},{"link_uuid":"5ab33770-7b00-4715-be7a-016902bd20a2","relation":"relates_to","target_id":"e59d-c078-724d-46e5"}],"description":"## Why\nEvery gate row and all post-ship dogfooding in this epic needs standing outcome\ninstrumentation: today nothing routinely ties plan-review verdicts to downstream outcomes\n(post-claim edits, reopens, force-closes, verifier FAILs), so false-positive drift stays\ninvisible until it burns author trust (the Tricorder <10% blocking-FP cliff). E1 froze the\nper-ticket **outcome corpus** (`runs/outcome_corpus.jsonl`, 628 rows) and the miner that\nproduces it; this ticket turns that one-shot artifact into a **re-runnable gate-eval job** that\nclassifies each reviewed ticket, emits trailing per-criterion FP-proxy metrics, and documents\nthe alarm/demotion playbook.\n\n## What\nCommit a re-runnable **gate-eval instrumentation job** at\n`docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py`.\n\n**Corpus acquisition (subprocess, not import).** The job refreshes the outcome corpus by\ninvoking `mine_outcome_corpus.py` **as a subprocess** (`python <harnesses>/mine_outcome_corpus.py`,\nwhich atomically writes `runs/outcome_corpus.jsonl`), then reads that JSONL. It does NOT\n`import` and call `build_corpus()`, because that entry calls `sys.exit()` on floor-check failure\n(`mine_outcome_corpus.py:381`), which would terminate the caller; and the miner lives in a\nnon-package `harnesses/` dir, so subprocess-by-path is also the clean invocation. A\n`--no-refresh` flag skips regeneration and reads the committed corpus (offline / CI use). It\nthen reads each reviewed ticket's persisted `REVIEW_RESULT` sidecars via\n`rebar.llm.plan_review.sidecar.all_review_results`.\n\n**Outcome classifier (deterministic; the honest finding is that the sidecar findings do NOT\ncarry the separating signal).** Investigation against the 8 §5.2 cases proved a classifier over\nthe sidecar findings *alone* reaches only **4/8** — the CAUGHT-BUT-IGNORED cases (c8cc, f5df)\nhave finding profiles at or *below* the MISSED cases, because \"caught-but-ignored\" is a fact\nabout the author's **post-claim edit**, not about what the gate saw. The separating signal lives\nin two outcome-corpus fields plus one sidecar-derived strength predicate. The classifier is a\nfirst-match cascade, applied ONLY to tickets with `had_persisted_review` AND a post-claim signal\n(`post_claim_edit_class != \"none\"` OR `review_round_count >= 2`); all others are **N/A**:\n\n```\nC1  post_claim_edit_class == \"operator-attested-retag\"  → CAUGHT-BUT-IGNORED\nC2  review_round_count >= 2                              → CAUGHT-BUT-IGNORED\nC3  has_strong_finding                                   → UNKNOWABLE\nC4  else                                                 → MISSED\n```\n- `review_round_count` is the **git-walk outcome-corpus** count (true count), not the pruned\n  on-disk sidecar count.\n- **`has_strong_finding`** (the exact \"substantive advisory\" predicate, evaluated over the\n  ticket's deduplicated round union — see Multi-round handling): ∃ a finding with\n  `decision ∈ {\"block\",\"advisory\"}` AND `priority >= 0.5` AND `severity ∈ {\"critical\",\"major\"}`.\n  The 0.5 floor is the codebase's own `RECALL_MIN_PRIORITY`\n  (`src/rebar/llm/plan_review/sidecar.py:299`); the severity conjunct excludes\n  high-priority-but-procedural (P6/P9) findings.\n\nThis **core** cascade reproduces the 8 frozen labels at **7/8** (only c8cc, a lone\n`substantive-unclassified` case, misclassifies as MISSED). A `substantive-unclassified → CAUGHT`\nrule would reach 8/8 but rests on that single case, so it is **deliberately excluded** as\noverfitting and documented as such. The README states plainly that the classifier separates via\noutcome-corpus fields + a sidecar strength predicate, NOT via sidecar findings alone (which\nachieve only 4/8) — the load-bearing methodological finding.\n\n**adverse post-claim edit** (used by both the classifier gate and the metrics below) is defined\nonce: `post_claim_edit_class ∈ {\"plan-authored-post-claim\", \"ac-strengthened\",\n\"substantive-unclassified\"}` (the substantive classes; `operator-attested-retag` is handled by\nC1; `cosmetic`/`none` are not adverse).\n\n**Multi-round handling (load-bearing — `all_review_results` returns every retained round).**\n`sidecar.all_review_results(ticket_id)` returns ALL retained review payloads (newest→oldest, up\nto the 50/ticket cap), not just the latest. For each ticket the harness forms the **deduplicated\nunion** of findings across all retained rounds, keyed by\n`(tuple(sorted(finding[\"criteria\"])), finding[\"finding\"])` — so a finding that persists across\nrounds counts exactly **once** (no denominator inflation for high-round tickets) and a finding\ncleared in a later round is still counted (no omission of earlier blocks). `has_strong_finding`\nis `∃ a strong finding in this union` (consistent with the §5.2 investigation — 8c4f's strong\nfinding lived in its earlier BLOCK round, cleared by round 2), and every per-criterion metric\ndenominator below counts C's findings in this union.\n\n**Per-criterion trailing metrics (FINDING-level, matching the parent epic's definition).** Over\nthe trailing window (see `--window`), joining each ticket's deduplicated finding union to its\noutcome row by `ticket_id`, for each criterion C:\n- **blocking_fp_proxy(C)** = (# of C's **blocking** findings whose ticket was subsequently\n  adjudicated not-block-worthy) / (total # of C's blocking findings). The automatic proxy for\n  \"adjudicated not-block-worthy\" is **`force_close OR reopen_count > 0`** (an explicit gate\n  bypass, or a post-close reopen). The earlier `(no adverse post-claim edit)` disjunct is\n  **removed**: blocking findings are remediated *pre-claim* in the review loop, so ~95% of\n  tickets legitimately have `post_claim_edit_class == \"none\"`, and that disjunct would fire on\n  nearly every honored block and mislabel it FP. This proxy is therefore a deliberately\n  conservative **lower bound** (force-close can also happen for orthogonal operator-attestation\n  reasons, ADR 0043), so the >10% alarm **triggers human review** of that criterion's recent\n  blocks rather than an automatic demotion. Per-FINDING, matching the parent's \"fraction of that\n  criterion's blocking findings … subsequently adjudicated not-block-worthy.\"\n- **advisory_application_rate(C)** = (# of C's **advisory** findings whose ticket later shows an\n  adverse post-claim edit) / (total # of C's advisory findings).\n- **rounds_per_ticket** = the `review_round_count` distribution over the window.\n- **sample_counts(C)** = `{\"blocking_findings\": int, \"advisory_findings\": int, \"tickets\": int}` —\n  the denominators (count of C's blocking findings, C's advisory findings, and distinct tickets\n  touching C, over the deduplicated union in the window). Emitted with each criterion so a rate\n  computed from a tiny sample is visible rather than hidden behind a bare fraction.\n\n**Empty / degenerate input.** On the live store (628 reviewed tickets) the corpus is always\nnon-empty; defensively, if the window resolves to zero tickets `--emit` exits non-zero with a\nmessage (rather than writing a trivial `{}`), a criterion with zero findings is omitted, and\n`--verify-repro` fails loudly if any of the 8 frozen case ids cannot be resolved.\n\n**`--window N`** bounds the corpus to the last `N` rows in the miner's deterministic emission\norder (the corpus has no timestamp field; emission order is the stable proxy, documented as\nsuch — a strictly chronological window is future work needing a timestamp). Default N=200.\n\n**Alarm / demotion rule (documented playbook).** When a criterion's trailing\n**blocking_fp_proxy exceeds 10%**, demote it from blocking to advisory via an ordinary\n`criteria_routing.json` edit (`default_posture: \"advisory\"`). Precedent for demotion on FP\nevidence: **T5e**, demoted to advisory in calibration-3 (task relishable-ammonitic-hoverfly).\n(T3/T10 are a *different* precedent — criteria kept non-blocking from the start; never demoted —\nso they are NOT cited as demotion precedent.) Dogfood monitoring, not a config flag; no\ngate/source behaviour change.\n\n## Scope\n- `docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py` — the job: a pure\n  top-level `classify(post_claim_edit_class, review_round_count, has_strong_finding) -> str`\n  (unit-testable), the `has_strong_finding` sidecar extractor, the finding-level metrics\n  computation, and CLI flags `--verify-repro`, `--emit`, `--window N`, `--no-refresh`.\n- `docs/experiments/plan-review-gate/README.md` — classifier rules, the 4/8-vs-7/8 finding, the\n  metric definitions + join key, cadence, and the metrics output path.\n- `docs/plan-review-gate.md` — the alarm/demotion playbook (>10% blocking-FP rule, T5e\n  precedent, operator response). The ONLY change outside `docs/experiments/`; documentation only.\n- `tests/unit/test_gate_eval_classifier.py` — a golden test importing the pure `classify` and\n  asserting the 8 frozen `(cls, rounds, strong) → label` tuples reproduce ≥6/8, plus a\n  non-triviality assertion on a metrics fixture and a `--window` subset check.\n- No change to `src/rebar/` behaviour — no gate or source behaviour change.\n\n## Acceptance Criteria\n- [ ] `--verify-repro` recomputes the classifier over the 8 frozen cases (MISSED: dc58-af7b,\n      db7b-c8fd, 5886-d028; CAUGHT-BUT-IGNORED: c8cc-68b8, f5df-0069, 115b-ceea, 8c4f-b81c;\n      UNKNOWABLE: 3006-e198), prints the confusion table, and asserts **≥6/8 agreement** (exits\n      non-zero below 6/8). Proving command:\n      `python docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py --verify-repro`.\n- [ ] `--emit` writes per-criterion metrics to\n      `docs/experiments/plan-review-gate/runs/gate_eval_metrics.json` — a non-trivial object with\n      ≥1 criterion whose `blocking_fp_proxy` and `advisory_application_rate` are **numeric**\n      (a float in [0,1], not null) and whose `sample_counts` is a non-empty dict with a\n      **positive total** (so the AC is NOT satisfiable by `{}`, all-null values, or all-zero\n      sample counts). Proving command:\n      `python docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py --emit && python -c \"import json;d=json.load(open('docs/experiments/plan-review-gate/runs/gate_eval_metrics.json'));assert d and any(isinstance(v.get('blocking_fp_proxy'),(int,float)) and isinstance(v.get('advisory_application_rate'),(int,float)) and isinstance(v.get('sample_counts'),dict) and sum(v['sample_counts'].values())>0 for v in d.values())\"`.\n- [ ] The pure `classify` reproduces ≥6/8 on the 8 frozen input tuples in a CI-collected test,\n      and `--window N` yields a subset for smaller N. Proving command:\n      `python -m pytest tests/unit/test_gate_eval_classifier.py -q`.\n- [ ] `docs/plan-review-gate.md` gains a new **\"Blocking-FP-proxy demotion\"** section\n      documenting the >10% `blocking_fp_proxy` alarm rule, the operator demotion response, and the\n      correct T5e precedent (not T3/T10, cited inside that section); the harnesses README\n      documents the `sidecar-findings-alone` 4/8-vs-7/8 finding. Proving command (both sentinels\n      are new content — neither pre-exists in its file, verified by `grep -c`):\n      `grep -q \"Blocking-FP-proxy demotion\" docs/plan-review-gate.md && grep -q \"sidecar-findings-alone\" docs/experiments/plan-review-gate/README.md`.\n- [ ] `make lint && make typecheck && make test` green; landed through Gerrit.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"docs/experiments/plan-review-gate/","reason":"instrumentation job"},{"path":"docs/plan-review-gate.md","reason":"alarm rule docs"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["depends_on","e95e-1543-cac7-47b9"],["parent","6982-2e75-f8fa-43b9"],["relates_to","e59d-c078-724d-46e5"]],"parent_id":"6982-2e75-f8fa-43b9","parent_status_uuid":"aa3209ef-3386-4868-a347-dac7200854fe","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"b1a4-af7a-4a48-465d","ticket_type":"story","title":"R7: standing gate-eval outcome instrumentation + dogfood FP monitoring","verify_commands":[]},"source_event_uuids":["e5bc246c-4329-4e76-bd0f-b4f6ad636e6f","2da4438c-01a3-40e4-9080-8f517cd33c24","d02d0f70-cc05-407d-ade2-5f067a0be8af","e764b8bc-6da0-49fc-bf53-3a1f5774831a","5ab33770-7b00-4715-be7a-016902bd20a2","528e363b-feb5-407d-9941-4719bc9f3e17","3ed28f0a-8e41-4361-b1d1-6e43793d7c57","a26937a2-cbee-4c3d-b00f-dfaa7cf44170","bda67a7b-7b53-4206-bddc-dc32ef632616","5531d09e-33ee-4be1-a519-d45b2fecdae2","dc9abb9f-5b20-4ff6-9e14-e609d920fe53","51d717ac-5439-42c8-a2cb-aca9457becf9","edcdf338-ce04-4e3d-b1aa-d438920fd1db","aa3209ef-3386-4868-a347-dac7200854fe","b21ee9e7-53b9-418e-a1c2-c6704bb4cf56","ec2e6fbc-fab7-4271-8b20-880532606511"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784260660055010352,"uuid":"85552937-1c1e-4867-a798-580d013453b3"}