{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","author_sig":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","data":{"coaching":[{"coaching":"Plan how subprocess return-code failure handling will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["ff21ea8e9c494b9f8"],"move_id":"9","move_name":"plan the verification","subject":"subprocess return-code failure handling"},{"coaching":"Pin down rounds_per_ticket distribution output schema with a concrete worked example.","decision":"advisory","finding_refs":["fa0b647515de582bf","feadccb8fec34027b"],"move_id":"6","move_name":"specification by example","subject":"rounds_per_ticket distribution output schema"},{"coaching":"Realign blocking_fp_proxy metric definition alignment to the parent's plan — the parent wins on conflict; if the parent is genuinely wrong, update the PARENT first (which forces its re-review), never silently diverge the leaf.","decision":"advisory","finding_refs":["f0a13306dccd08992"],"move_id":"13","move_name":"realign to parent plan","subject":"blocking_fp_proxy metric definition alignment"},{"coaching":"Plan how no-refresh flag verification coverage will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["ffd60084089a0582d"],"move_id":"9","move_name":"plan the verification","subject":"no-refresh flag verification coverage"},{"coaching":"Record an ADR for severity vocabulary coupling in has_strong_finding — it reads like a one-way door.","decision":"advisory","finding_refs":["ff81ef9e1fe608730"],"move_id":"8","move_name":"ADR / one-way-door","subject":"severity vocabulary coupling in has_strong_finding"},{"coaching":"Pin down window boundary and degenerate-input behaviour with a concrete worked example.","decision":"advisory","finding_refs":["f55677e9866ca50f1","f6d51c3b235a9e090"],"move_id":"6","move_name":"specification by example","subject":"window boundary and degenerate-input behaviour"},{"coaching":"Plan how acceptance-criteria completeness and provability will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f607dd457c67f9209"],"move_id":"9","move_name":"plan the verification","subject":"acceptance-criteria completeness and provability"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":9,"blocking":0,"dropped":13,"indeterminate":0},"det":{"P1":{"ac_items":5,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","probed":6,"ran":true,"references":6,"resolved":2,"status":"pass","unresolved_or_abstained":4},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":5,"blocking":false,"desc_chars":11307,"file_impact":2,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":5,"blocking":false,"name":"ac-quality","ran":true,"status":"fail","verify_commands_linted":80,"verify_lint_abstained":78},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":2844,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":2,"name":"file-impact-coverage","ran":true,"status":"pass"}},"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":238.9,"llm_calls":28,"llm_ms":473440.6,"total_ms":473793.2,"verify_requests":21},"remediation":{"baseline":"sidecar","eligible":false,"reasons":{"code_unchanged":false,"plan_changed":true,"registry_unchanged":true,"sidecar_baseline":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","G5","T2","T4","T5b","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":null,"blocking_enabled":null,"checklist_item":"","cohort":null,"criteria":["P6"],"decision":"advisory","drop_reason":null,"evidence":["vague/subjective terms present: clean"],"finding":"Acceptance-criteria / definition-of-done quality issues.","group_criteria":null,"group_id":null,"id":"f607dd457c67f9209","impact":0.4,"is_primary":null,"location":"","norm_id":"ned06ebc801a522e3","priority":0.4,"reason":null,"scenarios":[],"severity":"minor","suggested_fix":"Split compound criteria, replace subjective terms with observable outcomes, and state how each is verified.","tier":"DET","validity":1.0,"verification":null},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify that the harness checks the subprocess return code and exits non-zero (with an informative message) if the miner subprocess fails, rather than silently proceeding with a stale or absent corpus.","cohort":["T5b","T6","T9"],"criteria":["T5b"],"decision":"advisory","drop_reason":null,"evidence":["Plan states miner 'calls sys.exit() on floor-check failure (mine_outcome_corpus.py:381)' as the motivation for subprocess invocation","Plan does not mention checking subprocess return code or surfacing a non-zero exit as an error to the caller","--no-refresh flag skips regeneration but there is no specified fallback or error path when the subprocess itself fails during a normal (non---no-refresh) run"],"finding":"The plan specifies invoking `mine_outcome_corpus.py` as a subprocess but does not specify that the harness checks the subprocess return code. Since the miner calls `sys.exit()` on floor-check failure (explicitly cited at line 381), a failed miner run exits non-zero; if the harness silently continues, it reads a stale or absent corpus without any error surfaced to the operator.","group_criteria":null,"group_id":null,"id":"ff21ea8e9c494b9f8","impact":0.33,"is_primary":null,"location":"What section — 'Corpus acquisition (subprocess, not import)' paragraph; also AC --verify-repro proving command","norm_id":"n746c3b4c25662a04","priority":0.2063,"reason":"default-advisory","scenarios":["Miner floor-check fails on a partially updated corpus; harness silently reads the pre-existing stale JSONL and emits metrics based on stale data","First-ever run with no committed corpus: miner fails, harness has nothing to read, behaviour unspecified"],"severity":"minor","suggested_fix":"After `subprocess.run([...], check=False)`, inspect `result.returncode`; if non-zero, print the captured stderr and `sys.exit(1)` (or raise) before attempting to read `outcome_corpus.jsonl`.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] State the concrete output format for `rounds_per_ticket` in the Per-criterion trailing metrics definition (e.g. `{\"mean\": float, \"p50\": int, \"p95\": int, \"max\": int, \"n\": int}`) so an executor does not have to choose arbitrarily.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"advisory","drop_reason":null,"evidence":["'rounds_per_tick = the review_round_count distribution over the window'","No AC proving command checks the `rounds_per_ticket` key or its shape","ABSENCE: no format example, no schema fragment, no named statistic for this field"],"finding":"The `rounds_per_ticket` metric output format is unspecified — the plan says 'the `review_round_count` distribution over the window' but does not state whether this should be emitted as a histogram dict, a list of values, a {mean, p50, p95, max} summary, or something else. No AC verifies this field, so an executor must choose arbitrarily.","group_criteria":null,"group_id":null,"id":"fa0b647515de582bf","impact":0.264,"is_primary":null,"location":"What section — Per-criterion trailing metrics, `rounds_per_ticket` bullet","norm_id":"n184a3dc634bf6181","priority":0.165,"reason":"default-advisory","scenarios":["An executor emits a flat list; a downstream consumer of gate_eval_metrics.json expects a histogram dict and silently misreads it.","Two implementations of the job produce structurally incompatible outputs for this field with no way to adjudicate correctness."],"severity":"minor","suggested_fix":"Add one sentence to the `rounds_per_tick` bullet: 'Emitted as `{\"mean\": float, \"p50\": int, \"p95\": int, \"max\": int, \"n\": int}` over the `review_round_count` values of all tickets in the window.'","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Update parent epic 6982 Success Criteria to replace 'measured by R7's instrumentation against E1's committed finding-adjudication ground-truth corpus' with the actual proxy definition (force_close OR reopen_count > 0, documented as a conservative lower bound), then re-present the leaf as a consistent subset; alternatively, if the intent is to re-enable corpus-based measurement once e59d delivers the gold set, document the gap in both parent and leaf.","cohort":["G7"],"criteria":["G7"],"decision":"advisory","drop_reason":null,"evidence":["Parent SC: 'the blocking-FP proxy for a criterion is the fraction of that criterion's BLOCKING findings, over a trailing window of reviews, that are subsequently adjudicated false-positive / not-block-worthy — measured by R7's instrumentation against E1's committed finding-adjudication ground-truth corpus'","Leaf: 'blocking_fp_proxy(C) = (# of C's blocking findings whose ticket was subsequently adjudicated not-block-worthy) / (total # of C's blocking findings). The automatic proxy for \"adjudicated not-block-worthy\" is force_close OR reopen_count > 0'","The leaf explicitly notes the corpus was invalidated/descoped in E1, explaining the pivot — but the parent SC has not been updated to reflect this change, so the leaf contradicts the parent as written.","Per G7 conflict rule: 'the PARENT WINS. On any conflict between the leaf and the parent, the parent's plan is authoritative.' The productive resolution is to update the parent SC first, then re-review the leaf."],"finding":"The leaf redefines `blocking_fp_proxy` using `force_close OR reopen_count > 0` signals, directly contradicting the parent's Success Criteria which define the metric as measured 'against E1's committed finding-adjudication ground-truth corpus.' The parent SC still reads as written; the leaf diverges from it without the parent SC being updated first.","group_criteria":null,"group_id":null,"id":"f0a13306dccd08992","impact":0.264,"is_primary":null,"location":"Leaf 'What' section — blocking_fp_proxy definition; parent epic 6982-2e75-f8fa-43b9 Success Criteria: 'blocking_fp_proxy…measured by R7's instrumentation against E1's committed finding-adjudication ground-truth corpus'","norm_id":"nc1aff253f3dde3e3","priority":0.165,"reason":"default-advisory","scenarios":["An implementer reading the parent SC expects a corpus-based ground truth adjudication; the leaf delivers an event-signal proxy — the two are methodologically different and produce different numbers for the same criterion.","Future R-story implementations (R1-R5) that rely on 'the R7 blocking-FP proxy' as a gate will be evaluating against a different standard than the parent SC describes."],"severity":"minor","suggested_fix":"In parent epic 6982, revise the Success Criteria blocking_fp_proxy sentence to read: 'measured by R7's instrumentation using a conservative event-signal proxy (force_close OR reopen_count > 0), which is a lower bound pending the independent human-adjudicated gold set parked as idea e59d-c078-724d-46e5.' Then the leaf's approach is a compliant subset of the updated parent.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Define the exact JSON shape of `rounds_per_ticket` in the `gate_eval_metrics.json` output schema (e.g. `{\"p50\": int, \"p95\": int, \"mean\": float, \"n\": int}` or equivalent) and add it to the AC2 proving command's assertion.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Plan: '**rounds_per_ticket** = the `review_round_count` distribution over the window' — no JSON shape given","AC2 proving command only checks `blocking_fp_proxy`, `advisory_application_rate`, `sample_counts` — `rounds_per_ticket` absent from validation","No corresponding key in the AC2 assertion: `assert d and any(isinstance(v.get('blocking_fp_proxy'),...)`"],"finding":"The `rounds_per_ticket` metric output schema is never defined — the plan says it is 'the `review_round_count` distribution over the window' but does not specify the JSON shape emitted into `gate_eval_metrics.json` (histogram dict, percentile map, raw list, summary stats, etc.). The AC proving command only validates `blocking_fp_proxy`, `advisory_application_rate`, and `sample_counts`; `rounds_per_ticket` is neither validated nor shaped.","group_criteria":null,"group_id":null,"id":"feadccb8fec34027b","impact":0.264,"is_primary":null,"location":"What section — Per-criterion trailing metrics / `rounds_per_ticket` bullet; AC2 proving command","norm_id":"ne9fe7f37b64f4654","priority":0.165,"reason":"default-advisory","scenarios":["Implementer emits rounds_per_ticket as a raw list; downstream consumer or README expects a percentile dict — silent schema mismatch.","Two implementers independently produce incompatible shapes (e.g. {p50: int, p95: int} vs [int, int, ...]) with no contract to arbitrate."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an acceptance criterion (or extend AC3's unit-test scope) that verifies `--no-refresh` skips the miner subprocess and reads the committed `runs/outcome_corpus.jsonl` directly, e.g. by asserting no subprocess is spawned when the flag is set.","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["\"A `--no-refresh` flag skips regeneration and reads the committed corpus (offline / CI use).\"","None of the five ACs reference `--no-refresh`; the proving commands for AC1 (`--verify-repro`) and AC2 (`--emit`) do not include it; the unit test scope (AC3) covers only `classify` and `--window`."],"finding":"The `--no-refresh` CLI flag is explicitly described in the 'What' section as a named, behaviorally-distinct feature ('skips regeneration and reads the committed corpus — offline / CI use') but has no corresponding acceptance criterion that verifies it works. An implementer could ship a broken `--no-refresh` that silently invokes the subprocess anyway, and no AC would catch it.","group_criteria":null,"group_id":null,"id":"ffd60084089a0582d","impact":0.0,"is_primary":null,"location":"'What' section (corpus acquisition paragraph) and 'Scope' section (`gate_eval_instrumentation.py` bullet)","norm_id":"n9c148e731b124dbd","priority":0.0,"reason":"default-advisory","scenarios":["CI pipeline uses `--no-refresh` to avoid network/subprocess calls; a broken flag triggers the subprocess and fails in an offline environment — but this would never be caught by any gate criterion.","Reviewer cannot confirm `--no-refresh` behavior is correct without a verifying step, leaving the flag unspecified as to whether it also suppresses sidecar reads or only the miner subprocess."],"severity":"none","suggested_fix":"Extend AC3's proving command or add a separate AC: 'When invoked with `--no-refresh`, the harness does NOT call `mine_outcome_corpus.py` as a subprocess and reads `runs/outcome_corpus.jsonl` from disk; verify via `python -m pytest tests/unit/test_gate_eval_classifier.py -q -k no_refresh`.' Add a corresponding test in `tests/unit/test_gate_eval_classifier.py` that patches `subprocess.run` and asserts it is never called when `--no-refresh` is passed.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Either reference a codebase constant for the qualifying severity set in `has_strong_finding` (analogous to RECALL_MIN_PRIORITY for the priority floor), or add a comment citing the schema definition that must be kept in sync if severity vocabulary changes.","cohort":["T2","T5e","T7"],"criteria":["T5e"],"decision":"advisory","drop_reason":null,"evidence":["'severity ∈ {\"critical\",\"major\"}' appears as a literal set in the classifier spec with no citation to a codebase constant, unlike priority (which cites RECALL_MIN_PRIORITY)","The priority floor IS anchored: 'The 0.5 floor is the codebase's own RECALL_MIN_PRIORITY (src/rebar/llm/plan_review/sidecar.py:299)' — but no equivalent anchor exists for the severity set"],"finding":"The `has_strong_finding` predicate hardcodes the severity set {\"critical\",\"major\"} as an inline business rule with no reference to a codebase constant. If the severity vocabulary evolves (e.g., a new severity level is introduced between major and critical, or a level is renamed), the predicate silently drifts without any compile-time or constant-reference signal.","group_criteria":null,"group_id":null,"id":"ff81ef9e1fe608730","impact":0.0,"is_primary":null,"location":"What section — 'has_strong_finding' definition; docs/experiments/plan-review-gate/harnesses/gate_eval_instrumentation.py (to be written)","norm_id":"nfea0da1e4687f550","priority":0.0,"reason":"default-advisory","scenarios":["Severity taxonomy gains a new level (e.g., 'severe') that should qualify as strong, but the hardcoded set misses it","A future calibration pass renames 'major' to 'high' in the schema; the classifier silently under-counts strong findings"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify that `--window N` validates N as a positive integer and exits with a clear usage error (not a Python traceback) if N≤0 or non-integer.","cohort":["T5b","T6","T9"],"criteria":["T6"],"decision":"advisory","drop_reason":null,"evidence":["Plan says 'Default N=200' and '--window N bounds the corpus to the last N rows' but specifies no validation of N","Zero-ticket exit is specified only as a corpus-level condition, not as a --window misconfiguration guard","No mention of argument validation or error message for invalid --window values"],"finding":"The plan does not specify the behaviour of `--window N` for degenerate values of N (zero, negative, or non-integer input). The zero-tickets case triggers a non-zero exit, but it is reached only after the window slice is applied; if N≤0 the slice may silently produce an empty result whose error message ('zero tickets') is indistinguishable from a legitimately empty corpus, and a non-integer N would surface as an unhandled Python exception rather than a user-friendly error.","group_criteria":null,"group_id":null,"id":"f55677e9866ca50f1","impact":0.0,"is_primary":null,"location":"What section — '--window N' paragraph; AC --verify-repro and --emit proving commands","norm_id":"n3fa70e60ea3757da","priority":0.0,"reason":"default-advisory","scenarios":["Operator typos '--window -1' or '--window 0'; harness either silently emits nothing or raises an unhandled ValueError from argparse/slice logic","Operator passes '--window abc'; unhandled exception with a Python traceback rather than a usage message"],"severity":"none","suggested_fix":"Use `argparse` `type=int` plus a `choices`-or-custom-validator that rejects N≤0 with `parser.error('--window N must be a positive integer')`.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a test case (or AC proving command) that covers the zero-ticket/empty-window path: invoke `--emit --window 0` (or equivalent minimal fixture) and assert the process exits non-zero with a non-empty error message, per the plan's specified behavior.","cohort":["E3","E5","G5"],"criteria":["E5"],"decision":"advisory","drop_reason":null,"evidence":["Plan body: 'if the window resolves to zero tickets `--emit` exits non-zero with a message (rather than writing a trivial `{}`)' — an explicit CLI contract","AC `--emit` proving command only asserts a non-trivial positive result; no AC or test entry covers the zero-ticket exit-nonzero path","Test file description: 'a golden test … a non-triviality assertion on a metrics fixture and a `--window N` subset check' — no mention of empty-window failure-path coverage"],"finding":"The degenerate/empty-input behavior ('if the window resolves to zero tickets `--emit` exits non-zero with a message') is specified in the plan body but no test or AC proving command covers it — the test file and AC proofs exclusively exercise the happy path.","group_criteria":null,"group_id":null,"id":"f6d51c3b235a9e090","impact":0.0,"is_primary":null,"location":"Scope section (`tests/unit/test_gate_eval_classifier.py` description) and 'Empty / degenerate input' plan section; AC `--emit` proving command","norm_id":"n45144cd0621f83eb","priority":0.0,"reason":"default-advisory","scenarios":["A future corpus refresh results in a window with no matching tickets (e.g., very small --window N on a sparse corpus); the exit-nonzero contract goes untested and could silently regress to writing `{}` and exiting 0","CI runs with --window 0 or a stubbed empty fixture could mask a broken empty-path guard"],"severity":"none","suggested_fix":"In `test_gate_eval_classifier.py`, add a test that patches the corpus to an empty list and calls the `--emit` entry point (or the underlying emit function), asserting `SystemExit` with a non-zero code. Alternatively, add to the AC: `python gate_eval_instrumentation.py --emit --window 0; [ $? -ne 0 ]`.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a comment block and/or README entry explaining the subprocess-not-import rationale (sys.exit on floor-check failure at mine_outcome_corpus.py:381 would terminate the caller) so future maintainers cannot silently refactor it away.","cohort":["T2","T5e","T7"],"criteria":["T7","T5e"],"decision":"dropped","drop_reason":null,"evidence":["Plan's README scope lists: 'classifier rules, the 4/8-vs-7/8 finding, the metric definitions + join key, cadence, and the metrics output path' — subprocess rationale is ABSENT from this list","'It does NOT import and call build_corpus(), because that entry calls sys.exit() on floor-check failure (mine_outcome_corpus.py:381)' appears only in the What section prose, not committed to any doc artifact"],"finding":"The subprocess-vs-import rationale (specifically that mine_outcome_corpus.py calls sys.exit() at line 381 on floor-check failure, which would terminate the caller) is load-bearing for correctness but the plan's Scope section does NOT list this rationale as content for either the harnesses README or docs/plan-review-gate.md. A future maintainer refactoring to a direct import call would silently reintroduce the termination bug.","group_criteria":null,"group_id":null,"id":"f24fb7b53b1222593","impact":0.0,"is_primary":null,"location":"Scope section — docs/experiments/plan-review-gate/README.md content list; What section — 'Corpus acquisition (subprocess, not import)' paragraph","norm_id":"n89fefec9e41687ad","priority":0.0,"reason":"low-validity","scenarios":["A future maintainer sees subprocess invocation, considers it awkward, refactors to a direct import call, and reintroduces the sys.exit-kills-caller bug","mine_outcome_corpus.py is refactored and the line-381 reference becomes stale with no doc linking rationale to the constraint"],"severity":"none","suggested_fix":"In the harnesses README, add a short 'Corpus acquisition design note' bullet: 'The job invokes mine_outcome_corpus.py as a subprocess rather than importing build_corpus(), because build_corpus() calls sys.exit() on floor-check failure (see mine_outcome_corpus.py), which would terminate the caller process. Subprocess isolation prevents this.' Also add the same rationale as a block comment at the subprocess call site in gate_eval_instrumentation.py.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify that the `--emit` output write to `gate_eval_metrics.json` is atomic (write to a sibling temp file, then `os.replace`) so a mid-write failure or concurrent run never leaves a partially written file.","cohort":["T5b","T6","T9"],"criteria":["T5b"],"decision":"dropped","drop_reason":null,"evidence":["AC states '--emit writes per-criterion metrics to …/gate_eval_metrics.json'","No mention of atomic write (tmpfile + os.replace) in the plan","The plan specifies the miner 'atomically writes' its output but makes no parallel statement for gate_eval_metrics.json"],"finding":"The plan does not specify that the write to `gate_eval_metrics.json` (via `--emit`) is atomic (e.g., write-to-temp-then-rename). A process killed mid-write, or a second concurrent `--emit` invocation, can leave a partially written (corrupt) JSON file that subsequent readers silently consume.","group_criteria":null,"group_id":null,"id":"f0afb7154499786eb","impact":0.0,"is_primary":null,"location":"Scope — gate_eval_instrumentation.py; AC --emit proving command","norm_id":"n1b51c7db57e87c65","priority":0.0,"reason":"low-validity","scenarios":["CI job is cancelled mid-write; next run reads the torn JSON and the inline Python assertion in the proving command raises a JSONDecodeError","Two CI shards run --emit concurrently against the same workspace; interleaved writes corrupt the file"],"severity":"none","suggested_fix":"Write to `gate_eval_metrics.json.tmp` with `json.dump`, then call `os.replace('gate_eval_metrics.json.tmp', 'gate_eval_metrics.json')` to atomically swap.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Document in the README and `--help` text that `--window N` selects the last N rows in alphabetical ticket-id order (NOT chronological order), so the computed metrics represent a stable cross-section of the corpus rather than the most-recent N tickets; and add a note that operators seeking true recency-weighted metrics should await the timestamp-based window (future work).","cohort":["G6"],"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":["\"the corpus has no timestamp field; emission order is the stable proxy, documented as such — a strictly chronological window is future work\"","mine_outcome_corpus.py:379: `reviewed = sorted(tid for tid, tk in store.items() if review_round_count(tk) > 0)` — emission order is alphabetical ticket_id sort","The parent epic's 'Why' frames these metrics as detecting 'false-positive drift' — drift implies temporal monitoring"],"finding":"The `--window N` flag is framed as a 'trailing window' enabling FP-drift monitoring over time, but the corpus is emitted in sorted-ticket_id (alphabetical UUID) order — which has no temporal correlation. A 'last N rows' slice produces an arbitrary cross-section of tickets by UUID alpha-prefix, not the most-recent N tickets. This means blocking_fp_proxy and advisory_application_rate computed over a windowed corpus do NOT measure recent drift; they measure metrics over whatever tickets happen to have UUIDs near the end of the alphabet. The parent epic's goal ('false-positive drift stays invisible until it burns author trust') requires a temporally-meaningful window.","group_criteria":null,"group_id":null,"id":"f2c129b553c87abe9","impact":0.0,"is_primary":null,"location":"What section — '`--window N`' paragraph; Acceptance Criteria bullet 3 ('`--window N` yields a subset for smaller N')","norm_id":"n593e656543293556","priority":0.0,"reason":"low-validity","scenarios":["Operator runs `--emit --window 200` expecting recent-ticket FP rates; gets FP rates for tickets whose IDs start with letters 'r'–'z', which may all be old tickets from an earlier sprint, missing recent regressions entirely.","A criterion demoted last week shows no improvement in the metrics because the 200-row window misses the recently-remediated tickets."],"severity":"none","suggested_fix":"In the README and `--help` for `--window`, replace any 'trailing' framing with explicit language: 'selects the last N rows in deterministic alphabetical ticket-id emission order; this is NOT a recency window — it approximates coverage, not drift-over-time'. Until a timestamp is added to the corpus (future work), the entire 628-row corpus is a better FP-rate baseline than a windowed slice, and the plan might want to make `--window 0` or `--window all` mean 'no windowing' with a note that windowed sub-slicing is for reproducibility / subsetting, not recency.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Verify whether the miner's emission order (lexicographic sort on hex ticket IDs) has meaningful temporal correlation with ticket creation time, OR document that `--window N` is a lexicographic tail slice (not a recency window), and update the README and CLI help text accordingly.","cohort":["T1"],"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":["Plan states: 'the corpus has no timestamp field; emission order is the stable proxy, documented as such'","mine_outcome_corpus.py:379: `reviewed = sorted(tid for tid, tk in store.items() if review_round_count(tk) > 0)` — lexicographic sort on hex ticket ID strings","outcome_corpus.jsonl rows start '003d-', '0128-', '012e-', '0241-' — confirming lexicographic, not temporal, ordering","Plan acknowledges 'a strictly chronological window is future work needing a timestamp' but still relies on this order as a recency proxy without verifying any correlation"],"finding":"The plan's `--window N` slices 'the last N rows in the miner's deterministic emission order' and calls emission order the 'stable proxy' for recency — but `build_corpus()` sorts by `sorted(tid ...)`, a lexicographic sort on opaque hex ticket IDs (e.g. '003d-e6b0…', '0128-9a17…'), which has no guaranteed or verified temporal correlation with ticket creation time. The 'last N rows' will be the N tickets whose IDs sort last lexicographically, not the N most recently reviewed tickets.","group_criteria":null,"group_id":null,"id":"f4b985592e2942010","impact":0.0,"is_primary":null,"location":"Plan § '**`--window N`**' definition; mine_outcome_corpus.py:379 (`reviewed = sorted(tid …)`)","norm_id":"nd7340b41445ea3c7","priority":0.0,"reason":"low-validity","scenarios":["An operator runs `--window 200` expecting to see the 200 most recently reviewed tickets; instead they see the 200 tickets whose IDs happen to sort last alphabetically (e.g. 'f…', 'e…') — which may be an arbitrary mix of old and new tickets","If the per-criterion FP proxy rises for a recently introduced criterion, the `--window` mechanism may miss it entirely if that criterion's tickets happen to have low-sorting IDs","The README documents this as a recency proxy, misleading future operators who rely on the window for trend detection"],"severity":"none","suggested_fix":"In the harness, after reading the JSONL, sort rows by a temporal proxy (e.g. `review_round_count` is not temporal, but the ticket_id's UUID v4 prefix has no time component — so the honest fix is to either add a timestamp field to the corpus schema, or rename `--window` to `--tail` and document it as 'last N rows in corpus emission order (lexicographic by ticket ID, not chronological)' so operators are not misled.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify the subprocess failure-handling rule in the plan: either (a) treat a non-zero subprocess returncode as a fatal error (exit non-zero with the miner's stderr), or (b) fall back to the committed corpus with a logged warning — and add this to the scope/AC.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Plan: 'The job refreshes the outcome corpus by invoking `mine_outcome_corpus.py` as a subprocess … which atomically writes `runs/outcome_corpus.jsonl`'","Plan: 'A `--no-refresh` flag skips regeneration and reads the committed corpus (offline / CI use)' — implies refresh can fail, but no error-handling rule given","mine_outcome_corpus.py:381: `sys.exit(...)` on floor-check failure — confirmed by tool read","No AC or plan prose specifies: check returncode; propagate non-zero as fatal; fall back to committed corpus; etc."],"finding":"The plan specifies invoking `mine_outcome_corpus.py` as a subprocess and explains why (the miner calls `sys.exit()` on floor-check failure at line 381), but nowhere specifies what `gate_eval_instrumentation.py` must do when the subprocess returns a non-zero exit code. The fallback for a failed refresh sub-step is absent.","group_criteria":null,"group_id":null,"id":"f95293230f2049887","impact":0.33,"is_primary":null,"location":"What section — 'Corpus acquisition (subprocess, not import)' paragraph","norm_id":"n9fbede0aba47e55d","priority":0.1237,"reason":"low-validity","scenarios":["The miner exits non-zero (git objects pruned, floor check fails); the harness silently proceeds to read a stale or missing corpus and emits misleading metrics.","CI runs `--emit` without `--no-refresh`; miner fails; harness continues; AC2 assertion passes on stale data."],"severity":"minor","suggested_fix":"Add a sentence to the 'Corpus acquisition' paragraph: 'The harness checks `subprocess.returncode`; a non-zero exit is re-raised as a `RuntimeError` (the miner's stderr is included) so the caller sees the floor-check failure rather than silently reading a stale corpus.'","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan instructs the harness to read 'each reviewed ticket's persisted REVIEW_RESULT sidecars via rebar.llm.plan_review.sidecar.all_review_results' and join 'each REVIEW_RESULT finding to its ticket's outcome row by ticket_id' for per-criterion metrics, but `all_review_results` returns ALL historical review payloads for a ticket (newest→oldest), not just the latest. The plan does not specify which payload(s) feed the per-criterion finding enumeration: using all payloads double-counts findings that appear in multiple rounds (inflating denominators); using only the latest omits findings from earlier rounds that may have triggered the review outcome. This under-specification is load-bearing for the correctness of blocking_fp_proxy and advisory_application_rate.","group_criteria":null,"group_id":null,"id":"f2128916167e029d4","impact":0.0,"is_primary":null,"location":"What section — 'Per-criterion trailing metrics (FINDING-level)' / Scope bullet for gate_eval_instrumentation.py","norm_id":"ncee964c928a39e72","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Use `latest_review_result` (not `all_review_results`) for the per-criterion metrics join — it returns the single most-recent payload, avoiding double-counting. Reserve `all_review_results` if a future metric explicitly tracks per-round history. Update the Scope bullet to read: 'reads each reviewed ticket's latest persisted REVIEW_RESULT sidecar via rebar.llm.plan_review.sidecar.latest_review_result'.","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The per-criterion metrics computation joins 'each REVIEW_RESULT finding to its ticket's outcome row' using `all_review_results`, which returns ALL retained sidecar rounds (newest→oldest, up to the 50-per-ticket cap). The plan does not specify which round(s) contribute findings to the blocking_fp_proxy and advisory_application_rate denominators. Using all rounds inflates denominators non-linearly for high-round-count tickets (e.g., corpus shows tickets with 20 rounds), while using only the latest round would exclude earlier blocking findings that were cleared in subsequent rounds and wouldn't appear in the final sidecar. This ambiguity makes the metric definition insufficiently reproducible — two implementers will produce different denominators.","group_criteria":null,"group_id":null,"id":"fd2f3ae3b4399c920","impact":0.0,"is_primary":null,"location":"## What — 'Per-criterion trailing metrics (FINDING-level)' section; Scope — `gate_eval_instrumentation.py`","norm_id":"n930f33039428507a","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Add to the metrics spec: 'For each ticket, only the most-recent retained REVIEW_RESULT sidecar payload (`all_review_results(ticket_id)[0]`) contributes findings to the denominators; earlier rounds are not double-counted. Rationale: the most-recent review reflects the gate's final judgment after all author revisions.'","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan specifies that `has_strong_finding` reads sidecar findings 'via `rebar.llm.plan_review.sidecar.all_review_results`', but `all_review_results` returns ALL persisted review rounds (newest-first, up to the sidecar's on-disk retention cap), not just the latest. The plan never specifies whether the `has_strong_finding` predicate should be evaluated over the latest round only, or over ANY round across all persisted sidecars. This ambiguity is structurally load-bearing: a ticket with a strong finding in round 1 that was remediated by round 2 would fire the predicate differently under the two interpretations.","group_criteria":null,"group_id":null,"id":"f90dc2241c9567ff7","impact":0.0,"is_primary":null,"location":"'What' section — Outcome classifier, `has_strong_finding` definition; cross-referenced with sidecar.py:164 (`all_review_results`)","norm_id":"n8263ec6ef3d092d1","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Add to the `has_strong_finding` definition: 'evaluated over the MOST RECENT persisted sidecar only (`all_review_results(ticket_id)[0]`), since a remediation re-review producing only minor findings confirms the prior strong finding was addressed.'","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["T6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan does not specify harness behavior when `--emit` (or `--verify-repro`) is run but the corpus contains no tickets with persisted `REVIEW_RESULT` sidecars — i.e., the join between corpus rows and sidecars produces zero matching rows. The AC for `--emit` requires ≥1 criterion with numeric `blocking_fp_proxy` and positive `sample_counts`, but if the join is empty the harness cannot satisfy this AC; the plan is silent on what the harness should do (exit non-zero, emit a warning, emit an empty object).","group_criteria":null,"group_id":null,"id":"f0fb3d1a61f2c6a88","impact":0.0,"is_primary":null,"location":"AC for `--emit`; What section — 'Per-criterion trailing metrics'","norm_id":"nd1b2ca9c6bdac74b","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The `sample_counts` field is mandated by the AC2 proving command (`isinstance(v.get('sample_counts'), dict) and sum(v['sample_counts'].values()) > 0`) but its internal sub-field schema — what keys the dict contains and what each counts — is never defined anywhere in the plan (not in the What section's metric definitions, not in Scope, not in any other AC). An implementer cannot know whether `sample_counts` holds per-decision-type counts, per-ticket counts, or something else.","group_criteria":null,"group_id":null,"id":"f0dd45ec0a4954fa1","impact":0.0,"is_primary":null,"location":"Acceptance Criteria AC2 (--emit proving command) and 'What' section, Per-criterion trailing metrics","norm_id":"n087cd7138b9d8c89","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"In the 'What' section under 'Per-criterion trailing metrics', add: '`sample_counts` is a dict with at minimum the keys `{\"blocking_total\": <int>, \"advisory_total\": <int>}` — the raw denominators for `blocking_fp_proxy` and `advisory_application_rate` respectively — so the AC's non-triviality assertion is falsifiable by a real implementation gap.'","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The `sample_counts` block is required in every per-criterion metric output by AC2's proving command (`assert ... 'sample_counts' in v`), but its internal schema — what sub-fields it contains and their semantics — is never defined anywhere in the plan. An implementer cannot determine whether `sample_counts` should hold raw integer counts of blocking/advisory/total findings, ticket counts, or something else.","group_criteria":null,"group_id":null,"id":"f9e361c0892426c93","impact":0.0,"is_primary":null,"location":"Acceptance Criteria, AC2 — `--emit` proving command; 'Per-criterion trailing metrics' section in What","norm_id":"nef8ec01ee85c2504","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Add to the 'Per-criterion trailing metrics' section: `sample_counts` = `{blocking_total: int, advisory_total: int, fp_proxy_numerator: int, advisory_adverse_numerator: int}` — the raw counts the two rate metrics are derived from.","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The `sample_counts` block is required by the AC but its internal schema (sub-fields and their semantics) is never defined anywhere in the plan.","group_criteria":null,"group_id":null,"id":"fb65cdb948fc2c753","impact":0.0,"is_primary":null,"location":"Acceptance Criteria — `--emit` AC: '≥1 criterion carrying all three of `blocking_fp_proxy`, `advisory_application_rate`, and a `sample_counts` block'","norm_id":"nb39234c7c9f4a368","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Add to the 'Per-criterion trailing metrics' section: '`sample_counts` is `{\"n_blocking\": <denominator of blocking_fp_proxy>, \"n_advisory\": <denominator of advisory_application_rate>, \"n_fp_proxy_hits\": <numerator of blocking_fp_proxy>, \"window_rows\": <actual N used>}`.","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan's 'adverse post-claim edit' definition (`post_claim_edit_class ∈ {plan-authored-post-claim, ac-strengthened, substantive-unclassified}`) is materially narrower than the miner's `_SUBSTANTIVE_CLASSES` set (which also includes `premise-invalidated`, `scope-reduction`, `approach-change`, and `operator-attested-retag`). The `advisory_application_rate` metric uses 'adverse post-claim edit' as its join predicate, but the vocabulary that the miner actually emits for those three semantic classes differs from the plan's closed set — and the plan provides no rule for handling these 'extra' substantive classes.","group_criteria":null,"group_id":null,"id":"fdabaaf22fda7df7c","impact":0.0,"is_primary":null,"location":"'What' section — 'adverse post-claim edit' definition; cross-referenced at mine_outcome_corpus.py:419-427","norm_id":"n4c179ca9432aca66","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":[],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"no","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"d292170db13f1378","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":238.9,"llm_calls":28,"llm_ms":473440.6,"total_ms":473793.2,"verify_requests":21},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"b1a4-af7a-4a48-465d","ticket_type":"story","verdict":"PASS","verified_at_sha":"cb0f8ec3b0641860ea6139431ccc63ca528c4732"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784259521253587001,"uuid":"ed204faa-8271-435b-a115-8c5674e310be"}