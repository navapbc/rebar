_sha":"ab12a6085d666deab8ce99ff435955818446ad99","position":"1784831035546489001-569b25b2-96e9-47e0-97ac-e00796e71f5d"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"cd9e6a992544519f376d60f4f112163d595123cdcb2d7de2e0fdddb7e9501e81","event_uuid":"71b0f8d2-8fc0-40d1-b099-9750e7cf0d18","position":{"commit_sha":"ab12a6085d666deab8ce99ff435955818446ad99","position":"1784831035896200001-71b0f8d2-8fc0-40d1-b099-9750e7cf0d18"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"d9371d7bc45ac8b8ef80d72f7fafb48942875aad822536afa846ae56dddb11d1","event_uuid":"de2fc4d2-16d4-423f-8b1c-23991213e669","position":{"commit_sha":"533f763279b8196226fc7d78dd62abb400711813","position":"1784831506968545551-de2fc4d2-16d4-423f-8b1c-23991213e669"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-218_agent","claim_remote_session":null,"claimed_session":"765ab0e6-1638-418e-8e23-7da2a32dab32","comments":[],"created_at":1784770815549340001,"creation_channel":"cli","deps":[{"link_uuid":"6ac46bbc-af89-4e06-b064-e0a848b4a127","relation":"discovered_from","target_id":"bbf1-82e1-cf9d-494a"},{"link_uuid":"e3687a01-7fa9-46e8-897b-b26643e40c36","relation":"relates_to","target_id":"4636-432a-1871-4d74"}],"description":"## Correction\nOriginal framing ('no configurable source target') was WRONG. The completion-verification target IS configurable:\n - rebar verify-completion --ref <branch|tag|SHA> (default origin/main; also via REBAR_GATE_REF env and [snapshot].ref config; pass --ref HEAD for a stacked change / feature branch).\n - The close-gate precheck (_completion_precheck, transition_close.py:280) verifies source='attested', ref='HEAD', fetch=False — i.e. it verifies the current worktree HEAD's tree. So the target IS controllable by checking out the commit whose tree you want verified as HEAD before rebar transition <id> in_progress closed (e.g. checkout a stacked story's own commit so its scope AC is evaluated against just that story's tree, not the cumulative tip).\n\n## The actual defect: discoverability\nThe mechanism is not discoverable from the CLOSE workflow:\n - rebar transition <id> <cur> closed exposes NO --ref/--source flag and its --help says nothing about targeting a specific code state; the ref='HEAD' behaviour and the verify-completion --ref / REBAR_GATE_REF / [snapshot].ref levers are only documented on the standalone verify-completion command.\n - Result: closing a STACKED epic (bbf1: ef33<-ce4d<-94f9<-6673<-dfb9), I closed all stories against the cumulative main tip and hit false-negatives on per-story scope ACs ('no core module modified by this story — git diff'), because later stories' changes are present at the tip and the verifier can't run git. I worked around it with manual operator-attestation comments instead of targeting each story's own commit — because I did not discover the configurability.\n\n## Proposed fix (docs + surfacing)\n - Document, in the close/gate docs (docs/plan-review-gate.md and the transition help), how to target a specific code state at close: check out the target commit as HEAD before close (the ref='HEAD' contract), and/or run verify-completion --ref <commit> first; note the REBAR_GATE_REF / [snapshot].ref levers apply.\n - Surface it on the close path itself: add a --ref (and/or --source) passthrough to rebar transition ... closed that forwards to _completion_precheck, so a stacked-epic closer can target a story's own commit without checking out or hand-writing evidence comments.\n - Add the stacked-landing close recipe to the epic-execution / rebar-implement guidance.\n\n## Acceptance Criteria\n- [ ] The transition-close help and docs/plan-review-gate.md document how the close-time completion target is chosen (ref=HEAD) and how to target a specific commit (checkout and/or a forwarded --ref), including the stacked-epic recipe.\n- [ ] rebar transition <id> closed accepts a way to target the ticket's own commit (a forwarded --ref/--source, or a documented checkout pattern) such that a correctly-scoped stacked-epic story closes WITHOUT a manual operator-attestation comment (regression test).\n- [ ] make lint && make typecheck && make test green.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_commands/transition_close.py","reason":"Add configurable verification source target (--ref/--diff-base) to _completion_precheck; default to the ticket rebar-ticket commit"},{"path":"docs/plan-review-gate.md","reason":"Document the close-time verification target option"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["relates_to","4636-432a-1871-4d74"]],"parent_id":null,"parent_status_uuid":"569b25b2-96e9-47e0-97ac-e00796e71f5d","plan_review_phase":"execution","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"80af-c876-5856-4159","ticket_type":"bug","title":"Docs/discoverability: close-time completion-verification target is configurable (verify-completion --ref / REBAR_GATE_REF / [snapshot].ref) but not surfaced from the transition-close workflow","verify_commands":[]},"source_event_uuids":["38687c87-1