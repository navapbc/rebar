AAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"1679c49fcaab00efc1685d07a0517eb9e8e925bded25447cc7de0de507a0065a","event_uuid":"95d77b2c-dc32-40df-9ee9-9c3f49a4fe83","position":{"commit_sha":"cad37184b5d69e1fc88412396979e06e3f419ccf","position":"1784330936436445001-95d77b2c-dc32-40df-9ee9-9c3f49a4fe83"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"1dc9d1e39ec0dbba04b505968001c621b430f86dfcb84062d5931104478b9e4f","event_uuid":"e7854412-92ed-47c8-969f-f416ec770f0e","position":{"commit_sha":"3b50c27d3972dd25a5020da4e3b9473a1197e4a6","position":"1784332498555780345-e7854412-92ed-47c8-969f-f416ec770f0e"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-212_agent","claim_remote_session":null,"claimed_session":"9cdf9da4-c824-494c-b8ad-03c000f415ac","comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"--body","timestamp":1784330936436445001}],"created_at":1784330482141614001,"creation_channel":"cli","deps":[],"description":"# terraform-drift check permanently red: opcert_admin trust-policy phantom drift\n\n## Context / proven root cause\nThe `terraform-drift` GitHub Actions check has failed on every run against\n`origin/main` since opcert.tf landed (commit f78940a43, 2026-07-15). The check runs\n`terraform plan` over `infra/terraform/` with NO variable inputs\n(.github/workflows/terraform-drift.yml:61). `aws_iam_role.opcert_admin`'s\nassume_role_policy derives its principals from `var.opcert_admin_principal_arns`\n(opcert.tf:138), which defaults to `[]` (opcert.tf:29). The live role was applied with\nthe operator-supplied account-root principal (`arn:aws:iam::896586841071:root`, per the\ndocumented deploy pattern opcert.tf:26 / opcert-plan-assertions.sh:22). So every plan\nrenders an EMPTY principal and diffs it against live's account-root principal:\n\n    # aws_iam_role.opcert_admin will be updated in-place\n      ~ Principal = { ~ AWS = \"arn:aws:iam::896586841071:root\" -> [] }\n    Plan: 0 to add, 1 to change, 0 to destroy.   -> exit 2 -> check FAILS\n\nThis is an un-reconcilable phantom (applying the committed default would remove the\nprincipal), so it permanently reds the daily drift sweep and masks any real future drift.\n\n## Defect\nAsymmetry inside opcert.tf: the sibling operator-seeded SSM KEY param carries\n`lifecycle { ignore_changes = [value] }` (opcert.tf:57-59) precisely so plan/apply never\ndiff on an operator-owned value — but the equally operator-supplied trust principal was\nnot given the same guard.\n\n## Plan (fix direction: ignore_changes — user-approved)\nAdd `lifecycle { ignore_changes = [assume_role_policy] }` to `aws_iam_role.opcert_admin`.\nTerraform still creates the role; the operator owns the trust list out-of-band (honors the\ndocumented \"operator supplies principals at deploy\" intent and mirrors the key-param\nprecedent). This suppresses the phantom diff at PLAN time — no terraform apply required.\n\n## Acceptance criteria (measurable)\n1. `aws_iam_role.opcert_admin` in infra/terraform/opcert.tf declares\n   `lifecycle { ignore_changes = [assume_role_policy] }`.\n2. A hermetic source-contract test in tests/unit/test_opcert_deploy_infra.py asserts (1)\n   and was seen RED before the fix, GREEN after (with a mutation check returning it to RED).\n3. `terraform fmt -check` and `terraform validate` pass on the edited module.\n4. No existing opcert infra test is weakened; full unit suite for the file passes.\n\n## Verify command\n    cd /Users/joeoakhart/fix-opcert-drift-ignore-changes\n    ./.venv/bin/python -m pytest tests/unit/test_opcert_deploy_infra.py -q\n    cd infra/terraform && terraform fmt -check && terraform validate","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[],"parent_id":null,"parent_status_uuid":"ed289b1c-a3a2-4fb2-aedf-fc694234da5f","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":["infra","terraform","ci","opcert","drift"],"ticket_id":"7c91-0488-6226-4a10","ticket_type":"bug","title":"terraform-drift check permanently red: opcert_admin trust-policy phantom drift","verify_commands":[]},"source_event_uuids":["8e585ea1-4754-4c44-98ba-e7c4c82102c8","ed289b1c-a3a2-4fb2-aedf-fc694234da5f","689d08f0-5c55-4ee1-83e4-d414498494a4","95d77b2c-dc32-40df-9ee9-9c3f49a4fe83","e7854412-92ed-47c8-969f-f416ec770f0e"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784332498555780346,"uuid":"2c0881e1-7bf0-4944-ae06-942a7c5872a3"}