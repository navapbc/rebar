74e736401857119bf2b","position":"1784844996223143001-cd7dda0d-4c39-40f0-8df9-09255c4658f6"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"ececf6c14e0ace25fec47852c49d22630fc393b0476df5addcb61fa5f4c87afc","event_uuid":"a522fd69-8afb-442f-8be8-1c0899c24f79","position":{"commit_sha":"0f61f02240ace5206ded674e736401857119bf2b","position":"1784844996580651001-a522fd69-8afb-442f-8be8-1c0899c24f79"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"a44d68aeb6f05c4e25ea3d40559f6c37adf04f63e341ed867a2871b679c60542","event_uuid":"5cae36d2-870f-47ab-903f-fa0854fcc219","position":{"commit_sha":"32950c519303e6a52226ea08c4b431ee418b1d54","position":"1784845524256287954-5cae36d2-870f-47ab-903f-fa0854fcc219"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"5d1910a379cb98cc14f65f697bf0a0b865ba892e930b3217f4e4cf4e0391c634","event_uuid":"5535155a-65d1-422f-9a0b-f300d222a9d1","position":{"commit_sha":"6db01a2a0c024f3dd461ddeee0be18b251b8f65c","position":"1784846978885066001-5535155a-65d1-422f-9a0b-f300d222a9d1"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-218_agent","claim_remote_session":null,"claimed_session":"8c7cd05d-39e0-4f9f-a32b-dba3fcaa7918","comments":[],"created_at":1784844046287278001,"creation_channel":"cli","deps":[],"description":"## Why\n`rebar review-plan` runs a billable multi-pass LLM review whose only product is a\nplan-review claim attestation. Running it on a ticket that cannot be claimed yet — a\nterminal/paused status, or an `open` ticket still blocked by an unclosed dependency —\nspends the LLM call for nothing (the attestation is unusable) and assesses the plan\nagainst an environment that will change once the blocker lands, forcing a re-review\nanyway. Delaying the review until the ticket is claimable is both cheaper and more\ncorrect.\n\n## What\nFast-fail `review-plan` BEFORE any context assembly or LLM pass when the ticket is not\nclaimable, returning an unsigned INDETERMINATE verdict with no LLM call. `--force`\n(library `force=True`, MCP `force`) bypasses the check to review a non-claimable ticket\nanyway. `in_progress` tickets are never fast-failed (drift/execution re-reviews stay\nlegitimate); `bug`/`session_log` stay gate-exempt.\n\n## Scope\n- New `rebar.llm.plan_review.claimability` module: a cheap, fail-open claimability\n  check (one dep-graph read) plus a shared `indeterminate_verdict` builder that the\n  existing plan-relation-snapshot early return also adopts (keeps the package `__init__`\n  under the module-size cap).\n- Wire the check at the top of `_run_plan_review`, guarded by `force`.\n- Surface each indeterminate finding's reason + remediation in the CLI text renderer.\n- Documentation for the new behavior across the gate/workflow/exit-code guides.\n\n## Acceptance Criteria\n- [ ] `review-plan` on an `open` ticket blocked by an unclosed `depends_on`/`blocks`\n      prerequisite returns INDETERMINATE with `coverage.llm_ran=false`, a\n      `ticket-not-claimable` finding, signs no attestation, and exits 2.\n- [ ] `review-plan` on a `closed`/`idea`/`blocked` ticket fast-fails identically.\n- [ ] An `in_progress` ticket (even with an open blocker) is NOT fast-failed; the LLM\n      review runs.\n- [ ] `--force` / `force=True` bypasses the fast-fail and runs the full review.\n- [ ] `bug`/`session_log` tickets remain exempt (behavior unchanged).\n- [ ] The fast-fail performs no LLM or network call (proven by a runner that raises if\n      invoked).\n\n## File impact\n- src/rebar/llm/plan_review/claimability.py (new)\n- src/rebar/llm/plan_review/__init__.py\n- src/rebar/_cli/_llm_commands.py\n- src/rebar/_mcp_llm.py\n- tests/interfaces/lifecycle/test_plan_policy_dogfood.py\n- docs/plan-review-gate.md, docs/user-guide.md, docs/workflow-engine.md, docs/exit-codes.md, docs/concurrency.md, AGENTS.md, src/rebar/_guides/writing-a-passing-plan.md","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/llm/plan_review/claimability.py","reason":"New module: claimability precheck + shared indeterminate_verdict builder"},{"path":"src/rebar/llm/plan_review/__init__.py","reason":"Wire the fast-fail into _run_plan_review; adopt shared builder for snapshot-error return"},{"path":"src/rebar/_cli/_llm_commands.py","reason":"--force help, docstring, render indeterminate reason/remediation"},{"path":"src/rebar/_mcp_llm.py","reason":"Document not-claimable fast-fail on the review_plan MCP tool"},{"path":"tests/interfaces/lifecycle/test_plan_policy_dogfood.py","reason":"force=True on link-blocked reviews; new fast-fail tests"},{"path":"docs/plan-review-gate.md","reason":"Document the not-claimable fast-fail"},{"path":"src/rebar/_guides/writing-a-passing-plan.md","reason":"Author guide: review only when claimable"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[],"parent_id":null,"parent_status_uuid":"cd7dda0d-4c39-40f0-8df9-09255c4658f6","plan_review_phase":"execution","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"f5c0-46ce-fab1-487a","ticket_type":"story","title":"review-plan: fast-fail non-claimable tickets before running the LLM","verify_commands":[]},"source_event_uuids":["dde59cd3-ac6b-4aec-a807-568b477cf2c9","5030dc61-1479-4c55-90e8-4aef02a6d95e","bfe3a210-aea8-47a5-a3a9-d9c2e2acde30","cd7dda0d-4c39-40f0-8df9-09255c4658f6","a522fd69-8afb-442f-8be8-1c0899c24f79","5cae36d2-870f-47ab-903f-fa0854fcc219","5535155a-65d1-422f-9a0b-f300d222a9d1"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784846978885066002,"uuid":"8ccc1ca2-d3a1-417a-862e-338ac33cfe07"}