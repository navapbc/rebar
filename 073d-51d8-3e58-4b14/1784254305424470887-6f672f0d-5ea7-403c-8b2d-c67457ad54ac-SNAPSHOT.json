76fb0aa4"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"14c7a2b209b06fbddc907341d239070013a3e326b8eefd236c818843235b375e","event_uuid":"d01f83fa-b599-4b26-b074-c79501ad1da8","position":{"commit_sha":null,"position":"1784254305424470886-d01f83fa-b599-4b26-b074-c79501ad1da8"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-212_agent","claim_remote_session":null,"claimed_session":"aa9cb5ff-3fdb-44d3-8af8-c125c27f20ad","comments":[],"created_at":1784230951216184001,"deps":[],"description":"# Re-home the CLAUDE.md-native ticket-model content into authoritative docs\n\n## Why\n\nSlimming the root guidance file (S2) requires the ticket-model content it currently owns to have\nan authoritative home in `docs/` first, so nothing is lost when the root file becomes a set of\npointers. This story creates/extends the docs so every ticket-model topic is documented in `docs/`\nindependently of the root file.\n\n## What\n\nProduce the following documentation END STATE (this story is judged by what `docs/` contains\nafterward, not by which source paragraph moved where):\n\n- A new **`docs/ticket-model.md`** that documents, for agents, the four ticket-model concepts:\n  the `idea` status lifecycle (dispatch/gate/`validate` semantics), hierarchy/containment\n  (`parent_id`, not a link relation), linking (the six relations + the blocking-link promotion\n  concept), and the tags surface (including the `--set-tags` add-wins convergence caveat). It\n  cross-references `docs/event-schema.md` for the underlying event mechanics instead of restating\n  event bodies (avoids drift).\n- `docs/concurrency.md` (the I4a cascade section) additionally documents the cascade's **gate\n  interaction**: a cascaded parent claim runs the parent's own plan-review claim gate; epics/\n  stories are not gate-exempt; `--force` propagates up the cascade.\n- `docs/event-schema.md` contains a dedicated `## The session_log ticket type` section describing\n  the type semantics (gate/lifecycle-exempt, graph/health-excluded, non-blocking links only,\n  never Jira-synced), and no longer defers those semantics to the root file.\n- `docs/user-guide.md` documents the session-log **auto-rotation** behavior (the\n  `.rebar/current_session_log` pointer + session fingerprint).\n- `docs/README.md` indexes `docs/ticket-model.md`.\n\n## Scope\n\nIn: `docs/ticket-model.md` (new) and `docs/{event-schema,concurrency,user-guide,README}.md`.\nOut: editing the root guidance file (that is S2, which replaces these sections with pointers) and\nany code change. Docs-only; rollback is a plain `git revert`.\n\n## Design decisions (spike-validated)\n\nA grounded docs read established that most ticket-model *mechanics* already live in\n`docs/event-schema.md` (LINK/UNLINK, TAG_DELTA, CREATE genesis) and the cascade in\n`docs/concurrency.md` I4a — only the `idea` status is wholly unhomed. So the new\n`docs/ticket-model.md` carries the agent-facing *concept* with cross-refs, and the other docs get\nthree targeted gap-fills (the cascade gate nuance, a real session_log section, the auto-rotation\ndetail) rather than a bulk copy. Framing each criterion as an end-state the result must satisfy\nkeeps the plan verifiable by inspecting the produced docs.\n\n## Acceptance Criteria\n\n- [ ] `docs/ticket-model.md` exists and documents idea-status, hierarchy/containment, linking\n  (relations + promotion), and the tags surface incl. `--set-tags`, with a cross-ref to\n  `docs/event-schema.md` and no restated event bodies.\n  - Proving: `test -f docs/ticket-model.md && [ \"$(rg -c 'idea|parent_id|discovered_from|set-tags' docs/ticket-model.md)\" -ge 4 ] && rg -q 'event-schema' docs/ticket-model.md`\n- [ ] `docs/concurrency.md` documents the cascade's gate interaction (parent's own plan-review\n  gate; epics/stories not gate-exempt; `--force`).\n  - Proving (both strings are absent from concurrency.md today, so this fails until the section is added): `rg -q 'gate-exempt' docs/concurrency.md && rg -q 'plan-review' docs/concurrency.md`\n- [ ] `docs/event-schema.md` has a `## The session_log ticket type` section and does not defer\n  session_log semantics to the root file.\n  - Proving: `rg -q '## The session_log ticket type' docs/event-schema.md`\n- [ ] `docs/user-guide.md` documents session-log auto-rotation (currently absent).\n  - Proving: `rg -q 'auto-rotat|current_session_log' docs/user-guide.md`\n- [ ] `docs/README.md` indexes `docs/ticket-model.md`.\n  - Proving: `rg -q 'ticket-model' docs/README.md`\n- [ ] `make lint` passes.\n  - Proving: `make lint`","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"docs/ticket-model.md","reason":"new home for idea/hierarchy/linking/tags"},{"path":"docs/event-schema.md","reason":"session-log behavior home"},{"path":"docs/concurrency.md","reason":"cascade/linking/tags home"},{"path":"docs/README.md","reason":"index the new docs"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","81e2-ad5e-bfe2-4653"]],"parent_id":"81e2-ad5e-bfe2-4653","parent_status_uuid":"dd203fee-2617-4d29-bdfa-5774f0badeb4","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"073d-51d8-3e58-4b14","ticket_type":"story","title":"Re-home CLAUDE.md-native content into authoritative docs","verify_commands":[]},"source_event_uuids":["6c84bd76-1cdd-4d2e-8961-eeb740e1a22a","e29fe08b-cc0a-4e26-9243-b371332b7065","41c292b5-79a3-433d-a0fc-dfc3d4e629dd","3010e343-c21c-4c14-a798-38d2428e45d9","e1009df9-9d8e-4b3b-91bf-55e6f2e88541","a7d95819-9f92-49ce-81e3-481fb3a53f89","911d9dbf-ee93-4bbe-8acf-a7b860b71c41","2628af78-7ecd-4d9f-b699-9b0f03f5d167","dd203fee-2617-4d29-bdfa-5774f0badeb4","4658b28b-1fe3-4259-8eb2-f0cb76fb0aa4","d01f83fa-b599-4b26-b074-c79501ad1da8"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784254305424470887,"uuid":"6f672f0d-5ea7-403c-8b2d-c67457ad54ac"}