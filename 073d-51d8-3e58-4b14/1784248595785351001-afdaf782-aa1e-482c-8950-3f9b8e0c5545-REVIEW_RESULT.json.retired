{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","author_sig":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","data":{"coaching":[{"coaching":"Pin down AC1 proof command for all four concept topics with a concrete worked example.","decision":"advisory","finding_refs":["fa287b0359c65819a","f3a2162dac9cac61a","fc5753f10570a2f70","fe9da58eaf2876ed1","f263b01ce558c2136"],"move_id":"6","move_name":"specification by example","subject":"AC1 proof command for all four concept topics"},{"coaching":"Plan how AC2 verification of all three gate-interaction terms will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f08e518e6a17a37e8","fdf5be4bb3010ee12"],"move_id":"9","move_name":"plan the verification","subject":"AC2 verification of all three gate-interaction terms"},{"coaching":"State the concrete attestation evidence the [operator-attested] gate-interaction rule's authoritative source will require (a change id / vote outcome / timestamp), recorded on the ticket.","decision":"block","finding_refs":["f150aea9cd0e354d9","f91ba059639d8f775"],"move_id":"14","move_name":"state attestation evidence","subject":"gate-interaction rule's authoritative source"},{"coaching":"Test the riskiest assumption behind session_log type semantics content vocabulary first.","decision":"advisory","finding_refs":["f4c46c15ec2b060c9"],"move_id":"4","move_name":"riskiest-assumption test","subject":"session_log type semantics content vocabulary"},{"coaching":"Plan how discovered_from token in AC1 proof command will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f1176846adf8c0302"],"move_id":"9","move_name":"plan the verification","subject":"discovered_from token in AC1 proof command"},{"coaching":"Weigh at least one structural alternative for fold-versus-copy intent for cascade paragraph.","decision":"advisory","finding_refs":["fa9d09bdb7e0d8b33"],"move_id":"5","move_name":"weigh alternatives","subject":"fold-versus-copy intent for cascade paragraph"},{"coaching":"Propagate the revision for stale CLAUDE.md session-log pointer in architecture.md to the child tickets.","decision":"advisory","finding_refs":["f5ecd46cb72a890c4","f1140262ae956aa97","f325a0ed71a1ddaf4"],"move_id":"11","move_name":"propagate to children","subject":"stale CLAUDE.md session-log pointer in architecture.md"},{"coaching":"Plan how cross-reference from ticket-model.md to concurrency.md will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f083f72020f5631a8"],"move_id":"9","move_name":"plan the verification","subject":"cross-reference from ticket-model.md to concurrency.md"},{"coaching":"Plan how AC4 verification of session-id resolver cross-reference will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f6d497d7481cb9019"],"move_id":"9","move_name":"plan the verification","subject":"AC4 verification of session-id resolver cross-reference"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":16,"blocking":1,"dropped":2,"indeterminate":0},"det":{"P1":{"ac_items":6,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","probed":6,"ran":true,"references":6,"resolved":5,"status":"pass","unresolved_or_abstained":1},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":6,"blocking":false,"desc_chars":3686,"file_impact":4,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":6,"blocking":false,"name":"ac-quality","ran":true,"status":"pass","verify_commands_linted":38,"verify_lint_abstained":38},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":936,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":4,"name":"file-impact-coverage","ran":true,"status":"pass"}},"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":238.3,"llm_calls":28,"llm_ms":443557.6,"total_ms":443885.0,"verify_requests":30},"remediation":{"baseline":"sidecar","eligible":false,"reasons":{"code_unchanged":false,"plan_changed":false,"registry_unchanged":true,"sidecar_baseline":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","G5","T2","T4","T5b","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Clarify that the cascade gate-interaction content (plan-review gate exemption for bugs/session_logs, epics/stories not gate-exempt, --force propagation) must be sourced from docs/plan-review-gate.md (not from CLAUDE.md's cascade paragraph, which does not contain this nuance), and update the 'What' section and AC accordingly.","cohort":["G6"],"criteria":["G6"],"decision":"block","drop_reason":null,"evidence":["CLAUDE.md lines 61–67: cascade paragraph describes only basic parent-first mechanics, no mention of 'plan-review gate', 'gate-exempt', or '--force'","docs/plan-review-gate.md lines 50–51: 'Bugs and session_logs are exempt. --force=\"<reason>\" bypasses it'","docs/plan-review-gate.md line 222: 'bugs and session_logs are exempt from the whole gate'","AC proving: rg -n 'gate-exempt|plan-review gate|--force' docs/concurrency.md"],"finding":"The plan says to 'fold CLAUDE.md's cascade gate-interaction paragraph' into docs/concurrency.md I4a, but CLAUDE.md's actual cascade paragraph (lines ~61–67) contains only the basic parent-first mechanics — it does not mention plan-review gates, gate-exemption for epics/stories, or --force propagation. Those terms (which the AC's proving regex explicitly tests for: 'gate-exempt|plan-review gate|--force') currently appear in docs/plan-review-gate.md, not in CLAUDE.md. The sourcing label is wrong, which means the implementer may look in CLAUDE.md, find no gate-interaction nuance, and either omit the content or import the wrong text.","group_criteria":null,"group_id":null,"id":"f150aea9cd0e354d9","impact":1.0,"is_primary":null,"location":"What section — 'Fold CLAUDE.md's cascade gate-interaction paragraph into docs/concurrency.md I4a'; AC line 2","norm_id":"n9ff5b5cbbd3f21e6","priority":0.8889,"reason":"high-priority+criterion-opted-in","scenarios":["Implementer searches CLAUDE.md for 'gate-interaction paragraph', finds only the basic cascade description, writes new text without the gate-exemption/--force nuance, and the AC grep still fails.","Implementer imports the wrong passage (the basic cascade text) and the new section in concurrency.md lacks the terms the AC tests."],"severity":"critical","suggested_fix":"In the 'What' bullet for concurrency.md, replace 'Fold CLAUDE.md's cascade gate-interaction paragraph into docs/concurrency.md I4a' with 'Add a gate-interaction sub-note to docs/concurrency.md I4a drawing on docs/plan-review-gate.md (lines ~50–51, ~222): each parent in the cascade still faces its own plan-review gate; bugs and session_logs are gate-exempt but epics/stories are not; --force propagates to the child but each cascaded parent must independently satisfy or --force its own gate.'","tier":"LLM","validity":0.8889,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"high","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Either inline the specific gate-interaction rules (what happens when a cascade encounters a parent lacking a valid plan-review attestation; how `--force` propagates through the cascade gate check) directly in the plan, or add a reference to the specific CLAUDE.md section content that can be quoted verbatim, so the executor does not have to reconstruct the protocol.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["plan-review-gate.md §'Proportionate scrutiny': 'bugs and session_logs are exempt from the whole gate' — no mention of cascade exemption for epics/stories","concurrency.md I4a has zero mentions of plan-review gate, gate-exempt, or --force (confirmed by grep returning 0 hits)","The plan's own AC proving command (`rg -n 'gate-exempt|plan-review gate|--force' docs/concurrency.md`) implies these terms must appear, but their meaning in the cascade context is undefined in any reachable doc","CLAUDE.md (the authoritative source of this content) is out of scope"],"finding":"The 'gate-interaction nuance' to be added to docs/concurrency.md I4a references 'parent's own plan-review gate; epics/stories not gate-exempt; --force propagates' — but this interaction rule is not co-located with any existing schema or spec the executor can consult. plan-review-gate.md only says 'bugs and session_logs are exempt'; it does not address what happens to a parent's plan-review gate during a cascade, or whether --force on a child propagates through to bypass the parent's gate. An executor writing this paragraph would need to invent the protocol from first principles.","group_criteria":null,"group_id":null,"id":"f91ba059639d8f775","impact":0.67,"is_primary":null,"location":"AC#2 / What bullet: 'Fold CLAUDE.md's cascade gate-interaction paragraph into docs/concurrency.md I4a'","norm_id":"ncac1d5a86327ab02","priority":0.5863,"reason":"default-advisory","scenarios":["Executor writes that epics/stories are 'not gate-exempt' without specifying what that means operationally during a cascade (does the cascade abort if the parent lacks a valid plan-review attestation?)","Executor writes that --force propagates without specifying whether it propagates the bypass to parent gates or only to parent status transitions"],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Replace the single `rg -c` alternation check in AC1's proving command with four independent assertions — one per required topic — so all four must be present: `rg -q 'idea' docs/ticket-model.md && rg -q 'parent_id' docs/ticket-model.md && rg -q 'discovered_from' docs/ticket-model.md && rg -q 'set-tags' docs/ticket-model.md`.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["\"[ \\\"$(rg -c 'idea|parent_id|discovered_from|set-tags' docs/ticket-model.md)\\\" -ge 4 ]\" — alternation means a single term repeated 4+ times satisfies >= 4","VERIFY-COMMAND DEFECT TAXONOMY type 5: missing per-term cardinality assertion when the criterion names a count (all four topics must appear, not >= 4 hits of any one)"],"finding":"AC1's proving command uses `rg -c 'idea|parent_id|discovered_from|set-tags'` (alternation) and asserts the count is >= 4. Because `-c` counts lines matching ANY of the four patterns, a document with four or more lines mentioning only 'idea' — and omitting the other three topics entirely — would satisfy the assertion. The command does not guarantee all four concept topics are present.","group_criteria":null,"group_id":null,"id":"fa287b0359c65819a","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — first AC, proving command","norm_id":"nb0c9958dd03fb774","priority":0.55,"reason":"default-advisory","scenarios":["An executor documents the 'idea' lifecycle thoroughly (>= 4 mentions) but omits the parent_id/hierarchy section; CI still passes the AC check."],"severity":"major","suggested_fix":"Replace `[ \"$(rg -c 'idea|parent_id|discovered_from|set-tags' docs/ticket-model.md)\" -ge 4 ]` with `rg -q 'idea' docs/ticket-model.md && rg -q 'parent_id' docs/ticket-model.md && rg -q 'discovered_from' docs/ticket-model.md && rg -q 'set-tags' docs/ticket-model.md`.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Split AC2's proving command into three independent `rg -q` assertions — one per required nuance — so all three must appear: `rg -q 'plan-review gate' docs/concurrency.md && rg -q 'gate-exempt' docs/concurrency.md && rg -q -- '--force' docs/concurrency.md`.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["\"rg -n 'gate-exempt|plan-review gate|--force' docs/concurrency.md\" — alternation exits 0 on any single match","Plan body states three distinct nuances must be added to I4a: plan-review gate, gate-exempt status, and --force propagation"],"finding":"AC2's proving command `rg -n 'gate-exempt|plan-review gate|--force' docs/concurrency.md` returns hits (exit 0) if even ONE of the three terms is present. The plan explicitly requires all three nuances to be folded in ('parent's own plan-review gate; epics/stories not gate-exempt; --force propagates'), but the alternation check cannot distinguish one term present from all three present.","group_criteria":null,"group_id":null,"id":"f08e518e6a17a37e8","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — second AC, proving command","norm_id":"nfd77f484571d61f7","priority":0.55,"reason":"default-advisory","scenarios":["An executor adds only the --force propagation detail; the rg command returns a hit and the AC appears satisfied even though the plan-review-gate and gate-exempt nuances are missing."],"severity":"major","suggested_fix":"Replace the single alternation with: `rg -q 'plan-review gate' docs/concurrency.md && rg -q 'gate-exempt' docs/concurrency.md && rg -q -- '--force' docs/concurrency.md`","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an AC4 sub-check (or extend AC4's prove command) to verify that user-guide.md references config.md after the change, e.g. `rg -q 'config.md' docs/user-guide.md`.","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["'Cross-reference the session-id resolver already documented in docs/config.md (§ ~429-434)' — What section, user-guide bullet","AC4 prove command: `rg -n 'auto-rotat|current_session_log' docs/user-guide.md` — no check for config.md cross-reference"],"finding":"The 'What' section explicitly describes adding a cross-reference to the session-id resolver in docs/config.md when updating user-guide.md ('Cross-reference the session-id resolver already documented in docs/config.md (§ ~429-434)'), but no acceptance criterion verifies this cross-reference was actually added. This is described work with no covering criterion.","group_criteria":null,"group_id":null,"id":"f6d497d7481cb9019","impact":0.55,"is_primary":null,"location":"What section (user-guide.md bullet) vs AC4","norm_id":"n25bec5cec089526e","priority":0.55,"reason":"default-advisory","scenarios":["An implementer adds the auto-rotation detail without the config.md cross-reference and all ACs pass green, leaving the described cross-link absent."],"severity":"major","suggested_fix":"Extend AC4's prove line to: `rg -n 'auto-rotat|current_session_log' docs/user-guide.md && rg -q 'config\\.md' docs/user-guide.md`","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E6","F1"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"AC1's rg proving command uses a single OR-pattern with -c and -ge 4, meaning four lines all containing only 'idea' (and none containing 'parent_id', 'discovered_from', or 'set-tags') would satisfy the count check — so the command does NOT verify that all four concept topics are present.","group_criteria":null,"group_id":null,"id":"f3a2162dac9cac61a","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — AC1 proving command: `rg -c 'idea|parent_id|discovered_from|set-tags' docs/ticket-model.md` -ge 4","norm_id":"nd49e34af7b1141e9","priority":0.55,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"rg -q 'idea' docs/ticket-model.md && rg -q 'parent_id' docs/ticket-model.md && rg -q 'discovered_from' docs/ticket-model.md && rg -q 'set-tags' docs/ticket-model.md && rg -q 'event-schema' docs/ticket-model.md","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E6","F1"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"AC2's rg proving command uses a single OR-pattern `gate-exempt|plan-review gate|--force`, so a match on ANY ONE term exits 0 — an agent could add only `--force` to concurrency.md and the command would pass, leaving the other two stated nuances (parent's own plan-review gate; epics/stories not gate-exempt) unverified.","group_criteria":null,"group_id":null,"id":"fdf5be4bb3010ee12","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — AC2 proving command: `rg -n 'gate-exempt|plan-review gate|--force' docs/concurrency.md`","norm_id":"n3bdd2e187ae1c7ec","priority":0.55,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"rg -q 'plan-review gate' docs/concurrency.md && rg -q 'gate-exempt' docs/concurrency.md && rg -q -- '--force' docs/concurrency.md","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E6","F1"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"AC1's proving command uses `rg -c 'idea|parent_id|discovered_from|set-tags' docs/ticket-model.md` with a single alternation pattern; `rg -c` counts total lines matching ANY of the alternatives, not one per pattern. A document mentioning only `idea` four times would return count≥4 and pass, even if `parent_id`, `discovered_from`, and `set-tags` are completely absent — leaving three of the four required concept topics unverified.","group_criteria":null,"group_id":null,"id":"fc5753f10570a2f70","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — AC1 proving command","norm_id":"nc8dd670723e293e7","priority":0.55,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"rg -q 'idea' docs/ticket-model.md && rg -q 'parent_id' docs/ticket-model.md && rg -q 'discovered_from' docs/ticket-model.md && rg -q 'set-tags' docs/ticket-model.md && rg -q 'event-schema' docs/ticket-model.md","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"AC1's grep proof (`rg -c 'idea|parent_id|discovered_from|set-tags' docs/ticket-model.md` ≥ 4) is satisfiable by four hits of the single term `idea` (or any one term). It does not verify that all four named concept topics (idea lifecycle, hierarchy/containment via parent_id, linking via discovered_from, tags via set-tags) are each present as distinct documented topics — the AC would pass if three of the four topics are entirely absent but `idea` appears four times.","group_criteria":null,"group_id":null,"id":"fe9da58eaf2876ed1","impact":0.55,"is_primary":null,"location":"AC1 — 'Proving: test -f docs/ticket-model.md && [ \"$(rg -c 'idea|parent_id|discovered_from|set-tags' docs/ticket-model.md)\" -ge 4 ]'","norm_id":"n2ea243f162bd790e","priority":0.55,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"Replace the single `-c … -ge 4` check with five separate `rg -q` assertions (one per required term/topic) chained with `&&`, so each topic is independently gated.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E3"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"AC1's shell proof (`rg -c 'idea|parent_id|discovered_from|set-tags' docs/ticket-model.md -ge 4`) counts lines matching ANY of the four terms, not that all four topics are substantively present. A file covering only 'idea' extensively (≥4 lines) with no mention of parent_id, discovered_from, or set-tags would still pass the grep while missing three of the four required topics.","group_criteria":null,"group_id":null,"id":"f263b01ce558c2136","impact":0.55,"is_primary":null,"location":"Acceptance Criteria, AC1 — Proving shell command","norm_id":"nb1ced98724d4217c","priority":0.55,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"Replace the `-c` count check with four separate `rg -q` checks joined by `&&`, one per required topic term, so each topic must be individually present.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Enumerate the specific semantics the `## The session_log ticket type` section must carry (beyond what's already inline in the CREATE row), so the executor knows the content boundary and does not inadvertently duplicate or omit.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Plan says 'carrying the type semantics' but never lists what those semantics are","CLAUDE.md is explicitly Out of scope ('Out: editing CLAUDE.md (that is S2)')","event-schema.md line 46 already inline-documents: gate/lifecycle-exempt, exclude_session_logs, refuses STATUS, not Jira-synced, limited link types — but 'a real section' implies more; what more is unspecified","AC proving command only checks section header presence and absence of the old pointer — does not verify content coverage"],"finding":"The content vocabulary for the new '## The session_log ticket type' section in docs/event-schema.md is never defined in the plan. The plan says the section should carry 'the type semantics' to replace 'see CLAUDE.md \"Session logs\"', but CLAUDE.md is explicitly out of scope for this story. An executor cannot know what those semantics include beyond what's already inline in the CREATE row (gate/lifecycle-exempt, no STATUS, no Jira sync, limited links). The plan gives no spec of what additional content belongs in this dedicated section versus what is already present inline.","group_criteria":null,"group_id":null,"id":"f4c46c15ec2b060c9","impact":0.536,"is_primary":null,"location":"AC#3 / What bullet: 'Replace the pointer in docs/event-schema.md:46 … with a real ## The session_log ticket type section carrying the type semantics'","norm_id":"na1d20ccc2fd545f1","priority":0.469,"reason":"default-advisory","scenarios":["Executor writes a one-liner section that passes the grep but omits auto-rotation, link constraints, or other semantics CLAUDE.md documents","Executor duplicates the entire inline CREATE-row content into the new section, creating immediate drift risk the plan explicitly warns against"],"severity":"major","suggested_fix":"Add to the What bullet: 'The section should cover: (1) auto-rotation / `.rebar/current_session_log` pointer (cross-ref user-guide.md), (2) the session-log-specific link permission subset (relates_to/discovered_from only), (3) exclusion from plan-review gate and dependency graph — and must NOT restate the event-body details already in the CREATE row.'","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"insufficient","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a cross-reference from `docs/ticket-model.md`'s hierarchy/containment section to `docs/concurrency.md` (I4a cascade rules), and add a corresponding `rg -q 'concurrency' docs/ticket-model.md` assertion to the AC proving command.","cohort":["T2","T5e","T7"],"criteria":["T7"],"decision":"advisory","drop_reason":null,"evidence":["Plan says: 'hierarchy/containment (parent_id, not a link relation)' is one of the four topics in ticket-model.md","Plan separately says: 'the parent-first cascade already lives in docs/concurrency.md I4a'","AC proving command only checks for 'event-schema' cross-ref: `rg -q 'event-schema' docs/ticket-model.md` — no check for a concurrency.md cross-ref","Absence: no instruction to add a cross-ref from ticket-model.md → concurrency.md for cascade/gate behavior"],"finding":"docs/ticket-model.md will document hierarchy/containment (parent_id, cascade behavior) but neither the plan's What section nor the AC requires a cross-reference from ticket-model.md to docs/concurrency.md, where the parent-first cascade and gate-interaction nuance live. A reader following the ticket model's hierarchy concept will hit a navigability dead-end without that pointer.","group_criteria":null,"group_id":null,"id":"f083f72020f5631a8","impact":0.55,"is_primary":null,"location":"What section — docs/ticket-model.md spec; AC line 1 (ticket-model.md proving command)","norm_id":"nfac13b6863708e89","priority":0.3438,"reason":"default-advisory","scenarios":["A developer reads ticket-model.md to understand parent_id hierarchy, finds no pointer to the cascade/gate rules in concurrency.md, and either misses those rules or searches the whole docs tree unnecessarily."],"severity":"major","suggested_fix":"In the What section, amend: 'hierarchy/containment (parent_id, not a link relation) — cross-reference docs/concurrency.md I4a for cascade and gate-interaction rules.' Update the AC proving command to also check `rg -q 'concurrency' docs/ticket-model.md`.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Either name 'discovered_from' explicitly in the What section's linking-topic description (if it is one of the six required relations), or replace it in the AC1 prove command with a term that matches the described content (e.g. one of the actually-named link relations).","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["What section four topics: 'the `idea` status lifecycle, hierarchy/containment (`parent_id`, not a link relation), linking (the six relations + the promotion concept), and the tags surface + the `--set-tags` add-wins caveat' — no mention of 'discovered_from'","AC1 prove: `rg -c 'idea|parent_id|discovered_from|set-tags' docs/ticket-model.md`"],"finding":"The AC1 prove command uses the token 'discovered_from' (`rg -c 'idea|parent_id|discovered_from|set-tags'`) to verify ticket-model.md content, but 'discovered_from' does not appear anywhere in the four topics enumerated in the What section. This is a terminology mismatch between the described content and the acceptance criterion's verification step.","group_criteria":null,"group_id":null,"id":"f1176846adf8c0302","impact":0.33,"is_primary":null,"location":"AC1 prove command vs What section (ticket-model.md bullet)","norm_id":"n3022892bea2e0610","priority":0.165,"reason":"default-advisory","scenarios":["An implementer writing ticket-model.md doesn't know whether 'discovered_from' is a required term or an incidental one; if it's one of the six link relations that must be named, it belongs in the What description."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Resolve the contradiction between 'Fold … into docs/concurrency.md' (What section) and 'Out: editing CLAUDE.md' (Scope section) — if CLAUDE.md is intentionally untouched in this story, replace 'Fold' with 'Add' or 'Copy' to make clear this is an additive docs change, not a migration.","cohort":["E3","E5","G5"],"criteria":["E3"],"decision":"advisory","drop_reason":null,"evidence":["'Fold CLAUDE.md's cascade gate-interaction paragraph into docs/concurrency.md I4a' — 'fold into' implies removal from CLAUDE.md","'Out: editing CLAUDE.md (that is S2) and any code change. Docs-only.' — explicitly excludes CLAUDE.md changes","No AC verifies that CLAUDE.md is unchanged, and no AC verifies the paragraph was removed from CLAUDE.md — the ACs only check presence in concurrency.md"],"finding":"The 'What' section says 'Fold CLAUDE.md's cascade gate-interaction paragraph into docs/concurrency.md I4a', where 'fold into' conventionally means move (add there, remove from source), yet the Scope section explicitly states 'Out: editing CLAUDE.md'. These two statements contradict each other, leaving the implementer uncertain whether to also remove that paragraph from CLAUDE.md as part of this story.","group_criteria":null,"group_id":null,"id":"fa9d09bdb7e0d8b33","impact":0.264,"is_primary":null,"location":"What section ('Fold CLAUDE.md's cascade gate-interaction paragraph into docs/concurrency.md I4a') vs. Scope section ('Out: editing CLAUDE.md (that is S2)')","norm_id":"n9747c32d57bb8bd1","priority":0.165,"reason":"default-advisory","scenarios":["An implementer following 'fold into' removes the paragraph from CLAUDE.md, violating the Out constraint and triggering unintended S2 scope.","An implementer following the Out constraint copies the paragraph (leaving CLAUDE.md untouched), but the What language implied a move — both are plausible readings."],"severity":"minor","suggested_fix":"In the What section, change 'Fold CLAUDE.md's cascade gate-interaction paragraph into docs/concurrency.md I4a' to 'Add the cascade gate-interaction nuance from CLAUDE.md to docs/concurrency.md I4a (CLAUDE.md itself is unchanged until S2).' This aligns the language with the Scope Out constraint and removes ambiguity for the implementer.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Verify and address the 'see CLAUDE.md \"Session logs\"' pointer at docs/architecture.md:65 — either add architecture.md to the in-scope file list or explicitly justify its exclusion.","cohort":["E4"],"criteria":["E4"],"decision":"advisory","drop_reason":null,"evidence":["docs/architecture.md:65: 'leave it off so logs stay discoverable (see CLAUDE.md \"Session logs\").'","Plan scope: 'In: docs/ticket-model.md (new) and docs/{event-schema,concurrency,user-guide,README}.md' — architecture.md is Out.","AC3 only checks event-schema.md: 'rg -q \"## The session_log ticket type\" docs/event-schema.md'","ABSENCE: No mention of architecture.md:65 in the plan or its ACs."],"finding":"docs/architecture.md:65 also contains a 'see CLAUDE.md \"Session logs\"' pointer, but the plan only targets docs/event-schema.md:46 for replacement. The scope section says only event-schema.md is in-scope for this fix, leaving a second stale CLAUDE.md dereference uncorrected.","group_criteria":null,"group_id":null,"id":"f5ecd46cb72a890c4","impact":0.0,"is_primary":null,"location":"Scope / What section (event-schema.md pointer fix) and Design decisions","norm_id":"nca9b2a3a7f4388aa","priority":0.0,"reason":"default-advisory","scenarios":["After the story ships, architecture.md still points agents to CLAUDE.md for session-log semantics, defeating the stated goal of removing CLAUDE.md dependencies.","If S2 (CLAUDE.md slimming) later removes or rewrites the 'Session logs' section, architecture.md becomes a dangling reference."],"severity":"none","suggested_fix":"Add docs/architecture.md to the In-scope list and update its line 65 to cross-reference the new `## The session_log ticket type` section in docs/event-schema.md (e.g. 'see [event-schema.md §session_log](event-schema.md#the-session_log-ticket-type)').","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add `docs/architecture.md` to the edit scope (or explicitly call it out-of-scope with rationale) and update its line-65 `see CLAUDE.md \"Session logs\"` pointer to reference the new authoritative home (`docs/event-schema.md#the-session_log-ticket-type` or `docs/ticket-model.md`).","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["docs/architecture.md:65: 'leave it off so logs stay discoverable (see CLAUDE.md \"Session logs\").'","Plan scope: 'In: docs/ticket-model.md (new) and docs/{event-schema,concurrency,user-guide,README}.md' — architecture.md absent","Plan AC3: removes 'see CLAUDE.md \"Session logs\"' from event-schema.md but no corresponding fix for architecture.md"],"finding":"docs/architecture.md line 65 also contains 'see CLAUDE.md \"Session logs\"' — the same stale pointer the plan removes from docs/event-schema.md — but docs/architecture.md is not listed in the plan's scope (In:) and is therefore an unenumerated consumer that will be left with a dangling CLAUDE.md reference after the work lands.","group_criteria":null,"group_id":null,"id":"f1140262ae956aa97","impact":0.0,"is_primary":null,"location":"Scope section ('In:' list) / docs/architecture.md:65","norm_id":"n9b1c2e6188c7ea0c","priority":0.0,"reason":"default-advisory","scenarios":["After the work lands, a reader following the architecture.md session_log cross-reference hits a CLAUDE.md section that has been slimmed (S2 goal), finding no authoritative detail there — the new home (event-schema.md / ticket-model.md) is undiscoverable from the architecture.md entry point.","A future S2 CLAUDE.md slimming pass removes 'Session logs' content, breaking the architecture.md:65 pointer with no surviving reference."],"severity":"none","suggested_fix":"In the Scope section, add `docs/architecture.md` to the 'In:' list and add a bullet to the What section: 'Update the `see CLAUDE.md \"Session logs\"` cross-reference in `docs/architecture.md:65` to point to `docs/event-schema.md#the-session_log-ticket-type`.' Alternatively, if intentionally excluded, document the rationale.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add docs/architecture.md to the 'In' scope and replace its line-65 'see CLAUDE.md \"Session logs\"' pointer with a cross-reference to the new docs/event-schema.md § The session_log ticket type section.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["docs/architecture.md:65: 'leave it off so logs stay discoverable (see CLAUDE.md \"Session logs\")'","search_files query 'see CLAUDE.md' returned: docs/architecture.md:65 AND docs/event-schema.md:46","Plan's Scope 'In' list does not include docs/architecture.md"],"finding":"The plan targets only the 'see CLAUDE.md \"Session logs\"' pointer in docs/event-schema.md:46, but an identical stale pointer exists at docs/architecture.md:65 ('leave it off so logs stay discoverable (see CLAUDE.md \"Session logs\")') and is not addressed by the plan. After the work, docs/architecture.md will still point agents and contributors to CLAUDE.md for session_log semantics even though the authoritative home has moved to docs/event-schema.md.","group_criteria":null,"group_id":null,"id":"f325a0ed71a1ddaf4","impact":0.0,"is_primary":null,"location":"Scope section — 'In: docs/ticket-model.md (new) and docs/{event-schema,concurrency,user-guide,README}.md'; What section","norm_id":"nd86b2b523a567a40","priority":0.0,"reason":"default-advisory","scenarios":["After this story lands, a contributor or agent reading docs/architecture.md follows the 'see CLAUDE.md' pointer and finds the content has nominally moved, creating confusion about which doc is authoritative.","The next S2 (CLAUDE.md-slimming) story removes the Session logs section from CLAUDE.md, leaving docs/architecture.md with a broken conceptual pointer."],"severity":"none","suggested_fix":"In the Scope section, change 'In: docs/ticket-model.md (new) and docs/{event-schema,concurrency,user-guide,README}.md' to include docs/architecture.md, and add a What bullet: 'Update docs/architecture.md line 65 to cross-reference docs/event-schema.md § The session_log ticket type instead of CLAUDE.md.'","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Refine the 'only `idea` is unhomed' assertion to specify what aspect is missing (e.g. 'no agent-facing conceptual doc covering the idea lifecycle end-to-end, distinct from the user-guide.md CLI-usage section') so implementers know what to write and what to cross-reference rather than duplicate.","cohort":["E4"],"criteria":["E4"],"decision":"dropped","drop_reason":null,"evidence":["docs/user-guide.md:85-99: '### The `idea` status — a parking lot for undesigned work … rebar idea … rebar transition <id> idea open'","Plan assertion: 'Only `idea` is unhomed; the cascade (concurrency.md I4a) and the linking/tags write mechanics (event-schema.md) already have homes'","The plan's intent may be 'no agent-facing concept doc' but the assertion is stated as an absolute codebase fact."],"finding":"The plan's Design decisions assert 'only `idea` is unhomed' as a factual codebase premise used to scope out other work, but docs/user-guide.md lines 85-99 already contains a named section '### The `idea` status — a parking lot for undesigned work' covering the lifecycle (capture, promote). This undermines the exclusive-gap claim and may cause reviewers or implementers to over-scope docs/ticket-model.md's idea content, duplicating what already exists.","group_criteria":null,"group_id":null,"id":"f14ae08d8de733fef","impact":0.33,"is_primary":null,"location":"Design decisions: 'Only `idea` is unhomed'","norm_id":"n6d70206ab9d4b6dc","priority":0.1414,"reason":"low-validity","scenarios":["An implementer creating ticket-model.md duplicates the user-guide.md idea section verbatim, creating a drift risk.","A reviewer challenging the plan's premise finds the assertion falsified and loses trust in the spike-validation claim."],"severity":"minor","suggested_fix":"Replace 'Only `idea` is unhomed' with: 'The `idea` lifecycle is documented CLI-usage-style in docs/user-guide.md §85-99 but has no agent-facing conceptual home; docs/ticket-model.md will provide that, cross-referencing user-guide.md rather than duplicating it.'","tier":"LLM","validity":0.4286,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Define 'session fingerprint' in the plan (or point to the specific code/doc that defines it), so the executor can accurately describe how `.rebar/current_session_log` auto-rotation detection works.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Search for 'session fingerprint' across docs returns 0 hits","config.md §429-434 documents session-id resolution precedence (REBAR_SESSION_ID → CLAUDE_CODE_SESSION_ID → …), not a fingerprint mechanism","config.md line 451 mentions 'session_log current-log fingerprint' in passing but only in the context of a precedence-inversion note, with no definition of what the fingerprint is or how auto-rotation uses it","AC proving command (`rg -n 'auto-rotat|current_session_log' docs/user-guide.md`) only verifies presence, not correctness of the fingerprint description"],"finding":"The plan instructs adding 'the session-log auto-rotation detail (the `.rebar/current_session_log` pointer + session fingerprint)' to docs/user-guide.md, but 'session fingerprint' is a term whose vocabulary is never defined in the plan or in any reachable doc. The config.md cross-reference (§~429-434) covers the session-ID resolver (REBAR_SESSION_ID precedence chain), not a 'session fingerprint' used for auto-rotation detection.","group_criteria":null,"group_id":null,"id":"f2f616069ece652d7","impact":0.0,"is_primary":null,"location":"AC#4 / What bullet: 'Add the session-log auto-rotation detail (the .rebar/current_session_log pointer + session fingerprint) to docs/user-guide.md'","norm_id":"ncf8ec226b0853bda","priority":0.0,"reason":"veto:absence-refuted","scenarios":["Executor cannot determine what 'session fingerprint' means — whether it is a hash, the session-id value, a file mtime, or something else — and writes an inaccurate description","The auto-rotation mechanism is described incompletely, omitting the fingerprint comparison that triggers rotation"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.4286,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"3c8084d9a36ea7d3","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":238.3,"llm_calls":28,"llm_ms":443557.6,"total_ms":443885.0,"verify_requests":30},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"073d-51d8-3e58-4b14","ticket_type":"story","verdict":"BLOCK","verified_at_sha":"87304c5ea008b0da7ff4ab7ed4730b3d37b473fd"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784248595785351001,"uuid":"afdaf782-aa1e-482c-8950-3f9b8e0c5545"}