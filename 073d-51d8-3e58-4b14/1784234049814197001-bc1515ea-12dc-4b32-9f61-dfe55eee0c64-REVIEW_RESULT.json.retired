"applicable":true,"blocking":false,"file_impact":4,"name":"file-impact-coverage","ran":true,"status":"pass"}},"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":218.4,"llm_calls":28,"llm_ms":516827.9,"total_ms":517144.3,"verify_requests":23},"remediation":{"baseline":"sidecar","eligible":false,"reasons":{"code_unchanged":false,"plan_changed":false,"registry_unchanged":false,"sidecar_baseline":false,"within_window":false}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","G5","T2","T4","T5b","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add a proving command for the event-schema.md + user-guide.md AC, e.g.: `rg -n '## The session_log ticket type' docs/event-schema.md && rg -n 'session.log\\|capture helper' docs/user-guide.md`","cohort":["E2","E6","F1"],"criteria":["E6","F1"],"decision":"block","drop_reason":null,"evidence":["'docs/event-schema.md gains a `## The session_log ticket type` section; user-guide.md retains the capture helper.' — no `rg`, `test`, or grep command follows this criterion, unlike all other revised ACs.","ABSENCE: No proving command is provided for this criterion."],"finding":"The revised AC for docs/event-schema.md and user-guide.md ('gains a session_log ticket type section; user-guide.md retains the capture helper') has no proving command, making it unverifiable without manual inspection that could be omitted.","group_criteria":null,"group_id":null,"id":"f01d236e10a618469","impact":1.0,"is_primary":null,"location":"Revised Acceptance Criteria — third bullet (event-schema.md / user-guide.md)","norm_id":"n27b566c0ee79b295","priority":1.0,"reason":"high-priority+criterion-opted-in","scenarios":["An executor could add the section with the wrong heading (e.g., `### session_log type`) or omit user-guide.md and no automated check would catch it.","A reviewer running the proving commands would have no command to execute for this criterion, relying on manual inspection that may be skipped."],"severity":"critical","suggested_fix":"Add to that AC's bullet: `Proving: rg -n '## The session_log ticket type' docs/event-schema.md && rg -qn 'session.log' docs/user-guide.md`","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"low","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a `Proving:` shell command to the `docs/event-schema.md` + `user-guide.md` AC — e.g. `rg -n 'session_log ticket type' docs/event-schema.md && rg -n 'capture helper\\|append_session_log\\|session-log append' docs/user-guide.md`.","cohort":["T8"],"criteria":["T8"],"decision":"block","drop_reason":null,"evidence":["Every other revised AC has a proving command: ticket-model.md has `test -f docs/ticket-model.md && rg -c ...`, concurrency.md has `rg -n 'gate-exempt|plan-review|--force' docs/concurrency.md`, README.md has `rg 'ticket-model|idea status|tags' docs/README.md`.","The event-schema.md + user-guide.md AC has no `Proving:` line at all — it is the only revised AC without one.","This is a processing-protocol gap: the plan defines an output (new section heading) but specifies no verification rule co-located with the deliverable."],"finding":"The revised AC for `docs/event-schema.md` ('gains a `## The session_log ticket type` section') has no proving command, unlike every other revised AC which includes a shell one-liner. An executor cannot mechanically verify this deliverable was done.","group_criteria":null,"group_id":null,"id":"f3ef31726167ce83a","impact":1.0,"is_primary":null,"location":"Revised Acceptance Criteria — third bullet: 'docs/event-schema.md gains a `## The session_log ticket type` section; user-guide.md retains the capture helper.'","norm_id":"n5d6739742332be3d","priority":1.0,"reason":"high-priority+criterion-opted-in","scenarios":["Executor creates event-schema.md section under a slightly different heading (e.g. '## session_log type') — passes the plan's intent but there is no way to mechanically confirm correctness.","Reviewer cannot run a deterministic check to confirm the section was added, unlike for the other four deliverables."],"severity":"critical","suggested_fix":"Proving: `rg -n 'session_log ticket type' docs/event-schema.md && rg -n 'append_session_log\\|session-log append' docs/user-guide.md`","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"low","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a 'Proving:' verification command to the user-guide.md retention criterion, e.g. `rg -n 'capture helper|auto-rotation' docs/user-guide.md`.","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["All other revised ACs include a 'Proving:' command (rg, test -f)","The user-guide.md retention criterion has no corresponding 'Proving:' clause"],"finding":"The revised AC for user-guide.md ('user-guide.md retains the capture helper') has no verification step (no grep/test command), unlike every other revised AC, making it unverifiable as written.","group_criteria":null,"group_id":null,"id":"f46aff46e860a86d1","impact":1.0,"is_primary":null,"location":"Revised Acceptance Criteria, third bullet: 'docs/event-schema.md gains a ## The session_log ticket type section; user-guide.md retains the capture helper'","norm_id":"n85238d321c80d588","priority":1.0,"reason":"default-advisory","scenarios":["Reviewer cannot mechanically verify the user-guide.md capture-helper content was not accidentally removed."],"severity":"critical","suggested_fix":"Append: 'Proving: `rg -n 'capture.helper\\|auto-rotation\\|session.log' docs/user-guide.md`' to that AC bullet.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"low","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a 'Proving:' verification command to the event-schema.md criterion, e.g. `rg -n 'session_log ticket type' docs/event-schema.md`.","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["Revised ACs for ticket-model.md and concurrency.md include Proving: commands","The event-schema.md criterion has no Proving: clause"],"finding":"The revised AC for event-schema.md ('gains a ## The session_log ticket type section') also has no verification command, unlike the ticket-model.md and concurrency.md revised ACs.","group_criteria":null,"group_id":null,"id":"f4b111f707439f98b","impact":1.0,"is_primary":null,"location":"Revised Acceptance Criteria, third bullet: 'docs/event-schema.md gains a ## The session_log ticket type section'","norm_id":"n7b103d870f8a1fea","priority":1.0,"reason":"default-advisory","scenarios":["Reviewer cannot mechanically verify the new section heading exists in event-schema.md."],"severity":"critical","suggested_fix":"Append: 'Proving: `rg -n 'session_log ticket type' docs/event-schema.md`' to that AC bullet.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"low","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a machine-checkable 'Proving:' command for the event-schema.md AC, e.g. `rg -n 'session_log ticket type' docs/event-schema.md`.","cohort":["E3","E5","G5"],"criteria":["E3"],"decision":"advisory","drop_reason":null,"evidence":["All other revised ACs include a 'Proving:' command (rg, test -f, rg -n).","The event-schema.md AC has no 'Proving:' line."],"finding":"The revised AC for `docs/event-schema.md` ('gains a `## The session_log ticket type` section') has no machine-checkable proving command, unlike all other revised ACs which include a grep or test command. The AC is verifiable only by manual inspection, creating an inconsistency and a merge-time verification gap.","group_criteria":null,"group_id":null,"id":"f0106435c61800978","impact":1.0,"is_primary":null,"location":"Revised Acceptance Criteria, third bullet: 'docs/event-schema.md gains a `## The session_log ticket type` section'","norm_id":"ndcefb57549748ee9","priority":1.0,"reason":"default-advisory","scenarios":["Reviewer skips manual check; section is absent or misnamed; lint passes; AC is marked done incorrectly."],"severity":"critical","suggested_fix":"Append to the third revised AC: `Proving: rg -n 'session_log ticket type' docs/event-schema.md && rg -n 'capture helper\\|auto-rotation' docs/user-guide.md`","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"low","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Fix the ticket-model.md proving command to verify all four topics individually, e.g.: `rg -q 'idea' docs/ticket-model.md && rg -q 'parent_id' docs/ticket-model.md && rg -q 'discovered_from' docs/ticket-model.md && rg -q 'set-tags' docs/ticket-model.md`","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["'test -f docs/ticket-model.md && rg -c \\'idea|parent_id|discovered_from|set-tags\\' docs/ticket-model.md' — `rg -c` with an alternation returns one count of lines matching ANY of the alternatives, not a count per alternative.","VERIFY-COMMAND DEFECT: type 4 — fixture (command) does not actually exercise the claim that all four topics are present."],"finding":"The proving command for docs/ticket-model.md uses `rg -c 'idea|parent_id|discovered_from|set-tags'`, which counts only total matching LINES across all four patterns combined — a file containing 'idea' 10 times with no mention of 'set-tags' or 'parent_id' would pass the count check.","group_criteria":null,"group_id":null,"id":"f26ba73e691a3e319","impact":1.0,"is_primary":null,"location":"Revised Acceptance Criteria — first bullet, `Proving:` line","norm_id":"n119df45715c67b79","priority":0.875,"reason":"default-advisory","scenarios":["A doc covering only 'idea status' and 'hierarchy/containment' (using parent_id) but omitting linking (discovered_from) and tags (set-tags) would still produce a non-zero count."],"severity":"critical","suggested_fix":"Replace the single `rg -c` with four chained `rg -q` calls (one per required topic), each returning non-zero on failure: `rg -q 'idea' docs/ticket-model.md && rg -q 'parent_id' docs/ticket-model.md && rg -q 'discovered_from' docs/ticket-model.md && rg -q 'set.tags' docs/ticket-model.md`","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"broken_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"low","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Reinstate a semantic-completeness AC: add a requirement that the PR/change description includes a side-by-side diff (or explicit checklist) confirming no rule from the five CLAUDE.md sections was dropped when content was moved to its target doc.","cohort":["E3","E5","G5"],"criteria":["E3"],"decision":"advisory","drop_reason":null,"evidence":["Original AC: 'The moved content is semantically complete vs. the current CLAUDE.md sections (reviewer confirms via side-by-side diff in the change description; no rule dropped).'","Revised ACs omit this check entirely; proofs are structural (file exists, grep hits a keyword) not content-complete."],"finding":"The revised Acceptance Criteria drop the semantic-completeness verification that the original ACs explicitly required ('reviewer confirms via side-by-side diff in the change description; no rule dropped'). The revised ACs use existence/grep proofs only, which do not guarantee that every rule and nuance from the five CLAUDE.md sections lands in the target docs — content can be partially migrated and all revised ACs still pass green.","group_criteria":null,"group_id":null,"id":"f5a7a22d931910bba","impact":0.85,"is_primary":null,"location":"Revised Acceptance Criteria (all five bullets) vs. original AC bullet #2","norm_id":"nf4f73917b3d589ea","priority":0.7438,"reason":"default-advisory","scenarios":["An implementer creates docs/ticket-model.md with headings and stub text; all grep-based ACs pass, but substantial CLAUDE.md rules are never documented.","The cascade gate-interaction paragraph is partially copied; grep finds '--force' but the gate-exempt nuance is dropped."],"severity":"critical","suggested_fix":"Add back the original AC #2 verbatim, or a revised equivalent: '- [ ] Change description includes a section-by-section checklist confirming every rule and nuance from the five CLAUDE.md source sections is present in the target doc (reviewer sign-off required; not provable by grep alone).'","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"medium","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Remove or explicitly strike through the original Acceptance Criteria block, leaving only the revised ACs as the governing set (or add a clear header 'SUPERSEDED — see Revised ACs below').","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"advisory","drop_reason":null,"evidence":["Original AC: 'rg -l \\'parent-first|TAG_DELTA|hierarchy promotion|status .idea.|session_log\\' docs/' — expects a single pass across all five.","Revised AC: decomposes into concurrency.md + event-schema.md + ticket-model.md separately.","Both sets are present in the plan as-written with no visual strike-through or removal of the original."],"finding":"Two sets of acceptance criteria coexist in the plan — the original five bullets and the revised five bullets — and while the revised section says '(supersede the generic ones above)', the original bullets remain un-struck and both sets are grammatically active, which could cause an executor to check both sets and encounter conflicts (e.g., the original requires all five topics proven by a single `rg -l` command; the revised decomposes them differently).","group_criteria":null,"group_id":null,"id":"f3f0f9a89d9d4b55d","impact":0.536,"is_primary":null,"location":"Acceptance Criteria section (original) vs. Revised Acceptance Criteria section (de-risking block)","norm_id":"n0f32f079c0feae4d","priority":0.4594,"reason":"default-advisory","scenarios":["An executor runs original AC1's `rg -l` and finds it fails (session_log now lives in event-schema.md which the original command would still find, but the original hierarchy proves differently) — creates unnecessary confusion about what counts as done.","A reviewer checking 'did the executor satisfy ACs?' must manually adjudicate which set governs."],"severity":"major","suggested_fix":"Delete the original AC block entirely, or prefix it with `~~` strikethrough markdown and a note: `~~(Superseded by Revised Acceptance Criteria below)~~`.","tier":"LLM","validity":0.8571,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"medium","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Either strike the original Acceptance Criteria section entirely (leaving only the revised ACs) or explicitly mark each original AC as superseded/deleted, so exactly one set of criteria governs the implementation.","cohort":["COH","E1","T4"],"criteria":["COH","E1"],"decision":"advisory","drop_reason":null,"evidence":["Original AC set: 5 criteria including 'semantically complete vs. the current CLAUDE.md sections (reviewer confirms via side-by-side diff)'","Revised ACs: 5 different criteria, declared to 'supersede the generic ones above' but not replacing the original section","Original AC2 has no counterpart in the revised set"],"finding":"The plan presents two sets of Acceptance Criteria — the original five ACs and the 'Revised Acceptance Criteria (supersede the generic ones above)' — without removing the original set, leaving both active and partially contradictory. An implementer must decide which set governs.","group_criteria":null,"group_id":null,"id":"f1005b1b124c667b6","impact":0.536,"is_primary":null,"location":"'Acceptance Criteria' section (original ACs) vs. 'De-risking results' section (Revised Acceptance Criteria)","norm_id":"ncbbda3b3c66322bd","priority":0.4594,"reason":"default-advisory","scenarios":["Implementer satisfies revised ACs but not original AC2 (no side-by-side diff in change description). Reviewer using original ACs rejects the PR."],"severity":"major","suggested_fix":"Delete the original 'Acceptance Criteria' section and keep only the 'Revised Acceptance Criteria' block, or fold AC2's side-by-side diff verification into the revised set as an additional criterion.","tier":"LLM","validity":0.8571,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"medium","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Tighten the concurrency.md proving command to confirm the terms appear near the I4a heading, e.g. by grepping for the heading and the new terms in sequence or using a line-range check.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["'rg -n \\'gate-exempt|plan-review|--force\\' docs/concurrency.md' — no section anchor or line-range constraint is applied.","The AC text says 'I4a gains…' implying section-specific placement, but the command doesn't confirm that."],"finding":"The proving command for concurrency.md (`rg -n 'gate-exempt|plan-review|--force' docs/concurrency.md`) does not verify that these terms appear specifically in section I4a; if they already exist elsewhere in the file (or are added to the wrong section), the command passes without confirming correct placement.","group_criteria":null,"group_id":null,"id":"fa6dd81c93117e6c6","impact":0.44,"is_primary":null,"location":"Revised Acceptance Criteria — second bullet, `Proving:` line","norm_id":"n177a2995dbda4eeb","priority":0.33,"reason":"default-advisory","scenarios":["An executor adds the gate-interaction paragraph to a new appendix section rather than I4a; the proving command passes but the AC intent (fold into I4a) is not met."],"severity":"minor","suggested_fix":"Add a heading check before the term check: `rg -n 'I4a|parent-first cascade' docs/concurrency.md | head -5` then verify the term line numbers fall within that section. Or: `rg -A 60 'I4a' docs/concurrency.md | rg 'gate-exempt|plan-review|--force'`","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Reconcile the 'What' section's 'Copy content faithfully (no semantic loss)' directive with the De-risking section's 'do NOT restate event bodies (drift risk)' — remove or qualify the copy-faithfully instruction to match the cross-reference approach.","cohort":["COH","E1","T4"],"criteria":["COH"],"decision":"advisory","drop_reason":null,"evidence":["'Copy content faithfully (no semantic loss)' — What section","'do NOT restate event bodies (drift risk)' — De-risking results, ticket-model.md bullet"],"finding":"The 'What' section instructs 'Copy content faithfully (no semantic loss)' but the De-risking/refined plan explicitly contradicts this: 'do NOT restate event bodies (drift risk)' — the two sections give opposite directives to the implementer on how to handle event-schema content.","group_criteria":null,"group_id":null,"id":"f220d923790a39fb3","impact":0.264,"is_primary":null,"location":"'What' section vs. 'De-risking results' bullet: 'Cross-reference docs/event-schema.md … do NOT restate event bodies'","norm_id":"n644cd5f435bb2372","priority":0.132,"reason":"default-advisory","scenarios":["Implementer copies event body content into ticket-model.md (following 'What'), then reviewer rejects citing drift risk (following De-risking). Or implementer cross-references only and reviewer flags semantic loss."],"severity":"minor","suggested_fix":"Replace 'Copy content faithfully (no semantic loss)' in the What section with 'Preserve all concepts (no semantic loss); cross-reference rather than duplicate event bodies already defined in event-schema.md.'","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a formal dependency on the follow-on AGENTS.md story (ticket ID or explicit prerequisite) so the CLAUDE.md cleanup is tracked and not silently dropped; optionally add an interim comment in CLAUDE.md pointing to the new docs/ homes.","cohort":["T2","T5e","T7"],"criteria":["T7"],"decision":"advisory","drop_reason":null,"evidence":["\"Out: editing CLAUDE.md itself (that happens in the AGENTS.md story, which replaces these sections with pointers)\"","ABSENCE: No prerequisite ticket ID, no blocking relationship, no AC that verifies CLAUDE.md is eventually updated or that the follow-on story exists in the backlog."],"finding":"After this story lands, CLAUDE.md will still contain the five original sections (the plan explicitly scopes out editing CLAUDE.md), creating a temporary state where the same content exists in two places. The plan defers cleanup to 'the AGENTS.md story' but provides no ticket ID, prerequisite link, or AC that formally tracks or blocks on that follow-on work. If the AGENTS.md story is delayed or dropped, CLAUDE.md becomes a stale, authoritative-looking duplicate indefinitely.","group_criteria":null,"group_id":null,"id":"f7ef5ed7381a957e4","impact":0.0,"is_primary":null,"location":"Scope section: 'Out: editing CLAUDE.md itself (that happens in the AGENTS.md story, which replaces these sections with pointers)'","norm_id":"n06b6436e229d7f06","priority":0.0,"reason":"default-advisory","scenarios":["AGENTS.md story is deprioritized or dropped; CLAUDE.md retains original sections indefinitely alongside the new docs/ homes, confusing contributors about which is authoritative.","A contributor edits CLAUDE.md content (unaware it has been superseded) and the two copies diverge."],"severity":"none","suggested_fix":"In the Scope section, add: 'This story has a required successor: [AGENTS.md story ID] which replaces the five CLAUDE.md sections with pointers; until that story ships, CLAUDE.md and docs/ will temporarily duplicate content.' Add the AGENTS.md story as a blocking dependency in the ticket tracker.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Reconsider routing session-log fingerprint/rotation semantics to user-guide.md: consolidate all type-level and session-rotation semantics in event-schema.md's new `## The session_log ticket type` section, and limit user-guide.md to the CLI-command surface it already holds — so AGENTS.md can point agents at one location for session-log operational detail.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["Plan states: 'keep the *capture helper + auto-rotation* in `docs/user-guide.md` (its Session-logs section already exists)'","CLAUDE.md session-log section contains: fingerprint resolver (REBAR_SESSION_ID/CLAUDE_CODE_SESSION_ID/SESSION_ID chain), defensive rotation on session=None legacy pointer, 'A differing pointer fingerprint includes a missing one' — all multi-agent/agent-facing content","docs/user-guide.md Session-logs section (lines 163-173) is a brief CLI-command block with no agent-facing semantics","docs/README.md: user-guide.md is filed under 'User' audience ('Day-to-day use of rebar through the CLI'); event-schema.md is under 'Contributor' / 'Internals'","Plan's stated rationale for user-guide.md placement is structural convenience ('section already exists'), not audience-fit"],"finding":"The plan routes session-log auto-rotation and fingerprint semantics (REBAR_SESSION_ID/CLAUDE_CODE_SESSION_ID precedence chain, defensive rotation on session=None, per-session fingerprinting) to user-guide.md on the grounds that 'its Session-logs section already exists' — but user-guide.md is the User-audience doc, and this content is exclusively agent-facing (multi-agent session isolation, legacy pointer handling). Routing it there is an audience-fit mismatch: AGENTS.md (the planned consumer) would need to send agents to the user guide to understand rotation semantics, undermining the 'one agent-facing source of truth' goal. A clearly superior placement is to keep all of the session-log type semantics — including fingerprint/rotation — together in event-schema.md's new session_log section, and limit user-guide.md to the brief CLI-command surface it already covers.","group_criteria":null,"group_id":null,"id":"fa70a29069cd44992","impact":0.0,"is_primary":null,"location":"De-risking results — 'Session logs: split, don't lump' bullet; Revised AC item 3","norm_id":"n296adad7fd929dd6","priority":0.0,"reason":"default-advisory","scenarios":["An agent consulting docs/ for session-log rotation semantics (e.g. why their new session started a fresh log) follows AGENTS.md's pointer to event-schema.md's session_log section — which covers type semantics but not rotation — and must then also search user-guide.md, defeating single-source-of-truth","A contributor updating the fingerprint resolver looks in event-schema.md (natural home for type mechanics) but finds the rotation semantics in user-guide.md — two places to keep in sync"],"severity":"none","suggested_fix":"In the 'Session logs: split, don't lump' bullet, change the routing so that ALL agent-facing semantics (type behavior, gate exemption, visibility rules, fingerprint resolver, defensive rotation, session=None legacy behavior) go into event-schema.md's new section, and user-guide.md retains only the 'Capture helper' CLI commands it already has (rebar session-log append / start / session-logs). The config.md cross-reference for the fingerprint resolver stays as-is.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add an in-scope task to update the `session_log` forward-pointer in `docs/event-schema.md`'s CREATE row to point to the new `## The session_log ticket type` section in the same file (e.g. change 'see CLAUDE.md \"Session logs\"' to 'see [§ The session_log ticket type](#the-session_log-ticket-type) below').","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["docs/event-schema.md line 46: '**`session_log`** is a verbose-log type ... — see CLAUDE.md \"Session logs\".'","The plan says to create a new '## The session_log ticket type' section in event-schema.md — which is the very document that currently points to CLAUDE.md.","After plan execution, the forward-pointer in event-schema.md's CREATE row will point at CLAUDE.md content that has been superseded by the new section in the same file — a self-defeating pointer."],"finding":"`docs/event-schema.md`'s existing CREATE row already contains a forward-pointer to CLAUDE.md ('see CLAUDE.md \"Session logs\"'). The plan's scope explicitly excludes editing CLAUDE.md, but is silent about updating this stale intra-docs forward-pointer in event-schema.md once the session_log content moves into event-schema.md itself and user-guide.md.","group_criteria":null,"group_id":null,"id":"f61ce4ff34a9683d0","impact":0.0,"is_primary":null,"location":"Scope section ('Out: editing CLAUDE.md itself'); docs/event-schema.md line 46 (CREATE row).","norm_id":"ne628fa0ec5542651","priority":0.0,"reason":"default-advisory","scenarios":["An agent reading event-schema.md's CREATE row follows the 'see CLAUDE.md' pointer and finds content that may conflict with (or duplicate) the new section in the same file.","The stale pointer is not in scope per the plan's 'Out' definition, so an executor following the plan literally would leave it in place."],"severity":"none","suggested_fix":"In the CREATE row of docs/event-schema.md, replace '— see CLAUDE.md \"Session logs\"' with '— see [§ The session_log ticket type](#the-session_log-ticket-type) below' as part of this plan's deliverable.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Correct the de-risking claim: `docs/user-guide.md` has NO existing 'Session-logs section' — the plan must call for CREATING a new `## Session logs` section there rather than 'retaining' one that already exists.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":["Search for 'Session' in docs/user-guide.md: no matches","Search for 'session' in docs/user-guide.md: no matches","docs/user-guide.md content confirmed (lines 1-60): only sections are 'The everyday loop', 'Finding work', etc. — no Session-logs heading","Plan quote: 'its Session-logs section already exists'"],"finding":"The de-risking plan states 'keep the capture helper + auto-rotation in docs/user-guide.md (its Session-logs section already exists)' — but docs/user-guide.md has NO Session-logs section; searches for 'session', 'Session', 'Session log' in that file return zero matches. The named edit target (an existing 'Session-logs section' in user-guide.md) is hallucinated.","group_criteria":null,"group_id":null,"id":"faae6cc22674f3669","impact":0.0,"is_primary":null,"location":"De-risking results section: 'Session logs: split, don't lump' bullet — 'keep the capture helper + auto-rotation in docs/user-guide.md (its Session-logs section already exists)'","norm_id":"n6640afb2f5ecd65f","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":["An implementer following the plan looks for a 'Session-logs section' in user-guide.md to fold content into and finds nothing — they must create a new section rather than 'retaining' an existing one.","The AC ('docs/event-schema.md gains a session_log ticket type section; user-guide.md retains the capture helper') implies the section pre-exists; an implementer may incorrectly interpret this as 'no user-guide.md edit needed.'"],"severity":"none","suggested_fix":"Change 'user-guide.md retains the capture helper' to 'user-guide.md gains a new `## Session logs` section covering the capture helper and auto-rotation' (matching the same CREATION pattern as the event-schema.md section).","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"no","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] In the cascade gate-interaction paragraph being folded into `docs/concurrency.md` I4a, add a cross-reference to wherever `docs/ticket-model.md` documents per-type gate posture (or add a gate-posture column/note to ticket-model.md's type coverage, with concurrency.md referencing it).","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["CLAUDE.md lines 460-461: 'Epics/stories are **not** gate-exempt (only `bug`/`session_log` are)'","The plan says to fold 'that single paragraph into concurrency.md I4a' — but the gate-exempt type list (`bug`, `session_log`) is a vocabulary defined nowhere else in docs/ except CLAUDE.md.","The plan instructs `docs/ticket-model.md` to cover ticket types but the proving command checks only `idea|parent_id|discovered_from|set-tags` — not the gate-exemption posture per type."],"finding":"The gate-exemption type vocabulary referenced in the cascade gate-interaction paragraph (\"only `bug`/`session_log` are [gate-exempt]\") is a closed decision-rule enum that the plan folds into `docs/concurrency.md` I4a, but the plan does not specify that this enum be co-located with or cross-referenced from a schema/table that enumerates all ticket types and their gate posture. After the move, the authoritative type-exemption list will appear only in the folded prose in concurrency.md with no link to `docs/ticket-model.md`'s type coverage.","group_criteria":null,"group_id":null,"id":"f4f0e60adc56dcf4a","impact":0.0,"is_primary":null,"location":"De-risking results — 'Parent-first cascade: NOT new content' paragraph; CLAUDE.md lines 460-466 (gate-interaction paragraph being moved).","norm_id":"n8c4984bce72aee5f","priority":0.0,"reason":"veto:absence-refuted","scenarios":["An executor reading concurrency.md sees 'only bug/session_log are gate-exempt' with no cross-reference to where the full type list and exemption posture live, creating a maintenance trap where adding a new ticket type requires updating an undiscoverable location.","A future agent reasoning about which ticket types are gate-exempt cannot find the canonical table from docs/ticket-model.md (which covers types) without reading concurrency.md."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Correct the plan's premise: `docs/user-guide.md` does NOT currently have a Session-logs section — replace 'retains the capture helper' with 'gains a new Session-logs section covering the capture helper + auto-rotation', and add a corresponding proving command to the AC.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Search of docs/user-guide.md for 'session' returns zero matches.","Search of docs/user-guide.md for 'Session log' returns zero matches.","The plan's premise 'its Session-logs section already exists' is factually incorrect — the section does not exist in user-guide.md.","The revised AC for this deliverable has no proving command, so there is no fallback verification if this content is missing."],"finding":"The plan states that `user-guide.md` 'retains the capture helper + auto-rotation' for session logs (implying it already exists there), but the document currently contains zero session-log content. The plan treats this as a retention/preservation task, yet the executor must actually CREATE this content — a mismatch between the plan's framing and the real work required, with no fallback or AC proving command if the content does not yet exist.","group_criteria":null,"group_id":null,"id":"f404878cc589538b6","impact":0.0,"is_primary":null,"location":"De-risking results — 'Session logs: split, don't lump' paragraph: 'keep the capture helper + auto-rotation in `docs/user-guide.md` (its Session-logs section already exists)'.","norm_id":"n7deb2b2eefd58818","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":["An executor reads 'retains the capture helper' and interprets this as 'the content is already there; nothing to do for user-guide.md' — and skips creating it.","Even if the executor creates the section, there is no AC proving command to verify it was created correctly."],"severity":"none","suggested_fix":"Proving: `rg -n 'session-log\\|append_session_log\\|auto-rotation' docs/user-guide.md`","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"no","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"5fb00386db809d31","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":218.4,"llm_calls":28,"llm_ms":516827.9,"total_ms":517144.3,"verify_requests":23},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"073d-51d8-3e58-4b14","ticket_type":"story","verdict":"BLOCK","verified_at_sha":"ba2fb1dd4fd2cfb3c464cecbb17b66854f446a8b"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784234049814197001,"uuid":"bc1515ea-12dc-4b32-9f61-dfe55eee0c64"}