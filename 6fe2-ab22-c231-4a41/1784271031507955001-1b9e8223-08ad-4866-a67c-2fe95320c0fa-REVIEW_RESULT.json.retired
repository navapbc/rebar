{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","author_sig":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","data":{"coaching":[{"coaching":"Plan how documentation update verification step will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f7b9b97445a19f784","f6817b32823f6114d","fbaa03b76edf29805","ffe0f9e1a01ba96fe","f9b66ad60f414048e","f34f82fd2d27f190f"],"move_id":"9","move_name":"plan the verification","subject":"documentation update verification step"},{"coaching":"Pin down TypeError enforcement at internal creation seam with a concrete worked example.","decision":"advisory","finding_refs":["f3204aad288c0f55d"],"move_id":"6","move_name":"specification by example","subject":"TypeError enforcement at internal creation seam"},{"coaching":"Pin down legacy CREATE provisional reduction to unknown with a concrete worked example.","decision":"advisory","finding_refs":["feab94ae86596d0a0"],"move_id":"6","move_name":"specification by example","subject":"legacy CREATE provisional reduction to unknown"},{"coaching":"Plan how acceptance criteria completeness and provability will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f607dd457c67f9209"],"move_id":"9","move_name":"plan the verification","subject":"acceptance criteria completeness and provability"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":9,"blocking":0,"dropped":22,"indeterminate":0},"det":{"P1":{"ac_items":7,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","ran":true,"references":0,"resolved":0,"status":"pass"},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":7,"blocking":false,"desc_chars":7641,"file_impact":15,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":7,"blocking":false,"name":"ac-quality","ran":true,"status":"fail","verify_commands_linted":4,"verify_lint_abstained":4},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":1924,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":15,"name":"file-impact-coverage","ran":true,"status":"pass"}},"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":211.9,"llm_calls":30,"llm_ms":687203.5,"total_ms":687571.7,"verify_requests":25},"remediation":{"baseline":"signature","eligible":false,"reasons":{"code_unchanged":false,"plan_changed":true,"prior_sidecar":true,"registry_unchanged":true,"signed":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","F4","G5","T2","T4","T5b","T5d","T5e","T6","T7","T9","hedge","project.portability"]}},"findings":[{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add an acceptance criterion (or extend AC6) with a concrete check — e.g. `grep -q 'creation_channel' docs/event-schema.md docs/output-schemas.md` — that verifies the six-value enum and inference marker are documented in both files.","cohort":["E2","E6","F1"],"criteria":["E6","F1"],"decision":"advisory","drop_reason":null,"evidence":["Files section lists docs/event-schema.md and docs/output-schemas.md","ABSENCE: no AC references these files or includes a grep/diff/lint command to verify their content was updated"],"finding":"Documentation updates to docs/event-schema.md and docs/output-schemas.md are listed in the Files section as in-scope deliverables, but no acceptance criterion includes a proving command or observable check that these files were actually updated. An executor could skip the doc changes and all ACs would still pass.","group_criteria":null,"group_id":null,"id":"f7b9b97445a19f784","impact":0.55,"is_primary":null,"location":"Files section: 'docs/event-schema.md and docs/output-schemas.md: local channel contract'","norm_id":"na2e6cd3d846b9e56","priority":0.55,"reason":"default-advisory","scenarios":["Executor ships all code changes and passing tests but omits doc updates; all ACs are green and the story is closed, leaving the public-facing channel contract undocumented."],"severity":"major","suggested_fix":"Append to AC6: 'Prove docs are updated: `grep -qE \"cli|mcp|python|jira|import|unknown\" docs/event-schema.md docs/output-schemas.md`' — exits non-zero if any file is missing the enum vocabulary.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an AC (or extend AC6) that verifies docs/event-schema.md and docs/output-schemas.md expose the six-value enum and true-only inference marker — e.g. a doc-lint or grep-based check confirming the vocabulary is present.","cohort":["COH","E1","T5d"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["Files section states: 'docs/event-schema.md and docs/output-schemas.md: local channel contract.'","ABSENCE: No AC references these files, runs a doc-lint check, or asserts that the six-value enum and inference-marker contract appear in the docs.","All seven ACs reference only pytest invocations and python -m rebar.schemas.gen_types --check; none verify documentation content."],"finding":"The plan explicitly lists docs/event-schema.md and docs/output-schemas.md as file deliverables under Files, but no Acceptance Criterion verifies that these documentation files were updated. This is an uncovered deliverable with no observable done-definition.","group_criteria":null,"group_id":null,"id":"f6817b32823f6114d","impact":0.55,"is_primary":null,"location":"Files section: 'docs/event-schema.md and docs/output-schemas.md: local channel contract.' / Acceptance Criteria (all 7 ACs)","norm_id":"n2b609c2ea117ff60","priority":0.55,"reason":"default-advisory","scenarios":["Implementer updates code but omits or partially updates docs; no AC catches the omission and the story closes with stale documentation.","A downstream consumer reads the docs to understand the channel contract and finds the schema description missing or incorrect."],"severity":"major","suggested_fix":"Extend AC6: append 'and grep -E \"cli|mcp|python|jira|import|unknown\" docs/event-schema.md docs/output-schemas.md exits 0' or add a dedicated prose-lint step that fails if the channel enum definition is absent from the docs.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The Files section lists docs/event-schema.md and docs/output-schemas.md as deliverables, but no acceptance criterion verifies that the documentation was updated with the local channel contract.","group_criteria":null,"group_id":null,"id":"fbaa03b76edf29805","impact":0.55,"is_primary":null,"location":"Files section (docs/event-schema.md and docs/output-schemas.md) vs Acceptance Criteria (all 7 ACs)","norm_id":"nc114e1955ff82728","priority":0.55,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"Extend AC6 to include: 'docs/event-schema.md and docs/output-schemas.md document creation_channel (cli|mcp|python|jira|import|unknown) and creation_channel_inferred (Literal[true]). Verify by grep or doc-test.'","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E3"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The docs update for event-schema.md and output-schemas.md is listed in the Files section but no AC includes a validation step that confirms the documentation correctly reflects the six-value enum and the immutability contract — the AC6 proof (pytest + gen_types --check) validates code artifacts only.","group_criteria":null,"group_id":null,"id":"ffe0f9e1a01ba96fe","impact":0.55,"is_primary":null,"location":"Files section (docs/event-schema.md, docs/output-schemas.md) and AC6","norm_id":"nb1df435daed61b67","priority":0.55,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"Add a small pytest test in tests/interfaces/contracts/ (e.g., test_docs_creation_channel.py) that reads docs/event-schema.md and docs/output-schemas.md and asserts each of the six enum values (cli, mcp, python, jira, import, unknown) and the immutable-field guard are present; reference it in AC6's proof command.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The plan lists `docs/event-schema.md` and `docs/output-schemas.md` in the Files section as deliverables, but no AC requires verifying that those docs were updated. An agent could skip the documentation updates and all ACs would still pass.","group_criteria":null,"group_id":null,"id":"f9b66ad60f414048e","impact":0.55,"is_primary":null,"location":"Files section and Acceptance Criteria (all ACs)","norm_id":"n013e5b1570094135","priority":0.55,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"AC6 claims 'docs expose the same six-value enum' as part of its done definition, but the proof command (`uv run pytest ... && python -m rebar.schemas.gen_types --check`) contains no step that verifies docs/event-schema.md or docs/output-schemas.md content. An implementer could skip the documentation update entirely and still pass all listed AC6 checks.","group_criteria":null,"group_id":null,"id":"f34f82fd2d27f190f","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — AC6 proof command; Files — docs/event-schema.md and docs/output-schemas.md","norm_id":"n10761269811c78f2","priority":0.55,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"Add a small contract test or shell assertion — e.g., `python -c \"import pathlib; doc=pathlib.Path('docs/event-schema.md').read_text(); [assert v in doc for v in ('cli','mcp','python','jira','import','unknown')]\"` — appended to the AC6 proof command, or extract it into tests/interfaces/contracts/test_schema_coverage.py which is already in the proof list.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":null,"blocking_enabled":null,"checklist_item":"","cohort":null,"criteria":["P6"],"decision":"advisory","drop_reason":null,"evidence":["6 criterion line(s) bundle multiple deliverables with 'and' (split so each is independently verifiable)."],"finding":"Acceptance-criteria / definition-of-done quality issues.","group_criteria":null,"group_id":null,"id":"f607dd457c67f9209","impact":0.4,"is_primary":null,"location":"","norm_id":"ned06ebc801a522e3","priority":0.4,"reason":null,"scenarios":[],"severity":"minor","suggested_fix":"Split compound criteria, replace subjective terms with observable outcomes, and state how each is verified.","tier":"DET","validity":1.0,"verification":null},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a test case (in test_creation_channel.py or a contract test) that calls composer.create_core without creation_channel and asserts TypeError is raised, covering the 'no default enforces attribution' guarantee from the What section.","cohort":["COH","E1","T5d"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["What section: 'make composer.create_core require an internal keyword-only creation_channel with no default, so omission raises TypeError at the internal seam, and validate it before writing.'","ABSENCE: No AC includes a test asserting that calling create_core without creation_channel raises TypeError.","AC4 covers rejection of invalid enum values, but not the missing-argument case."],"finding":"The plan body explicitly promises that omitting creation_channel from a create_core call raises TypeError ('so omission raises TypeError at the internal seam'), but no AC verifies this enforcement. If a future caller is added without the keyword argument, the guarantee is untested.","group_criteria":null,"group_id":null,"id":"f3204aad288c0f55d","impact":0.44,"is_primary":null,"location":"What section: 'make composer.create_core require an internal keyword-only creation_channel with no default, so omission raises TypeError at the internal seam' / Acceptance Criteria (all 7 ACs)","norm_id":"n5f9e35d8c0de32d1","priority":0.2514,"reason":"default-advisory","scenarios":["A future internal caller (e.g. a new automation script) invokes create_core without the keyword; the TypeError guarantee is the safety net but it has never been tested and could be silently removed during a refactor.","The keyword-only constraint is accidentally dropped when the signature is refactored; existing callers all pass it explicitly so no existing test fails."],"severity":"minor","suggested_fix":"Add to test_creation_channel.py: `def test_create_core_requires_creation_channel(): with pytest.raises(TypeError): composer.create_core(title='x', ...)  # omit creation_channel`","tier":"LLM","validity":0.5714,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add a `process_snapshot` migration guard (analogous to the `managed_refs` / `attestations` guards) that sets `state['creation_channel'] = 'unknown'` when `'creation_channel'` is absent from `compiled_state`, so SNAPSHOT-tipped legacy tickets project the correct provisional value.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["Plan: 'A legacy CREATE with no value provisionally reduces to creation_channel=unknown without creation_channel_inferred, remaining eligible for e622 inference.'","process_snapshot (lines 744-793): every additive field needing a legacy default has an explicit 'if X not in compiled_state' guard (managed_refs L763, attestations L772, keyring L791). No such guard is specified for creation_channel.","Plan: 'Child e622 treats absent/None/unknown-without-marker as unresolved legacy input so positive Jira inference can replace this provisional fallback.' — This requires the value to be 'unknown', not absent/None."],"finding":"The plan states that a legacy CREATE with no creation_channel value 'provisionally reduces to creation_channel=unknown', but omits the process_snapshot migration guard required to deliver this for compacted (SNAPSHOT-tipped) tickets. Every prior additive field with a legacy-default behavior has an explicit 'if X not in compiled_state' guard in process_snapshot (managed_refs, attestations, keyring). Without an analogous guard here, a ticket whose most-recent SNAPSHOT predates this feature will restore with creation_channel absent/None from make_initial_state — not 'unknown' — breaking the e622 inference contract that treats 'absent/None/unknown-without-marker as unresolved legacy input'.","group_criteria":null,"group_id":null,"id":"feab94ae86596d0a0","impact":0.0,"is_primary":null,"location":"What section / reducer/_processors.py process_snapshot / Acceptance Criteria AC4","norm_id":"nf55fb3bb8d2cbc9c","priority":0.0,"reason":"default-advisory","scenarios":["A ticket last compacted before this story ships: process_snapshot restores compiled_state (no creation_channel key), leaves make_initial_state seed (None or absent). Downstream e622 inference treats None the same as unknown per the plan — but the plan's AC4 test 'Prove with -k invalid or legacy' may not exercise the SNAPSHOT-restore path, masking the gap.","The compactor runs after this story ships, writing creation_channel=unknown into the SNAPSHOT; future replays are then correct. But tickets NOT re-compacted stay broken until e622 or the next compaction."],"severity":"none","suggested_fix":"In process_snapshot, add: `if 'creation_channel' not in compiled_state: state['creation_channel'] = 'unknown'` (without setting creation_channel_inferred, preserving the e622 eligibility marker contract).","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"medium","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Explicitly specify in the What/Files section whether `gen_types.py --check` mode must be implemented as part of this story (and what it checks: that the generated types.py is up-to-date with the schema), or replace the proving command with a deterministic alternative such as `python -m rebar.schemas.gen_types && git diff --exit-code src/rebar/types.py`.","cohort":["E2","E6","F1"],"criteria":["E6","F1"],"decision":"dropped","drop_reason":null,"evidence":["AC6 proving command: 'python -m rebar.schemas.gen_types --check'","What section: 'Extend src/rebar/schemas/gen_types.py so JSON Schema {\"const\": true} generates Literal[True], then regenerate src/rebar/types.py'","Files section: 'src/rebar/schemas/gen_types.py: render JSON Schema const values as Literal[...] before generated-type checks'","ABSENCE: no mention of implementing or specifying a --check flag in gen_types.py anywhere in the plan"],"finding":"The proving command `python -m rebar.schemas.gen_types --check` in AC6 assumes a `--check` mode exists or will be implemented, but the What/Files sections only say 'Extend gen_types.py so JSON Schema {\"const\": true} generates Literal[True]' — no `--check` flag implementation is mentioned anywhere in the plan. If the flag does not exist, the AC6 proving command silently fails or errors, leaving the const-rendering claim unverifiable.","group_criteria":null,"group_id":null,"id":"fbe544bc7ea772e5d","impact":0.0,"is_primary":null,"location":"Acceptance Criteria, AC6: '...python -m rebar.schemas.gen_types --check'","norm_id":"nf71f577d2136bb67","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":["Agent implements the const→Literal[True] logic but `--check` flag does not exist, so `python -m rebar.schemas.gen_types --check` exits with an unrecognised-argument error — AC6 cannot be proven green.","Alternatively, the flag exists but was added by a prior story and is undocumented here; the executor cannot tell and may re-implement it incorrectly."],"severity":"none","suggested_fix":"Replace `python -m rebar.schemas.gen_types --check` in AC6 with `python -m rebar.schemas.gen_types && git diff --exit-code src/rebar/types.py` (exits non-zero if the regenerated file differs from the committed one), which proves both that generation succeeds and that the committed types.py is in sync — without requiring a new CLI flag.","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"no","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add an explicit statement in the What section (or the identity.py file bullet) clarifying that `identity_cli` passes `cli` to BOTH `create_identity_core` and `ensure_identity_for` when it invokes them, and add an AC1 test case (or -k cli fixture) that exercises the ensure_identity_for CLI code path.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"dropped","drop_reason":null,"evidence":["'identity_cli passes cli' is stated for the identity creation path","'ensure_identity_for' gets creation_channel=\"python\" as default","ABSENCE: no explicit statement that identity_cli overrides ensure_identity_for's default to cli when calling it from the CLI boundary"],"finding":"The plan says 'identity_cli passes cli' for `create_identity_core` and that `ensure_identity_for` receives `creation_channel=\"python\"` as default, but it does not explicitly state whether `identity_cli` also passes `cli` to `ensure_identity_for` when it invokes it. AC1 claims 'identity creation persist creation_channel=cli' for CLI, yet `ensure_identity_for` may be the actual writer in some CLI flows, so without an explicit call-site decision the executor may leave a CLI-triggered `ensure_identity_for` call with the default `python` value.","group_criteria":null,"group_id":null,"id":"f378e793101399e00","impact":0.33,"is_primary":null,"location":"What section: 'Add creation_channel=\"python\" keyword parameters to create_identity_core and ensure_identity_for. Local library callers use that default; identity_cli passes cli.'","norm_id":"nd0a40f86c6f7b863","priority":0.0825,"reason":"veto:absence-refuted","scenarios":["Executor sets default=python on ensure_identity_for, wires identity_cli → create_identity_core(cli) correctly, but forgets to override ensure_identity_for(cli) in the CLI path. AC1's -k cli test could still pass if the test only exercises the create_identity_core path, leaving the ensure_identity_for CLI path silently tagged python."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add an explicit rollback/back-out plan for the `create_core` signature tightening — either describe an expand-contract sequence (temporarily add a default that warns, then remove it in a follow-up) or document the revert commit strategy if a caller is missed.","cohort":["T2","T4","T7"],"criteria":["T4"],"decision":"dropped","drop_reason":null,"evidence":["'make composer.create_core require an internal keyword-only creation_channel with no default, so omission raises TypeError at the internal seam'","'Every existing caller is updated in this story'","No rollback/back-out plan or expand-contract sequence (e.g., add with a default first, then tighten in a follow-up) is described anywhere in the plan"],"finding":"The plan makes `create_core`'s `creation_channel` a mandatory keyword-only parameter (no default), which is a breaking change at the internal seam for every existing caller. The plan acknowledges this and says 'Every existing caller is updated in this story,' but provides no explicit rollback or back-out path if a caller is missed or the migration is partially deployed. Relying solely on regression tests (which execute after the fact) is not a reversibility mechanism.","group_criteria":null,"group_id":null,"id":"fc0328de54cf69687","impact":0.0,"is_primary":null,"location":"What section — 'Make composer.create_core require an internal keyword-only creation_channel with no default'; Files section: src/rebar/_commands/composer.py, src/rebar/_lib_writes.py, src/rebar/_mcp_writes.py, etc.","norm_id":"n9a35c3b02aa2f6cd","priority":0.0,"reason":"low-validity","scenarios":["A caller file is overlooked during the update sweep — it silently fails at runtime with TypeError only when that code path is exercised","Partial deployment (e.g., composer.py updated but _lib_writes.py not yet landed) causes breakage with no safe revert path"],"severity":"none","suggested_fix":"Use an expand-contract sequence: in this story, add `creation_channel` with a default of `'unknown'` plus a deprecation warning; assert all callers are updated and tests pass; then remove the default in a fast-follow commit. This gives a safe rollback point between the two steps.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"medium","reversibility":"moderate","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an ADR or CLAUDE.md section capturing the three novel decisions: (1) explicit boundary threading for channel provenance (vs. stack inspection/context), (2) _IMMUTABLE_EDIT_FIELDS as the extension point for audit-immutable CREATE fields, and (3) const→Literal generation convention in gen_types.py.","cohort":["T5b","T5e","T9"],"criteria":["T5e"],"decision":"dropped","drop_reason":null,"evidence":["'Explicit boundary threading is chosen because the interface knows the channel and the shared core does not.'","'Define _IMMUTABLE_EDIT_FIELDS = frozenset({\"creation_channel\", \"creation_channel_inferred\"}) in reducer/_processors.py'","'Extend src/rebar/schemas/gen_types.py so JSON Schema {\"const\": true} generates Literal[True]'","Files list includes docs/event-schema.md and docs/output-schemas.md but no ADR or CLAUDE.md update"],"finding":"Three novel architectural decisions — explicit boundary threading for channel provenance, the _IMMUTABLE_EDIT_FIELDS immutability pattern, and the JSON Schema const→Literal[True] generation convention — are described only in the plan's 'Approach Rationale' section and will not be persisted in a durable design record (ADR, CLAUDE.md, or equivalent). Future contributors modifying the reducer, schema generator, or adding a new interface will have no authoritative record of why these patterns exist.","group_criteria":null,"group_id":null,"id":"f4f13303321e16d25","impact":0.0,"is_primary":null,"location":"Approach Rationale section; Files list (docs/event-schema.md, docs/output-schemas.md only)","norm_id":"n10c8960199a3149e","priority":0.0,"reason":"low-validity","scenarios":["A developer adds a new interface and wonders why they must pass creation_channel explicitly rather than reading it from context — no ADR explains the rationale.","A developer modifying the schema generator encounters const→Literal and doesn't know this was an intentional convention established here.","A future story attempts to make _IMMUTABLE_EDIT_FIELDS mutable without realising the audit-immutability contract depends on it."],"severity":"none","suggested_fix":"Add a short ADR (e.g., docs/adr/0001-creation-channel-provenance.md) or a CLAUDE.md 'Design Decisions' section covering these three points and link it from the Files list.","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Document (in the ADR or CLAUDE.md) the extension procedure for adding a new channel value: which artifact is the source-of-truth (schema), how to regenerate types.py, and that validate_creation_channel must be updated in the same commit; optionally, derive the validator's vocabulary directly from the schema at import time to eliminate the redundant hand-maintained list.","cohort":["T5b","T5e","T9"],"criteria":["T5e"],"decision":"dropped","drop_reason":null,"evidence":["'Add the canonical creation-channel enum to src/rebar/schemas/common.schema.json with exactly cli, mcp, python, jira, import, unknown.'","'Add the matching runtime constant plus validate_creation_channel(...) helper to src/rebar/reducer/_version.py and a contract test that prevents runtime/schema vocabulary drift.'","types.py is a generated artifact but the validator in _version.py is hand-maintained; a future engineer could update the schema without updating the validator (or vice versa) before the contract test is run."],"finding":"The six-value closed enum (cli, mcp, python, jira, import, unknown) is encoded redundantly in at least three artifacts — common.schema.json, the validate_creation_channel helper in reducer/_version.py, and regenerated types.py — with no single authoritative source-of-truth and no documented procedure for adding a new channel value. The plan marks the enum 'closed' but does not document how to extend it, making future additions error-prone (silent divergence between schema, validator, and generated types is possible if one artifact is updated and the others are not).","group_criteria":null,"group_id":null,"id":"f4684100423d2b049","impact":0.0,"is_primary":null,"location":"What section; src/rebar/schemas/common.schema.json; src/rebar/reducer/_version.py; src/rebar/types.py","norm_id":"n0c1208d711cb0206","priority":0.0,"reason":"low-validity","scenarios":["Story e622 (Jira/import) needs to add 'jira' as an active channel in the validator — the developer updates _version.py but forgets to regenerate types.py, and the contract test only runs in CI, causing a late failure.","A 'webhook' channel is added in common.schema.json but the validate_creation_channel guard in _version.py is not updated, silently accepting or rejecting it inconsistently."],"severity":"none","suggested_fix":"In reducer/_version.py, load the valid channel values from the parsed common.schema.json at module init (e.g., via importlib.resources) rather than maintaining a duplicate list, so the schema is the single source of truth and schema/validator drift becomes impossible.","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an explicit test case to test_creation_channel.py (under the `invalid` marker) that passes None and a non-string value (e.g., an integer) to validate_creation_channel and asserts the expected error type/message.","cohort":["E5","F4","G5"],"criteria":["E5"],"decision":"dropped","drop_reason":null,"evidence":["AC 4 says 'New local writers reject unknown or values outside the closed enum' and tests with -k 'invalid or legacy'","The plan specifies validate_creation_channel raises on unknown/off-vocabulary strings but does not address non-string inputs (None, int, etc.)","ABSENCE: no AC test key targets type-invalid inputs to the validator"],"finding":"The new validate_creation_channel helper's behavior for non-string/None inputs (e.g., passing an integer or None as creation_channel) is not covered by any AC test assertion; the ACs only prove rejection of off-vocabulary string values, leaving the type-error branch of the validator implicitly unspecified.","group_criteria":null,"group_id":null,"id":"ff0568947390584e3","impact":0.0,"is_primary":null,"location":"AC 4 / src/rebar/reducer/_version.py (validate_creation_channel)","norm_id":"nbb2bed7ab9bea3a1","priority":0.0,"reason":"low-validity","scenarios":["A caller accidentally passes creation_channel=None (e.g. from an optional config value) — the validator's behavior is unspecified in tests, potentially silently coercing or raising an unhelpful error","A future caller passes an integer channel code — the closed-enum guard may or may not catch it depending on implementation"],"severity":"none","suggested_fix":"Extend the -k invalid AC or add a direct unit test: `pytest.raises(TypeError/ValueError, match=...)` for `validate_creation_channel(None)` and `validate_creation_channel(42)` in the schema-contract test suite, and document the expected exception type in the helper's docstring.","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"insufficient","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Confirm `validate_creation_channel` warrants extraction to `reducer/_version.py` (only one call site in `create_core`); either add a second direct call site (e.g., the e622 inbound seam imports it directly) or document why the contract-test import justifies the helper placement, or inline the check in `create_core` alongside the existing `ticket_type not in _TYPES` guard.","cohort":["A1"],"criteria":["A1"],"decision":"dropped","drop_reason":null,"evidence":["grep for `create_core(` confirms exactly 6 callers, all routed through the single `create_core` function — meaning `validate_creation_channel` itself has ONE call site","The existing vocabulary guard for ticket_type is inline in `create_core` as a direct `if ticket_type not in _TYPES` check, not extracted to a separate helper","The plan's stated reason ('a contract test that prevents runtime/schema vocabulary drift') is a testing motivation, not a reuse motivation — the test could equally import the enum constant from `_version.py` without requiring a separate validator function"],"finding":"`validate_creation_channel` helper in `reducer/_version.py` has exactly one call site (`create_core` in `composer.py`), making it a single-caller abstraction that does not meet the Rule-of-Three bar; the plan does not explain why it must live in `_version.py` rather than inline in `create_core` alongside the existing validation logic.","group_criteria":null,"group_id":null,"id":"fef49db7434605048","impact":0.0,"is_primary":null,"location":"What section: 'Add the matching runtime constant plus validate_creation_channel(...) helper to src/rebar/reducer/_version.py'","norm_id":"n4efe435226008ba6","priority":0.0,"reason":"low-validity","scenarios":["A new contributor searching for validation logic finds it split between `_version.py` (channel) and `create_core` (ticket_type, priority) without an obvious reason for the split.","If a second call site for channel validation never materializes (the Jira seam in e622 uses the same helper via `create_core`, not directly), the abstraction remains single-use indefinitely."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Confirm that `Literal[True]` (requiring a gen_types.py extension) is preferable to `NotRequired[bool]` for the `creation_channel_inferred` marker; if the only use-case is a presence-check flag, `NotRequired[bool]` requires no generator change and is equally expressive for consumers.","cohort":["A1"],"criteria":["A1"],"decision":"dropped","drop_reason":null,"evidence":["Search for `\"const\"` in schemas shows only string consts (`\"1\"`, `\"2\"`, `\"3\"`) in workflow schemas that are NOT in TOP_LEVEL_OBJECTS and thus never processed by gen_types today","gen_types.py docstring: 'Custom, dependency-free. We resolve exactly the constructs rebar's schemas use' — boolean const is a new construct not currently used","The `creation_channel_inferred` field with `{\"const\": true}` would be the sole consumer of the new code path at delivery time","An alternative: emit `NotRequired[bool]` for the optional marker — equally valid for type-checking, no generator change needed"],"finding":"The `gen_types.py` extension to render `{\"const\": true}` as `Literal[True]` serves exactly one field (`creation_channel_inferred`) across one schema (`ticket_state.schema.json`), while the existing generator explicitly scopes itself to 'exactly the constructs rebar's schemas use' — but no schema currently uses `const` with a boolean value, making this a one-consumer generator feature.","group_criteria":null,"group_id":null,"id":"f97e4224f6facce59","impact":0.0,"is_primary":null,"location":"What section: 'Extend src/rebar/schemas/gen_types.py so JSON Schema {\"const\": true} generates Literal[True]' / Files: src/rebar/schemas/gen_types.py","norm_id":"n41d7880eb1378fe7","priority":0.0,"reason":"low-validity","scenarios":["The generator gains a code path exercised by only one field; if `creation_channel_inferred` is later dropped or changed, the const-bool path becomes dead code.","A reviewer of gen_types.py must understand the const-bool path even though it has no historical precedent in the schemas."],"severity":"none","suggested_fix":"If `creation_channel_inferred` is purely a presence marker (callers check `state.get('creation_channel_inferred')`), declare it as `NotRequired[bool]` in the schema (`{\"type\": \"boolean\"}`) and skip the `const`-extension entirely — no gen_types.py change needed and the typing contract is unchanged for the single consumer.","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add `src/rebar/reducer/_state.py` to the Files section and specify that `make_initial_state` seeds `creation_channel` (and optionally `creation_channel_inferred`) so the `_IMMUTABLE_EDIT_FIELDS` guard in `process_edit` is reached rather than pre-empted by the existing 'field not in state' drop.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":["process_edit (reducer/_processors.py line 496): 'if field_name not in state: continue' — fields absent from state are dropped before any named guard runs","_state.py is not listed in the Files section despite make_initial_state being the source that seeds the initial state dict used by all processors","Plan says '_IMMUTABLE_EDIT_FIELDS = frozenset({\"creation_channel\", \"creation_channel_inferred\"}) in reducer/_processors.py; process_edit skips those names before its generic assignment' — but the existing 'not in state' guard fires first"],"finding":"reducer/_state.py (make_initial_state) is an unenumerated edit target: process_edit's existing guard 'if field_name not in state: continue' (line 496 of _processors.py) silently drops any EDIT field that is not already seeded in the initial state dict. If `creation_channel` is not seeded by `make_initial_state`, the proposed _IMMUTABLE_EDIT_FIELDS guard in process_edit is effectively dead — the 'unknown field' path already drops it before the immutability check can fire.","group_criteria":null,"group_id":null,"id":"f28a75151814d24cf","impact":0.33,"is_primary":null,"location":"Files section / src/rebar/reducer/_processors.py process_edit / What bullet on _IMMUTABLE_EDIT_FIELDS","norm_id":"n2e24be2257dd567f","priority":0.0825,"reason":"veto:absence-refuted","scenarios":["An EDIT event carrying creation_channel is received; the 'not in state' guard drops it silently because make_initial_state never seeded creation_channel; the _IMMUTABLE_EDIT_FIELDS check is never reached; the immutability contract appears to pass tests but the guard is a no-op","A future refactor removes the 'not in state' guard — the _IMMUTABLE_EDIT_FIELDS guard then becomes the only protection, but only if it was placed before the assignment block"],"severity":"minor","suggested_fix":"Either (a) seed `creation_channel: None` in make_initial_state so the field is always present in state (making _IMMUTABLE_EDIT_FIELDS the active guard), or (b) reorder process_edit so the _IMMUTABLE_EDIT_FIELDS check runs BEFORE the 'not in state' guard and document this explicitly in the plan.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a `process_snapshot` migration hunk to the plan (in reducer/_processors.py) that seeds `creation_channel='unknown'` when `creation_channel` is absent from the restored `compiled_state`, mirroring the existing `managed_refs` / `attestations` / `keyring` migrations in that function.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":["process_snapshot (reducer/_processors.py lines 744-778) restores all fields from compiled_state verbatim and does NOT replay process_create","A SNAPSHOT written before this story ships will have no creation_channel in its compiled_state; after restore, the ticket state has no creation_channel at all (not even 'unknown')","The plan says 'A legacy CREATE with no value provisionally reduces to unknown without creation_channel_inferred' — this is true for uncompacted tickets (CREATE replays) but not for compacted tickets (SNAPSHOT restore)","reducer/_processors.py is listed in Files but no process_snapshot migration hunk is mentioned for creation_channel"],"finding":"Pre-feature SNAPSHOTs (compacted tickets) will silently omit creation_channel from projected state rather than projecting 'unknown', because process_snapshot restores compiled_state verbatim and skips process_create — yet the plan's legacy-unknown projection logic relies on process_create being replayed.","group_criteria":null,"group_id":null,"id":"faf870b0af3e34513","impact":0.0,"is_primary":null,"location":"What bullet: 'A legacy CREATE with no value provisionally projects creation_channel=unknown without creation_channel_inferred' / reducer/_processors.py process_snapshot","norm_id":"n0591d3f2801a1022","priority":0.0,"reason":"veto:absence-refuted","scenarios":["A legacy ticket is compacted (SNAPSHOT written) before this story ships; after upgrade, show/list/search return a TicketState with no creation_channel field instead of creation_channel='unknown'","e622's 'eligible for Jira inference' logic checks creation_channel=unknown or absent — a compacted ticket is silently absent rather than 'unknown', potentially breaking the inference eligibility test"],"severity":"none","suggested_fix":"In process_snapshot, after restoring compiled_state, add: `if 'creation_channel' not in compiled_state: state['creation_channel'] = 'unknown'` — this mirrors the managed_refs / attestations migration pattern already present in the function.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"medium","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Confirm the plan's gen_types extension is explicitly specified: add a `const` branch in `_pytype` BEFORE the `jtype is None` fallthrough that emits `Literal[<value>]` when a node has a `const` key, then verify `python -m rebar.schemas.gen_types --check` enforces `Literal[True]` for the marker field.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":["_pytype method (gen_types.py lines 115-149): handles '$ref', 'enum', isinstance(jtype, list), jtype=='array', jtype=='object', jtype is None, and scalar — no branch for 'const'","A node with only `{\"const\": true}` has no 'type' and no 'enum' key; jtype is None; the method emits 'Any' instead of 'Literal[True]'","Plan explicitly says 'Extend src/rebar/schemas/gen_types.py so JSON Schema {\"const\": true} generates Literal[True]' — confirming the current generator lacks this"],"finding":"The gen_types.py _pytype method has no handling for the JSON Schema `const` keyword; the plan adds `{\"const\": true}` for creation_channel_inferred but the generator currently only handles `$ref`, `enum`, `type` (list/scalar/array/object), and None — a `const`-only node falls through to the None branch and emits `Any` instead of `Literal[True]`.","group_criteria":null,"group_id":null,"id":"f5a4fd5c7658ffc89","impact":0.0,"is_primary":null,"location":"What bullet: 'Extend src/rebar/schemas/gen_types.py so JSON Schema {\"const\": true} generates Literal[True]' / src/rebar/schemas/gen_types.py _pytype method","norm_id":"n7214651aa3d9c301","priority":0.0,"reason":"low-validity","scenarios":["gen_types is run after schema changes; creation_channel_inferred: NotRequired[Any] is emitted instead of NotRequired[Literal[True]]; the --check drift gate passes with wrong types","AC6 ('gen_types renders const true as Literal[True]') fails because the implementation was not added"],"severity":"none","suggested_fix":"In _pytype, before the `jtype = node.get('type')` block, add: `if 'const' in node: self._used_typing.add('Literal'); return f'Literal[{node[\"const\"]!r}]'`","tier":"LLM","validity":0.4286,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Justify why `{\"const\": true}` is chosen over `{\"enum\": [true]}` for the `creation_channel_inferred` marker field, or switch to `{\"enum\": [true]}` to avoid adding a new gen_types code path when the existing `enum` branch already produces `Literal[True]` with zero changes.","cohort":["T1"],"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":["Plan states: 'Extend src/rebar/schemas/gen_types.py so JSON Schema {\"const\": true} generates Literal[True]'","gen_types.py _pytype() already has: `if \"enum\" in node: ... return \"Literal[\" + ... + \"]\"` (line 119–121)","gen_types.py _def_pytype() also handles enum defs: `if \"enum\" in node: self._used_defs.add(def_name); return _camel(def_name)` (lines 96–98), emitting Literal aliases","JSON Schema draft 2020-12 {\"enum\": [true]} is semantically equivalent to {\"const\": true} for the boolean-flag use case, and would flow through the existing enum branch unchanged","No existing schema in the repo uses {\"const\": <non-string>} — the only const usages are string version discriminators (workflow.v1/v2/v3.schema.json), not handled by gen_types at all"],"finding":"The plan introduces a new gen_types.py code path to render JSON Schema {\"const\": true} as Literal[True], but the existing generator already renders {\"enum\": [...]} as Literal[...] via its _pytype `enum` branch. Using {\"enum\": [true]} for the creation_channel_inferred marker field would produce identical Literal[True] output with zero generator changes, making the proposed const-handling extension unnecessary and its correctness unverified.","group_criteria":null,"group_id":null,"id":"f3c46953edca25f6a","impact":0.0,"is_primary":null,"location":"What section / Files: src/rebar/schemas/gen_types.py; plan phrase 'Extend src/rebar/schemas/gen_types.py so JSON Schema {\"const\": true} generates Literal[True]'","norm_id":"n3517043aa5a62468","priority":0.0,"reason":"low-validity","scenarios":["A bug in the new const-handling branch (e.g. handling const: false, const: null, or const: 0 unexpectedly) could silently corrupt generated types for future schemas that use const for other purposes.","If {\"const\": true} is also used in future schemas for non-boolean sentinels, the codegen branch must be revisited again, creating maintenance debt that {\"enum\": [true]} avoids entirely."],"severity":"none","suggested_fix":"In ticket_state.schema.json, declare creation_channel_inferred as `{\"enum\": [true]}` instead of `{\"const\": true}`. The existing _pytype enum branch in gen_types.py already renders this as `Literal[True]` (a single-element enum). No gen_types changes are needed, the CI drift gate stays green, and the schema vocabulary remains consistent with the existing enum-first approach throughout common.schema.json.","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Amend the Approach Rationale to explicitly acknowledge that `contextvars` is already used for analogous cross-cutting attribution in this codebase (e.g. `PROXY_IDENTITY`, `_batch_sink`) and state why explicit keyword threading is preferred over that pattern for `creation_channel` (e.g. testability, avoids implicit MCP-context coupling, consistent with the `source_*` precedent).","cohort":["T1"],"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":["Plan says: 'Thread the value explicitly rather than inspecting the call stack or introducing global context.'","src/rebar/_mcp_auth.py line 62: `PROXY_IDENTITY: contextvars.ContextVar[str | None] = contextvars.ContextVar(...)` — already threads MCP-boundary identity implicitly","src/rebar/_commands/_seam.py line 40: `_batch_sink: contextvars.ContextVar[...] = contextvars.ContextVar(...)` — already threads import-batch context implicitly across the append_event seam","ABSENCE: the Approach Rationale section does not mention or dismiss the in-repo contextvars pattern, only generic 'stack inspection or context-local state'"],"finding":"The plan's architecture section dismisses context-local state as an alternative without acknowledging that Python's contextvars — already used in this codebase for analogous cross-cutting attribution (MCP proxy identity in _mcp_auth.py, batch sink in _commands/_seam.py, gate session in llm/config.py) — represents established prior art that could thread creation_channel implicitly through the MCP request context without modifying every internal call site.","group_criteria":null,"group_id":null,"id":"fb50cf3e4ef2631eb","impact":0.0,"is_primary":null,"location":"Approach Rationale section: 'Explicit boundary threading is chosen because the interface knows the channel and the shared core does not. It is simpler and more testable than stack inspection or context-local state'","norm_id":"nd278d06cdc89c9e5","priority":0.0,"reason":"low-validity","scenarios":["A reviewer or future maintainer may not realize why explicit threading was chosen over the established in-repo contextvars pattern (PROXY_IDENTITY), creating confusion when the next cross-cutting attribute is added.","If the explicit-threading approach is later found inconvenient (e.g. a third-party library calling create_core without threading the channel), the plan provides no migration path — whereas a contextvars fallback would provide one."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.4286,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a rollback-state note to the plan asserting that (1) already-written CREATE events and SNAPSHOTs with `creation_channel` are silently ignored by a rolled-back reducer via the existing `process_create` present-only pattern and `additionalProperties:true`, and (2) if the schema changes are reverted, any consumer relying on `ticket_state.schema.json` validation will need to be made aware that the field may still appear in persisted state.","cohort":["T11"],"criteria":["T11"],"decision":"dropped","drop_reason":null,"evidence":["Plan states: 'SNAPSHOT durability … OUT of scope here'","process_snapshot (reducer/_processors.py line 744-748) restores ALL compiled_state keys verbatim: 'for key, value in compiled_state.items(): state[key] = value' — a SNAPSHOT written after this story with creation_channel in compiled_state would silently populate state[\"creation_channel\"] in a rolled-back reducer that doesn't know the field","The plan never explicitly asserts that rolled-back code correctly ignores or handles already-persisted creation_channel keys in CREATE events and SNAPSHOTs — the rubric requires asserting the schema STATE AFTER rollback, not merely that rollback exits 0","additionalProperties:true on ticket_state.schema.json provides passive forward-compat but the plan does not mention this as the rollback safety mechanism"],"finding":"The plan does not assert the post-rollback schema/storage state after creation_channel events and SNAPSHOTs have been written, leaving it ambiguous whether a rollback leaves the store in a consistent and fully-operable state.","group_criteria":null,"group_id":null,"id":"f2b35d148231ec7e9","impact":0.0,"is_primary":null,"location":"Scope section ('SNAPSHOT durability is OUT of scope') and What section ('Store creation_channel in CREATE.data')","norm_id":"nac4f9c7e4b920575","priority":0.0,"reason":"low-validity","scenarios":["Story is deployed, some tickets are created with creation_channel in their CREATE events, compaction runs producing SNAPSHOTs with creation_channel in compiled_state, then the story is rolled back — the old reducer silently carries the field but no validation or consumer contract covers it","A rollback that also reverts the schema changes causes the schema validator to reject existing TicketState outputs carrying creation_channel (if additionalProperties:false were ever enforced in a consumer)"],"severity":"none","suggested_fix":"Add a brief 'Rollback safety' paragraph to the Approach Rationale: 'Rolling back this story's code changes leaves already-written creation_channel keys in CREATE.data and SNAPSHOT compiled_state. The existing reducer reads CREATE.data fields present-only (the source_* pattern), so an old reducer simply never reads creation_channel — no error, no data loss. SNAPSHOT restoration (process_snapshot) carries all compiled_state keys into state verbatim; an old consumer that does not use the key is unaffected (additionalProperties:true). No event files need to be rewritten on rollback.'","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify exactly where in `gen_types.py._pytype()` the `{\"const\": true}` → `Literal[True]` branch is added (before the `jtype` check, keyed on `\"const\" in node`), and confirm it composes correctly with the `NotRequired[...]` wrapper that `_object_block` applies to optional fields.","cohort":["T3"],"criteria":["T3"],"decision":"dropped","drop_reason":null,"evidence":["gen_types.py _pytype() handles: '$ref', 'enum', list jtype, 'array', 'object', scalar types — no 'const' key is checked anywhere in the file","No existing schema uses {\"const\": true} as a property node today (verified by search)","Plan states: 'Encode the marker as {\"const\": true}; Extend gen_types.py so JSON Schema {\"const\": true} generates Literal[True]'","Current fallthrough: a node with only 'const' key and no 'type'/'enum' would hit the jtype=None branch and return 'Any', causing the --check drift-gate to silently accept Any instead of Literal[True]","Partially-verified: the integration (gen_types extension) exists conceptually but the specific const-handling surface is unimplemented and unconfirmed to work as described"],"finding":"gen_types.py currently has no handler for JSON Schema {\"const\": true} nodes — the _pytype() method will fall through to the jtype=None → Any branch, silently emitting Any instead of Literal[True] for the creation_channel_inferred marker field.","group_criteria":null,"group_id":null,"id":"fefd1249c4565facf","impact":0.0,"is_primary":null,"location":"What section: 'Extend src/rebar/schemas/gen_types.py so JSON Schema {\"const\": true} generates Literal[True]'; src/rebar/schemas/gen_types.py _pytype() method","norm_id":"ndb43366d806b1b6a","priority":0.0,"reason":"low-validity","scenarios":["The plan's AC requires 'python -m rebar.schemas.gen_types --check' to pass with Literal[True] emitted for creation_channel_inferred — this will fail silently (emit Any) unless a 'const' branch is explicitly added to _pytype()","AC line: 'gen_types renders const true as Literal[True]' — unachievable without the branch addition, which the plan names but does not specify"],"severity":"none","suggested_fix":"In _pytype(), add an early branch: `if \"const\" in node: self._used_typing.add(\"Literal\"); return f\"Literal[{node['const']!r}]\"` — placed before the jtype check so a bare {\"const\": true} node is resolved to Literal[True] rather than falling through to Any.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify in the plan exactly where in gen_types._pytype()'s dispatch chain the `{\"const\": <value>}` branch is inserted, whether it applies to all const types or only boolean True, and confirm it does not affect existing string-const workflow schemas.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["gen_types._pytype() has no `const` branch: it checks `$ref`, `enum`, `type` as list, `array`, `object`, `None` — but never `const`.","workflow.v1/v2/v3.schema.json already use `{\"const\": \"1\"}/{\"const\": \"2\"}/{\"const\": \"3\"}` string consts that _pytype() currently ignores.","Plan says only 'render JSON Schema const true as Literal[True]' — leaves open: where in the dispatch chain, and whether string consts in other schemas are affected."],"finding":"The plan requires extending gen_types._pytype() to handle JSON Schema `{\"const\": true}` → `Literal[True]`, but neither the dispatch location within the existing enum/ref/type chain nor the scope (boolean-only vs. any const value) is specified; existing workflow schemas use string consts that are currently also unhandled.","group_criteria":null,"group_id":null,"id":"f364b4f7a31f031c4","impact":0.264,"is_primary":null,"location":"What §1 ('Extend src/rebar/schemas/gen_types.py so JSON Schema {\"const\": true} generates Literal[True]'); src/rebar/schemas/gen_types.py _pytype() lines 115–149","norm_id":"nfdcc7c84d7fca65d","priority":0.066,"reason":"low-validity","scenarios":["An implementer adding a `const` branch before the `enum` check would cause `{\"const\": \"2\"}` in workflow schemas to suddenly emit `Literal['2']` instead of `Any`, silently changing generated types for unrelated schemas.","An implementer adding the branch after the `type` check would leave `{\"const\": true}` without a `type` key falling to the final `return self._scalar(jtype)` path with jtype=None → `Any`, defeating the feature."],"severity":"minor","suggested_fix":"Add a `if 'const' in node: return f'Literal[{node[\"const\"]!r}]'` branch as the FIRST check in _pytype() (before `$ref`), and note in the plan that existing workflow schemas' string consts are currently unreferenced by any TypedDict so the change has no observable effect on generated types.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Clarify in the plan whether _IMMUTABLE_EDIT_FIELDS is checked before or after the existing `if field_name not in state` guard in process_edit, and confirm the intended behavior covers both legacy (creation_channel absent) and new tickets (creation_channel present).","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Current process_edit: `if field_name not in state: continue` — already skips fields absent from state.","Plan says _IMMUTABLE_EDIT_FIELDS guard fires 'before its generic assignment' but does not address the case where creation_channel is absent from state (legacy ticket — field never initialized by process_create).","If creation_channel is absent from state on a legacy ticket, the existing `not in state` guard skips it — _IMMUTABLE_EDIT_FIELDS would never be reached for that field, making the guard appear redundant for legacy tickets but necessary only for tickets where creation_channel IS in state."],"finding":"The plan's `_IMMUTABLE_EDIT_FIELDS` guard interacts ambiguously with process_edit's existing `if field_name not in state: continue` guard: for legacy tickets where creation_channel was never set (absent from state), the existing guard already silently skips it — meaning _IMMUTABLE_EDIT_FIELDS only fires when the field IS in state, but the plan does not specify this interaction or confirm the two guards are not redundant/conflicting.","group_criteria":null,"group_id":null,"id":"ffeb3d5203883e206","impact":0.0,"is_primary":null,"location":"What §5 ('process_edit skips those names before its generic assignment'); src/rebar/reducer/_processors.py process_edit lines 485–511","norm_id":"n2a91a0a754307d53","priority":0.0,"reason":"low-validity","scenarios":["An implementer places the _IMMUTABLE_EDIT_FIELDS check AFTER the `not in state` guard — legacy tickets are already protected but a ticket with creation_channel in state is also correctly blocked.","An implementer places it BEFORE the `not in state` guard — behavior is correct but logic reads oddly, and a review may ask 'why guard a field that might not be in state at all?'","The plan's provisional `creation_channel=unknown` projection for legacy tickets means after the plan is implemented, legacy tickets DO have creation_channel in state — making _IMMUTABLE_EDIT_FIELDS the only guard for them. This transition is not called out."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Consolidate the two-part rejection rule into a single precise specification co-located with the validate_creation_channel description: `value not in VOCAB` raises (catches off-vocab), AND `value == 'unknown'` raises (catches the reserved value) for new live writes.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Plan What §2: 'validate_creation_channel(...) helper to reducer/_version.py ... every local live writer rejects unknown or off-vocabulary values'","Plan Approach Rationale: 'A closed enum keeps audit results comparable; unknown is reserved for historical compatibility and is rejected for new live writes.'","AC line 4: 'New local writers reject unknown or values outside the closed enum' — the word 'or' here is logically ambiguous: does it mean 'unknown is itself outside the closed enum' (contradicting the six-value definition) or 'unknown AND values outside the closed enum are both rejected'?"],"finding":"The plan states 'unknown is reserved for historical compatibility and is rejected for new live writes' but the six-value enum (which includes `unknown`) is the schema vocabulary that validate_creation_channel validates against — the dual-rejection rule (invalid-enum AND valid-but-reserved-unknown) is split across two plan sections and never formulated as a single implementable predicate.","group_criteria":null,"group_id":null,"id":"f2495f7d7b2c688e0","impact":0.33,"is_primary":null,"location":"What §2 ('create_core calls this helper, so every local live writer rejects unknown or off-vocabulary values'); Approach Rationale ('unknown is reserved for historical compatibility and is rejected for new live writes'); AC line 4","norm_id":"n163f0795d352a7d1","priority":0.0825,"reason":"veto:absence-refuted","scenarios":["An implementer reads the AC literally: 'reject unknown or values outside the closed enum' → implements validate_creation_channel as `if value not in ENUM: raise` which accepts 'unknown' (since it IS in the enum) — live writes with channel='unknown' succeed, defeating the guard.","An implementer reads the Approach Rationale: 'unknown is rejected for new live writes' → adds a second condition `if value == 'unknown': raise` — correct behavior but the two-condition logic is nowhere stated as the spec."],"severity":"minor","suggested_fix":"In the What §2 description of validate_creation_channel, add: 'Rejects if value is not in the six-value vocabulary OR if value == \"unknown\" (reserved for legacy projection only; never a valid new-write channel).'","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify the exact injection site for the provisional `creation_channel=unknown` fallback — e.g., 'set in process_create when data.get(\"creation_channel\") is None, so it propagates into compiled_state and any subsequent SNAPSHOT'.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["process_create does not set creation_channel at all (confirmed by reading lines 105–199).","Plan says 'projects creation_channel=unknown without creation_channel_inferred' but does not say: in process_create when data.get('creation_channel') is None? In make_initial_state? In a post-replay pass?","SNAPSHOT durability is listed as OUT of scope — but if the provisional value is only set in process_create (not persisted to SNAPSHOT), it will be absent from compiled_state in the SNAPSHOT and re-derived only on live replay."],"finding":"The plan specifies that legacy CREATEs with no channel provisionally project `creation_channel=unknown` but does not specify WHERE in the reducer pipeline this projection is injected — process_create, make_initial_state, or a post-replay normalization step — which determines whether the provisional value survives SNAPSHOT round-trips.","group_criteria":null,"group_id":null,"id":"f2a3d7644ada1f105","impact":0.33,"is_primary":null,"location":"What §5 ('A legacy CREATE with no value provisionally projects creation_channel=unknown without creation_channel_inferred'); src/rebar/reducer/_processors.py process_create lines 105–199","norm_id":"n03758429d9026c58","priority":0.0943,"reason":"veto:absence-refuted","scenarios":["If injection is in process_create (data.get → None → set 'unknown'): the value is included in compiled_state and thus in any SNAPSHOT written thereafter — correct for audit.","If injection is in make_initial_state: it pre-seeds the state before replay, but process_create would then overwrite it with None if data has no creation_channel.","The distinction matters for the e622 child story that replaces 'unknown' with inferred Jira channel: it must know whether to look at compiled_state['creation_channel'] or raw CREATE data."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E4"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"`JIRA_BIND` is named in the plan as a real existing event type whose processors must ignore `creation_channel` (both in the 'What' section and in AC5), but `JIRA_BIND` does not exist anywhere in the codebase — it is absent from `KNOWN_EVENT_TYPES` in `reducer/_version.py`, from the replay dispatch in `reducer/_replay.py`, and from every search across the repo.","group_criteria":null,"group_id":null,"id":"fde0d6dc176ed14eb","impact":0.0,"is_primary":null,"location":"What section (immutable-field guard paragraph) and AC5: 'STATUS, LINK, JIRA_BIND, plus other specialized events also cannot replace genesis provenance'","norm_id":"n7096bb46c4ee907d","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":[],"severity":"none","suggested_fix":"In the What section and AC5, replace 'STATUS, LINK, JIRA_BIND, plus other specialized events' with 'STATUS, LINK, and other non-CREATE events'. If a Jira-binding event is intended for a future story, note it explicitly as out-of-scope rather than treating it as a currently-existing type.","tier":"LLM","validity":0.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"no","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"no","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"`JIRA_BIND` is named in the plan as a real existing event type whose processor must ignore `creation_channel`, but it does not exist anywhere in the codebase — absent from `KNOWN_EVENT_TYPES`, `_processors.py`, and every event-dispatch table.","group_criteria":null,"group_id":null,"id":"f9de583775f1c9f0d","impact":0.0,"is_primary":null,"location":"What section (immutable-field guard paragraph): 'STATUS, LINK, JIRA_BIND, plus other specialized events also cannot replace genesis provenance'; AC5: 'STATUS, LINK, JIRA_BIND, plus other specialized events also cannot replace genesis provenance'","norm_id":"ncb89f89e8202f586","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":[],"severity":"none","suggested_fix":"Replace `JIRA_BIND` with the actual event types emitted by the Jira reconciler (e.g. `BRIDGE_ALERT`, or clarify that no Jira-specific event type currently exists in KNOWN_EVENT_TYPES and the guard only needs to cover EDIT/STATUS/LINK/UNLINK/etc.).","tier":"LLM","validity":0.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"no","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"no","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"apply_inbound_records.py calls rebar.ensure_identity_for() (a public library function that will acquire creation_channel='python' as its default) but is not listed in the Files section and is not updated in this story. Every Jira-originated ghost-mint between this story landing and e622 will be stamped creation_channel='python', which is factually incorrect. This is a concrete unenumerated consumer of the changed ensure_identity_for signature.","group_criteria":null,"group_id":null,"id":"f3f7e055f911b846a","impact":0.0,"is_primary":null,"location":"Files section / src/rebar/_engine/rebar_reconciler/apply_inbound_records.py line 69","norm_id":"nf69042a8279fe839","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Add a note in the Scope section explicitly naming apply_inbound_records.py as a call site that will produce incorrect attribution during the delivery window, and consider whether passing creation_channel='jira' at that one call site is safe to include in this story rather than waiting for e622.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"2a60190f7e1a92e9","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":211.9,"llm_calls":30,"llm_ms":687203.5,"total_ms":687571.7,"verify_requests":25},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"6fe2-ab22-c231-4a41","ticket_type":"story","verdict":"PASS","verified_at_sha":"89e59453cdde62ec41b0de08905a2b9bb4cad45f"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784271031507955001,"uuid":"1b9e8223-08ad-4866-a67c-2fe95320c0fa"}