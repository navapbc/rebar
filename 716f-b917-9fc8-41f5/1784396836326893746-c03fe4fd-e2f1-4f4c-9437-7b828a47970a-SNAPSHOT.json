authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"835b55fca4b63e91c95c34b503739af7cb27808050741e847d8a437b9c0569c4","event_uuid":"16e57b3f-84b6-4d49-80db-93fb3f888855","position":{"commit_sha":"06f2a73f1e00b18b1339ae67411a9bf7b04c14a0","position":"1784395807802187001-16e57b3f-84b6-4d49-80db-93fb3f888855"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"4bae7566a4bafcf8a877112d63106780ccaca60808d2317f29e6a33ae117996d","event_uuid":"c3b9a2d8-1197-4ad1-badf-45b223004345","position":{"commit_sha":"263594f5105325bfa4f31c8f9215a9fcc265ee3b","position":"1784396836326893745-c3b9a2d8-1197-4ad1-badf-45b223004345"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-214_agent","claim_remote_session":null,"claimed_session":"e1dc6410-25d7-406a-b015-01c40c9fa16a","comments":[],"created_at":1784392254555896001,"creation_channel":"cli","deps":[],"description":"## Why\n\nThe module-size soft cap (800 LOC, docs/architecture.md) has a grandfathering escape hatch: `.github/module-size-allowlist.txt` (bare-path membership) + `.github/module-size-ceilings.txt` (per-file growth ratchet), asserted in sync by tests/unit/test_module_size_contract.py and enforced by a shell gate mirrored in gerrit-verify.yaml + test.yml. 12 files are currently grandfathered over the cap. The escape hatch lets over-cap modules persist and (via ceiling bumps) keep growing.\n\n## Goal\n\nDrain the allowlist to zero by splitting each grandfathered module along a real call-graph seam (never mechanically; never creating a <100-LOC file), landing each split as its own Gerrit change on main. Then remove the allowlist/ceilings escape-hatch mechanism entirely (so no module can ever be exempted again — the 800 cap becomes absolute) and add a hard gate so the module-size limit itself cannot be changed through the normal contribution process (an admin must manually override).\n\n## Decomposition\n\nPhase 1 — one child story per grandfathered module (12), each: split on a logical seam, graduate the file off BOTH allowlist + ceilings + its architecture.md remedy row, land on main.\nPhase 2 — one child story: delete the allowlist+ceilings mechanism, replace the contract test with an absolute 'nothing over 800' test, prune the architecture.md offender table, and add the limit-lock gate.\n\n## Acceptance Criteria\n\n- [ ] .github/module-size-allowlist.txt no longer exists (or is empty) and no src/rebar/**/*.py file exceeds 800 LOC (verify: find src/rebar -name '*.py' | xargs wc -l | awk '$1>800')\n- [ ] The allowlist/ceilings mechanism (both files + the sync contract test + the shell gate's allowlist branch) is removed; CI still fails any new over-cap file\n- [ ] A hard gate blocks changing the 800 limit through the normal contribution process (admin manual override required); documented\n- [ ] Every child story landed on main via Gerrit (LLM-Review +1 AND Verified +1)","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":".github/module-size-allowlist.txt","reason":"drained to empty then removed"},{"path":".github/module-size-ceilings.txt","reason":"drained then removed"},{"path":"tests/unit/test_module_size_contract.py","reason":"replaced by absolute no-over-cap test"},{"path":"docs/architecture.md","reason":"offenders table pruned"},{"path":".github/workflows/gerrit-verify.yaml","reason":"module-size gate simplified + limit lock"},{"path":".github/workflows/test.yml","reason":"module-size gate simplified + limit lock"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[],"parent_id":null,"parent_status_uuid":"21fa06f0-2c56-4d0c-8f12-28b527fb2856","preconditions_summary":{"status":"pre-manifest"},"priority":1,"reverts":[],"status":"in_progress","tags":["module-size","tech-debt"],"ticket_id":"716f-b917-9fc8-41f5","ticket_type":"epic","title":"Drain module-size allowlist to zero, then lock the module-size limit","verify_commands":[]},"source_event_uuids":["8f056bb0-322a-4d75-8b41-a324e63976b2","b63d475c-1d7a-4df2-b2d1-7db0f63cda95","62ef5162-2042-448f-ada0-ddce2b6d7da7","21fa06f0-2c56-4d0c-8f12-28b527fb2856","16e57b3f-84b6-4d49-80db-93fb3f888855","c3b9a2d8-1197-4ad1-badf-45b223004345"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784396836326893746,"uuid":"c03fe4fd-e2f1-4f4c-9437-7b828a47970a"}