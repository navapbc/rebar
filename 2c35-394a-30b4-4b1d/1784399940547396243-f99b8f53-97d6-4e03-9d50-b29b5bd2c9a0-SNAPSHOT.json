2b285978e","position":"1784399940547396242-c127a4eb-d3dd-40ff-a3c5-d2bde9ac2870"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-214_agent","claim_remote_session":null,"claimed_session":"e1dc6410-25d7-406a-b015-01c40c9fa16a","comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Pushed Gerrit change 794 (https://rebar.solutions.navateam.com/c/rebar/+/794). Extracted the ${{ }} expression validator into new leaf src/rebar/llm/workflow/lint_expr.py (166 LOC, pure stdlib). lint_refs.py 870 -> 733 LOC, graduated off allowlist/ceilings; stale sub-floor arch.md row deleted. Verified in-session: make lint clean; module-size contract 5 passed; test_contracts+test_v2_ir+test_editor_batch 56 passed; re-export identity + __all__ + lint.py import chain OK. Awaiting LLM-Review + Verified votes before close.","timestamp":1784398791451679001}],"created_at":1784397402479007001,"creation_channel":"cli","deps":[],"description":"## Summary\nGraduate `src/rebar/llm/workflow/lint_refs.py` (currently 870 LOC, over the 800 soft cap and grandfathered on the module-size gate) off the allowlist by extracting the self-contained single-`${{ }}`-expression reference validator into a new pure-stdlib leaf `src/rebar/llm/workflow/lint_expr.py`. This is a pure/mechanical refactor: no behavior, signature, or logic changes.\n\n## Seam (existing call-graph cluster)\nMove the expression-grammar + expression-validation cluster — `_ID`, `_NAME`, `_ALLOWED_EXPR`, `ENGINE_INJECTED_INPUTS`, `_OutputContract`, `_Scope`, `_validate_expression` (~137 LOC) — into `lint_expr.py`. The leaf imports only stdlib (`re`, `dataclasses`, `collections.abc.Mapping`); ZERO rebar imports (a true leaf). `_output_fields_map` STAYS in lint_refs because it pulls the step-contract library (`.executor.contract_for`, `.steps`); the shared regexes/constants used by staying functions (`_EXPR_RE`, `_ENV_RE`, `_LITERAL_ONLY_FIELDS`, `_PLACEHOLDER`) STAY.\n\n## Back-compat\nlint_refs re-imports the moved names for its own internal use (`_OutputContract`, `_Scope`, `_validate_expression`) and re-exports `ENGINE_INJECTED_INPUTS` (added to `__all__`) — `lint.py:27` and `tests/unit/workflow/test_contracts.py:19` import it via lint_refs. `_Scope`/`_OutputContract`/`_validate_expression` have no external importers.\n\n## Deviation from docs/architecture.md\nThe offenders-table remedy row for `lint_refs.py` (docs/architecture.md, ~line 269) names a future `lint_contracts.py` seam and EXPLICITLY records that that seam is today SUB-FLOOR (the pure contract cluster is <100 LOC, below the 100-LOC leaf floor). This ticket does NOT take that stale seam; it takes the larger expression-validation seam (~137 LOC, inside [100,800]) which cleanly clears the floor. This ticket deletes that stale/superseded arch.md row (arch.md tracks active oversized modules; a resolved module's row is removed, not rewritten).\n\n## Acceptance Criteria\n- [ ] New leaf sized in [100,800]: `L=$(wc -l < src/rebar/llm/workflow/lint_expr.py); [ \"$L\" -ge 100 ] && [ \"$L\" -le 800 ]` exits 0.\n- [ ] lint_refs under cap: `[ \"$(wc -l < src/rebar/llm/workflow/lint_refs.py)\" -le 800 ]` exits 0.\n- [ ] Graduated off allowlist: `! grep -q 'lint_refs.py' .github/module-size-allowlist.txt` exits 0.\n- [ ] Graduated off ceilings: `! grep -q 'lint_refs.py' .github/module-size-ceilings.txt` exits 0.\n- [ ] arch.md remedy row deleted: `! grep -q 'lint_refs' docs/architecture.md` exits 0.\n- [ ] Module-size contract stays consistent: `python -m pytest tests/unit/test_module_size_contract.py -q` exits 0.\n- [ ] Back-compat re-exports + behavior unchanged: `python -m pytest tests/unit/workflow/test_contracts.py tests/unit/workflow/test_v2_ir.py tests/unit/workflow/test_editor_batch.py -q` exits 0.\n- [ ] Lint/format clean: `make lint` prints 'All checks passed!' (exit 0).\n\n## Testing plan\nPure/mechanical refactor (symbol move + re-export; no signature/logic change) — E5 testing-plan is not-applicable; the existing tests are the oracle.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/llm/workflow/lint_expr.py","reason":"NEW pure-stdlib leaf: the single-${{ }}-expression reference validator (moved _ID/_NAME/_ALLOWED_EXPR/ENGINE_INJECTED_INPUTS/_OutputContract/_Scope/_validate_expression)"},{"path":"src/rebar/llm/workflow/lint_refs.py","reason":"remove the moved cluster; re-import the 3 internal names and re-export ENGINE_INJECTED_INPUTS via __all__; 870 -> ~737 LOC"},{"path":".github/module-size-allowlist.txt","reason":"remove the lint_refs.py grandfather line (graduates off the gate)"},{"path":".github/module-size-ceilings.txt","reason":"remove the lint_refs.py ceiling line"},{"path":"docs/architecture.md","reason":"delete the stale/sub-floor lint_refs.py offenders-table remedy row (named lint_contracts.py)"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","716f-b917-9fc8-41f5"]],"parent_id":"716f-b917-9fc8-41f5","parent_status_uuid":"dc476b43-fcf6-46d2-81e2-cff6fcc39226","preconditions_summary":{"status":"pre-manifest"},"priority":1,"reverts":[],"status":"in_progress","tags":["module-size"],"ticket_id":"2c35-394a-30b4-4b1d","ticket_type":"story","title":"Split lint_refs.py — extract the ${{ }} expression validator into lint_expr.py","verify_commands":[]},"source_event_uuids":["7a1ed8f9-974a-4f3a-bd69-f90208fc08f9","23702d7d-1d81-4946-8b41-587501fd0173","b8d60df2-dee0-4951-91fd-7b3816f6dcc4","54763fb9-e65d-41dc-9460-950f9a30f0d1","dc476b43-fcf6-46d2-81e2-cff6fcc39226","05ccc5e5-e8c3-4897-a081-ce9be02b75d6","fbc55247-73b9-4b80-b3b3-149922cf8ca5","c127a4