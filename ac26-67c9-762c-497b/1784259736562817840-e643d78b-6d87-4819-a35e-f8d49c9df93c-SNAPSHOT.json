AC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"4672a93e022318e84ebdc0caee569dbe5da6f04dcf5b8a21577a9da08bf62cdb","event_uuid":"7e363bb9-2e65-4cb8-a774-931756428f47","position":{"commit_sha":"479cab163d7be1ed79328bb96cff72ab5f533ab2","position":"1784257710890548001-7e363bb9-2e65-4cb8-a774-931756428f47"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"958ec4fcdfd1545c9325ab11ab7f1145a31c24710d97a04db57903b3a5d6184d","event_uuid":"989e0d15-d639-40b2-85d8-2445cc61483c","position":{"commit_sha":"7e8ff9d833718bb5dfe94028e615fd38d6e8281b","position":"1784259736562817839-989e0d15-d639-40b2-85d8-2445cc61483c"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-211_agent","claim_remote_session":null,"claimed_session":"dd03eb60-2371-4b50-91b1-9fd0c63ef175","comments":[],"created_at":1784257702751403001,"creation_channel":"unknown","deps":[{"link_uuid":"a07b523b-223c-45e1-a96d-81e27cf127e4","relation":"relates_to","target_id":"4f8d-542c-69ad-4a9c"}],"description":"## Summary\nA catastrophic intermittent failure of the enrich-prune concurrency test (`intended=250\npersisted=68 lost=182`): an orphaned `.git/index.lock` (left by an abnormally-terminated git\nunder CI memory/FS pressure) wedges EVERY store write for 300s. `_reclaim_if_stale_index_lock`\n(`src/rebar/_store/gitutil.py`) only reclaims a lock older than `_INDEX_LOCK_STALE_S=300`, but\n`_with_index_lock_retry` waits only ~2s — so any orphan cascades ~5 minutes of `StoreError`\nraises. Distinct from the Mode A object-DB single-loss (ticket 4f8d / change 747).\n\n## Reproduction Steps\n1. Plant a young (age-0) `.git/index.lock` in the tracker's worktree gitdir.\n2. Call `stage_and_commit` (holds the write lock). Every write RAISES in ~2s with\n   `fatal: Unable to create '…/index.lock': File exists`; the lock persists for 300s.\n   (Confirmed locally; the real orphan source is a SIGKILL/OOM/FS-fault git termination on CI.)\n\n**Expected:** a locked write self-heals (reclaims the orphan) — under the exclusive write lock\nthe lock is provably not a live peer's.\n**Actual:** wedges every write for 300s → 73% write loss.\n\n## Root Cause\nThe store's git write helpers run UNDER the exclusive `write_lock` (dual-window fcntl+mkdir),\nwhich serializes ALL rebar git on a tracker across processes (verified: 0 natural index.lock\nfirings over ~2250 writes). So an `index.lock` present under the lock is provably an ORPHAN.\nBut `_reclaim_if_stale_index_lock` applies the conservative 300s age gate (correct only for\nUNLOCKED callers, where a live peer might hold it), so a young orphan wedges everything.\n\n## Fix\nAdd `force=True` to `_reclaim_if_stale_index_lock` (bypass the age gate, keep the device+inode\nTOCTOU re-validation) threaded through `_with_index_lock_retry(force_reclaim=…)`; the four\nlocked git helpers (`_git_add`/`_git_commit`/`_git_rm`/`_git_commit_paths`) pass it. Under the\nwrite lock a young orphan is reclaimed on the first retry → the write self-heals.\n\n## Acceptance Criteria\n- [ ] Under the write lock, a young orphan `index.lock` is reclaimed immediately (RED test:\n  `test_orphan_index_lock_under_write_lock_self_heals`, mutation-checked).\n- [ ] The UNLOCKED reclaim (`force=False`) still preserves a young lock (safety invariant kept).\n- [ ] The concurrency test passes; make lint + typecheck pass; no existing test weakened.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["relates_to","4f8d-542c-69ad-4a9c"]],"parent_id":null,"parent_status_uuid":"80205b07-f20d-4d5e-a8cd-fa5d835fe6df","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"ac26-67c9-762c-497b","ticket_type":"bug","title":"Orphan .git/index.lock wedges all store writes for 300s under the write lock (enrich-prune Mode B cascade)","verify_commands":[]},"source_event_uuids":["e36c5e98-d15e-4ef7-af25-d34ed1cd0e45","a07b523b-223c-45e1-a96d-81e27cf127e4","80205b07-f20d-4d5e-a8cd-fa5d835fe6df","7e363bb9-2e65-4cb8-a774-931756428f47","989e0d15-d639-40b2-85d8-2445cc61483c"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784259736562817840,"uuid":"e643d78b-6d87-4819-a35e-f8d49c9df93c"}