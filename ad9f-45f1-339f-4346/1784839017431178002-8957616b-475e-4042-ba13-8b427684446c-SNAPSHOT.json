-b91e-0640ec580edb"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"2bb87a7dab57dadf3cb444fbb72ad32ebe5ed5ab0efab47310c7cbb42a211910","event_uuid":"517a7d71-b416-4ea7-858b-8260f75258de","position":{"commit_sha":"b1748e72d6cf6d7b068b5a64533d12a826e5d11e","position":"1784835327719649001-517a7d71-b416-4ea7-858b-8260f75258de"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"93526c3c417a63dfaf2711f53f91c9031a4b0a3d53d23c940d093c4990a02642","event_uuid":"8054c3c3-d994-4503-82e3-3387ec40b2cc","position":{"commit_sha":"9fd59dcb24dcbe7d7c465ac812486f639ab5a202","position":"1784835788754987242-8054c3c3-d994-4503-82e3-3387ec40b2cc"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"e5c27f83d598f2288442ab8f8455237a87f006fc434fc1dad048090bf432b82e","event_uuid":"8365ca2b-c67e-49b3-8c2a-f7e4812109f6","position":{"commit_sha":"5a6efc0ae92fa286f817d2b3d1cce2b13150567b","position":"1784839017431178001-8365ca2b-c67e-49b3-8c2a-f7e4812109f6"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-218_agent","claim_remote_session":null,"claimed_session":"765ab0e6-1638-418e-8e23-7da2a32dab32","comments":[],"created_at":1784833891931465001,"creation_channel":"cli","deps":[{"link_uuid":"1811b408-7516-4f3f-a516-2c3da435543a","relation":"discovered_from","target_id":"80af-c876-5856-4159"}],"description":"## Context / Problem\nDiscovered from 80af: `rebar verify-commit-ticket` fails 'ticket store not found' in a fresh linked worktree because it is a PURE INTERCEPT (_cli/__init__.py:438) dispatched before the arms that call the centralized `ensure_initialized`, and it does not self-manage init — yet it resolves ids against the store. The mount step is replicated per dispatch-arm and skipped entirely by the intercepts, so the \"command forgot to mount the store\" bug is structurally possible.\n\n## Design (agreed)\nThe MOUNT half of init (`ensure_initialized(init_only=True)` → `_create_tracker`: symlink a worktree to the main repo store / attach to an existing tickets branch; already a no-op under REBAR_TRACKER_DIR override) should run at ONE central CLI choke point, BEFORE both the pure intercepts and the set-based dispatch, for every store-touching command. The RECONVERGE half (`reads.ensure_fresh`) is already shared across CLI/library/MCP via the _reads facade and stays in the leaves (init_only vs full differ ONLY by reconverge). Per the tolerance we agreed: the per-arm `ensure_initialized` calls may remain (idempotent re-mount is cheap and non-fatal); the central gate's job is to guarantee no command skips mount. Commands that must NOT auto-mount (policy=none): `init` (is init), `scratch` (fs-only), `explain` (guides, no store), and pure no-store reads.\n\nScope: CLI surface only. Library (`import rebar`) and MCP intentionally do NOT auto-mount (they require explicit init_repo / assume a mounted store; embedders inject a tracker which no-ops the gate) — unchanged here.\n\n## Acceptance Criteria\n- [ ] `rebar verify-commit-ticket` in a fresh linked worktree (no .tickets-tracker) auto-mounts (symlink to main repo store) and resolves the id, instead of 'ticket store not found' — regression test.\n- [ ] The mount runs at a single central CLI gate covering the pure intercepts; no store-touching command can skip it.\n- [ ] `explain` (and init/scratch) are NOT force-mounted — they keep working with no store — guard test.\n- [ ] REBAR_TRACKER_DIR override still short-circuits the gate (tests/embedding unaffected).\n- [ ] make lint && make typecheck && make test green; docs/cli-reference regenerated if the CLI surface changed.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_cli/__init__.py","reason":"central mount gate at the entry choke point before intercepts+dispatch; init-policy classification"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[],"parent_id":null,"parent_status_uuid":"6385c37a-837a-479a-b91e-0640ec580edb","plan_review_phase":"execution","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"ad9f-45f1-339f-4346","ticket_type":"task","title":"Centralize CLI store-mount so no command (incl. pure intercepts like verify-commit-ticket) can skip it","verify_commands":[]},"source_event_uuids":["a8d93d44-3828-48a9-984b-31504a5a0d17","1811b408-7516-4f3f-a516-2c3da435543a","c384fe5b-eb20-4afe-9a4b-c29cbe6f36d5","a67c278f-b952-40c4-b542-a7ab355dba84","6385c37a-837a-479a-b91e-0640ec580edb","517a7d71-b416-4ea7-858b-8260f75258de","8054c3c3-d994-4503-82e3-3387ec40b2cc","8365ca2b-c67e-49b3-8c2a-f7e4812109f6"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784839017431178002,"uuid":"8957616b-475e-4042-ba13-8b427684446c"}