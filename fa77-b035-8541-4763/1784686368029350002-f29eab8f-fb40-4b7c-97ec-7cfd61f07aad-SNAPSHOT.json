b5","position":{"commit_sha":"ea30cd3e4489f637bf52e877429dc98e1f625ff4","position":"1784686368029350001-8b75bc26-c7c7-4752-acf6-188e514499b5"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":null,"claim_remote_session":null,"claimed_session":null,"comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Held-out TDD validation complete: full restored oracle 12/12 GREEN; defect-seeded omission of */.archived correctly failed the hidden archive test, then restored. make check passes. Full default suite is running as regression-safety evidence. The two loose tracker records were identified as an older PASS/signature pair superseded by a later committed review after plan edits; they will be quarantined recoverably after the ignore migration lands.","timestamp":1784686368029350001}],"created_at":1784685380502855001,"creation_channel":"cli","deps":[{"link_uuid":"c87fdbc7-3138-4db0-893c-ad68ca527e4c","relation":"discovered_from","target_id":"acaf-bb4d-9eba-470c"}],"description":"## Problem\ntracker_head_sha intentionally rejects any git status output, but initialized ticket stores do not ignore reducer-owned per-ticket .archived and .write.lock runtime markers. A normal store with archived tickets is therefore permanently dirty and every plan review returns unsigned INDETERMINATE store-read-failure. The live store also has two old orphan review/signature events that fsck recovery must reconcile separately.\n\n## Plan\n- Add the two reducer runtime marker patterns to the canonical tickets-branch gitignore ensure.\n- Add migration and clean-store regression coverage proving existing stores converge and strict tracker_head_sha succeeds with runtime markers present.\n- Use the supported fsck recovery path for genuinely orphaned event files; do not weaken strict dirty/unmerged detection.\n\n## Acceptance Criteria\n- [ ] Per-ticket .archived and .write.lock runtime markers are ignored in new and migrated ticket stores.\n- [ ] tracker_head_sha succeeds on an otherwise-clean store containing those markers.\n- [ ] Genuine untracked event files remain visible to git status and still produce store-read-failure.\n- [ ] Existing gitignore ensure tests and focused relation snapshot tests pass.\n- [ ] The live store is clean after supported recovery and the blocked 75de plan review can proceed.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_commands/init.py","reason":"Ignore reducer-owned per-ticket runtime markers in new and migrated ticket stores."},{"path":"src/rebar/reducer/marker.py","reason":"Single-source the per-ticket marker filenames used by the gitignore ensure."},{"path":"tests/interfaces/store/test_lock_gitignored.py","reason":"Prove seeded and migrated stores ignore runtime markers while staying clean."},{"path":"tests/unit/test_plan_relation_snapshot.py","reason":"Prove strict tracker HEAD remains sensitive to genuine untracked events."}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[],"parent_id":null,"parent_status_uuid":"d9d43dac-8365-4e28-9060-f8dbab48f097","preconditions_summary":{"status":"pre-manifest"},"priority":1,"reverts":[],"status":"in_progress","tags":["plan-review","ticket-store"],"ticket_id":"fa77-b035-8541-4763","ticket_type":"bug","title":"Plan relation snapshots reject rebar runtime marker files","verify_commands":[]},"source_event_uuids":["4e2253c6-77d8-42dc-bfba-308621b61219","c87fdbc7-3138-4db0-893c-ad68ca527e4c","66d099a0-4811-438b-b134-79672f2f9972","d9d43dac-8365-4e28-9060-f8dbab48f097","4260c0d8-455d-49a0-ab09-bd8820bfbb0d","9e867fe9-ab46-4002-9cd7-76b8c7fa2207","8b75bc26-c7c7-4752-acf6-188e514499b5"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784686368029350002,"uuid":"f29eab8f-fb40-4b7c-97ec-7cfd61f07aad"}