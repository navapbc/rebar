b03e-18c69a1a6c35"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"b913beae6d9c3665a0d680e32fafeb2bfd5b422338cdc4ed53865cd2b98c8621","event_uuid":"e8ee1487-7e0b-47ca-97cf-4ee2491677d5","position":{"commit_sha":"cc4299710939a88234c61296f425541ac7d5c1be","position":"1784858155378879001-e8ee1487-7e0b-47ca-97cf-4ee2491677d5"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"af9c53e260a55e4b4e7404c2eca4d2e240b9d38867d1e7ef7eb558c8e1f0d66d","event_uuid":"2c015046-bac7-480b-a0df-c407d0024002","position":{"commit_sha":"49e7aefbb739bfb149ebc9e150196f3a496704e2","position":"1784862054493134001-2c015046-bac7-480b-a0df-c407d0024002"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":null,"claim_remote_session":null,"claimed_session":null,"comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Discovered during the epic plan-review gate (finding: lizard/jscpd adapters had no registered consumer). Direct parent linkage records provenance; an extra discovered_from edge was rejected correctly as redundant with the parent-child relationship. Dependencies recorded on 0734, 21fb, and 3ba0; a532 now depends on this story.","timestamp":1784825029316646001},{"author":"RebarBotNava","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Plan refinement after PASS advisories: implement direct adapter composition, not the unused language-dispatch table. Add a per-command  dict to the metrics evaluation context; its lifecycle is exactly one  invocation (no module/global state). A focused cache helper keys by producer name plus immutable repo root/scan-root inputs and stores both AnalyzerResult and Unavailable, so each of scc/lizard/jscpd executes at most once in that context. Rework the existing scc specs to read this cache, and register structural/high-confidence  and  specs that expose the adapters' normalized payloads or preserve Unavailable as registry Unavailable. If ANALYZERS/resolve_analyzer/analyze_or_unavailable remain unused after this direct composition, remove that dead dispatch while retaining AnalyzerResult/Analyzer protocol compatibility. Prove deduplication with a unit call-count test that evaluates both scc-backed specs in one context and asserts one scc invocation; separately assert one call and exact payload/Unavailable propagation for lizard and jscpd. Add interface tests through  for value and missing-producer output. Adapter-level nonzero/malformed handling is already pinned by 21fb/3ba0 tests and will be retained, not duplicated. This per-context design is chosen over lru_cache/module state to avoid stale cross-command and cross-test results.","timestamp":1784858030967009001},{"author":"RebarBotNava","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Correction to the preceding refinement: the per-command context field is analysis_cache; its lifecycle is one metrics_cli invocation. The new registered metric ids are complexity_summary and duplication_summary. Interface tests exercise metrics_cli. All other refinement text is unchanged.","timestamp":1784858058955172001},{"author":"RebarBotNava","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"RED oracle confirmed before production edits. Contract card: authoritative sources are this story AC, the normalized AnalyzerResult payloads from scc/lizard/jscpd, and registry Unavailable semantics. Tier: unit registry evaluation with canonical adapter fakes for exact payload/call-count/cache-lifecycle behavior, plus metrics_cli interface tests for real rendering. All five required tests are RED for the intended missing behavior: absent complexity/duplication specs, repeated scc invocation, and producer reasons collapsed to generic no-data. Happy path is test_structural_metrics_share_one_result_per_producer; unavailable, cache isolation, and CLI rendering remain held out.","timestamp":1784858155378879001},{"author":"RebarBotNava","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Full gate first run: 7111 passed, 29 skipped, 2 failed because pre-existing held-out tests encoded superseded behavior (two SCC calls; generic no-data replacing producer Unavailable). Corrected those tests under revert-first discipline: temporary mutations restoring each old behavior made both revised tests RED for the intended reasons; restored implementation then both GREEN. Focused metrics suite, lint, and mypy GREEN; final full suite rerun active as process 87760.","timestamp":1784862054493134001}],"created_at":1784824963574327001,"creation_channel":"cli","deps":[{"link_uuid":"277e9c2c-e662-4e74-b24c-7283fa3d902a","relation":"depends_on","target_id":"0734-ceae-be55-4fa7"},{"link_uuid":"4530b0d0-15d2-4a81-b05d-071fce3a79b9","relation":"depends_on","target_id":"21fb-f4cd-3eaa-4b60"},{"link_uuid":"3cdc6004-b96c-445a-8a81-edc0ba435836","relation":"depends_on","target_id":"3ba0-9350-8337-429a"}],"description":"## Problem\nThe existing epic decomposition builds lizard and jscpd adapters, but only the scc LOC payload is consumed by registered code_health metrics. Without an explicit integration slice, the epic can close with working adapters that users never observe.\n\n## Plan\n- After the adapter and LOC-migration stories land, add a code-health composition seam that invokes each configured signal producer at most once per metrics evaluation context and preserves honest Unavailable outcomes.\n- Register structural/high-confidence code_health MetricSpecs for observable complexity and duplication summaries, alongside the scc-derived size metrics from 0734.\n- Keep scc and jscpd as external PATH tools and lizard behind the metrics extra; no core hard dependency or import-time tool loading.\n- Extend the metrics command/E2E output so Python and Go fixture projects expose loc, complexity, and duplication values when tools are present, and clear Unavailable entries when any producer is absent.\n\n## Acceptance Criteria\n- [ ] The code_health lens exposes registered complexity and duplication metrics backed by the lizard and jscpd adapters; adapter outputs are not dead code.\n- [ ] One metrics evaluation does not rerun the same external analyzer once per registered metric.\n- [ ] Missing lizard, scc, or jscpd yields an honest Unavailable reason naming the missing producer; no zeros and no raw exception string.\n- [ ] Python and Go interface tests assert loc, complexity, and duplication values through the real metrics entry point when tools are available.\n- [ ] Core-only imports remain dependency-free; lint, typecheck, focused metrics tests, and the full default suite pass.\n\n## Dependencies\nDepends on 0734 (registered LOC migration), 21fb (lizard adapter), and 3ba0 (jscpd adapter). The cross-language validation story a532 must depend on this integration slice.\n\n## Likely files\n- src/rebar/metrics/analyzer.py or a focused analyzer-composition module\n- src/rebar/metrics/git_metrics.py / registry integration seam\n- src/rebar/_commands/metrics.py context cache\n- tests/unit/metrics/ and tests/interfaces/test_metrics_polyglot.py","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/metrics/analyzer.py","reason":"compose per-signal analyzers behind the shared AnalyzerResult contract"},{"path":"src/rebar/metrics/git_metrics.py","reason":"register structural complexity and duplication MetricSpecs"},{"path":"src/rebar/_commands/metrics.py","reason":"carry or cache one analyzer result per metrics evaluation context"},{"path":"tests/unit/metrics/","reason":"unit contracts for composition, caching, and Unavailable propagation"},{"path":"tests/interfaces/test_metrics_polyglot.py","reason":"Python and Go observable lens output"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["depends_on","0734-ceae-be55-4fa7"],["depends_on","21fb-f4cd-3eaa-4b60"],["depends_on","3ba0-9350-8337-429a"],["parent","839b-f6d2-7e1a-4051"]],"parent_id":"839b-f6d2-7e1a-4051","parent_status_uuid":"46eaf14f-c15f-41dc-80c5-1ba08c839565","plan_review_phase":"execution","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":["metrics","code-health","integration"],"ticket_id":"c23c-c32b-982c-4196","ticket_type":"story","title":"Wire complexity and duplication analyzer outputs into code_health metrics","verify_commands":[]},"source_event_uuids":["2fcc7290-fb8c-478e-9a44-08039d08eb8c","88360219-ace9-49c9-9f42-602a43808602","277e9c2c-e662-4e74-b24c-7283fa3d902a","4530b0d0-15d2-4a81-b05d-071fce3a79b9","3cdc6004-b96c-445a-8a81-edc0ba435836","b9a3be24-7f5e-4f15-b7ee-b66b7847cb7c","8730425d-d319-410c-b634-b8745ed87ed5","4f354415-32cc-46fb-9d7a-df24db521d37","6b43bbd4-f2da-43e9-8a7a-970bb646bf64","46eaf14f-c15f-41dc-80c5-1ba08c839565","3e515013-675c-402f-b03e-18c69a1a6c35","e8ee1487-7e0b-47ca-97cf-4ee2491677d5","2c015046-bac7-480b-a0df-c407d0024002"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784862054493134002,"uuid":"f89677d5-dda0-4869-bd20-7198f21446dd"}