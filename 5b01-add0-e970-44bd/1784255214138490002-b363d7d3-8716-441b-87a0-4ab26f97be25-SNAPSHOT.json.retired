G3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"1a9bc3de066f2775322fc80b38e088f6aee47d6d528cf1d832b362b781a6e7fc","event_uuid":"17879dee-cdd0-4f59-956c-6ed7d205de43","position":{"commit_sha":null,"position":"1784252681601314001-17879dee-cdd0-4f59-956c-6ed7d205de43"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"af74ac18a2042723840e9d0f835f5ac1dd4fac539a0d8ba730203fb0f98b6f03","event_uuid":"3807c323-62b9-41fc-afe0-25f934651350","position":{"commit_sha":null,"position":"1784252681836690001-3807c323-62b9-41fc-afe0-25f934651350"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"b436de6c205ad504d4765e9118ca8d3745eff932f59d91a0004834dca58dafba","event_uuid":"b7c56e38-98e8-4b3d-b833-906b15aefd9d","position":{"commit_sha":null,"position":"1784254310138805896-b7c56e38-98e8-4b3d-b833-906b15aefd9d"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"46a3152f2cc08a1e316fe2698711b970e382dc401b4c2905c9cb17ece3c96d2c","event_uuid":"526fba79-3fd5-48be-9616-fb6a7bc92f0f","position":{"commit_sha":null,"position":"1784255214138490001-526fba79-3fd5-48be-9616-fb6a7bc92f0f"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-212_agent","claim_remote_session":null,"claimed_session":"aa9cb5ff-3fdb-44d3-8af8-c125c27f20ad","comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"[operator-attested] PER-TOOL-POINTER DECISION: DEFER (default). No .github/copilot-instructions.md, .cursor/rules/, or Gemini config added in this story. Rationale: AGENTS.md is read natively by Codex (and the .codex/config.toml doc-fallback now points at it) and is bridged into Claude Code via CLAUDE.md's @AGENTS.md import; Cursor (.cursor/rules MDC) and GitHub Copilot (.github/copilot-instructions.md) use their own mechanisms and do NOT read root AGENTS.md natively (matches plan-review T1 advisory). Adding per-tool pointer files for those is deliberately deferred as follow-up — none added here. Antigravity is covered by the committed .agents/rules/rebar.md (a short reference-and-summary, since .agents/rules/* cannot @-import). Evidence: change id = this Gerrit change (5b01 sweep); recorded 2026-07-16.","timestamp":1784255214138490001}],"created_at":1784230965710933001,"deps":[{"link_uuid":"ff04e020-46af-4e1a-9b3a-2db5ae169db4","relation":"depends_on","target_id":"6642-814b-8bc5-4ff4"},{"link_uuid":"e1d009cd-8c31-4fd9-afff-ceea3dffd2ff","relation":"depends_on","target_id":"955c-7a98-2485-4209"},{"link_uuid":"e2222363-3a66-4f85-9ad1-1e506081adfd","relation":"depends_on","target_id":"46f8-cd08-7bf5-4508"}],"description":"# Bring provider configs under version control + repo-wide CLAUDE.md reference sweep\n\n## Why\n\nOnce `AGENTS.md` is canonical, two things must happen so the migration ships to other providers\nand clones: (1) the committed-tree references to `CLAUDE.md` must move to the new structure, and\n(2) the provider-config scaffolding must be **committed** — a spike found that `.codex/config.toml`\nand `.agents/rules/rebar.md` are **untracked, locally `.git/info/exclude`d files on one machine**\n(`git ls-files` returns nothing for them), so today no other clone or provider sees them.\n\n## What\n\nA `git grep 'CLAUDE\\.md'` over tracked files gives the complete surface (24 refs). Ownership is\nsplit, and this story owns a defined subset:\n\n- **This story updates** (CLAUDE.md → AGENTS.md or the new docs home): `CONTRIBUTING.md:570`,\n  `README.md:354`, `rebar.toml:3`, `docs/architecture.md:65,233`, `docs/api-stability.md:25`,\n  `docs/exit-codes.md:43`, `docs/jira-sync-setup.md:484`, `docs/llm-framework.md:462`,\n  `docs/releasing.md:250`, `docs/workflow-editor.md:160`, `docs/workflow-engine.md:29`,\n  `docs/adr/0043-…:121`, `docs/plan-review-criteria-guide.md:462,467`,\n  `scripts/jira-pressure-test/e2e_field_validation_probe.sh:130`, and the plan-review criteria\n  text in `src/rebar/llm/plan_review/criteria_routing.json:407`,\n  `src/rebar/llm/reviewers/plan_review_T5e.md:10`, plus the prose comment in\n  `src/rebar/reducer/_processors.py:307`. (The rename breaks zero code — every `src/` hit is a\n  prose comment; the unrelated `CLAUDE_CODE_SESSION_ID` env var does not match `CLAUDE.md`.)\n- **Owned by other stories (out of scope here):** `docs/event-schema.md:46` (S1 replaces that\n  pointer) and `examples/claude-skills/{rebar-implement/SKILL.md,rebar-janitor/phases/discovery.md}`\n  (S5 repoints them).\n- **Deliberately NOT changed:** `CHANGELOG.md` (3 hits) — a changelog is a historical record of\n  past changes made when the file *was* `CLAUDE.md`; rewriting it would falsify history.\n- **Commit the Codex config:** bring `.codex/config.toml` under version control (`git add -f`,\n  it is currently locally excluded) pointing at `AGENTS.md`, comment updated to the completed state.\n- **Commit the generic rules file:** bring `.agents/rules/rebar.md` under version control as a\n  concise distillation that **references `AGENTS.md`** as the source of truth (Antigravity\n  `.agents/rules/*` does not support `@`-imports, so a short reference-and-summary, not a symlink).\n- **Per-tool pointers:** record the decision on optional `.github/copilot-instructions.md` /\n  `.cursor/rules` / Gemini config. Default: **defer to a follow-up** (none added here).\n\n## Scope\n\nIn: the ~17 owned files listed above, `.codex/config.toml`, `.agents/rules/rebar.md`. Out: files\nowned by S1/S5, `CHANGELOG.md`, the root-file/template changes. **Depends on S1, S2, S3** (S1 and\nS5 must land their reference updates for the global tree to be clean; S2 must create `AGENTS.md`).\nRollback: `git revert` — docs/config/text only, no data migration.\n\n## Assumption (flag for override)\n\nThe epic's goal (guidance *available to* Codex/Cursor/Antigravity) is only met if the provider\nconfigs are committed, so this story brings `.codex/` and `.agents/` into version control. If the\nteam wants provider configs to stay per-developer/local, drop those two bullets.\n\n## Acceptance Criteria\n\n- [ ] This story's 17 owned files carry no `CLAUDE.md` reference (verifiable on this story alone;\n  the thin `CLAUDE.md` pointer, historical `CHANGELOG.md`, and the S1-/S5-owned files are excluded\n  because they are out of this story's scope).\n  - Proving: `[ \"$(git grep -c 'CLAUDE\\.md' -- ':!CLAUDE.md' ':!CHANGELOG.md' ':!docs/event-schema.md' ':!examples' ':!docs/experiments' | awk -F: '{s+=$2} END{print s+0}')\" = 0 ]`\n- [ ] The plan-review criteria text (both the `src/rebar/llm` files and the\n  `docs/plan-review-criteria-guide.md` mirror) references `AGENTS.md`, not `CLAUDE.md`.\n  - Proving: `[ \"$(git grep -c 'CLAUDE\\.md' -- src/rebar/llm docs/plan-review-criteria-guide.md | awk -F: '{s+=$2} END{print s+0}')\" = 0 ]`\n- [ ] `.codex/config.toml` is git-tracked and points at `AGENTS.md`.\n  - Proving: `[ -n \"$(git ls-files .codex/config.toml)\" ] && git grep -q 'AGENTS.md' -- .codex/config.toml`\n- [ ] `.agents/rules/rebar.md` is git-tracked and references `AGENTS.md` as the source of truth.\n  - Proving: `[ -n \"$(git ls-files .agents/rules/rebar.md)\" ] && git grep -q 'AGENTS.md' -- .agents/rules/rebar.md`\n- [ ] [operator-attested] The per-tool-pointer decision (default: defer) is recorded as a comment\n  on this ticket citing the choice.\n- [ ] `make lint && make test` pass and the module-size CI gate is green.\n  - Proving: `make lint && make test`","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":".codex/config.toml","reason":"read AGENTS.md natively"},{"path":".agents/rules/rebar.md","reason":"reconcile with AGENTS.md"},{"path":"CONTRIBUTING.md","reason":"reference sweep"},{"path":"README.md","reason":"reference sweep"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["depends_on","46f8-cd08-7bf5-4508"],["depends_on","6642-814b-8bc5-4ff4"],["depends_on","955c-7a98-2485-4209"],["parent","81e2-ad5e-bfe2-4653"]],"parent_id":"81e2-ad5e-bfe2-4653","parent_status_uuid":"17879dee-cdd0-4f59-956c-6ed7d205de43","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"5b01-add0-e970-44bd","ticket_type":"story","title":"Retarget provider shims to AGENTS.md + repo-wide reference sweep + optional per-tool pointers","verify_commands":[]},"source_event_uuids":["edaa02fb-78f8-45cb-b6d6-c03e0a8ce606","ff04e020-46af-4e1a-9b3a-2db5ae169db4","e1d009cd-8c31-4fd9-afff-ceea3dffd2ff","71c7c53c-ab98-46f6-81fc-423a021f02cd","a3f3e826-0acb-4ba6-9c61-6944dce424e0","8b59d604-8681-4fe6-806b-cddac45b8ed3","23438efb-15f5-472a-b0c2-65c85fc8be1c","03e248ad-f4d9-40ff-bba3-044846bb9e88","cec6edc0-bb18-4be9-a4ac-e27fc66089b1","83feb632-4263-49af-9bb0-820daba21b2c","e2222363-3a66-4f85-9ad1-1e506081adfd","17879dee-cdd0-4f59-956c-6ed7d205de43","3807c323-62b9-41fc-afe0-25f934651350","b7c56e38-98e8-4b3d-b833-906b15aefd9d","526fba79-3fd5-48be-9616-fb6a7bc92f0f"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784255214138490002,"uuid":"b363d7d3-8716-441b-87a0-4ab26f97be25"}