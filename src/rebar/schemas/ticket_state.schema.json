{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/navapbc/rebar/schemas/ticket_state.schema.json",
  "title": "TicketState",
  "description": "Compiled ticket state as emitted by `rebar show <id>` (and the library show_ticket / MCP show_ticket tool), and the element shape of `list` / `search`. This is replay-derived state, not an event. Unknown properties are allowed so the event-sourced shape can evolve without breaking consumers. Shared sub-objects (comment/dep/file_impact_entry/verify_command_entry) are $ref'd from common.schema.json.",
  "type": "object",
  "additionalProperties": true,
  "required": ["ticket_id", "ticket_type", "title", "status", "priority", "tags"],
  "properties": {
    "ticket_id": {
      "type": "string",
      "description": "Canonical ticket id (the directory name on the tickets branch)."
    },
    "ticket_type": { "$ref": "common.schema.json#/$defs/ticket_type" },
    "title": { "type": "string" },
    "status": { "$ref": "common.schema.json#/$defs/ticket_status" },
    "priority": { "$ref": "common.schema.json#/$defs/priority" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assignee": { "type": ["string", "null"] },
    "parent_id": { "type": ["string", "null"] },
    "alias": {
      "type": ["string", "null"],
      "description": "Human-friendly slug (e.g. 'damp-filth-cup')."
    },
    "description": { "type": ["string", "null"] },
    "author": { "type": ["string", "null"] },
    "created_at": {
      "type": ["integer", "null"],
      "description": "Creation timestamp in nanoseconds (time.time_ns())."
    },
    "env_id": { "type": ["string", "null"] },
    "comments": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/comment" }
    },
    "deps": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/dep" }
    },
    "file_impact": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/file_impact_entry" }
    },
    "verify_commands": {
      "type": "array",
      "description": "DD-level verification commands (always present; default []).",
      "items": { "$ref": "common.schema.json#/$defs/verify_command_entry" }
    },
    "bridge_alerts": { "type": "array" },
    "reverts": { "type": "array" },
    "preconditions_summary": { "type": "object" }
  }
}
