{
  "_comment": "Committed routing index for the code-review gate (analog of plan_review/criteria_routing.json). Top-level _-prefixed keys are stripped by registry.routing_index(). The secret-detection / high-critical-security keys ship blocking_enabled=false (advisory in v1); WS5 flips exactly those two to true (the deterministic gitleaks/semgrep detectors, fail-closed).",
  "security": {
    "exec": "AGENT",
    "applies_to": ["**/auth*", "**/*secret*", "**/security/**", "**/signing*", "**/*cred*"],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "performance": {
    "exec": "AGENT",
    "applies_to": [],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "i18n": {
    "exec": "1-TURN",
    "applies_to": ["**/locale/**", "**/*i18n*", "**/translations/**"],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "a11y": {
    "exec": "1-TURN",
    "applies_to": ["**/*.html", "**/*.jsx", "**/*.tsx", "**/templates/**"],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "db-migrations": {
    "exec": "AGENT",
    "applies_to": ["**/migrations/**", "**/alembic/**", "**/*schema*.sql"],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "docs": {
    "exec": "1-TURN",
    "applies_to": ["**/*.md", "docs/**", "**/README*"],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "supply-chain": {
    "exec": "1-TURN",
    "applies_to": ["**/requirements*.txt", "**/pyproject.toml", "**/package*.json", "**/*.lock", "**/Pipfile*"],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "api-compat": {
    "exec": "AGENT",
    "applies_to": ["**/*api*", "**/schemas/**", "**/*.proto", "**/cli*", "**/mcp_server*"],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "iac": {
    "exec": "AGENT",
    "applies_to": ["**/*.tf", "**/*.tfvars", "**/k8s/**", "**/helm/**", "**/ansible/**", "**/Dockerfile*"],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "tests": {
    "exec": "AGENT",
    "applies_to": ["**/test_*.py", "**/*_test.py", "**/tests/**"],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "llm-prompts": {
    "exec": "AGENT",
    "applies_to": ["**/reviewers/**", "**/prompts*", "**/*.prompt", "**/schemas/*.schema.json"],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "deletion-impact": {
    "_comment": "story f983: CONTENT-triggered (not glob) overlay — registry.content_triggered_overlays fires it when the diff removes a def/class/signature, so applies_to is empty. ADVISORY (blocking_enabled=false): a now-dangling reference is a coach-not-block finding, verified in Pass-2 and decided in Pass-3 like every other overlay.",
    "exec": "AGENT",
    "applies_to": [],
    "default_posture": "advisory",
    "block_threshold": 0.95,
    "blocking_enabled": false
  },
  "secret-detection": {
    "exec": "DET",
    "applies_to": [],
    "default_posture": "blocking",
    "block_threshold": 0.5,
    "blocking_enabled": true,
    "detector": { "id": "rebar.builtin.security.secrets-gitleaks" },
    "fail_mode": "closed"
  },
  "high-critical-security": {
    "exec": "DET",
    "applies_to": [],
    "default_posture": "blocking",
    "block_threshold": 0.5,
    "blocking_enabled": true,
    "detector": { "id_prefix": "rebar.builtin.security." },
    "fail_mode": "closed"
  },
  "public-exposure-without-auth": {
    "_comment": "task 830a: deterministic public-exposure signals (0.0.0.0/0 ingress, public IP, internet-facing LB, non-loopback compose bind) on the *.tf / docker-compose diff — the code-level counterpart to plan-review T10. ADVISORY (blocking_enabled=false, fail_mode=open): a match is a coach-not-block coverage finding, since boundary controls (gateway/mTLS/network policy) may live outside the diff. NOT under the fail-closed rebar.builtin.security. prefix.",
    "exec": "DET",
    "applies_to": ["**/*.tf", "**/*.tfvars", "**/docker-compose*.yml", "**/docker-compose*.yaml", "**/compose*.yml", "**/compose*.yaml"],
    "default_posture": "advisory",
    "block_threshold": 0.5,
    "blocking_enabled": false,
    "detector": { "id_prefix": "rebar.builtin.iac.public-exposure." },
    "fail_mode": "open"
  }
}
