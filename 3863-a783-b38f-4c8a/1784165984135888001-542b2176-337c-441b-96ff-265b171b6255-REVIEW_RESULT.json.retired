{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","data":{"coaching":[{"coaching":"Plan how acceptance criteria verification gaps will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f607dd457c67f9209"],"move_id":"9","move_name":"plan the verification","subject":"acceptance criteria verification gaps"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":1,"blocking":0,"dropped":4,"indeterminate":0},"det":{"P1":{"ac_items":13,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","probed":5,"ran":true,"references":5,"resolved":2,"status":"pass","unresolved_or_abstained":3},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":13,"blocking":false,"desc_chars":6781,"file_impact":3,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":13,"blocking":false,"name":"ac-quality","ran":true,"status":"fail","verify_commands_linted":77,"verify_lint_abstained":77},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":1705,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":3,"name":"file-impact-coverage","ran":true,"status":"pass"}},"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":199.8,"llm_calls":29,"llm_ms":459749.2,"total_ms":460076.0,"verify_requests":45},"remediation":{"baseline":"signature","eligible":false,"reasons":{"code_unchanged":false,"plan_changed":true,"prior_sidecar":true,"registry_unchanged":true,"signed":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","F4","G5","T2","T4","T5b","T5d","T5e","T6","T9","hedge"]}},"findings":[{"block_threshold":null,"blocking_enabled":null,"checklist_item":"","cohort":null,"criteria":["P6"],"decision":"advisory","drop_reason":null,"evidence":["1 criterion line(s) bundle multiple deliverables with 'and' (split so each is independently verifiable)."],"finding":"Acceptance-criteria / definition-of-done quality issues.","group_criteria":null,"group_id":null,"id":"f607dd457c67f9209","impact":0.4,"is_primary":null,"location":"","norm_id":"ned06ebc801a522e3","priority":0.4,"reason":null,"scenarios":[],"severity":"minor","suggested_fix":"Split compound criteria, replace subjective terms with observable outcomes, and state how each is verified.","tier":"DET","validity":1.0,"verification":null},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Document that `block_threshold: 0.9` is a provisional value pending calibration, and confirm whether the overlay schema supports a per-invocation or per-project override (or note the absence as an accepted constraint).","cohort":["T2","T4","T5e"],"criteria":["T5e"],"decision":"dropped","drop_reason":null,"evidence":["'Configure ... block_threshold: 0.9' — plan specifies a fixed numeric threshold in routing config","'live semantic calibration' is explicitly out of scope, meaning the threshold is being committed without a measurement basis","The parent epic references a calibration child ticket, implying 0.9 is provisional and will need adjustment"],"finding":"The `block_threshold: 0.9` value is hardcoded in `criteria_routing.json` with no mechanism for per-project or per-environment override, while live semantic calibration is explicitly deferred to a child ticket — making this a soon-to-change threshold that is not configurable at the overlay level.","group_criteria":null,"group_id":null,"id":"ff295b8030b8b88ec","impact":0.0,"is_primary":null,"location":"Approach section — 'block_threshold: 0.9'; Scope section — 'live semantic calibration' listed as out of scope","norm_id":"n446c1a816d552332","priority":0.0,"reason":"low-validity","scenarios":["When the calibration child ticket runs and determines a different threshold is needed, a code change to criteria_routing.json is required rather than a configuration override — every project using the shared overlay is affected simultaneously.","If false-positive or false-negative rates at 0.9 are unacceptable in practice, there is no per-project escape hatch short of forking the overlay."],"severity":"none","suggested_fix":"Add a comment or companion field in `criteria_routing.json` (e.g., `block_threshold_note: provisional-pending-calibration`) and verify that the overlay schema allows overriding this value at the client level; if not, note the limitation explicitly in the plan.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Enumerate `test_reviewer_prompt_hygiene.py` as a consumer of the new project rubric, and either extend its scan to include `.rebar/prompts/plan-review-project-portability.md` or add a dedicated hygiene assertion in `test_project_portability_criterion.py` that verifies no bare-DO-NOT-only blocks exist in the authored rubric body.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":["test_reviewer_prompt_hygiene.py line 26: `REVIEWERS_DIR = Path(passes.__file__).parent.parent / 'reviewers'`; line 26: `PLAN_REVIEW_PROMPTS = sorted(REVIEWERS_DIR.glob('plan_review_*.md'))`","Plan names `.rebar/prompts/plan-review-project-portability.md` as a new edit target but does not enumerate `test_reviewer_prompt_hygiene.py` as a consumer to update or extend","ABSENCE: no mention of the hygiene gate or affirmative-framing constraint anywhere in the plan"],"finding":"`test_reviewer_prompt_hygiene.py` scans only `src/rebar/llm/reviewers/plan_review_*.md` for bare-DO-NOT hygiene compliance. The new project rubric at `.rebar/prompts/plan-review-project-portability.md` lives outside that directory and will be silently excluded from the affirmative-framing hygiene gate. The plan neither enumerates this test as a consumer of the new prompt file nor adds a corresponding hygiene check for the project rubric.","group_criteria":null,"group_id":null,"id":"fa62fbd714043050f","impact":0.0,"is_primary":null,"location":"Scope / `.rebar/prompts/plan-review-project-portability.md`","norm_id":"n1af06d85e3702fb7","priority":0.0,"reason":"low-validity","scenarios":["The new rubric is authored with a bare-DO-NOT-only block (e.g. 'Do not emit a finding when silence is the only signal.') — the hygiene gate passes because it never sees the `.rebar/prompts/` file, and the violation ships undetected.","A later contributor edits the project rubric and adds a prohibition without an affirmative redirect — no test catches it."],"severity":"none","suggested_fix":"In `tests/unit/test_project_portability_criterion.py`, add a test (e.g. `k rubric_hygiene`) that reads the authored `.rebar/prompts/plan-review-project-portability.md` and calls `bare_do_not_only_blocks` (importable from `test_reviewer_prompt_hygiene`) asserting an empty result.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add `checklist_item: str` (and optionally `impact: str`) to the `Required finding fields` section of the rubric spec so the rubric-declared contract matches the production `P1Finding` schema and the finder's coaching spec.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Plan specifies five fields: `location: str`, `finding: str`, `scenarios: list[str]`, `evidence: list[str]`, `criteria: list[str]`.","Production P1Finding in passes.py (lines 85-105) defines eight fields: the five above PLUS `impact: str` (default=''), `checklist_item: str` (default=''), `suggested_fix: str` (default='').","plan_review_finder.md coaching spec (line 15-16): '(c) express it as ONE `- [ ]` checklist line (set `checklist_item`)' — required for every finding.","AC `finding_schema_markers` will test for 'five typed field markers specified in this plan', cementing the incomplete set as the test oracle.","ABSENCE: `checklist_item` and `impact` are not mentioned anywhere in the plan's `Required finding fields` specification."],"finding":"The plan's `Required finding fields` section specifies only five typed fields (location, finding, scenarios, evidence, criteria), but the production `P1Finding` schema also mandates `checklist_item: str` — which the finder's coaching spec (`plan_review_finder.md`) explicitly requires for every finding. The rubric document will serve as the machine-readable contract for `finding_schema_markers` tests, and the LLM reading the rubric during Pass 1 will treat `Required finding fields` as authoritative. Omitting `checklist_item` (and `impact`, which Pass 3 uses) from the rubric-declared field list means the rubric is structurally incomplete relative to the schema it must conform to.","group_criteria":null,"group_id":null,"id":"f43556a4d7762defc","impact":0.0,"is_primary":null,"location":"Approach section — `## Required finding fields` specification","norm_id":"nb129cbe8a5d30864","priority":0.0,"reason":"low-validity","scenarios":["A Pass-1 LLM reading the portability rubric sees `Required finding fields` as the authoritative contract and omits `checklist_item` from portability findings; Pass-4 coaching then has no `checklist_item` to render into the coaching output, silently degrading the coaching experience for portability findings.","The `finding_schema_markers` test verifies exactly the five fields the plan lists and passes green even though the production schema expects eight fields — test gives false assurance of schema completeness."],"severity":"none","suggested_fix":"Extend the `Required finding fields` list in the Approach section to include `checklist_item: str` (the finding as ONE `- [ ]` actionable line) and `impact: str` (consequence if unaddressed), matching the full `P1Finding` Pydantic model in `passes.py`. Update the AC `finding_schema_markers` test expectation to verify all seven non-optional fields.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E1"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The Approach requires the rubric to contain a `## Finding threshold` second-level heading (listed first among the four required headings), but no acceptance criterion verifies its presence. This is a described deliverable with no covering criterion.","group_criteria":null,"group_id":null,"id":"f1f2c8961967e7872","impact":0.0,"is_primary":null,"location":"Approach — 'The rubric body uses these exact second-level headings' vs. Acceptance Criteria (all ACs)","norm_id":"n8ae17151fb45da46","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Add: '- [ ] The rubric contains the exact `## Finding threshold` second-level heading. Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_criterion.py -k finding_threshold`.'","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"6c06e89eda93a97d","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":199.8,"llm_calls":29,"llm_ms":459749.2,"total_ms":460076.0,"verify_requests":45},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"3863-a783-b38f-4c8a","ticket_type":"story","verdict":"PASS","verified_at_sha":"79a10387a16d551668c4408716b135376480005f"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784165984135888001,"uuid":"542b2176-337c-441b-96ff-265b171b6255"}