AC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"4e39da8d08b595dd57f7d5dc113a744536bf0e67b8d70cdeddc648bd9d5ae30a","event_uuid":"381b5100-58c5-43de-aad9-ed249bd34c02","position":{"commit_sha":"84570f7cad21b1c8a1e8508fe7cc205604b373f2","position":"1784610422934358001-381b5100-58c5-43de-aad9-ed249bd34c02"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":null,"claim_remote_session":null,"claimed_session":null,"comments":[],"created_at":1784609951762704001,"creation_channel":"cli","deps":[{"link_uuid":"d223a6e4-681e-449b-9e44-19a10878d0ab","relation":"relates_to","target_id":"266e-c8b6-0cb0-44ae"}],"description":"## Problem\nThe `[rebar:<id>]` citation section in `docs/writing-a-passing-plan.md` (shipped by 266e-c8b6-0cb0-44ae) states the edge requirement (this ticket `depends_on -> <id>`, OR `<id> blocks -> this ticket`) but never says the edge must be DIRECT. The shipped verifier `det_citation._edge_verified` checks only the plan ticket's OWN direct deps plus the cited ticket's direct `blocks` (no recursion), so a transitive/indirect dependency does NOT satisfy it — the citation then reads as edge-unbacked and grounds as normal (fails closed) with no warning in the doc. This footgun was hit in practice (a ticket transitively depending on a config ticket still needed a direct edge).\n\n## Approach (docs-only; no behavior change)\nAdd one clause to the EXISTING citation section stating the edge must be DIRECT and that a transitive/indirect dependency does not count. Rationale for docs-only scope: the verifier ALREADY implements direct-edge-only checks correctly (`det_citation._edge_verified` has no recursion) — the code is right and only the documentation lags, so the sound fix is to align the doc, not change any behavior.\n\n## Grounding (verified via Read)\n- CONFIRMED `docs/writing-a-passing-plan.md` contains the \"## Citing a prerequisite's symbol (`[rebar:<id>]`)\" section with the edge-requirement paragraph.\n- CONFIRMED `src/rebar/llm/plan_review/det_citation.py` `_edge_verified` checks only direct edges (the plan ticket's own `deps` for `depends_on -> C`, and `resolve_deps(C)` for `blocks -> P`) — no recursive closure — so \"direct\" is accurate to the shipped behavior.\n\n## Acceptance criteria\n- [ ] The citation section explicitly states the upstream edge must be DIRECT and that a transitive/indirect dependency does not satisfy it. PROVE: `grep -Eiqw \"direct\" docs/writing-a-passing-plan.md && grep -Eiq \"transitive|indirect\" docs/writing-a-passing-plan.md` (the first grep is word-anchored so it does not match \"indirect\").\n- [ ] The change is confined to the single doc file. PROVE: `[ \"$(git diff --name-only origin/main | wc -l)\" -eq 1 ] && git diff --name-only origin/main | grep -qxE \"docs/writing-a-passing-plan.md\"`.\n\n## Files likely touched\n- docs/writing-a-passing-plan.md\n\n## Estimated scope: XS","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"docs/writing-a-passing-plan.md","reason":"add a direct-edge/transitive-does-not-count clause to the [rebar:<id>] citation section"}],"keyring":[],"managed_refs":[["relates_to","266e-c8b6-0cb0-44ae"]],"parent_id":null,"parent_status_uuid":"","preconditions_summary":{"status":"pre-manifest"},"priority":3,"reverts":[],"status":"open","tags":["docs","plan-review"],"ticket_id":"01f8-11eb-4772-4c80","ticket_type":"task","title":"writing-a-passing-plan: [rebar:<id>] citations require a DIRECT edge (transitive deps do not count)","verify_commands":[]},"source_event_uuids":["f79c1c54-7f1c-4a58-853a-e1e9a14708ed","510bcaee-9e99-43f8-a59c-eb71168d3926","d223a6e4-681e-449b-9e44-19a10878d0ab","381b5100-58c5-43de-aad9-ed249bd34c02"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784610422934358002,"uuid":"d3f1a495-5a89-4e35-88aa-38f1a17cdba1"}