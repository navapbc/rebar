{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","data":{"compacted_at":1784754915729743432,"compiled_state":{"alias":"bilineate-obsidian-coot","assignee":"","attestations":{"plan-review":{"algorithm":"sshsig","author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","envelope":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.opcert.v1+json\", \"signatures\": [{\"keyid\": \"ade0f2ef-51cc-45a2-bb97-c09846cd3df5\", \"sig\": \"\"}]}","head_sha":"bd7572a9ef4f49567d56981c9576115f90914926","key_id":null,"kind":"plan-review","manifest":["plan-review: PASS","ticket: ce4d-c3ca-5412-4798","material: 371c8ba68d3d6eea","model: claude-sonnet-4-6","runner: pydantic_ai","blocking: 0","advisory: 14","rebar-version: 0.9.1 (0ea16f5f4)","regver: b058e30f0de6a907","verified-at-sha:c44f3fb70655b81037d0a6aa99b3777457e67eee","dep absent src/rebar/_engine/rebar_reconciler/_backend.py","dep absent src/rebar/_engine/rebar_reconciler/adapters/jira/backend.py","dep absent tests/reconciler/test_backend_contract.py"],"material_fingerprint":"371c8ba68d3d6eea","merged_log_commit":"c44f3fb70655b81037d0a6aa99b3777457e67eee","principal":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","signature":null,"signed_at":1784748302386299000}},"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","authorship":{"signed":14,"unsigned":0},"authorship_ledger":[{"content_hash":"fa2762c83906299d98596fae6489d9334f1d54fadbc49ebbbacc0ac1ce0a6837","event_uuid":"ae5e50ba-7f8b-4c7f-b7d9-12eb90a35ebe","position":{"commit_sha":"65543640571d4b608410b0d8bead5f89341c9339","position":"1784695335201222001-ae5e50ba-7f8b-4c7f-b7d9-12eb90a35ebe"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAE