{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","data":{"compacted_at":1784759817204458502,"compiled_state":{"alias":"symbolic-drafty-anaconda","assignee":"","attestations":{"plan-review":{"algorithm":"sshsig","author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","envelope":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.opcert.v1+json\", \"signatures\": [{\"keyid\": \"ade0f2ef-51cc-45a2-bb97-c09846cd3df5\", \"sig\": \"\"}]}","head_sha":"bd7572a9ef4f49567d56981c9576115f90914926","key_id":null,"kind":"plan-review","manifest":["plan-review: PASS","ticket: dfb9-d2d1-455d-48d9","material: 8cb6cc45f320efc8","model: claude-sonnet-4-6","runner: pydantic_ai","blocking: 0","advisory: 12","rebar-version: 0.9.1 (0ea16f5f4)","regver: b058e30f0de6a907","verified-at-sha:c44f3fb70655b81037d0a6aa99b3777457e67eee","dep f9789a9a8c5220c08dd0d6e580dd9bdb161f8a021948929172b44d74aae280b2 src/rebar/_engine/rebar_reconciler/__main__.py","dep 2c4802b9fd60c76afac5eee4cf0ce379768dcfebeabf720f48ec1675f726808d src/rebar/_engine/rebar_reconciler/_loader.py","dep absent src/rebar/_engine/rebar_reconciler/adapters/jira/acli.py","dep d12cc98e3f4972ddbff92cf267d9ba71022ff2b6f83c4fffe9afeb1f8f6dd6fe src/rebar/_engine/rebar_reconciler/adapters/jira/jira_fields.py","dep 43f04c7392d36968415e511a3b49dda312729e500a67c20401d6881bccae301b src/rebar/_engine/rebar_reconciler/inbound_fields.py","dep a0afda9905f019b036fb4a564cbba05cceacbc29c096530a535bf5425b09bba4 tests/unit/rebar_reconciler/state/test_config_jira_wiring.py"],"material_fingerprint":"8cb6cc45f320efc8","merged_log_commit":"c44f3fb70655b81037d0a6aa99b3777457e67eee","principal":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","signature":null,"signed_at":1784749822211256000}},"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","authorship":{"signed":16,"unsigned":0},"authorship_ledger":[{"content_