{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","author_sig":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","data":{"coaching":[{"coaching":"Pin down local write-gate refusal invocation and exit code with a concrete worked example.","decision":"advisory","finding_refs":["f426db301900ce1ac"],"move_id":"6","move_name":"specification by example","subject":"local write-gate refusal invocation and exit code"},{"coaching":"Plan how minimum observation window for pre-flip gate will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f9caa11ce15206a5b"],"move_id":"9","move_name":"plan the verification","subject":"minimum observation window for pre-flip gate"},{"coaching":"Pin down author_sig non-emptiness assertion in shell pipeline with a concrete worked example.","decision":"advisory","finding_refs":["fb086089e7c3564d5","f2901015fb1000c22"],"move_id":"6","move_name":"specification by example","subject":"author_sig non-emptiness assertion in shell pipeline"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":7,"blocking":0,"dropped":5,"indeterminate":0},"det":{"P1":{"ac_items":5,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","ran":true,"references":0,"resolved":0,"status":"pass"},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":5,"blocking":false,"desc_chars":6264,"file_impact":1,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":5,"blocking":false,"name":"ac-quality","ran":true,"status":"pass","verify_commands_linted":41,"verify_lint_abstained":40},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":1586,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":1,"name":"file-impact-coverage","ran":true,"status":"pass"}},"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":305.1,"llm_calls":28,"llm_ms":359555.7,"total_ms":360274.5,"verify_requests":19},"remediation":{"baseline":"sidecar","eligible":false,"reasons":{"code_unchanged":false,"plan_changed":false,"registry_unchanged":false,"sidecar_baseline":false,"within_window":false}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","G5","T12","T2","T4","T5b","T5e","T6","T9","hedge"]}},"findings":[{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add a pinned proving command for the local write-gate refusal test, specifying the exact `rebar` subcommand, the env-var or config key to unset for the signing key, and the expected non-zero exit — e.g. `REBAR_SIGNING_KEY='' rebar claim --title 'test' 2>&1; [ $? -ne 0 ]`.","cohort":["E2","E6","F1"],"criteria":["E2","E6"],"decision":"advisory","drop_reason":null,"evidence":["Plan text: 'the local write-gate refuses an unsignable non-exempt write with the signing key unset (with require_authenticated=true, a non-exempt write with no resolvable signing key is refused, exit non-zero)'","No rebar command or environment variable name is given for unsetting the signing key","Contrast with AC1 which provides explicit rebar commands with flags"],"finding":"AC3 describes the local write-gate refusal test in prose ('the local write-gate refuses an unsignable non-exempt write when the signing key is unset') but provides no pinned rebar invocation — an executor cannot reproduce this check without guessing the correct subcommand, flags, and environment setup.","group_criteria":null,"group_id":null,"id":"f426db301900ce1ac","impact":0.67,"is_primary":null,"location":"Acceptance Criteria — AC3 'Enforcement is real, not advisory', local write-gate paragraph","norm_id":"na9cf0b68ceb69e13","priority":0.5863,"reason":"default-advisory","scenarios":["An executor runs an arbitrary rebar write subcommand without knowing which subcommand triggers a non-exempt write, or which env-var/config key controls the signing key — the test is ambiguous and may be run incorrectly, producing a false-positive pass."],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] State a concrete minimum observation window (e.g. 'at least one full hourly local cycle = 60 min') and provide trigger commands or a confirmation check for the enrich drain and reconciler (e.g. `rebar enrich-drain --run-once && rebar reconcile --run-once`) so all writers are deterministically exercised rather than waiting for organic runs.","cohort":["E2","E6","F1"],"criteria":["E2","F1"],"decision":"advisory","drop_reason":null,"evidence":["Plan text: 'let the writers run (or trigger each)' — 'or trigger each' is presented as equivalent but triggering the enrich drain and reconciler requires knowing their invocation","Plan text: 'local auto-updates hourly; CI/Gerrit deploy from main' — implies a ~1-hour minimum window for local, but this is implicit","Plan text: 'the enrich drain, and the reconciler' — no trigger command or confirmation check is provided for these two processes"],"finding":"The minimum observation window for the PRE-FLIP GATE is unspecified — 'let the writers run (or trigger each)' does not state how long to wait or how to confirm the enrich drain and reconciler have been exercised, making 'EVERY active writer operates' un-verifiable in-session without a time bound or trigger confirmation.","group_criteria":null,"group_id":null,"id":"f9caa11ce15206a5b","impact":0.536,"is_primary":null,"location":"Acceptance Criteria — PRE-FLIP GATE, 'let the writers run (or trigger each)' and 'Record C0, the window'","norm_id":"nd6f3fc1293dffc01","priority":0.402,"reason":"default-advisory","scenarios":["An executor waits an arbitrary period, observes no new events from the enrich drain (because it happened to have nothing to process), and incorrectly concludes the drain is signing-compliant — the gate passes vacuously for that writer."],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Resolve the contradiction between 'What' (describes replacing an existing `enforce_since` rollout-prep pin `ce3f8bc...`) and AC#2 ('enforce_since is written here for the first time'): either clarify that the prior pin was set outside this epic's child tasks (and reword AC#2 accordingly, e.g. 'no earlier child of this epic modifies enforce_since; the current value ce3f8bc... was set by a rollout-prep step outside the epic') or, if enforce_since truly does not yet exist, remove the 'replacing the current rollout-prep pin' language from What.","cohort":["COH","E1","T4"],"criteria":["COH","E1"],"decision":"advisory","drop_reason":null,"evidence":["What: 'replacing the current rollout-prep pin `ce3f8bcbe13d37e93a0758f7f73cb3ebeac3b043`'","AC#2: 'enforce_since is written here for the first time (no earlier child modifies it)'"],"finding":"The 'What' section says enforce_since is currently set to a 'rollout-prep pin' (`ce3f8bcbe13d37e93a0758f7f73cb3ebeac3b043`) and this change 'replaces' it, implying enforce_since already exists in rebar.toml. Yet AC#2 asserts 'enforce_since is written here for the first time (no earlier child modifies it).' These two statements directly contradict each other, leaving the implementer uncertain whether enforce_since currently exists in rebar.toml or not.","group_criteria":null,"group_id":null,"id":"f23a2d097942780c7","impact":0.536,"is_primary":null,"location":"What section (first bullet) vs. AC#2","norm_id":"n3d016a4bcba220a2","priority":0.402,"reason":"default-advisory","scenarios":["An implementer checks rebar.toml and finds enforce_since already present (rollout-prep pin), contradicting 'first time' language — unclear if prior pin was set by a non-child task outside the epic, or if the AC is simply wrong.","A post-hoc auditor reading the plan cannot determine the prior state of enforce_since, making the AC's proving command ambiguous in what it proves."],"severity":"major","suggested_fix":"In AC#2, replace 'enforce_since is written here for the first time (no earlier child modifies it)' with 'no earlier child of this epic has modified enforce_since to its final value; the pre-existing rollout-prep pin (ce3f8bc...) is replaced atomically in this single commit.' In the What section, keep the 'replacing' language as-is since it correctly describes the mechanical edit.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"medium","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Extend proving command (b) with a `jq`-based JSON content check so the assertion is machine-executable, e.g.: pipe the filenames into `xargs -I{} sh -c 'jq -e \\'(.author_sig // \"\") | length > 0\\' \".tickets-tracker/{}\" || { echo \"UNSIGNED: {}\"; exit 1; }'` — or equivalent — so empty/absent `author_sig` causes a non-zero exit.","cohort":["E2","E6","F1"],"criteria":["E6","F1"],"decision":"advisory","drop_reason":null,"evidence":["Plan text: 'git -C .tickets-tracker diff --name-only --diff-filter=A C0..origin/tickets | grep -E \\'/[0-9].*\\\\.json$\\' | grep -v -- \\'-SNAPSHOT.json\\'' — this pipeline yields filenames only","Plan text: 'yields only files whose JSON has a non-empty author_sig' — this assertion is in prose but no `jq` / `xargs` step follows to actually read JSON content","Defect taxonomy match: (6) prose-vs-structured assertion target — asserting on filenames, not on the structured artifact"],"finding":"The PRE-FLIP GATE proving command (b) outputs filenames but never actually reads JSON to assert `author_sig` is non-empty — the prose claim 'yields only files whose JSON has a non-empty author_sig' is not machine-executable as written, leaving the structural assertion unverified.","group_criteria":null,"group_id":null,"id":"fb086089e7c3564d5","impact":0.44,"is_primary":null,"location":"Acceptance Criteria — PRE-FLIP GATE, proving command (b)","norm_id":"n904b3b3ca566760c","priority":0.22,"reason":"default-advisory","scenarios":["A writer emits an in-scope event file with an empty or missing author_sig field; the filename-only grep passes because the filename matches the pattern, but the JSON content is never checked — the gate silently misses the violation."],"severity":"minor","suggested_fix":"Replace the prose assertion with a composed shell command:\n```\ngit -C .tickets-tracker diff --name-only --diff-filter=A \"$C0\"..origin/tickets \\\n  | grep -E '/[0-9][^/]*\\.json$' | grep -v -- '-SNAPSHOT.json' \\\n  | while IFS= read -r f; do\n      jq -e '(.author_sig // \"\") | length > 0' \".tickets-tracker/$f\" > /dev/null \\\n        || { echo \"UNSIGNED: $f\"; exit 1; }\n    done\n```\nThis makes the assertion executable and fails fast on the first unsigned event.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Strengthen AC1 proving command (b) to actually assert `author_sig` content — e.g., pipe the filename list into a `python -c` or `jq` snippet that reads each file and asserts `.author_sig // \"\" | length > 0`; or rely solely on command (a) (`rebar verify-identity --all --require-authenticated --since C0`) and drop the false claim that command (b) verifies JSON content.","cohort":["E4"],"criteria":["E4"],"decision":"advisory","drop_reason":null,"evidence":["Plan text: 'git -C .tickets-tracker diff --name-only --diff-filter=A C0..origin/tickets | grep -E \"/[0-9].*\\\\.json$\" | grep -v -- \"-SNAPSHOT.json\" yields only files whose JSON has a non-empty author_sig'","The pipeline produces filenames only; no `jq` or `python` step reads the JSON content to assert author_sig presence","src/rebar/_commands/verify_authorship.py:341 — author_sig presence is checked at runtime by the tool, not by filename"],"finding":"AC1 proving command (b) is described as confirming that non-SNAPSHOT event files 'have a non-empty author_sig', but the shell pipeline as written only filters filenames — it does not open JSON files to assert non-empty author_sig content. The plan's prose asserts the pipeline 'yields only files whose JSON has a non-empty author_sig', but the grep does no JSON parsing; filenames passing the filter could still contain unsigned events (empty or absent author_sig). AC1(a) via `rebar verify-identity --all --require-authenticated --since C0` covers this gap through the tool, but the plan describes command (b) as an independent corroborating check, which it is not.","group_criteria":null,"group_id":null,"id":"f2901015fb1000c22","impact":0.44,"is_primary":null,"location":"Acceptance Criteria — PRE-FLIP GATE, proving command (b)","norm_id":"n321f95a40bdc5893","priority":0.22,"reason":"default-advisory","scenarios":["A writer emits an unsigned non-SNAPSHOT event (e.g., a still-old build writing a bare STATUS event); command (b) lists the file but does not detect the missing author_sig; the operator incorrectly concludes 0ba4 is live everywhere and proceeds to flip — causing enforced unsigned events post-boundary."],"severity":"minor","suggested_fix":"Replace the pure-filename grep with a step that reads each file: e.g., `git -C .tickets-tracker diff --name-only --diff-filter=A C0..origin/tickets | grep -E '/[0-9].*\\.json$' | grep -v -- '-SNAPSHOT.json' | while IFS= read -r f; do python -c \"import json,sys; d=json.load(open('.tickets-tracker/'+sys.argv[1])); sys.exit(0 if d.get('author_sig') else 1)\" \"$f\" || echo \"UNSIGNED: $f\"; done` and assert the loop emits no lines. Or simply remove the erroneous description of what command (b) proves and document it as a filename-only sanity check, with command (a) being the authoritative check.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Correct AC2's 'enforce_since is written here for the first time' language to 'enforce_since is updated here from its rollout-prep pin to the 8d91 anchor SHA' — reflecting that the TOML field already exists and this change replaces its value.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["rebar.toml line 97: `enforce_since = \"ce3f8bcbe13d37e93a0758f7f73cb3ebeac3b043\"` — the field is already present with a rollout-prep pin","Plan AC2: 'enforce_since is written here for the first time (no earlier child modifies it)'","The proving command checks the value correctly but the 'first time' claim is false and could mislead an auditor or a future reviewer checking 8d91's scope"],"finding":"AC2 claims `enforce_since` is 'written here for the first time (no earlier child modifies it)' but the field already exists in `rebar.toml` with a rollout-prep pin value (`ce3f8bcbe13d37e93a0758f7f73cb3ebeac3b043`). The plan is *changing* an existing value, not making a first write.","group_criteria":null,"group_id":null,"id":"f377c766f2a6e2535","impact":0.264,"is_primary":null,"location":"AC2 — 'The flip is atomic and pins the 8d91 anchor'","norm_id":"n2e3575c605129912","priority":0.198,"reason":"default-advisory","scenarios":["A reviewer checking the AC proof may look for a git diff showing a net-new TOML key addition but instead see only a value replacement, causing confusion about whether the AC is satisfied.","If 8d91 or another dependency story had already changed enforce_since to the anchor SHA, this AC's 'first time' language would silently mask a double-write."],"severity":"minor","suggested_fix":"Replace: 'enforce_since is written here for the first time (no earlier child modifies it)'\nWith: 'enforce_since is changed here from its rollout-prep pin to the 8d91 anchor SHA; no earlier child in this epic sets it to the anchor value (8d91 records the anchor but explicitly does not write rebar.toml).'","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Clarify AC2's 'written here for the first time' language to accurately reflect that `enforce_since` already exists in `rebar.toml` (set by the 27ae rollout-prep fix) and this change **updates** its value from the rollout-prep pin (`ce3f8b...`) to the 8d91 anchor (`8dcef7...`), rather than inserting the key for the first time.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["AC2 text: 'enforce_since is written here for the first time (no earlier child modifies it)'","rebar.toml line 97: `enforce_since = \"ce3f8bcbe13d37e93a0758f7f73cb3ebeac3b043\"` — the key already exists with the rollout-prep pin","Plan 'What' section correctly says 'replacing the current rollout-prep pin ce3f8bcbe13d37e93a0758f7f73cb3ebeac3b043' — showing the plan author knows the key exists, but AC2 contradicts this with 'for the first time'"],"finding":"AC2 states 'enforce_since is written here for the first time (no earlier child modifies it)' — but `rebar.toml` already contains `enforce_since = \"ce3f8bcbe13d37e93a0758f7f73cb3ebeac3b043\"` (the rollout-prep pin from the 27ae fix). An implementer reading AC2 literally will be uncertain whether to INSERT a new key or UPDATE the existing one, and may incorrectly treat the key's prior existence as evidence a sibling ticket already landed part of this work.","group_criteria":null,"group_id":null,"id":"fafa4de2d66a3161e","impact":0.264,"is_primary":null,"location":"Acceptance Criteria — AC2 ('The flip is atomic and pins the 8d91 anchor')","norm_id":"n9521260834e0423a","priority":0.165,"reason":"default-advisory","scenarios":["An implementer reads AC2 and, seeing 'written here for the first time', checks rebar.toml, finds enforce_since already present, and incorrectly concludes another ticket has already partially landed this change — causing confusion or a stalled implementation.","An implementer treats the presence of the existing key as a sign the AC is stale and skips verification, potentially missing that the *value* must change from ce3f8b... to 8dcef7..."],"severity":"minor","suggested_fix":"Replace the AC2 parenthetical '(no earlier child modifies it)' with '(its value is updated here from the rollout-prep pin to the 8d91 anchor — no sibling or child changes the final anchor value before this flip)' to accurately describe the rebar.toml state.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an ADR or CLAUDE.md section documenting the enforcement policy: the semantics of `enforce_since`, why SNAPSHOT events are the sole unsigned-permitted type (and how `authorship_ledger` compensates), and the rationale for the 8d91 anchor SHA.","cohort":["T2","T5b","T5e"],"criteria":["T5e"],"decision":"dropped","drop_reason":null,"evidence":["Scope says 'plus a runbook/rollback note' but no mention of ADR or design-doc update.","The SNAPSHOT exemption ('SNAPSHOT is the sole permitted unsigned type (a compaction artifact the merge-gate re-verifies via the snapshot's authorship_ledger)') is a non-obvious architectural rule mentioned only in an AC comment, not in a durable decision record.","Future maintainers encountering the `enforce_since` pin or the SNAPSHOT carve-out in code will have no canonical reference for why these choices were made."],"finding":"No ADR, CLAUDE.md, or design-doc update is planned to capture the architectural decisions introduced by enforcement: the semantics of `enforce_since`, the SNAPSHOT exemption rule (why SNAPSHOTs are the sole permitted unsigned type and how the `authorship_ledger` re-verification compensates), and the enforcement policy itself.","group_criteria":null,"group_id":null,"id":"ffa89da02c58749f8","impact":0.0,"is_primary":null,"location":"## Scope / ## What / AC: 'The flip is atomic and pins the 8d91 anchor'","norm_id":"n45c755b0b08a6c3b","priority":0.0,"reason":"veto:absence-refuted","scenarios":["A future engineer modifying the merge-gate or adding a new event type doesn't know SNAPSHOT is exempt and why, leading to accidental enforcement breakage or unsafe bypass.","The `enforce_since` anchor SHA becomes opaque over time as the context of bug 8d91 fades — without an ADR, its provenance is lost."],"severity":"none","suggested_fix":"Create `docs/adr/NNN-identity-enforcement-flip.md` (or a CLAUDE.md section) covering: (1) the `enforce_since` boundary and its anchor SHA provenance, (2) the SNAPSHOT exemption and its re-verification contract via `authorship_ledger`, (3) the rollback procedure reference. Link it from the runbook note.","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an observability requirement: enforcement gate rejections must emit a structured log line (or metric increment) that operators can monitor or alert on post-flip, and the rollback runbook should specify the log query / alert that signals 'a writer is being rejected'.","cohort":["T2","T5b","T5e"],"criteria":["T5b"],"decision":"dropped","drop_reason":null,"evidence":["Rollback AC says 'if a writer surface unexpectedly fails post-flip' but specifies no detection mechanism (no alert, no metric, no log query).","No mention of instrumenting the enforcement rejection path with a log event or metric that operators can monitor.","The pre-flip gate validates writers before the flip, but post-flip silent failures (e.g., a writer surface that was missed) would be detectable only by 'main goes red' or manual observation."],"finding":"The plan specifies no observability mechanism (metric, log line, or alert) for when the enforcement gate fires and rejects a write in production. The rollback is triggered by a writer 'unexpectedly fails post-flip', but there is no defined detection path — operators have no real-time signal that enforcement is rejecting legitimate writes.","group_criteria":null,"group_id":null,"id":"fad425b0371439836","impact":0.0,"is_primary":null,"location":"AC: 'A documented rollback path exists' / ## What: 'Provide a documented fast-revert (rollback) path'","norm_id":"nfa7d981447b69ab1","priority":0.0,"reason":"veto:absence-refuted","scenarios":["A writer surface not covered in the pre-flip window (e.g., a rarely-triggered reconciler path) starts emitting unsigned events post-flip; operators have no alert and discover the problem only when a push fails or data is missing.","The enforcement gate starts rejecting writes silently (non-zero exit swallowed by a wrapper script); without an instrumented log line, the failure is invisible until downstream data gaps appear."],"severity":"none","suggested_fix":"In the runbook/rollback note AC, add: 'Post-flip monitoring: query `rebar verify-identity` rejection logs (or a named metric `identity.enforcement.rejected_count`) for the 24h window after the flip; alert if non-zero. The rollback trigger is any unexpected non-zero rejection on a known-good writer surface.'","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add at least one staged-rollout step between 'pre-flip gate passes' and 'full enforcement on' — for example, enable enforcement locally for one session (or one writer surface) and confirm AC4 before landing the config change that covers all surfaces.","cohort":["T12","T6","T9"],"criteria":["T12"],"decision":"dropped","drop_reason":null,"evidence":["'the **only** change that writes both the flag and `enforce_since`'","AC2: '`identity.require_authenticated = true` **and** `enforce_since = ...` land in **one** change'","No intermediate canary or per-surface rollout step is described between pre-flip validation and full enforcement."],"finding":"The flip is a single 100%-traffic atomic switch with no staged/canary rollout step. Although the pre-flip gate (AC1) de-risks it, the rubric binary check requires a behavior change to reach production via flag/canary/staged rollout rather than a one-shot flip. The plan has no intermediate stage (e.g., enabling enforcement on a single writer surface first, verifying, then broadening) between 'all writers proven-signed' and 'full enforcement on'.","group_criteria":null,"group_id":null,"id":"f850eff15b3298f31","impact":0.0,"is_primary":null,"location":"What section / AC2 (atomic flip)","norm_id":"ne2dc7b97540f2234","priority":0.0,"reason":"low-validity","scenarios":["If the pre-flip gate passes but a writer surface has a latent signing bug only triggered in production load patterns, all pushes go red simultaneously with no partial-exposure safety net.","A writer that auto-updates config hourly could race: it picks up the new config mid-operation window before the operator has confirmed all surfaces pass AC4."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"system","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"medium","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Before landing the flip, execute a dry-run of the rollback procedure in a non-production or local context (e.g., apply the revert diff, confirm `rebar verify-identity` exits 0, confirm a write succeeds) and record the result in AC5 alongside the operator attestation.","cohort":["T12","T6","T9"],"criteria":["T12"],"decision":"dropped","drop_reason":null,"evidence":["AC5: '[operator-attested] the rollback step is captured in the runbook (recorded as a comment on this ticket with the exact revert diff + procedure)'","No AC requires a dry-run or test execution of the revert before the flip is landed.","The word 'tested' does not appear in AC5."],"finding":"The rollback path is documented but not demonstrated/tested pre-flip. AC5 requires '[operator-attested]' evidence (a comment on the ticket with the revert diff), but never requires the operator to actually execute the revert in a test or staging context to prove it works end-to-end. The rubric requires a 'tested' way to undo quickly.","group_criteria":null,"group_id":null,"id":"f4d3009c1e916146c","impact":0.0,"is_primary":null,"location":"AC5 — Documented rollback path","norm_id":"nf43498c14e8c4a34","priority":0.0,"reason":"low-validity","scenarios":["The revert diff is written correctly but a Gerrit merge rule or CI hook introduced since 8d91 blocks the revert commit, making the fast-revert slower than expected.","The rollback lands but some writers cached the enforcement flag in memory and do not re-read config for up to an hour, leaving enforcement active past the revert."],"severity":"none","suggested_fix":"Add to AC5: 'Prior to landing the flip, the operator has executed the revert diff in a local test environment, confirmed `rebar verify-identity --all` exits 0 post-revert, and confirmed a representative write succeeds. Evidence recorded in the runbook comment.'","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Document the expected behavior for already-running local processes during the up-to-1-hour config auto-update window (e.g., specify that signing is unconditional post-0ba4 regardless of config, or that operators should restart long-running local processes after the flip lands).","cohort":["T12","T6","T9"],"criteria":["T9"],"decision":"dropped","drop_reason":null,"evidence":["'local auto-updates hourly; CI/Gerrit deploy from `main`'","AC1 validates writers BEFORE the flip, but does not specify what happens to already-running local processes that hold the old config after the flip lands.","No AC or scope item addresses restarting or invalidating long-running local processes after the config change."],"finding":"The config-flip coexistence window for long-running local processes is not fully addressed. The plan notes local processes auto-update config hourly, meaning after the flip commits there is up to a ~1-hour window where some local rebar processes read the new config (enforcement on) while others still hold the old config (enforcement off). The pre-flip gate proves events are already signed, but if a local process holds a stale in-memory config that still bypasses signing, it could emit unsigned events that the now-live merge-gate rejects.","group_criteria":null,"group_id":null,"id":"f52367aba6e36646c","impact":0.0,"is_primary":null,"location":"Why section ('local auto-updates hourly') / AC1 pre-flip gate","norm_id":"ncc94b3915c8a9569","priority":0.0,"reason":"low-validity","scenarios":["A developer has a local rebar session open at flip time; it auto-updates config within the hour and then refuses its own pending write because the signing key is not set — surprising the developer with a mid-session failure.","A long-running local reconciler process does not pick up the new config for up to 59 minutes and continues emitting events; the merge-gate rejects them if signing was conditional on the config value."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"23f532f0f4a521ef","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":305.1,"llm_calls":28,"llm_ms":359555.7,"total_ms":360274.5,"verify_requests":19},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"8d39-85d7-8f34-45e6","ticket_type":"story","verdict":"PASS","verified_at_sha":"43d1545237745f4666dcc13c81587c824251e51d"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784257096347700001,"uuid":"87ef7ce9-a3c2-4963-8e72-05b053e8ed47"}