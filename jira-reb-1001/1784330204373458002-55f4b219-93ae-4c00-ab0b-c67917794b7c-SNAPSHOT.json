{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","data":{"compacted_at":1784330204373458002,"compiled_state":{"alias":null,"assignee":null,"attestations":{"plan-review":{"algorithm":"sshsig","author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","envelope":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.opcert.v1+json\", \"signatures\": [{\"keyid\": \"ade0f2ef-51cc-45a2-bb97-c09846cd3df5\", \"sig\": \"\"}]}","head_sha":"95cbc7bb4cbcd7f8de3ff15753b1f421469de5e1","key_id":null,"kind":"plan-review","manifest":["plan-review: PASS","ticket: jira-reb-1001","material: 843c9d6e817d692b","model: claude-sonnet-4-6","runner: pydantic_ai","blocking: 0","advisory: 4","rebar-version: 0.8.0 (95cbc7bb4-dirty)","regver: efe0f612161b342c","verified-at-sha:95cbc7bb4cbcd7f8de3ff15753b1f421469de5e1","dep b199211117f28cfabfb0565e43295a87b2f79d4d0c0d9e3bcc237e98c2957be1 .rebar/criteria_routing.json","dep absent .rebar/evals/code-review-project-review-phase-boundaries.eval.yaml","dep absent .rebar/prompts/code-review-project-review-phase-boundaries.md","dep c2d3e3aec191dbd0aa821223472c1c64fc0e4e3ac71ba0868f45c3039d5cd304 docs/llm-framework.md","dep a9d4f83a9385fb71f1ab019cbee1f1bad7cf2519f5fe537ff70bbd69b313ce0b src/rebar/_cli/_llm_eval_commands.py","dep 7484afe8411725047c7ee7e92401960883b533510a203425e01f394dd0f29cc2 src/rebar/llm/code_review/batch_runner.py","dep d7bbafc995a10cd840b3bdf2041e83e5ed9995ddd3249740ddee5ff240e1d930 src/rebar/llm/code_review/workflow_ops.py","dep 1c00daa0e8238f313bd30b7e4f14a70aa5b98b1ee9f6a663089302f90bba1543 src/rebar/llm/criteria/ids.py","dep 402d078ca397f123412c5467c7beb7dfd37eea4b1e83224602fc2b9054d4fc06 src/rebar/llm/evals/eval.py","dep f8921ed322e282aca9177915023cccec4d3b05f2f8caed4f67d8d0d5df03e579 src/rebar/llm/evals/eval_solver.py"],"material_fingerprint":"843c9d6e817d692b","merged_log_commit":"95cbc7bb4cbcd7f8de3ff15753b1f421469de5e1","principal":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","signature":null,"signed_at":1784330204373162000}},"author":"reconciler","authorship":{"signed":14,"unsigned":1},"authorship_ledger":[{"content_hash":"745f59405a84c7b15dcbcc7bd3b832ff20e035a1ac34394a5eead00355233fe2","event_uuid":"557f4301-02ba-4886-bae5-55c5023a3c3a","position":{"commit_sha":"9521b40644f5a74cf4f00c1acd3841a4f68aa230","position":"1784317484247374001-557f4301-02ba-4886-bae5-55c5023a3c3a"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"5850bb67bcf0ade4b3a6a314af82beb2f945718774edc53eca873927f6f1b03d","event_uuid":"1b400851-46e8-44de-a9b2-a19f4cce5444","position":{"commit_sha":"72cf9cf85853668cf8e3b051de0c6de0a803efca","position":"1784317487366133001-1b400851-46e8-44de-a9b2-a19f4cce5444"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"bf511480c08f6c38dd908f0273ee92abf2b14374ca2b995791544a152e774a5a","event_uuid":"4d8e163d-639c-4e06-a034-0519fb59f8d7","position":{"commit_sha":"baf489afc5f9b6062b742a6c40ceceb1237935f4","position":"1784317616525363001-4d8e163d-639c-4e06-a034-0519fb59f8d7"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"d9097e77fd5fa4e37dfc87919ee0a604ee7f2a7c948a0e2f757a75e2ff2227aa