f66-423b-bf9b-c32e7a6d6921"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"9b577bb008d9b9ffeb793597fc2a662ce8c38bc94cae755fc9382955e44464ff","event_uuid":"342ecd10-a9e5-474f-adc6-bb12df3a2b60","position":{"commit_sha":"873339cc1b4e2b6c17fc7d4a9912c6dabdc31f66","position":"1784838306245340001-342ecd10-a9e5-474f-adc6-bb12df3a2b60"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"9a03c1053c2dd7d2505c00a4c4961609eaaebf3f6fd603647c15dd2ed8b6a9ec","event_uuid":"4b3404a5-6f87-4109-905f-f7eb53f284ab","position":{"commit_sha":"d3d1f98746d56ce29277f37a260b5d9db63d177c","position":"1784838724919588963-4b3404a5-6f87-4109-905f-f7eb53f284ab"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-218_agent","claim_remote_session":null,"claimed_session":"765ab0e6-1638-418e-8e23-7da2a32dab32","comments":[],"created_at":1784835937941011001,"creation_channel":"cli","deps":[{"link_uuid":"6560e831-9f43-4be0-aa16-4312f29817d5","relation":"discovered_from","target_id":"80af-c876-5856-4159"}],"description":"## Context / Problem\nDiscovered from 80af. `rebar transition <id> in_progress closed` (with verify.require_completion_verification_for_close=true) does its work in TWO steps against the git tree — verify, then sign — reading HEAD INDEPENDENTLY each time. A commit landing in the verify→sign window splits them; rebar correctly refuses to attest a tree it didn't verify, but CLOSES THE TICKET ANYWAY without a completion attestation, and its suggested remedy (\"re-close to certify\") is a no-op because the ticket is already closed. Full report (evidence, repro, analysis): ~/.claude/jobs/e9e3a20d/tmp/rebar-completion-race-bug-report.md\n\n## Evidence (observed)\nClosing 4030-df44-540f-4ec0 from a worktree another agent was committing into:\n  \"Warning: closed ... WITHOUT a completion signature — the code drifted between verify (5d2b47f) and sign (70ca791); not attesting stale state. Re-close to certify against the current tree.\"\n- 5d2b47f = the ticket's real merged work (verifier checked this).\n- 70ca791 = an UNRELATED in-flight commit from another agent in the shared worktree (signer saw this).\nPost: ticket closed, attestation kinds = ['plan-review'] (NO 'completion'). The suggested re-close is a no-op (already closed). Only \"recovery\" is --force-close (itself the 'did not validate' signal) or fabricating a manifest via `rebar sign` — not acceptable.\n\n## Root cause (hypothesis)\nTOCTOU in transition_close.py: verify_completion(ref=\"HEAD\") resolves HEAD→A; the pre-sign drift guard reads head_sha() again→B; A!=B → refuse sign; the close transition proceeds regardless (verify→close→sign ordering). It treats \"the working tree\" as an ambient global instead of pinning one revision for the whole verify+sign+close unit. Note: 80af's --ref fix only made the NON-default (--ref) path coherent (verify and sign both pin the ref); the DEFAULT (no --ref) path STILL reads HEAD twice and still splits.\n\n## Expected\nEither (a) pin ONE revision for the whole verify+sign+close unit (verify+sign+close all bind that rev; a concurrent commit can't split them) — the attestation binds verified-at-sha:A which is immutable and WAS verified, so an unrelated HEAD move to B should not invalidate it (same 'unrelated movement must not invalidate' principle as 790c's plan-review fix); OR (b) on drift, do NOT close — abort and leave the ticket in_progress so the operator re-runs the close (the plan-review gate's retryable posture). Plus a first-class non-force recovery (e.g. `rebar reverify-completion <id>`, analogous to sign-review/resign_plan_review) for an already-closed-but-unsigned ticket. Immediate 80af-based workaround exists: reopen → transition in_progress closed --ref <verified-sha> re-verifies+signs the real commit coherently.\n\n## Acceptance Criteria\n- [ ] A completion close whose HEAD moves to an UNRELATED commit between verify and sign does NOT produce a closed-without-signature ticket — either it pins the verified rev and signs it, or it aborts the close and leaves the ticket in_progress (retryable). Verified by a test that moves HEAD in the verify→sign window.\n- [ ] There is a non-`--force`, non-fabrication recovery to obtain the completion attestation for a closed-but-unsigned ticket (or the close never lands unsigned on a benign race in the first place).\n- [ ] The residual unsigned-close message (if any) names an ACTUALLY-WORKING recovery, not a no-op re-close.\n- [ ] make lint && make typecheck && make test green.\n\n## Possibly related (from the same report; separate triage)\n- PlanReviewGenerationChanged raised with IDENTICAL before==after generation hashes (~19x); blind re-run signs. (Distinct from 790c's related-material case.)\n- review-code silent-empty output when backgrounded (exits 0 with empty result).","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_commands/transition_close.py","reason":"resolve HEAD->sha once at close entry as the default ref; thread the concrete sha through verify_completion + the pre-sign drift guard so verify and sign bind the same immutable commit"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[],"parent_id":null,"parent_status_uuid":"4b64e261-0f66-423b-bf9b-c32e7a6d6921","plan_review_phase":"execution","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"4de6-0669-0025-4238","ticket_type":"bug","title":"completion close: verify->sign TOCTOU race closes a ticket permanently unsigned, with no non-force recovery","verify_commands":[]},"source_event_uuids":["0f0f8bf1-7a35-41f5-856f-8d0d9f8e9c45","6560e831-9f43-4be0-aa16-4312f29817d5","d954a681-38bb-474f-b0a9-efbb66aee514","e07e3447-81a9-411e-b007-a7c28e16dd49","4b64e261-0f66-423b-bf9b-c32e7a6d6921","342ecd10-a9e5-474f-adc6-bb12df3a2b60","4b3404a5-6f87-4109-905f-f7eb53f284ab"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784838724919588964,"uuid":"80375ce5-ce0e-4a26-9afb-f33db0ff1566"}