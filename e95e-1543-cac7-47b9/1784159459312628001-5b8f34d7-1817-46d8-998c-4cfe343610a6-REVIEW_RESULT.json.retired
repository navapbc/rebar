{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","data":{"coaching":[{"coaching":"Test the riskiest assumption behind sidecar overflow finding data shape first.","decision":"block","finding_refs":["fb009eb920e191e60","f4369ab97766b5f71"],"move_id":"4","move_name":"riskiest-assumption test","subject":"sidecar overflow finding data shape"},{"coaching":"Plan how rebar show CLI output schema coverage will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"block","finding_refs":["f748abab65d03e838","f1dabd0cb1bcc8349","f194efa4e548ea0c4"],"move_id":"9","move_name":"plan the verification","subject":"rebar show CLI output schema coverage"},{"coaching":"Pin down AC3 proving command specification with a concrete worked example.","decision":"advisory","finding_refs":["f9a6e0d1e8c1d6e3d"],"move_id":"6","move_name":"specification by example","subject":"AC3 proving command specification"},{"coaching":"Plan how adjudication runner script and invocation path will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["fa11fb33dc24b53af"],"move_id":"9","move_name":"plan the verification","subject":"adjudication runner script and invocation path"},{"coaching":"Pin down indeterminate sidecar bucket handling rule with a concrete worked example.","decision":"advisory","finding_refs":["fa7d0265cc59b0f72"],"move_id":"6","move_name":"specification by example","subject":"indeterminate sidecar bucket handling rule"},{"coaching":"Plan how kappa double-labeled subset floor verification will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f9acabd17f811625c"],"move_id":"9","move_name":"plan the verification","subject":"kappa double-labeled subset floor verification"},{"coaching":"Pin down had_persisted_review derivation protocol with a concrete worked example.","decision":"advisory","finding_refs":["f77dab55136b41605","fa545016277792f25"],"move_id":"6","move_name":"specification by example","subject":"had_persisted_review derivation protocol"},{"coaching":"Plan how eight case-ticket presence verification will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["ffa5b5b40f5a4e5e3"],"move_id":"9","move_name":"plan the verification","subject":"eight case-ticket presence verification"},{"coaching":"Plan how rubric file content and format requirements will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f84451333045becf1","f8e83883b56d343e2"],"move_id":"9","move_name":"plan the verification","subject":"rubric file content and format requirements"},{"coaching":"Plan how pre-flight probe failure path coverage will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["faeb4424bbdc36ac6"],"move_id":"9","move_name":"plan the verification","subject":"pre-flight probe failure path coverage"},{"coaching":"Pin down Rater B label-blindness enforcement mechanism with a concrete worked example.","decision":"advisory","finding_refs":["f3a5f14fd0e1a1ae5","f88a4fd92094119c5"],"move_id":"6","move_name":"specification by example","subject":"Rater B label-blindness enforcement mechanism"},{"coaching":"Pin down decision and source field semantic overlap with a concrete worked example.","decision":"advisory","finding_refs":["f99de1cbc026809dd"],"move_id":"6","move_name":"specification by example","subject":"decision and source field semantic overlap"},{"coaching":"Weigh at least one structural alternative for kappa.py vs existing cohens_kappa implementation.","decision":"advisory","finding_refs":["f55c7b40d7ca64f42"],"move_id":"5","move_name":"weigh alternatives","subject":"kappa.py vs existing cohens_kappa implementation"},{"coaching":"Plan how docs/research directory creation prerequisite will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["face4744f6e719289"],"move_id":"9","move_name":"plan the verification","subject":"docs/research directory creation prerequisite"},{"coaching":"Run a quick pre-mortem on Rater B partial-failure recovery path: how could this plan fail?","decision":"advisory","finding_refs":["f236e6a27c40a586d"],"move_id":"3","move_name":"pre-mortem","subject":"Rater B partial-failure recovery path"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":17,"blocking":3,"dropped":11,"indeterminate":0},"det":{"P1":{"ac_items":5,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","probed":12,"ran":true,"references":12,"resolved":0,"status":"pass","unresolved_or_abstained":12},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":5,"blocking":false,"desc_chars":12027,"file_impact":1,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":5,"blocking":false,"name":"ac-quality","ran":true,"status":"fail","verify_commands_linted":134,"verify_lint_abstained":133},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":3029,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":1,"name":"file-impact-coverage","ran":true,"status":"pass"}},"floored_criteria":["E1","G1G2"],"floored_finding_ids":["ffa5b5b40f5a4e5e3","face4744f6e719289"],"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":204.3,"llm_calls":30,"llm_ms":618263.0,"total_ms":618591.7,"verify_requests":30},"narrowed":true,"remediation":{"baseline":"sidecar","eligible":true,"reasons":{"code_unchanged":true,"plan_changed":true,"registry_unchanged":true,"sidecar_baseline":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","F4","G5","T2","T4","T5b","T5d","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Fix the Step 3 surfaced/dropped classification rule to correctly handle overflow: either (a) use the sidecar's bucket membership (e.g. add a top-level `source_bucket` field in the mining script that records which verdict bucket each finding came from), or (b) distinguish overflow by cross-referencing coverage.counts.advisory_overflow or by checking whether the finding's `id` appears in the `verdict['overflow']` list vs `verdict['advisory']`, so that capped-advisory (overflow) findings land in the 'dropped' population, not 'surfaced'.","cohort":["E4"],"criteria":["E4"],"decision":"block","drop_reason":null,"evidence":["Plan states: 'surfaced = rows with decision ∈ {block, advisory} and no drop_reason; dropped = rows carrying a drop_reason (Pass-3 completion/novelty floor) or in the advisory-overflow set. Both are present in the sidecar — dropped findings are NOT reconstructed from PASS verdicts.'","sidecar.py:394-401: build_payload docstring confirms overflow+dropped are persisted","sidecar.py:472-478: all_findings = blocking + advisory + overflow + indeterminate + dropped — overflow IS a separate source bucket","sidecar.py:429: '\"decision\": f.get(\"decision\")' — the slim record captures each finding's individual decision field","orchestrator.py:447: '\"overflow\": advisory[advisory_cap:]' — overflow is a split of the advisory list; these findings' per-finding decision field is already set to 'advisory' by pass3_decide before the cap split","sidecar.py:311: 'SURFACED_DECISIONS = (\"block\", \"advisory\")' — the shared vocabulary does NOT include overflow as a separate decision value","There is no 'overflow' value in the per-finding decision field — overflow items retain 'advisory' as their decision"],"finding":"The plan's Step 3 `build_adjudication_corpus.py` classification rule — 'surfaced = rows with decision ∈ {block, advisory} and no drop_reason; dropped = rows carrying a drop_reason or in the advisory-overflow set' — is unverifiable using `build_payload`'s actual output, because overflow findings appear in the sidecar's `findings[]` array with `decision='advisory'` and no `drop_reason`. The orchestrator places `advisory[advisory_cap:]` into the separate `verdict['overflow']` bucket, but these findings' per-finding `decision` field is set by pass3_decide BEFORE the cap split, so it remains 'advisory'. The sidecar's `_slim()` faithfully captures that `decision` field, making overflow findings indistinguishable from genuinely-surfaced advisory findings under the plan's rule.","group_criteria":null,"group_id":null,"id":"fb009eb920e191e60","impact":1.0,"is_primary":null,"location":"Step 3 ('Build the finding-adjudication corpus'), 'Data source (grounded in sidecar.build_payload)' bullet; also AC #3 proving command","norm_id":"n7a2417014db746c0","priority":0.8889,"reason":"high-priority+criterion-opted-in","scenarios":["The adjudication script uses `decision ∈ {block, advisory}` and no `drop_reason` to classify a finding as 'surfaced', but advisory-overflow findings match this rule exactly and end up in the surfaced sample, contaminating it with findings the gate deliberately did not surface to the agent.","The 'dropped' population is smaller than expected (missing the overflow cohort), skewing the ≥90-dropped-findings floor and the stratification in ways that undermine the corpus's representativeness of the gate's actual suppression behavior."],"severity":"critical","suggested_fix":"In `build_adjudication_corpus.py`, after reading each sidecar payload, reconstruct bucket membership by checking whether advisory findings' IDs appear beyond the `advisory_overflow` cap boundary, or add a `source_bucket` field during mining (e.g. 'blocking', 'advisory', 'overflow', 'dropped') so the surfaced/dropped split uses bucket membership rather than the per-finding `decision` field alone.","tier":"LLM","validity":0.8889,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"high","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify in Step 3 the exact field/mechanism by which `build_adjudication_corpus.py` distinguishes overflow advisory findings from surfaced advisory findings in the persisted sidecar payload (e.g., a `tier` field, a bucket position indicator, or an explicit `overflow: true` stamp), and reconcile the adjudication-corpus `decision` enum so overflow findings have an unambiguous value.","cohort":["T8"],"criteria":["T8"],"decision":"block","drop_reason":null,"evidence":["orchestrator.py line 446-447: `'surfaced': advisory[:advisory_cap], 'overflow': advisory[advisory_cap:]` — overflow items are advisory findings not yet stamped with a different decision","finalize_verdict (line 538): `'overflow': overflow` — overflow list contains advisory-decision findings","sidecar.py build_payload line 475: `verdict.get('overflow', [])` — these findings carry decision='advisory' when persisted in _slim()","Plan Step 3: 'dropped = rows carrying a drop_reason (Pass-3 completion/novelty floor) or in the advisory-overflow set' — implies overflow rows can be identified, but gives no field-level mechanism since their decision is 'advisory', same as surfaced findings","Plan adjudication schema: `decision ∈ {block, advisory, dropped}` — the schema cannot represent overflow-advisory as distinct from surfaced-advisory using the decision field alone"],"finding":"The plan's classification rule for 'dropped' findings in Step 3 misrepresents the sidecar's actual data shape for overflow findings: overflow findings carry `decision='advisory'` in the persisted payload (not `decision='dropped'`), so the rule 'dropped = rows in the advisory-overflow set' cannot be mechanically applied from the `decision` field alone.","group_criteria":null,"group_id":null,"id":"f4369ab97766b5f71","impact":1.0,"is_primary":null,"location":"Step 3, 'Data source (grounded in sidecar.build_payload)' bullet; adjudication-corpus schema `decision ∈ {block, advisory, dropped}`","norm_id":"n0b78000d15b29be2","priority":0.8889,"reason":"high-priority+criterion-opted-in","scenarios":["build_adjudication_corpus.py filters on decision='advisory' and no drop_reason for 'surfaced'; it will collect overflow findings (decision='advisory', no drop_reason) as 'surfaced' even though the plan intends them as 'dropped', skewing the dropped/surfaced ratio and invalidating the ≥90 dropped floor.","Alternatively the script tries to use a separate 'source bucket' field that doesn't exist in the slimmed sidecar payload, causing a KeyError."],"severity":"critical","suggested_fix":"Add: 'Overflow advisory findings are identified by checking that the finding's `id` appears in the `coverage.counts` advisory_overflow range (i.e., rank > advisory_surfaced count when findings are sorted by priority within the advisory set), OR by requiring build_payload to stamp overflow findings with `\"overflow\": true`. Overflow findings map to `decision=\"dropped\"` in the adjudication corpus schema.'","tier":"LLM","validity":0.8889,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"high","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E4"],"decision":"block","drop_reason":null,"evidence":[],"finding":"The plan asserts that 'reopen_count (int), force_close (bool), completion_verifier_fail_count (int), review_round_count (int)' are 'read via the `rebar show` CLI', but the `rebar show` output schema (ticket_state.schema.json) does not include these fields. Only `last_reopened_at` (a timestamp) appears as a reopen-related field; grep finds zero occurrences of `reopen_count`, `completion_verifier_fail_count`, or `review_round_count` anywhere in `src/rebar/`. These are derived counts that would need to be computed from event-history replay (the same git-object mining the script already does), not a simple `rebar show` read. If the script assumes `rebar show` returns these counts and they aren't there, the outcome corpus silently ships null/missing values for load-bearing schema fields.","group_criteria":null,"group_id":null,"id":"f748abab65d03e838","impact":0.85,"is_primary":null,"location":"Step 1 — 'Current-state fields … are read via the `rebar show` CLI' and Outcome-corpus schema: `reopen_count (int), force_close (bool), completion_verifier_fail_count (int), review_round_count (int)`","norm_id":"na207f6f900bc7337","priority":0.7556,"reason":"high-priority+criterion-opted-in","scenarios":[],"severity":"critical","suggested_fix":"Revise Step 1 to specify that these four counts are derived from the git-object event history (e.g., count STATUS events transitioning closed→open for reopen_count; scan for FORCE_CLOSE event type for force_close; count completion_verifier_fail sidecar events; count plan-review REVIEW_RESULT sidecar events per ticket for review_round_count) — and remove the claim that they come from `rebar show`.","tier":"LLM","validity":0.8889,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"high","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Correct Step 1's data-source claim: specify that `reopen_count`, `force_close`, `completion_verifier_fail_count`, `review_round_count`, and `had_persisted_review` must be **derived from event-stream replay** (STATUS/DESCRIPTION/REVIEW_RESULT event counts from the git-object walk), not from `rebar show`; update the README regeneration command and AC#2 to reflect this.","cohort":["T3"],"criteria":["T3"],"decision":"advisory","drop_reason":null,"evidence":["Plan Step 1: 'Current-state fields are read via the `rebar show` CLI'","src/rebar/reducer/_state.py make_initial_state(): no reopen_count, force_close, completion_verifier_fail_count, review_round_count, or had_persisted_review fields in the schema","src/rebar/reducer/_present.py public_state(): strips only INTERNAL_KEYS = {parent_status_uuid, last_status_env_id}; none of the five fields appear","src/rebar/reducer/_processors.py process_status(): records `last_reopened_at` (a timestamp) on the closed→open edge, not a reopen_count integer","Evidence class: Contradicted — `rebar show` output definitively does not carry these fields"],"finding":"The plan states that `reopen_count`, `force_close`, `completion_verifier_fail_count`, `review_round_count`, and `had_persisted_review` are 'read via the `rebar show` CLI' (Step 1), but none of these fields exist in the reducer's public state schema emitted by `rebar show`. The reducer's `make_initial_state()` and `public_state()` do not include any of these fields; `last_reopened_at` is a timestamp (not a count), and `force_close` is a transition parameter, not a persisted state key. These values must be derived from raw event-stream replay, not from the current-state CLI.","group_criteria":null,"group_id":null,"id":"f1dabd0cb1bcc8349","impact":0.85,"is_primary":null,"location":"Step 1: Outcome corpus schema / 'Current-state fields are read via the `rebar show` CLI'; AC line 2 ('runs/outcome_corpus.jsonl is committed … carrying … reopen_count, force_close, completion_verifier_fail_count … and review_round_count')","norm_id":"nc430bc4ac64f01fd","priority":0.7556,"reason":"default-advisory","scenarios":["mine_outcome_corpus.py attempts to read reopen_count from rebar show JSON output and gets KeyError or None for every ticket, silently producing incorrect corpus rows","had_persisted_review (the filter for Step 3's adjudication corpus) is absent from rebar show, so Step 3 has no viable filter source unless derived from git-object sidecar replay separately"],"severity":"critical","suggested_fix":"In Step 1, replace 'Current-state fields are read via the `rebar show` CLI' with: 'Current-state fields requiring event-history counts (`reopen_count`, `force_close`, `completion_verifier_fail_count`, `review_round_count`, `had_persisted_review`) are derived from the same git-object event replay used for `post_claim_edit_class`; `rebar show` is used only for `ticket_type` and `level` (fields it actually emits).'","tier":"LLM","validity":0.8889,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"high","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["T3"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The plan asserts 'Current-state fields (reopen/force-close/verifier-fail/round counts) are read via the rebar show CLI,' but the ticket_state schema (ticket_state.schema.json) confirms rebar show does NOT emit reopen_count, force_close (bool), completion_verifier_fail_count, or review_round_count. Only `last_reopened_at` (a single timestamp) is in compiled state. The `force_close` fact lives in a git audit COMMENT event (not compiled state); `completion_verifier_fail_count` lives in the reducer-IGNORED COMPLETION_VERDICT sidecar; `reopen_count` and `review_round_count` are not derived fields in the reducer at all. An implementer following this plan will call `rebar show` expecting these four fields and get KeyError or None, silently producing a corpus with zeroed/null columns.","group_criteria":null,"group_id":null,"id":"f194efa4e548ea0c4","impact":0.85,"is_primary":null,"location":"What § Step 1 ('Current-state fields … are read via the rebar show CLI') and Outcome-corpus schema definition","norm_id":"n53c4331f22f01f28","priority":0.7556,"reason":"default-advisory","scenarios":[],"severity":"critical","suggested_fix":"For each of the four fields, use git-object event scanning (already available in the script) rather than rebar show: count STATUS events with current_status='closed' and a force_close_reason key for force_close; count STATUS open←closed transitions for reopen_count; count COMPLETION_VERDICT events with schema='completion_verifier_fail_v1' for completion_verifier_fail_count; count REVIEW_RESULT sidecar events per ticket for review_round_count. Update Step 1 and the README regeneration command accordingly.","tier":"LLM","validity":0.8889,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"high","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"AC3's proving command is described in prose ('a jq/python check that every row has source, tp_fp, rationale and the surfaced/dropped counts meet the floor') rather than as a concrete executable command — this is defect-taxonomy issue #6 (prose assertion target) and leaves the exact check undefined.","group_criteria":null,"group_id":null,"id":"f9a6e0d1e8c1d6e3d","impact":0.55,"is_primary":null,"location":"AC3 — 'Proving command: a jq/python check that every row has `source`, `tp_fp`, `rationale` and the surfaced/dropped counts meet the floor.'","norm_id":"nf1065d277ee97137","priority":0.4813,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add a named adjudication-runner script (e.g. `harnesses/run_adjudicators.py`) to Scope and to the AC 3 proving command, OR explicitly state that `build_adjudication_corpus.py` is responsible for invoking both LLM raters (and update its description and the proving command accordingly).","cohort":["E2","E6","F1"],"criteria":["E2","E6"],"decision":"advisory","drop_reason":null,"evidence":["Scope lists: 'mine_outcome_corpus.py, build_adjudication_corpus.py, kappa.py, adjudicate_rubric_a.md, adjudicate_rubric_b.md' — no adjudication runner","Step 4: 'Rater A (primary): an LLM adjudicator run with rubric harnesses/adjudicate_rubric_a.md' — no invocation mechanism described","AC 3 proving command checks field presence only: 'every row has source, tp_fp, rationale' — does not cite a script that produced those labels","ABSENCE: no script named adjudicate.py, run_raters.py, or similar appears anywhere in the plan"],"finding":"No adjudication-runner script is listed in scope or named in any proving command. Step 4 requires actually invoking two LLM raters (Rater A with rubric_a.md, Rater B with rubric_b.md) to populate `tp_fp`, `rater_a`, and `rater_b` fields, but the Scope section lists only `build_adjudication_corpus.py` (described as 'samples findings'), `kappa.py`, and two rubric markdown files — no script that calls an LLM API, feeds it the rubric, and writes the adjudication labels. An executor cannot complete step 4 without either (a) deciding that `build_adjudication_corpus.py` must also run both LLM raters (contradicting its described role) or (b) creating an unlisted script from scratch.","group_criteria":null,"group_id":null,"id":"fa11fb33dc24b53af","impact":0.536,"is_primary":null,"location":"Step 4 / Scope section / AC 3","norm_id":"n25239e997b017c14","priority":0.469,"reason":"default-advisory","scenarios":["Executor builds the unadjudicated corpus with build_adjudication_corpus.py, then has no script to invoke the LLMs — AC 3 cannot be satisfied without improvising an unlisted artifact","build_adjudication_corpus.py is silently expected to also call the LLM API, but its description says 'samples findings ... written to runs/adjudication_corpus.jsonl' — the adjudication step is conflated with the sampling step without being stated"],"severity":"major","suggested_fix":"Extend the Scope bullet to read: '`harnesses/run_adjudicators.py` — invokes Rater A (model A, rubric_a.md) over the full sample and Rater B (model B, rubric_b.md) over the stratified ≥50-finding subset, writing `rater_a`/`rater_b` fields into the corpus; takes `--rater {a,b}` and `--model <id>` flags.' Add a proving command to AC 3: `python .../run_adjudicators.py --rater a && python .../run_adjudicators.py --rater b --blind` exits 0.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a classification rule in Step 3 (and the README schema) for `decision='indeterminate'` sidecar findings: state whether they are excluded from the corpus, counted as 'dropped', or placed in a third category — co-located with the surfaced/dropped definition.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Plan Step 3: 'surfaced = rows with decision ∈ {block, advisory} and no drop_reason; dropped = rows carrying a drop_reason (Pass-3 completion/novelty floor) or in the advisory-overflow set'","sidecar.py lines 472-478: `all_findings = verdict.get('blocking',[]) + verdict.get('advisory',[]) + verdict.get('overflow',[]) + verdict.get('indeterminate',[]) + verdict.get('dropped',[])`","orchestrator.py: `indeterminate` findings carry decision='indeterminate' and no drop_reason — they match neither 'surfaced' (not in {block,advisory}) nor 'dropped' (no drop_reason, not overflow)","ABSENCE: no rule in Step 3 assigns indeterminate findings to either bin or excludes them"],"finding":"The `indeterminate` bucket in the sidecar payload is unclassified by Step 3's surfaced/dropped rule, leaving `build_adjudication_corpus.py` with no instruction on how to handle those findings.","group_criteria":null,"group_id":null,"id":"fa7d0265cc59b0f72","impact":0.536,"is_primary":null,"location":"Step 3, 'Data source (grounded in sidecar.build_payload)' bullet","norm_id":"n9074e24962371a94","priority":0.469,"reason":"default-advisory","scenarios":["A ticket reviewed when the LLM verifier failed (verify_failed path) produces indeterminate findings; build_adjudication_corpus.py has no instruction and would silently skip or misclassify them, producing an undocumented gap in corpus coverage."],"severity":"major","suggested_fix":"Add one sentence: 'Findings with decision=\"indeterminate\" (Pass-2 verify-failure survivors) are excluded from the adjudication corpus and their count is recorded in the README under a separate `excluded_indeterminate` field.'","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a cardinality assertion to `kappa.py` and the AC 4 proving command: `kappa.py` should exit non-zero (with an actionable message) if the binary `{TP,FP}` double-labeled subset after pairwise ambiguous exclusion has fewer than 50 rows, and the proving command should surface that count.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["AC 4: 'stratified-by-criterion ≥50-finding double-labeled subset'","AC 4 proving command: 'python .../kappa.py runs/adjudication_corpus.jsonl prints kappa and the README value matches' — no assertion on subset size","ABSENCE: no `--assert-min-n 50` or equivalent flag described for kappa.py"],"finding":"The `kappa.py` proving command (`python .../kappa.py runs/adjudication_corpus.jsonl`) does not verify that the double-labeled subset meets the ≥50-finding floor stated in the AC and Step 4. kappa.py could run on a subset of 10 rows and print a passing kappa value, satisfying the current AC as written even though the floor is violated.","group_criteria":null,"group_id":null,"id":"f9acabd17f811625c","impact":0.55,"is_primary":null,"location":"AC 4 / Step 4 — 'stratified-by-criterion ≥50-finding double-labeled subset'","norm_id":"nf1a855a4bf9218eb","priority":0.4125,"reason":"default-advisory","scenarios":["LLM adjudication of Rater B is only partially completed (e.g. 30 rows labeled due to API quota); kappa.py still prints a value and exits 0; AC 4 passes even though the floor is unmet","The corpus has enough ambiguous-excluded rows that the binary subset falls below 50; kappa.py reports a value without flagging this"],"severity":"major","suggested_fix":"Add to `kappa.py`'s contract: 'prints `n_binary=<count>` alongside kappa; exits non-zero if count < 50 with message \"double-labeled binary subset too small: <count> < 50\".' Update AC 4 proving command to: `python .../kappa.py runs/adjudication_corpus.jsonl` prints kappa ≥ 0.7 **and** `n_binary ≥ 50`.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Specify in Step 1's mining algorithm that `had_persisted_review` is derived by checking for the presence of at least one REVIEW_RESULT sidecar event for the ticket in the git object store (via the same git-object replay scan that Step 3 uses), and that the outcome-corpus mining pass performs this scan as part of its single pass over git objects.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["Schema: `had_persisted_review (bool)` described as 'load-bearing: Step 3 samples findings only from tickets where it is true'","Mining method described as: 'git rev-list --objects --all + git cat-file (method in report §5)' focused on CREATE events and DESCRIPTION-edit event timestamps","ABSENCE: no step in the mining algorithm mentions scanning for REVIEW_RESULT sidecar events keyed by ticket_id to populate had_persisted_review","The plan separately says Step 3 uses 'REVIEW_RESULT sidecar events (recovered via git-object replay of the tickets branch)' — but doesn't say this same scan is used to derive had_persisted_review in Step 1"],"finding":"The plan does not describe the mechanism by which `had_persisted_review` (a load-bearing field in the outcome corpus used to gate which tickets are eligible for Step 3 sampling) is computed during git-object mining. The script must determine, for each ticket, whether at least one REVIEW_RESULT sidecar event exists in the git object store — but the mining algorithm described (git rev-list --objects --all + git cat-file to recover CREATE/DESCRIPTION-edit events) is oriented toward the outcome corpus fields. No step connects REVIEW_RESULT sidecar recovery to `had_persisted_review` derivation.","group_criteria":null,"group_id":null,"id":"f77dab55136b41605","impact":0.536,"is_primary":null,"location":"Step 1 (outcome corpus schema) and Step 3 ('restricted to tickets with had_persisted_review=true')","norm_id":"n5bdb0b5b6da5eae4","priority":0.402,"reason":"default-advisory","scenarios":["Implementer populates had_persisted_review using only on-disk tracker state (rebar CLI) rather than git-object history, producing a different set than Step 3's git-object recovery — the two steps are then inconsistent","Implementer assumes had_persisted_review is derivable from the outcome-corpus mining pass and doesn't add the REVIEW_RESULT scan, producing had_persisted_review=false for all tickets (making Step 3 sample nothing)"],"severity":"major","suggested_fix":"In the mining script design, describe a single joint pass: for each ticket, collect (a) CREATE + DESCRIPTION-edit events for outcome fields, and (b) presence of any REVIEW_RESULT event blob for had_persisted_review=true. Both are recoverable from the same git rev-list output.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The outcome-corpus field `had_persisted_review` is defined in the schema but no derivation protocol is specified anywhere in the plan — the mining script section (Step 1) explains how to recover `reopen_count`, `force_close`, `completion_verifier_fail_count`, and `review_round_count` from git objects and `rebar show`, but is silent on how `had_persisted_review` is determined.","group_criteria":null,"group_id":null,"id":"fa545016277792f25","impact":0.536,"is_primary":null,"location":"Step 1 (What) — outcome-corpus schema; mine_outcome_corpus.py description","norm_id":"ned1be724c4960f50","priority":0.402,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"had_persisted_review = True iff `git rev-list --objects --all | git cat-file --batch-check` yields at least one blob whose path matches `.tickets-tracker/<ticket_id>/*-REVIEW_RESULT.json`.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":null,"blocking_enabled":null,"checklist_item":"","cohort":null,"criteria":["P6"],"decision":"advisory","drop_reason":null,"evidence":["4 criterion line(s) bundle multiple deliverables with 'and' (split so each is independently verifiable).","verify command `wc -l runs/outcome_corpus.jsonl` inspects output with `wc` but asserts nothing — add an exit-code or comparison (-q, [ \"$(...)\" -eq N ], jq -e) so a failure is observable"],"finding":"Acceptance-criteria / definition-of-done quality issues.","group_criteria":null,"group_id":null,"id":"f607dd457c67f9209","impact":0.4,"is_primary":null,"location":"","norm_id":"ned06ebc801a522e3","priority":0.4,"reason":null,"scenarios":[],"severity":"minor","suggested_fix":"Split compound criteria, replace subjective terms with observable outcomes, and state how each is verified.","tier":"DET","validity":1.0,"verification":null},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an AC (or extend AC5) that verifies `harnesses/adjudicate_rubric_a.md` and `harnesses/adjudicate_rubric_b.md` are committed and each contains at minimum the verbatim TP/FP definition block and the required JSON output schema, e.g., with a grep/content check in the proving commands.","cohort":["COH","E1","T5d"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["Scope: 'harnesses/adjudicate_rubric_a.md, adjudicate_rubric_b.md (new; committed alongside corpus_sample.py).'","Step 4: 'Rubric contract (both files): each rubric states the TP/FP definitions above verbatim, instructs criterion-aware judgment … and fixes the output as one JSON object per finding.'","No AC contains a proving command that checks for the existence or content of these two files."],"finding":"The Scope section lists `harnesses/adjudicate_rubric_a.md` and `harnesses/adjudicate_rubric_b.md` as named deliverables, and Step 4 specifies non-trivial content requirements for each (verbatim TP/FP definitions, criterion-aware judgment instructions, fixed JSON output format, independent wording for Rater B). However, no AC verifies these files are committed or that they satisfy the rubric contract. AC5 indirectly depends on them (kappa requires Rater B's labels), but the proving command only runs `kappa.py` on the already-produced corpus — it cannot detect a missing or malformed rubric file.","group_criteria":null,"group_id":null,"id":"f84451333045becf1","impact":0.44,"is_primary":null,"location":"Scope section ('adjudicate_rubric_a.md', 'adjudicate_rubric_b.md') vs Step 4 rubric contract vs AC5 proving command ('python .../kappa.py runs/adjudication_corpus.jsonl')","norm_id":"nc674d341e468a865","priority":0.275,"reason":"default-advisory","scenarios":["An implementer commits placeholder rubric files (or omits them) and still passes AC5 because kappa.py only reads the already-produced adjudication_corpus.jsonl, which could have been built with a different rubric.","The 'independently-authored' and 'different model id' constraints on Rater B's rubric are unverified — there is no AC gate enforcing rubric independence."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E5"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The pre-flight object-availability probe's failure path — halting with an error and writing nothing when the recovered-ticket count falls below 500 — has no AC coverage; only the happy path (--dry-run exits 0, wc -l ≥ 500) is proven.","group_criteria":null,"group_id":null,"id":"faeb4424bbdc36ac6","impact":0.44,"is_primary":null,"location":"## What, Step 1 (Pre-flight object-availability probe) and AC line 1 (Proving command: `--dry-run` exits 0, `wc -l` ≥ 500)","norm_id":"n408d59cc4a6fea0d","priority":0.275,"reason":"default-advisory","scenarios":[],"severity":"minor","suggested_fix":"Add to AC1: 'Proving command (failure path): run the script with a mocked/overridden count below 500 (e.g. `--max-objects 400` flag or a unit test patching the count) and assert exit code ≠ 0, the error message contains \"gc/pruned objects\", and `outcome_corpus.jsonl` does not exist.'","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Specify in Step 4 (and the adjudication runner's contract) that Rater B's input rows have `rater_a` and `tp_fp` fields removed/masked before being passed to the model, and add this to `adjudicate_rubric_b.md`'s rubric contract section.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"advisory","drop_reason":null,"evidence":["'Rater B ... re-labels a stratified-by-criterion ≥50-finding subset BLIND to Rater A's labels'","Adjudication-corpus schema includes `rater_a` field in the same row as `rater_b`","No instruction in the rubric contract or harness spec to strip `rater_a` before feeding rows to Rater B"],"finding":"The plan does not specify a mechanism to guarantee Rater B's blindness to Rater A's labels. The corpus file (`adjudication_corpus.jsonl`) will already contain `rater_a` values when Rater B is run against it. Without explicitly stripping or withholding `rater_a` from Rater B's input, a prompt that includes the full row leaks the first label, undermining the independence the kappa measurement requires.","group_criteria":null,"group_id":null,"id":"f3a5f14fd0e1a1ae5","impact":0.33,"is_primary":null,"location":"Step 4 — 're-labels a ≥50-finding subset BLIND to Rater A's labels'","norm_id":"ne581206c898dc174","priority":0.2063,"reason":"default-advisory","scenarios":["run_adjudicators.py naively serializes the full JSON row as context for Rater B — the rater_a field is visible in the prompt, producing an echo rather than an independent judgment","kappa appears inflated; the validity gate passes on correlated labels that do not reflect genuine inter-rater reliability"],"severity":"minor","suggested_fix":"Add to Step 4: 'The adjudication runner serializes each row for Rater B with the `rater_a`, `tp_fp`, and `rationale` fields omitted from the prompt context, ensuring label blindness.'","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The plan requires Rater B to label a 50-finding subset 'BLIND to Rater A's labels', but no mechanism is specified to prevent Rater B from seeing the `tp_fp` and `rater_a` fields already written into `adjudication_corpus.jsonl` by Rater A. If `kappa.py` or the Rater B invocation script reads the same JSONL file without stripping those fields before presenting findings to the Rater B LLM, the 'blind' requirement fails, and the kappa value is inflated by anchoring rather than measuring true independent agreement.","group_criteria":null,"group_id":null,"id":"f88a4fd92094119c5","impact":0.33,"is_primary":null,"location":"What, Step 4 — Double-label and compute inter-rater reliability; Rater B description","norm_id":"n3a7842d389eaa6b6","priority":0.2063,"reason":"default-advisory","scenarios":[],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The adjudication-corpus schema's `decision` field (`∈ {block, advisory, dropped}`) and `source` field (`∈ {surfaced, dropped}`) both contain the value `dropped` with different but overlapping semantics, and no processing protocol is co-located in the schema specifying how the two fields interact — specifically whether a row with `source=surfaced` may ever carry `decision=dropped`, and what the TP/FP semantics are for such a cross-combination.","group_criteria":null,"group_id":null,"id":"f99de1cbc026809dd","impact":0.264,"is_primary":null,"location":"Step 3 (What) — adjudication-corpus schema definition","norm_id":"ne5b3fb0cdd2fd297","priority":0.165,"reason":"default-advisory","scenarios":[],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify in Step 4 (or in a shared 'context template' section referenced by both rubric files) the exact fields from the adjudication corpus row and ticket plan that are presented to each LLM rater, and add a fallback for findings with null/empty criteria[] or unavailable ticket plan text.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Plan Step 4: 'each rubric states the TP/FP definitions above verbatim, instructs criterion-aware judgment (the finding's criteria and the ticket plan are provided as context), and fixes the output as one JSON object per finding {finding_id, tp_fp ∈ {TP,FP,ambiguous}, rationale}'","ABSENCE: no specification of how finding fields (finding text, evidence, scenarios, criteria list) and ticket plan text are serialized into the prompt — JSON block? Markdown? Which fields included?","ABSENCE: no instruction on how to handle findings with null or empty criteria[], or findings whose ticket plan is unavailable from git objects","This is an instruction-locality gap: the rubric content contract is defined in the plan, but the context-preparation contract (what the LLM actually receives) is left to the executor"],"finding":"The rubric files (`adjudicate_rubric_a.md`, `adjudicate_rubric_b.md`) are deliverables that govern all TP/FP labeling outcomes and therefore the kappa gate, but their prompt-context format (how the finding text, plan text, and `criteria` field are presented to the LLM) is not specified anywhere in the plan, leaving the executor to invent it independently for each rubric.","group_criteria":null,"group_id":null,"id":"f8e83883b56d343e2","impact":0.264,"is_primary":null,"location":"Step 4, 'Rubric contract (both files)' bullet; Scope listing of adjudicate_rubric_a.md / adjudicate_rubric_b.md","norm_id":"na15bbd2619b7fe3a","priority":0.132,"reason":"default-advisory","scenarios":["Rater A's harness includes the full finding JSON (with all sidecar fields including scores); Rater B's independently-authored rubric omits priority/validity scores. The two raters operate on different evidence sets, making kappa meaningless.","A finding has null criteria[]; Rater A skips criterion-aware judgment, Rater B halts — no fallback specified."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Confirm whether `harnesses/kappa.py` should import and delegate to `rebar.llm.evals.eval.cohens_kappa` (the existing tested implementation) rather than re-implementing Cohen's kappa, or document why a separate implementation is required.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["src/rebar/llm/evals/eval.py:343: `def cohens_kappa(rater_a: list, rater_b: list) -> float:` — EXISTS and is tested","resolve_symbol confirmed: rebar.llm.evals.eval.cohens_kappa EXISTS in installed environment","Plan says: 'committed harnesses/kappa.py computes Cohen's kappa on the binary {TP, FP} labels' — no mention of existing implementation","ABSENCE: no acknowledgment that eval.cohens_kappa exists or rationale for re-implementing"],"finding":"The plan specifies a new `harnesses/kappa.py` that computes Cohen's kappa from scratch, but `rebar.llm.evals.eval.cohens_kappa` already exists as a tested, importable function in the installed package. The plan names `kappa.py` as a committed artifact without acknowledging or reusing the existing implementation.","group_criteria":null,"group_id":null,"id":"f55c7b40d7ca64f42","impact":0.0,"is_primary":null,"location":"Scope section: 'harnesses/kappa.py' + Step 4: 'committed harnesses/kappa.py computes Cohen's kappa'","norm_id":"n09134e80d3121d55","priority":0.0,"reason":"default-advisory","scenarios":["The new kappa.py diverges from the existing cohens_kappa() in edge-case handling (e.g. empty sequences, degenerate constant-label cases already handled in eval.py), producing different kappa values for the same input and making results non-comparable with other eval.py users.","A future auditor sees two kappa implementations and is unsure which is canonical."],"severity":"none","suggested_fix":"In kappa.py: `from rebar.llm.evals.eval import cohens_kappa` and delegate to it, keeping kappa.py as a thin CLI wrapper that reads the adjudication_corpus.jsonl, filters ambiguous rows pairwise, and calls cohens_kappa(rater_a_labels, rater_b_labels).","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a fallback for Rater B partial failure: specify whether `kappa.py` should halt and require a full re-run (preserving blind guarantee), or accept partial labels above a minimum coverage threshold, and document the recovery command in the README.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Plan Step 4 Rater B: 're-labels a stratified-by-criterion ≥50-finding subset BLIND to Rater A's labels'","Plan Step 5: specifies only the kappa<0.7 outcome; no handling of partial Rater B completion","ABSENCE: no retry policy, no minimum partial-coverage threshold, no instruction on whether partially-labeled subsets are usable for kappa computation"],"finding":"No fallback is specified for a partial failure of Rater B's labeling run (e.g., LLM API error mid-batch over the ≥50-finding stratified subset), leaving the executor without a defined recovery path that preserves the blind-labeling requirement.","group_criteria":null,"group_id":null,"id":"f236e6a27c40a586d","impact":0.0,"is_primary":null,"location":"Step 4, Rater B bullet; Step 5 (kappa validity gate)","norm_id":"n6fd4a878f05eacdd","priority":0.0,"reason":"default-advisory","scenarios":["Rater B completes 40/55 findings before an API timeout; kappa.py has no guidance on whether to compute kappa on 40 findings or halt and re-run — if it computes on 40, the stratification guarantee is broken."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] State the intended model family or specific model id (or a selection criterion such as 'Rater A: the current default plan-review model; Rater B: a different provider's frontier model') for both raters in Step 4, so the executor has a stated default rather than an open design choice.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"dropped","drop_reason":null,"evidence":["'Rater B ... a different model id from Rater A' — no model id stated for either rater","AC 4: 'README.md with both rater/model identities' — identities must be chosen, not discovered"],"finding":"The model IDs for Rater A and Rater B are unspecified — the plan states only that Rater B must use 'a different model id from Rater A' but names no concrete models. An executor must choose both models without guidance, which affects reproducibility of the kappa result and the README's 'rater/model identities' record.","group_criteria":null,"group_id":null,"id":"f54d46c4ab869f191","impact":0.0,"is_primary":null,"location":"Step 4 — 'a different model id from Rater A' / AC 4 — 'recorded in runs/README.md with both rater/model identities'","norm_id":"n9dc5823ad103fa68","priority":0.0,"reason":"low-validity","scenarios":["Executor picks two models that are actually the same family/checkpoint under different API aliases; independence claim is weakened","Rater A is run with a very capable model and Rater B with a weak one, skewing kappa downward and causing a spurious gate failure"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.4286,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a small feasibility pilot (e.g., double-label 10–15 findings spanning at least 4 criteria) before committing to the full corpus build, record the pilot kappa, and specify a recovery path (e.g., rubric reconciliation round, threshold recalibration, or fallback to partial ground truth) if the pilot kappa is below 0.7.","cohort":["T2","T4","T7"],"criteria":["T2"],"decision":"dropped","drop_reason":null,"evidence":["'kappa ≥ 0.7 → labels are usable ground truth. kappa < 0.7 → labels are declared unusable, kappa.py exits non-zero'","'no labels are shipped as ground truth for downstream E/R stories'","No prior measurement of LLM rater agreement on plan-review TP/FP is cited; the 0.7 threshold is conventional social-science practice applied without domain validation.","Rubric B is authored independently with 'different emphasis/examples' — the degree of divergence (and its effect on kappa) is uncharacterized."],"finding":"The kappa ≥ 0.7 gate threshold is asserted as a fixed success criterion without any feasibility pilot to verify that two independent LLM raters can reliably agree on plan-review TP/FP labels at that level. LLM inter-rater agreement on subjective plan-review findings is a novel, unvalidated task; if agreement is structurally lower (e.g., kappa ≈ 0.5), the entire story's deliverable — usable ground truth for E2/E3/E6/R1/R7 — is declared unusable with no fallback path.","group_criteria":null,"group_id":null,"id":"fd651e3f7640067de","impact":0.0,"is_primary":null,"location":"Step 4 (Double-label and compute inter-rater reliability) and Step 5 (Apply the validity gate)","norm_id":"n77f7dea5b5a43e29","priority":0.0,"reason":"veto:absence-refuted","scenarios":["Two LLM raters with different rubrics and different model IDs systematically interpret 'FP' differently for criterion-specific edge cases (e.g., T7 stale-reference vs. T4 compat), yielding kappa ~0.55 — the entire corpus is declared unusable and E2/E3/E6 are blocked.","The 50-finding double-labeled subset, being stratified by criterion, contains several criteria with few examples, making the kappa estimate statistically unstable even if pointwise agreement is decent."],"severity":"none","suggested_fix":"Insert a Step 3.5: before running the full adjudication, run both raters on a 15-finding stratified pilot sample, compute kappa, and gate Step 4's full run on pilot-kappa ≥ 0.6 (allowing for small-sample noise). If pilot kappa < 0.6, reconcile the rubrics before proceeding. Record the pilot result in the README alongside the final kappa.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Before writing `build_adjudication_corpus.py`, add a one-time probe step (e.g., `--count-available` flag or a README note with an observed count) that reads a sample of actual sidecar payloads from git objects and reports how many surfaced and dropped rows are available, confirming the ≥90-dropped floor is achievable before the script is committed as the AC proving command.","cohort":["T2","T4","T7"],"criteria":["T2"],"decision":"dropped","drop_reason":null,"evidence":["'its docstring states it retains \"the full advisory OVERFLOW + DROPPED sets (not surfaced to the agent but retained here for analysis)\"'","'So: surfaced = rows with decision ∈ {block, advisory} and no drop_reason; dropped = rows carrying a drop_reason … Both are present in the sidecar — dropped findings are NOT reconstructed from PASS verdicts.'","No empirical probe of actual sidecar payloads is described; the floor is derived from the docstring assertion, not from counting available dropped rows."],"finding":"The ≥90-dropped-findings floor for the adjudication corpus is grounded only in a reading of `sidecar.build_payload`'s docstring, which the plan quotes as evidence that dropped findings are persisted in sidecar payloads. If the actual persisted sidecar payloads (recovered from git objects) have a different schema, older format, or did not always persist advisory-overflow/dropped sets, `build_adjudication_corpus.py` may not find enough dropped findings to meet the floor — with no diagnostic or fallback specified.","group_criteria":null,"group_id":null,"id":"fbe33bad10436b587","impact":0.0,"is_primary":null,"location":"Step 3 (Build the finding-adjudication corpus) — 'Data source (grounded in sidecar.build_payload)' paragraph and AC: '≥280 surfaced and ≥90 dropped'","norm_id":"n52ce1c596747c233","priority":0.0,"reason":"veto:absence-refuted","scenarios":["Sidecars written before a payload-schema change do not include the advisory-overflow set, meaning the available dropped findings across all tickets with had_persisted_review=true number fewer than 90 — the floor cannot be met and the script halts or produces an undersized corpus.","The `drop_reason` field was added in a later version of the sidecar schema; older sidecar events lack it, making dropped-finding recovery incomplete for early tickets in the corpus."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add a mechanism to validate that LLM-pair kappa translates to label quality — e.g. a small human-adjudicated spot-check sample (≥20 findings) compared against both raters' labels, or explicit acknowledgment in the README that kappa here measures LLM-pair consistency (not human-equivalent reliability), with downstream consumers warned accordingly.","cohort":["G6"],"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":["Rater B uses 'a different model id from Rater A' and 'an independently-authored rubric' — these controls reduce but do not eliminate correlated LLM errors","The plan states 'kappa ≥ 0.7 → labels are usable ground truth' with no qualification that this equivalence was established for human raters","No spot-check or human calibration sample is specified to validate that LLM kappa translates to label quality","ABSENCE: the plan contains no acknowledgment that two LLMs from adjacent model families may agree for wrong (shared) reasons"],"finding":"The kappa validity gate uses two LLM raters (different models, independently-worded rubrics) to measure inter-rater reliability, but LLMs trained on overlapping corpora tend to make correlated errors — meaning kappa ≥ 0.7 can be achieved even when both raters share systematic biases (e.g. both over-labeling confident-sounding findings as TP). The plan partially mitigates this with different models and rubrics, but does not acknowledge that LLM-pair kappa is not equivalent to human-pair kappa as a validity signal, and provides no mechanism to detect correlated systematic error.","group_criteria":null,"group_id":null,"id":"f64e9c464f0fbe010","impact":0.0,"is_primary":null,"location":"Step 4 (Inter-rater reliability) and Step 5 (kappa gate)","norm_id":"n9040a12829bc3507","priority":0.0,"reason":"low-validity","scenarios":["Both LLMs are trained on similar data and tend to label 'scope' findings as TP regardless of actual defect presence — kappa reaches 0.82 but the labels are systematically wrong, E2/E3/E6 are built on bad ground truth","A criterion with low population (e.g. T5c) has all TP findings correctly surfaced by both raters, yielding apparent high kappa driven by agreement on easy cases, masking disagreement on harder edge cases"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Justify committing a custom `kappa.py` over using `sklearn.metrics.cohen_kappa_score` (or equivalent), or switch to the library and reduce kappa.py to a thin wrapper that handles the pairwise-ambiguous-exclusion logic only.","cohort":["T1"],"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":["Plan states: 'committed harnesses/kappa.py computes Cohen's kappa on the binary {TP, FP} labels of the double-labeled subset (ambiguous excluded pairwise), prints the value'","No mention of scikit-learn, scipy, or any existing statistics library anywhere in the plan","ABSENCE: plan neither evaluates nor rejects available prior art for this computation"],"finding":"The plan commits a custom `harnesses/kappa.py` to compute Cohen's kappa, reinventing functionality that is directly available in well-tested standard libraries (e.g., `sklearn.metrics.cohen_kappa_score`), with no consideration of prior art.","group_criteria":null,"group_id":null,"id":"f0ab4e223ebce3671","impact":0.0,"is_primary":null,"location":"Step 4 / Scope / AC bullet 4 — 'committed harnesses/kappa.py computes Cohen's kappa'","norm_id":"n03e9f432320ca504","priority":0.0,"reason":"low-validity","scenarios":["Custom kappa.py may mis-handle edge cases (zero-division when one rater assigns all-TP, identical distributions, etc.) that sklearn handles correctly by default","Adding a custom script increases maintenance surface for a two-line computation"],"severity":"none","suggested_fix":"Replace the custom kappa implementation with `from sklearn.metrics import cohen_kappa_score`; keep `kappa.py` as a thin wrapper that (1) loads the corpus, (2) filters to the double-labeled subset, (3) excludes ambiguous pairwise, and (4) calls `cohen_kappa_score(rater_a_labels, rater_b_labels)`. Add `scikit-learn` to the harness dependencies in the README.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Ground the sidecar capability assertion in a concrete code citation (file path + key fields in the payload schema) or a sample committed REVIEW_RESULT event, confirming that `drop_reason` and the advisory-overflow set are present in persisted sidecar events before committing to the '≥90 dropped' AC floor.","cohort":["T1"],"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":["Plan states: 'the sidecar payload persists per-finding rows with decision, drop_reason, criteria, and fingerprints, and its docstring states it retains the full advisory OVERFLOW + DROPPED sets'","Plan further asserts: 'dropped findings are NOT reconstructed from PASS verdicts' — implying they must be present in the sidecar","ABSENCE: no code citation (file path + line range) verifying that the sidecar schema includes drop_reason and the overflow set in committed REVIEW_RESULT events; no sample payload shown"],"finding":"The plan's adjudication-corpus build (Step 3) rests on an unverified capability assertion that `sidecar.build_payload` actually persists the full OVERFLOW+DROPPED finding sets in the on-disk sidecar events — the plan cites only its own paraphrase of the docstring as evidence, without grounding this in code or data inspection.","group_criteria":null,"group_id":null,"id":"fb2fedc8b93a370ba","impact":0.0,"is_primary":null,"location":"Step 3 — 'Data source (grounded in sidecar.build_payload)' paragraph; AC bullet 3","norm_id":"n595fe2e7255e42ae","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":["If the sidecar only stores surfaced (block/advisory) findings and omits the overflow/dropped set, the '≥90 dropped' floor in the AC cannot be met and the entire adjudication corpus is infeasible","If drop_reason is nullable-but-absent (rather than present-and-null) for non-dropped rows, the source classification logic silently mislabels rows"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.3333,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"no","claims_absence":"no","committed_work_relies_on_unbacked_claim":"no","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["T3"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The pre-flight probe uses `git rev-list --count --objects --all` to count recovered ticket-genesis events, but combining `--count` and `--objects` is a non-standard flag interaction: `--count` causes git rev-list to output only a single integer (the commit count) and suppresses the per-object lines that `--objects` would normally add. The result is a commit count, NOT an object/ticket count, making the '≥ 500 reviewed tickets recovered' floor comparison semantically wrong — it compares commit count to a ticket-row floor.","group_criteria":null,"group_id":null,"id":"f40928129ab7bb121","impact":0.0,"is_primary":null,"location":"What § Step 1 pre-flight: 'runs `git rev-list --count --objects --all` and counts recovered ticket-genesis events'","norm_id":"ne8bcf0206bebda54","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":[],"severity":"none","suggested_fix":"Use `git rev-list --objects --all | grep -c 'genesis\\|CREATE'` (or equivalent Python subprocess parsing) to count ticket-genesis events; or use `git cat-file --batch-check --batch-all-objects` to list all objects and filter. Drop `--count` from the rev-list invocation since it conflicts with per-object enumeration.","tier":"LLM","validity":0.4286,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"no","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"yes","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The `post_claim_edit_class` classification window ('between the ticket's first transition-into-`in_progress` and its close') is under-specified for tickets with reopen_count > 0: a reopened ticket has multiple in_progress→closed cycles, so using only the 'first' transition-into-in_progress will misclassify edits that occurred in a later round (e.g. between second claim and second close) as outside the post-claim window, silently producing wrong `post_claim_edit_class` values for any multi-round ticket in the corpus.","group_criteria":null,"group_id":null,"id":"f935250fd40038cb5","impact":0.0,"is_primary":null,"location":"What, Step 1 — `post_claim_edit_class` definition; outcome-corpus schema `reopen_count` field","norm_id":"nf1c34b9ee405606c","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Use per-round windows: for each (in_progress, close) event pair ordered by timestamp, classify edits that fall within that pair's interval; assign the most-specific edit class across all rounds for the row, or add a `rounds` sub-array if per-round detail is needed.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The `post_claim_edit_class` field requires 'exactly one per row' from a 7-value closed vocabulary, but no conflict-resolution rule is specified for tickets with multiple post-claim edits that would each fall into different classes (e.g., a `cosmetic` edit followed by an `approach-change` edit within the same post-claim window).","group_criteria":null,"group_id":null,"id":"f9616233171e6f6e5","impact":0.0,"is_primary":null,"location":"Step 1 (What) — post_claim_edit_class definition; §5.2 taxonomy","norm_id":"n8ebad5fb44d98437","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Add a priority ladder (e.g., premise-invalidated > approach-change > scope-reduction > ac-strengthened > plan-authored-post-claim > operator-attested-retag > cosmetic > none) so the most impactful class is always assigned when multiple edits occur.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a proving sub-command or note to AC3 requiring that each of the 8 named case tickets (dc58-af7b, db7b-c8fd, 5886-d028, c8cc-68b8, f5df-0069, 115b-ceea, 8c4f-b81c, 3006-e198) resolves via `rebar show` (e.g., a `--verify-s5` exit-code check or a separate `--check-cases` flag) so the described 'confirmed present' verification is gated by an AC.","cohort":["COH","E1","T5d"],"criteria":["E1"],"decision":"advisory","drop_reason":"novelty","evidence":["Step 2: 'All eight case tickets are confirmed present in the store (`rebar show` resolves each).'","AC3 proving command: 'python .../mine_outcome_corpus.py --verify-s5 prints the derived figures.' — no `rebar show` step."],"finding":"The plan body (Step 2) describes a mandatory verification step — 'All eight case tickets are confirmed present in the store (`rebar show` resolves each)' — but no AC proving command covers this check. The AC3 proving command only runs `--verify-s5` and checks printed figures; it does not include a `rebar show` check for each of the 8 named tickets (dc58-af7b, db7b-c8fd, 5886-d028, c8cc-68b8, f5df-0069, 115b-ceea, 8c4f-b81c, 3006-e198). This is described work with no covering criterion.","group_criteria":null,"group_id":null,"id":"ffa5b5b40f5a4e5e3","impact":0.44,"is_primary":null,"location":"Step 2 body ('All eight case tickets are confirmed present in the store') vs AC3 proving command ('python .../mine_outcome_corpus.py --verify-s5 prints the derived figures')","norm_id":"nf83920b86b499a92","priority":0.275,"reason":"default-advisory","scenarios":["An implementer runs `--verify-s5`, sees figures print, and considers AC3 satisfied — without ever confirming the 8 named tickets are resolvable, leaving the §5 disambiguation claim unverified."],"severity":"minor","suggested_fix":"Extend the AC3 proving command: add `python .../mine_outcome_corpus.py --verify-s5 --check-cases` exits 0 (where `--check-cases` runs `rebar show` on each of the 8 ids and errors if any is missing), or add a one-liner `for id in dc58-af7b db7b-c8fd ...; do rebar show $id; done` as a second proving command in AC3.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a note to Step 0 or the Scope section that `docs/research/` is a new directory to be created alongside the SOTA report file.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":"novelty","evidence":["list_directory('docs') output: no 'research/' entry in docs/","search_files for 'docs/research' returns only cache hits referencing the missing path, not the directory itself","The file is the §5 provenance baseline that the re-verification table in AC#2 depends on"],"finding":"The `docs/research/` directory does not exist in the repository, yet the plan's first committed artifact (`docs/research/task-decomposition-sota-2026.md`) is placed there without noting that the parent directory must be created.","group_criteria":null,"group_id":null,"id":"face4744f6e719289","impact":0.0,"is_primary":null,"location":"Step 0 and Scope: 'docs/research/task-decomposition-sota-2026.md (landed from 143d5074e — §5 provenance baseline)'","norm_id":"n40c1c9f49d1e580d","priority":0.0,"reason":"default-advisory","scenarios":["An executor who misses that the parent directory must be created will encounter a path error when trying to write the file, or will create it in the wrong location."],"severity":"none","suggested_fix":"Add to Step 0: '(creates `docs/research/` if absent)' so the executor knows the parent directory is new.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence"