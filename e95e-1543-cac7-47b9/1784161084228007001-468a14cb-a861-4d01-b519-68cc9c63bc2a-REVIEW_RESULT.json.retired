{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","data":{"coaching":[{"coaching":"Test the riskiest assumption behind random seed absence in stratified sampling first.","decision":"advisory","finding_refs":["f8da04b25195a5738"],"move_id":"4","move_name":"riskiest-assumption test","subject":"random seed absence in stratified sampling"},{"coaching":"Pin down AC4 concrete proving command with a concrete worked example.","decision":"advisory","finding_refs":["f3ab2857be5a3ec0f"],"move_id":"6","move_name":"specification by example","subject":"AC4 concrete proving command"},{"coaching":"Pin down stratification algorithm for finding sampling with a concrete worked example.","decision":"advisory","finding_refs":["f9a199fff1b71c607"],"move_id":"6","move_name":"specification by example","subject":"stratification algorithm for finding sampling"},{"coaching":"Pin down positional DROPPED-segment slice formula with a concrete worked example.","decision":"advisory","finding_refs":["f5a47c5a6768f4002","f37bb25ed105b1ab3"],"move_id":"6","move_name":"specification by example","subject":"positional DROPPED-segment slice formula"},{"coaching":"Plan how Rater B blind-labeling isolation mechanism will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f88a4fd92094119c5"],"move_id":"9","move_name":"plan the verification","subject":"Rater B blind-labeling isolation mechanism"},{"coaching":"Plan how AC5 README-vs-kappa.py match verification will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f948610069c88e416"],"move_id":"9","move_name":"plan the verification","subject":"AC5 README-vs-kappa.py match verification"},{"coaching":"Pin down rubric file content and contract specification with a concrete worked example.","decision":"advisory","finding_refs":["f5db9de56e29c1b79","ff66f321ede48a1e0"],"move_id":"6","move_name":"specification by example","subject":"rubric file content and contract specification"},{"coaching":"Test the riskiest assumption behind atomic write pattern for adjudication corpus first.","decision":"advisory","finding_refs":["f3529b97bf0c5b5f7"],"move_id":"4","move_name":"riskiest-assumption test","subject":"atomic write pattern for adjudication corpus"},{"coaching":"Run a quick pre-mortem on LLM batch call failure and retry strategy: how could this plan fail?","decision":"advisory","finding_refs":["f2bee5cb400b5539b","f1292b5365e68b23f"],"move_id":"3","move_name":"pre-mortem","subject":"LLM batch call failure and retry strategy"},{"coaching":"Pin down scan-both directive scope for retired event files with a concrete worked example.","decision":"advisory","finding_refs":["f570eec1bdb8b2e1a"],"move_id":"6","move_name":"specification by example","subject":"scan-both directive scope for retired event files"},{"coaching":"Plan how ticket comment re-verification requirement coverage will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f2d0e82bca32d90e8"],"move_id":"9","move_name":"plan the verification","subject":"ticket comment re-verification requirement coverage"},{"coaching":"Research prior art / OSS for canonical atomic-write helper in rebar codebase before building it custom.","decision":"advisory","finding_refs":["fbb621f636a1ae38a"],"move_id":"2","move_name":"prior-art research","subject":"canonical atomic-write helper in rebar codebase"},{"coaching":"State the concrete attestation evidence the [operator-attested] sidecar payload positional-bucketing structure attestation will require (a change id / vote outcome / timestamp), recorded on the ticket.","decision":"advisory","finding_refs":["fbefbb284108e0d24"],"move_id":"14","move_name":"state attestation evidence","subject":"sidecar payload positional-bucketing structure attestation"},{"coaching":"Plan how acceptance-criteria completeness and verifiability will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f607dd457c67f9209"],"move_id":"9","move_name":"plan the verification","subject":"acceptance-criteria completeness and verifiability"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":19,"blocking":0,"dropped":15,"indeterminate":0},"det":{"P1":{"ac_items":5,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","probed":12,"ran":true,"references":12,"resolved":0,"status":"pass","unresolved_or_abstained":12},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":5,"blocking":false,"desc_chars":13088,"file_impact":1,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":5,"blocking":false,"name":"ac-quality","ran":true,"status":"fail","verify_commands_linted":162,"verify_lint_abstained":161},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":3294,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":1,"name":"file-impact-coverage","ran":true,"status":"pass"}},"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":196.1,"llm_calls":30,"llm_ms":932044.3,"total_ms":932381.1,"verify_requests":39},"remediation":{"baseline":"sidecar","eligible":false,"reasons":{"code_unchanged":false,"plan_changed":true,"registry_unchanged":true,"sidecar_baseline":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","F4","G5","T2","T4","T5b","T5d","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify a fixed random seed (e.g., `--seed 42`) for the stratified sampling in `build_adjudication_corpus.py` and document it in the README regeneration command so the corpus is bit-reproducible from committed inputs.","cohort":["T5b","T5e","T9"],"criteria":["T9","T5e"],"decision":"advisory","drop_reason":null,"evidence":["'Target ~300 surfaced + ~100 dropped findings, stratified by criterion'","Scope: README documents 'the exact regeneration commands'","ABSENCE: no mention of a fixed random seed or deterministic sampling algorithm"],"finding":"`build_adjudication_corpus.py` performs stratified sampling from the persisted findings population but no random seed is specified. Re-running the script produces a different sample, meaning the committed `adjudication_corpus.jsonl` is not reproducible from the committed inputs alone — violating the plan's stated goal of a 'committed, versioned corpus' with 'exact regeneration commands'.","group_criteria":null,"group_id":null,"id":"f8da04b25195a5738","impact":0.67,"is_primary":null,"location":"Step 3 / Scope: `runs/README.md` regeneration commands / `harnesses/build_adjudication_corpus.py`","norm_id":"ne6841434b471c2db","priority":0.5863,"reason":"default-advisory","scenarios":["Developer runs the regeneration command six months later to validate the corpus; gets a different 400-finding sample; kappa computed on the new sample differs from the committed value; provenance chain breaks."],"severity":"major","suggested_fix":"Pass `random.seed(args.seed)` (defaulting to 42) before any sampling call, and include `--seed 42` in the documented regeneration command.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Replace the prose proving command in AC4 with a concrete, runnable jq/python command that checks both field presence and floor counts, e.g.: `jq -e 'select(.source and .tp_fp and .rationale) | .source' runs/adjudication_corpus.jsonl | wc -l` plus `jq -r 'select(.source==\"surfaced\")' runs/adjudication_corpus.jsonl | wc -l` asserting ≥280.","cohort":["E2","E6","F1"],"criteria":["E6","F1"],"decision":"advisory","drop_reason":null,"evidence":["'Proving command: a python/jq check that every row has source, tp_fp, rationale and the surfaced/dropped counts meet the floor' — the command is described in prose, not written out.","All other ACs have concrete commands (--dry-run, wc -l, --verify-s5, kappa.py); this one does not.","The defect taxonomy item (5): missing cardinality assertion when the criterion names a count — the floor counts (≥280, ≥90) are named but no jq assertion is given."],"finding":"AC4's proving command is described as 'a python/jq check' but no concrete command is provided, violating the requirement that every completion-relevant claim has a concrete proving command that produces evidence on success.","group_criteria":null,"group_id":null,"id":"f3ab2857be5a3ec0f","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — AC for adjudication corpus: 'Proving command: a python/jq check that every row has source, tp_fp, rationale and the surfaced/dropped counts meet the floor'","norm_id":"n67bf1d655345a2ba","priority":0.55,"reason":"default-advisory","scenarios":["Executor writes a one-line jq that only checks field presence but not counts, incorrectly satisfying the AC.","The adjudication corpus has 279 surfaced rows (1 below floor) but the vague proving command passes anyway."],"severity":"major","suggested_fix":"Proving command: `python -c \"import json,sys; rows=list(map(json.loads,open('runs/adjudication_corpus.jsonl'))); surf=sum(1 for r in rows if r['source']=='surfaced'); drop=sum(1 for r in rows if r['source']=='dropped'); assert all(set(['source','tp_fp','rationale'])<=r.keys() for r in rows),'missing fields'; assert surf>=280,f'surfaced={surf}<280'; assert drop>=90,f'dropped={drop}<90'; print(f'OK surf={surf} drop={drop}')\"` ","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Specify the stratification algorithm in Step 3 (e.g. 'proportional to criterion frequency, minimum 5 surfaced per criterion, random sample within each stratum, seed=42') so the executor can implement it without design choices.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"advisory","drop_reason":null,"evidence":["'stratified by criterion id and by bucket' — no allocation rule specified.","'if the population is smaller, all available are taken' — only the degenerate case is handled; the normal-case sampling algorithm is absent."],"finding":"The stratification algorithm for sampling ~300 surfaced and ~100 dropped findings from the available population is not specified. The plan says 'stratified by criterion id and by bucket' but does not define the per-stratum allocation (proportional to population? equal per criterion? capped per criterion?), leaving a real design choice to the executor.","group_criteria":null,"group_id":null,"id":"f9a199fff1b71c607","impact":0.67,"is_primary":null,"location":"Step 3 — 'samples plan-review findings... Target ~300 surfaced + ~100 dropped findings, stratified by criterion id and by bucket'","norm_id":"ne185274d007b3389","priority":0.5025,"reason":"default-advisory","scenarios":["Executor uses proportional stratification, causing rare criteria with few findings to be underrepresented, degrading kappa reliability for those criteria.","Executor uses equal-per-criterion allocation, causing common criteria to be severely undersampled relative to their actual prevalence."],"severity":"major","suggested_fix":"Add: 'Stratification: proportional to each criterion's share of the total surfaced population, with a minimum of 5 findings per criterion; ties broken by random shuffle with fixed seed (e.g. seed=42); dropped findings sampled proportionally to surfaced ratio per criterion.'","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] In Step 3's positional-bucketing rule, specify the exact four-segment slice using all five `coverage.counts` offsets: `OVERFLOW = findings[B:B+O]`, `INDETERMINATE = findings[B+O:B+O+I]`, `DROPPED = findings[B+O+I:]` (where B=blocking+advisory_surfaced, O=advisory_overflow, I=indeterminate), so the implementer knows to skip the indeterminate block between overflow and the final dropped segment.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["plan states: 'SURFACED = findings[: blocking + advisory_surfaced]' and 'DROPPED = the overflow segment ++ the trailing dropped segment'","sidecar.py build_payload line 472-477: `all_findings = verdict.get('blocking',[]) + verdict.get('advisory',[]) + verdict.get('overflow',[]) + verdict.get('indeterminate',[]) + verdict.get('dropped',[])`","coverage.counts stores {blocking, advisory_surfaced, advisory_overflow, dropped, indeterminate} — the indeterminate count is needed to skip that segment when slicing DROPPED","The plan never states that the DROPPED slice must offset by coverage.counts['indeterminate'] to skip past the indeterminate block"],"finding":"The positional DROPPED-segment slicing formula is underspecified: `indeterminate` findings sit between `overflow` and `dropped` in the persisted `findings[]` array (sidecar `build_payload` concatenates `blocking + advisory + overflow + indeterminate + dropped`), so 'DROPPED = overflow segment ++ trailing dropped segment' cannot be extracted without also consuming the `indeterminate` count from `coverage.counts`. A naive implementation reading 'the tail after SURFACED' would silently absorb indeterminate findings into the DROPPED bucket, mis-labelling them and inflating the DROPPED count.","group_criteria":null,"group_id":null,"id":"f5a47c5a6768f4002","impact":0.67,"is_primary":null,"location":"Step 3 — `build_adjudication_corpus.py`, positional-bucketing rule: 'DROPPED = the overflow segment ++ the trailing dropped segment'","norm_id":"n24ee447e82b97088","priority":0.5025,"reason":"default-advisory","scenarios":["build_adjudication_corpus.py implements DROPPED as findings[blocking+advisory_surfaced:], thereby including all indeterminate findings in the DROPPED bucket — they are then adjudicated as 'correctly suppressed' or 'missed defect', corrupting the kappa substrate.","A review with many INDETERMINATE findings (e.g. verify_failed=True) produces a severely inflated DROPPED count, making the ≥90 dropped floor easy to hit with noise."],"severity":"major","suggested_fix":"Replace the prose 'DROPPED = the overflow segment ++ the trailing dropped segment' with the explicit index formula: let B = counts.blocking + counts.advisory_surfaced, O = counts.advisory_overflow, I = counts.indeterminate; then SURFACED = findings[:B], OVERFLOW = findings[B:B+O], INDETERMINATE = findings[B+O:B+O+I], DROPPED_ONLY = findings[B+O+I:]; the adjudication corpus samples from SURFACED (source=surfaced) and from OVERFLOW+DROPPED_ONLY (source=dropped), excluding INDETERMINATE entirely.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Clarify that the DROPPED positional slice uses all five `coverage.counts` offsets: `SURFACED = findings[:blocking+advisory_surfaced]`; `OVERFLOW = findings[blocking+advisory_surfaced : blocking+advisory_surfaced+advisory_overflow]`; `INDETERMINATE = findings[blocking+advisory_surfaced+advisory_overflow : blocking+advisory_surfaced+advisory_overflow+indeterminate]`; `DROPPED = findings[blocking+advisory_surfaced+advisory_overflow+indeterminate :]` — the `indeterminate` segment must be excluded from the DROPPED bucket (or documented as a separate excluded bucket) since it represents unverified-but-not-suppressed findings.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Plan states: 'findings = blocking ++ advisory_surfaced ++ overflow ++ indeterminate ++ dropped' and 'DROPPED = the overflow segment ++ the trailing dropped segment' — the indeterminate segment is named in the ordering but excluded from the DROPPED definition.","sidecar.py build_payload lines 472-477 (confirmed by tool): `all_findings = verdict.get('blocking',[]) + verdict.get('advisory',[]) + verdict.get('overflow',[]) + verdict.get('indeterminate',[]) + verdict.get('dropped',[])` — indeterminate sits BETWEEN overflow and dropped.","orchestrator.py lines 506-512 confirm `coverage.counts` carries all five counts including `indeterminate`.","A script that implements DROPPED as `findings[blocking+advisory_surfaced+advisory_overflow : blocking+advisory_surfaced+advisory_overflow+dropped_count]` is correct, but the plan text 'DROPPED = the overflow segment ++ the trailing dropped segment' implies `findings[blocking+advisory_surfaced:]` or similar, silently absorbing indeterminate rows into DROPPED."],"finding":"The positional-bucketing formula for the DROPPED segment omits the `indeterminate` segment, making the slice formula wrong by `coverage.counts['indeterminate']` entries.","group_criteria":null,"group_id":null,"id":"f37bb25ed105b1ab3","impact":0.67,"is_primary":null,"location":"Step 3 — `build_adjudication_corpus.py`, positional-bucketing rule: 'DROPPED = the overflow segment ++ the trailing dropped segment'","norm_id":"nf76efe91914e9d41","priority":0.5025,"reason":"default-advisory","scenarios":["A ticket with verify_failed=True can have many INDETERMINATE findings. build_adjudication_corpus.py reads `DROPPED = findings[blocking+advisory_surfaced:]` and silently absorbs all indeterminate findings into the DROPPED bucket, inflating the ≥90 dropped floor with noise and assigning TP/FP adjudications to unverified findings rather than truly suppressed ones.","Kappa is computed on a contaminated corpus — indeterminate findings adjudicated as 'dropped' corrupt the inter-rater reliability signal."],"severity":"major","suggested_fix":"Add to Step 3 (and the README positional-bucketing rule): 'The five-segment offsets must all be applied: `n_s = blocking + advisory_surfaced`; `n_ov = advisory_overflow`; `n_ind = indeterminate`; `n_d = dropped` (all from `coverage.counts`). `SURFACED = findings[:n_s]`; `OVERFLOW = findings[n_s:n_s+n_ov]` (excluded from both buckets); `INDETERMINATE = findings[n_s+n_ov:n_s+n_ov+n_ind]` (excluded — unverified, not a suppression decision); `DROPPED = findings[n_s+n_ov+n_ind:]`. The adjudication corpus samples from SURFACED (bucket=surfaced) and DROPPED (bucket=dropped) only; OVERFLOW and INDETERMINATE are excluded.'","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The plan requires Rater B to label a 50-finding subset 'BLIND to Rater A's labels', but no mechanism is specified to prevent Rater B from seeing the `tp_fp` and `rater_a` fields already written into `adjudication_corpus.jsonl` by Rater A. If `kappa.py` or the Rater B invocation script reads the same JSONL file without stripping those fields before presenting findings to the Rater B LLM, the 'blind' requirement fails, and the kappa value is inflated by anchoring rather than measuring true independent agreement.","group_criteria":null,"group_id":null,"id":"f88a4fd92094119c5","impact":0.67,"is_primary":null,"location":"What, Step 4 — Double-label and compute inter-rater reliability; Rater B description","norm_id":"n3a7842d389eaa6b6","priority":0.5025,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":null,"blocking_enabled":null,"checklist_item":"","cohort":null,"criteria":["P6"],"decision":"advisory","drop_reason":null,"evidence":["4 criterion line(s) bundle multiple deliverables with 'and' (split so each is independently verifiable).","vague/subjective terms present: clean","verify command `wc -l runs/outcome_corpus.jsonl` inspects output with `wc` but asserts nothing — add an exit-code or comparison (-q, [ \"$(...)\" -eq N ], jq -e) so a failure is observable"],"finding":"Acceptance-criteria / definition-of-done quality issues.","group_criteria":null,"group_id":null,"id":"f607dd457c67f9209","impact":0.4,"is_primary":null,"location":"","norm_id":"ned06ebc801a522e3","priority":0.4,"reason":null,"scenarios":[],"severity":"minor","suggested_fix":"Split compound criteria, replace subjective terms with observable outcomes, and state how each is verified.","tier":"DET","validity":1.0,"verification":null},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a concrete README-content proving command to AC3 and AC5 that checks for required section headings and the kappa value match, e.g. `grep -q 'AGREES\\|CORRECTED-TO' docs/experiments/plan-review-gate/runs/README.md` for AC3 and `grep -qF \"$(python .../kappa.py runs/adjudication_corpus.jsonl | grep -oP '[0-9.]+')\" runs/README.md` for AC5.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["'the README value matches' is asserted but no command compares the kappa.py output to the README value.","README must also contain: both schemas, the §5 re-verification table, retention caps, the exact regeneration commands, provenance, positional-bucketing rule — none of these are commanded for verification.","AC3 requires the re-verification table to record per-figure AGREES/CORRECTED-TO annotations, but no command checks the README for these annotations."],"finding":"AC5 states that 'the README value matches' the kappa printed by kappa.py, but there is no concrete command that verifies this match. The README content (re-verification table, kappa value, rater/model identities) is load-bearing for downstream consumers but no AC or proving command checks that the README actually contains these required sections.","group_criteria":null,"group_id":null,"id":"f948610069c88e416","impact":0.55,"is_primary":null,"location":"AC5 — 'README records it with both rater/model identities... the README value matches. Proving command: python .../kappa.py runs/adjudication_corpus.jsonl prints kappa and the README value matches'","norm_id":"n8d5ba5dc451f0160","priority":0.3929,"reason":"default-advisory","scenarios":["The README is committed without the re-verification table or with the wrong kappa value; kappa.py passes its own check but the README is stale or incomplete.","A downstream story (E2/E3) consumes the README and finds missing schema documentation, blocking its work."],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.7143,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an AC that verifies both `harnesses/adjudicate_rubric_a.md` and `harnesses/adjudicate_rubric_b.md` exist and contain the required elements (TP/FP definition, criterion-aware judgment instruction, JSON-per-finding output spec, independent wording between A and B).","cohort":["COH","E1","T5d"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["Scope: 'adjudicate_rubric_a.md', 'adjudicate_rubric_b.md' listed as new committed files","Step 4 rubric contract: 'each states the TP/FP definitions verbatim, instructs criterion-aware judgment... and fixes output as one JSON object per finding {finding_id, tp_fp ∈ {TP,FP,ambiguous}, rationale}'","ABSENCE: no AC line checks that these files exist or satisfy the contract"],"finding":"The rubric files `harnesses/adjudicate_rubric_a.md` and `harnesses/adjudicate_rubric_b.md` are in-scope deliverables with a specific contract (Step 4: TP/FP definitions verbatim, criterion-aware judgment context, fixed JSON output per finding, independently worded), but no Acceptance Criterion verifies their existence or compliance with that contract.","group_criteria":null,"group_id":null,"id":"f5db9de56e29c1b79","impact":0.44,"is_primary":null,"location":"Scope section (lists adjudicate_rubric_a.md, adjudicate_rubric_b.md); Step 4 (specifies rubric contract); Acceptance Criteria (no matching entry)","norm_id":"n45b4b29ce26889b0","priority":0.3143,"reason":"default-advisory","scenarios":["Implementer produces rubric files that omit the TP/FP definition or use a non-JSON output format; the kappa validity gate passes anyway because no AC enforces rubric contract compliance"],"severity":"minor","suggested_fix":"Add to Acceptance Criteria: '`harnesses/adjudicate_rubric_a.md` and `harnesses/adjudicate_rubric_b.md` are committed; each contains the TP/FP definitions verbatim and a fixed `{finding_id, tp_fp, rationale}` JSON output contract; rubric B is worded independently of rubric A (no shared prompt boilerplate beyond the schema definition). Proving command: `grep -c \"TP\" adjudicate_rubric_a.md adjudicate_rubric_b.md` both ≥ 1 and a reviewer diff confirms independent wording.'","tier":"LLM","validity":0.7143,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The two rubric files `adjudicate_rubric_a.md` and `adjudicate_rubric_b.md` are named in Scope and their contract is specified in Step 4 (they must state TP/FP definitions verbatim, include criterion-aware judgment, and fix the output schema), but no Acceptance Criterion verifies that these files are committed or satisfy the rubric contract. An implementer could omit them or deliver them without the required TP/FP definitions and the AC gate would still pass.","group_criteria":null,"group_id":null,"id":"ff66f321ede48a1e0","impact":0.44,"is_primary":null,"location":"Scope (harnesses list) / What Step 4 / Acceptance Criteria (all four ACs — none cover rubric files)","norm_id":"n498e4440a14cf00e","priority":0.3143,"reason":"default-advisory","scenarios":[],"severity":"minor","suggested_fix":"Add to AC #4: 'Proving command: `grep -q \"TP/FP\" harnesses/adjudicate_rubric_a.md && grep -q \"TP/FP\" harnesses/adjudicate_rubric_b.md` exits 0; both files contain the output schema `{finding_id, tp_fp ∈ {TP,FP,ambiguous}, rationale}` and the verbatim TP/FP definitions from the README.'","tier":"LLM","validity":0.7143,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify atomic write (`.tmp` + `os.replace`) or a checkpoint/resume mechanism for `adjudication_corpus.jsonl` in `build_adjudication_corpus.py` so a mid-batch LLM failure leaves the previous committed state intact.","cohort":["T5b","T5e","T9"],"criteria":["T5b","T9"],"decision":"advisory","drop_reason":null,"evidence":["Outcome corpus: 'written atomically (.tmp + os.replace)'","Adjudication corpus: no analogous atomicity statement — ABSENCE","Step 4: Rater A labels 'the full sample' (~400 LLM calls) with no checkpoint or atomic-write guarantee mentioned"],"finding":"`adjudication_corpus.jsonl` is written by `build_adjudication_corpus.py` via batched LLM calls (Rater A adjudicates ~400 findings) but the plan specifies no atomic write pattern for this file — unlike `outcome_corpus.jsonl` which explicitly uses `.tmp` + `os.replace`. A mid-batch LLM failure leaves a partial/corrupt file with no recovery path.","group_criteria":null,"group_id":null,"id":"f3529b97bf0c5b5f7","impact":0.33,"is_primary":null,"location":"Step 3 / Scope: `harnesses/build_adjudication_corpus.py` / AC: `runs/adjudication_corpus.jsonl` is committed","norm_id":"n47ed9552ec87aabc","priority":0.2063,"reason":"default-advisory","scenarios":["Rater A LLM call fails at finding #250 of 400 — partial JSONL is left on disk; subsequent `kappa.py` run reads corrupt/incomplete corpus; downstream E2/E3 receive a silently-wrong ground truth."],"severity":"minor","suggested_fix":"Write findings to a `.tmp` file and `os.replace` atomically on completion, exactly as specified for `outcome_corpus.jsonl`; alternatively, write to a per-finding staging file and merge only on full completion.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify retry/backoff (e.g., exponential backoff with ≥3 retries) for each LLM adjudication call in `build_adjudication_corpus.py`, with a defined behavior on exhaustion (halt with error, not silent skip).","cohort":["T5b","T5e","T9"],"criteria":["T5b"],"decision":"advisory","drop_reason":null,"evidence":["'Rater A (primary): LLM adjudicator… labels the full sample TP/FP/ambiguous' — no retry/error handling mentioned","'Rater B (independent): a second LLM adjudicator… re-labels a stratified-by-criterion ≥50-finding subset' — no error handling mentioned","ABSENCE: no mention of retry, backoff, circuit-breaker, or graceful degradation for LLM calls anywhere in the plan"],"finding":"LLM adjudication calls (Rater A over ~400 findings, Rater B over ≥50 findings) have no retry, backoff, or error-handling strategy specified. A transient API failure mid-batch produces an unspecified outcome — the plan is silent on whether the call is retried, skipped, or fatal.","group_criteria":null,"group_id":null,"id":"f2bee5cb400b5539b","impact":0.33,"is_primary":null,"location":"Step 4 / `harnesses/build_adjudication_corpus.py`, `adjudicate_rubric_a.md`, `adjudicate_rubric_b.md`","norm_id":"n28450e2894668051","priority":0.2063,"reason":"default-advisory","scenarios":["Transient LLM timeout at finding #180 of 400 silently drops remaining findings if the script continues, or aborts leaving a partial file if it raises; neither path is specified."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Replace the unbacked `rebar.llm.completion_sidecar` public-reader-API citation with the actual mechanism: directly scan `*-COMPLETION_VERDICT.json` (and `*.retired`) files in `.tickets-tracker/<ticket_id>/`, filter by `event['data']['schema'] == 'completion_verifier_fail_v1'`, and count — the `completion_sidecar` module has no all-history reader equivalent to `all_review_results`.","cohort":["E4"],"criteria":["E4"],"decision":"advisory","drop_reason":null,"evidence":["src/rebar/llm/completion_sidecar.py defines only: emit(), prune(), latest_fail_verdict(), latest_pass_record(), build_payload() — no all-history reader function exists.","all_review_results (plan_review sidecar) has a full-history analogue; completion_sidecar does NOT.","The plan's own derivation rule says 'number of COMPLETION_VERDICT events with data.schema==\"completion_verifier_fail_v1\"' — counting all events across history, not just the latest.","Plan also correctly says to scan event files directly, but the API citation implies the sidecar provides the abstraction when it does not."],"finding":"The plan cites `rebar.llm.completion_sidecar` as a 'clean public reader API' (parallel to `all_review_results`) for reading retained COMPLETION_VERDICT history, but `completion_sidecar.py` exposes only `latest_fail_verdict` and `latest_pass_record` — there is NO `all_completion_results` or equivalent full-history reader. The `completion_verifier_fail_count` derivation requires counting ALL COMPLETION_VERDICT events with `schema==\"completion_verifier_fail_v1\"` across a ticket's history, which the sidecar's public API cannot supply. The plan's own event-file scanning approach is the correct mechanism, but the API citation is unbacked and will mislead the implementer.","group_criteria":null,"group_id":null,"id":"faffb1c73873f24aa","impact":0.33,"is_primary":null,"location":"Step 1, 'Data source' paragraph: '…completion sidecars are read through their clean public reader APIs (`rebar.llm.plan_review.sidecar.all_review_results`, `rebar.llm.completion_sidecar`)…'; also `completion_verifier_fail_count` derivation bullet.","norm_id":"nafb6493794caa893","priority":0.2063,"reason":"default-advisory","scenarios":["An implementer following the plan calls `completion_sidecar.all_completion_results(ticket_id)` or similar and gets an AttributeError — no such API exists.","An implementer reads only `latest_fail_verdict` thinking that is the 'public reader API', producing `completion_verifier_fail_count` of 0 or 1 instead of the true count across all retained events."],"severity":"minor","suggested_fix":"Change the Step 1 data-source sentence to: 'Plan-review history is read via `rebar.llm.plan_review.sidecar.all_review_results`; COMPLETION_VERDICT fail counts are derived by scanning `*-COMPLETION_VERDICT.json` / `*.retired` event files directly and counting payloads with `schema==\"completion_verifier_fail_v1\"` (the `completion_sidecar` module provides only `latest_fail_verdict`/`latest_pass_record`, not a full-history reader).' Update the `completion_verifier_fail_count` derivation bullet accordingly.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Clarify that `completion_verifier_fail_count` requires raw event-file scanning for COMPLETION_VERDICT events (not a reader API call), and remove `rebar.llm.completion_sidecar` from the 'clean public reader APIs' list (or name the specific function used, which would need to be added to the module if an API approach is wanted).","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["src/rebar/llm/completion_sidecar.py exposes latest_fail_verdict() and latest_pass_record() — single-record readers, no count-all function","The Step 1 derivation correctly specifies counting COMPLETION_VERDICT events by scanning event files: 'number of COMPLETION_VERDICT events with data.schema==\"completion_verifier_fail_v1\"' — this requires raw event scanning, not an API","Listing completion_sidecar as a 'clean public reader API' parallel to all_review_results implies a count-all or list-all API exists in it when it does not"],"finding":"The plan's Step 1 data-source section lists `rebar.llm.completion_sidecar` as one of the 'clean public reader APIs' alongside `all_review_results`, but the completion_sidecar module exposes only `latest_fail_verdict` and `latest_pass_record` (single-record readers) — it has no count-all function for COMPLETION_VERDICT events. The `completion_verifier_fail_count` derivation the plan specifies (count of COMPLETION_VERDICT events with data.schema==\"completion_verifier_fail_v1\") correctly requires raw event-file scanning, not the completion_sidecar reader API. Listing completion_sidecar as a reader API in the same breath as all_review_results suggests an API-level read is available for this field when it isn't.","group_criteria":null,"group_id":null,"id":"f3fea42b08842fd57","impact":0.33,"is_primary":null,"location":"Step 1, data-source paragraph: 'Plan-review and completion sidecars are read through their clean public reader APIs (`rebar.llm.plan_review.sidecar.all_review_results`, `rebar.llm.completion_sidecar`)'","norm_id":"ndd6440ebea8114ee","priority":0.2063,"reason":"default-advisory","scenarios":["Implementer calls completion_sidecar.some_count_function() expecting an API — finds no such function, causing confusion about whether raw event scanning is intended","Implementer uses only latest_fail_verdict() (single-record) and underscores completion_verifier_fail_count, missing that counting requires scanning all COMPLETION_VERDICT event files"],"severity":"minor","suggested_fix":"Revise the data-source sentence to: 'Plan-review review-round history is read via `rebar.llm.plan_review.sidecar.all_review_results`; `completion_verifier_fail_count` is derived by scanning raw event files in the ticket directory for COMPLETION_VERDICT events with data.schema==\"completion_verifier_fail_v1\" (no count-all API exists in completion_sidecar).'","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a fallback protocol to Step 4 (and the rubric contract): specify what `build_adjudication_corpus.py` / `kappa.py` does when a rater call returns malformed JSON or an out-of-vocab `tp_fp` (e.g. retry once, then mark as `ambiguous`/excluded, and halt if the double-labeled subset falls below the 50-finding floor).","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Plan specifies rubric output contract as 'one JSON object per finding {finding_id, tp_fp ∈ {TP,FP,ambiguous}, rationale}' but states no retry, skip, or error-exit behavior when that contract is violated.","Plan states 'kappa.py exits non-zero' only for the kappa < 0.7 case — no exit or error behavior is defined for a rater that returns 0 valid labels.","ABSENCE: no retry count, no minimum-response threshold, no behavior for partial rater failure (e.g. rater B labels only 30 of 50 findings) is defined."],"finding":"No fallback protocol is specified for when an LLM rater call (Rater A or Rater B) returns malformed JSON, an out-of-vocabulary `tp_fp` value, or fails entirely — leaving the kappa computation substrate silently incomplete.","group_criteria":null,"group_id":null,"id":"f1292b5365e68b23f","impact":0.33,"is_primary":null,"location":"Step 4 — 'Rubric contract (both files)' and 'Kappa: committed harnesses/kappa.py computes Cohen's kappa'","norm_id":"nefc0083946a51c73","priority":0.2063,"reason":"default-advisory","scenarios":["Rater B's LLM call times out on 20 of 50 findings; kappa.py silently drops those rows and computes kappa on N=30 — the ≥50 stratified subset requirement is no longer met but no error is raised.","A finding returns tp_fp='uncertain' (hallucinated out-of-vocab value); kappa.py crashes or silently skips it, producing a lower effective N without surfacing the problem."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Clarify the 'scan both `*-<TYPE>.json` and `*-<TYPE>.json.retired`' directive to explicitly scope it to reducer-known event types (STATUS, COMMENT, EDIT) used for outcome-corpus fields, and note that REVIEW_RESULT sidecar files are compaction-preserved and never appear as `.retired`, so `all_review_results` API handles them without `.retired` scanning.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["src/rebar/_commands/compact.py:293-308: compaction renames folded event files to *.retired ONLY for reducer-known types (fold_files are the pre-SNAPSHOT events)","src/rebar/llm/plan_review/sidecar.py:7-14: 'REVIEW_RESULT is NOT in KNOWN_EVENT_TYPES ... compaction PRESERVES it (forward-compat payload, never absorbed into a SNAPSHOT)' — so REVIEW_RESULT files are never renamed to .retired","src/rebar/llm/plan_review/sidecar.py:182-185: all_review_results scans only files ending in '-REVIEW_RESULT.json', not '.retired' variants"],"finding":"The plan's Step 1 data-source description says the mining script scans 'both `*-<TYPE>.json` and `*-<TYPE>.json.retired`' to yield the full event history — but this scan-both directive applies only to reducer-known event types (STATUS, COMMENT, EDIT) that compaction folds into SNAPSHOTs and renames to `.retired`. REVIEW_RESULT sidecar events are compaction-PRESERVED and are therefore never renamed to `.retired`. The `all_review_results` API already handles REVIEW_RESULT files correctly by scanning only `*-REVIEW_RESULT.json` files. The plan does not clearly scope 'scan both' to reducer-known types, leaving ambiguity about whether the mining script should also try to scan `*-REVIEW_RESULT.json.retired` files (which would always be empty in practice).","group_criteria":null,"group_id":null,"id":"f570eec1bdb8b2e1a","impact":0.264,"is_primary":null,"location":"Step 1, data-source paragraph: 'scanning both `*-<TYPE>.json` and `*-<TYPE>.json.retired` yields the full event history reproducibly'","norm_id":"n1e87a4618d7f2840","priority":0.132,"reason":"default-advisory","scenarios":["An implementer writes the mining script to scan *-REVIEW_RESULT.json.retired files as a supplement to all_review_results, adding dead code that scans a set that is always empty","An implementer omits scanning *.retired files for STATUS/COMMENT/EDIT events (misreading 'scan both' as already handled by all_review_results), missing compacted history for post_claim_edit_class and reopen_count derivation"],"severity":"minor","suggested_fix":"Add a parenthetical: 'scanning both `*-<TYPE>.json` and `*-<TYPE>.json.retired` for reducer-known event types (STATUS, COMMENT, EDIT — the types compaction folds and renames to .retired); REVIEW_RESULT sidecar events are compaction-preserved and never renamed to .retired, so all_review_results handles them without .retired scanning.'","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Either add an AC note that the ticket comment recording each derived figure is required (making it verifiable), or remove the ticket-comment requirement from Step 2 if it is considered out-of-scope for a formal gate.","cohort":["COH","E1","T5d"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["Step 2: '…the README re-verification table and the ticket comment record each derived figure **beside** the §5 published figure marked `AGREES` or `CORRECTED-TO <n>`'","AC3: verifies only 'the README re-verification table records…'; no mention of ticket comment","ABSENCE: no AC line covers the ticket comment deliverable"],"finding":"Step 2 mandates that 'the README re-verification table AND the ticket comment record each derived figure', but no AC verifies the ticket comment requirement — only the README table is covered.","group_criteria":null,"group_id":null,"id":"f2d0e82bca32d90e8","impact":0.0,"is_primary":null,"location":"Step 2 body ('the README re-verification table and the ticket comment record each derived figure'); AC3 ('README re-verification table records, per figure, the derived value...')","norm_id":"n3715dcd9910c319f","priority":0.0,"reason":"default-advisory","scenarios":["Implementer commits the README table and passes all ACs, but omits the ticket comment; the §5 re-verification is not traceable in the ticket's audit trail, which matters for E2/E3 consumers that check ticket history"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.7143,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Confirm `mine_outcome_corpus.py` (and `build_adjudication_corpus.py`) use `from rebar._store.fsutil import atomic_write` for final corpus file writes rather than re-coding the `.tmp + os.replace` pattern inline.","cohort":["A1"],"criteria":["A1"],"decision":"advisory","drop_reason":null,"evidence":["`src/rebar/_store/fsutil.py:57`: `def atomic_write(path, data, ...)` — stdlib-only, no rebar.* imports, explicitly designed for reuse across layers","`src/rebar/_store/fsutil.py:1`: 'consolidates the many inline temp-file+rename sites' — the canonical consolidation point","Plan Step 1 already specifies `rebar.llm.plan_review.sidecar.all_review_results` import, confirming `rebar.*` is in scope for these scripts"],"finding":"The plan specifies atomic writes for `outcome_corpus.jsonl` via an inline `.tmp + os.replace` pattern (Step 1), but the codebase already has a canonical `rebar._store.fsutil.atomic_write` helper that encapsulates exactly this pattern with additional crash-safety guarantees (fsync, permissions, error cleanup). The plan's harness scripts already import `rebar.*` APIs (Step 1 uses `rebar.llm.plan_review.sidecar.all_review_results`), so the import is not a barrier.","group_criteria":null,"group_id":null,"id":"fbb621f636a1ae38a","impact":0.0,"is_primary":null,"location":"Step 1: 'written atomically (.tmp + os.replace) to runs/outcome_corpus.jsonl'","norm_id":"n64e53a2b3726c163","priority":0.0,"reason":"default-advisory","scenarios":["An inline .tmp+os.replace in the harness script lacks the permission-reset that fsutil.atomic_write applies, potentially producing a 0o600 (mkstemp default) output file","Error cleanup on failure (unlink of temp) is omitted in naive inline implementations"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5714,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Cite (or commit) the authoritative schema definition for the plan-review sidecar `findings[]` payload order and `coverage.counts` key names, and add a runtime assertion in `build_adjudication_corpus.py` that validates the positional contract against an actual sample payload before writing the corpus.","cohort":["T1"],"criteria":["T1"],"decision":"advisory","drop_reason":null,"evidence":["Plan states: 'The script buckets by position: SURFACED = findings[: blocking + advisory_surfaced] (shown to the agent); DROPPED = the overflow segment ++ the trailing dropped segment'","Plan states: 'coverage.counts = {blocking, advisory_surfaced, advisory_overflow, dropped, indeterminate}'","No schema file, test, or commit reference is cited to validate this positional contract."],"finding":"The plan's positional-bucketing rule asserts a specific internal sidecar payload structure — `findings = blocking ++ advisory_surfaced ++ overflow ++ indeterminate ++ dropped` with exact segment lengths from `coverage.counts` — but provides no citation to a schema definition, test, or version-stamped spec. If the actual payload order or the `coverage.counts` field names differ, the bucketing silently mis-labels surfaced findings as dropped (or vice versa).","group_criteria":null,"group_id":null,"id":"fbefbb284108e0d24","impact":0.0,"is_primary":null,"location":"Step 3 — 'Exact surfaced/dropped bucketing' subsection","norm_id":"na4c7be37279642bf","priority":0.0,"reason":"default-advisory","scenarios":["A prior refactor reordered the `findings` list (e.g. moved `indeterminate` before `overflow`), making the positional slice wrong for all rows; the adjudication corpus has a systematically wrong `source` label.","The `coverage.counts` keys are named differently in the actual payload (e.g. `advisory` instead of `advisory_surfaced`), causing a KeyError or silent zero-count for that segment."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] State the default model IDs for Rater A and Rater B in the plan (e.g. 'Rater A: claude-opus-4, Rater B: gemini-2.5-pro') so the executor need not choose and the kappa result is reproducible.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"dropped","drop_reason":null,"evidence":["'a second LLM adjudicator with an independently-authored rubric harnesses/adjudicate_rubric_b.md and a different model id from Rater A'","No model names or families are specified anywhere in the plan or ACs.","README is required to 'record... both rater/model identities' — implying they are chosen at run time, not pre-decided."],"finding":"The LLM model IDs for Rater A and Rater B are not specified anywhere in the plan. The plan requires Rater B to use 'a different model id from Rater A' but neither model is named, deferring a real design choice to the executor.","group_criteria":null,"group_id":null,"id":"f8ef2138519b8cf03","impact":0.264,"is_primary":null,"location":"Step 4 — 'Rater A (primary): LLM adjudicator... Rater B (independent): a second LLM adjudicator... a different model id from Rater A'","norm_id":"ncd4e7a254dfbc700","priority":0.066,"reason":"low-validity","scenarios":["Executor picks the same model family for both raters (e.g. two versions of the same model), which could inflate kappa by shared training artifacts and undermine the independence requirement.","Executor picks models with different context windows, causing systematic differences in finding comprehension unrelated to rater agreement."],"severity":"minor","suggested_fix":"Add a 'Rater model defaults' sub-bullet to Step 4: 'Rater A: <model-id-A> (primary); Rater B: <model-id-B> (must differ from Rater A in provider or version)' and reference the same defaults in the README schema description.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Expose at minimum the kappa gate (0.7) and ticket-count floor (500) as CLI args or a config section in `runs/README.md`-referenced config file so they can be adjusted without editing script source.","cohort":["T5b","T5e","T9"],"criteria":["T5e"],"decision":"dropped","drop_reason":null,"evidence":["'if that count falls below a floor of 500… it halts'","'kappa ≥ 0.7 → labels are usable ground truth'","'≥280 surfaced and ≥90 dropped'","'stratified-by-criterion ≥50-finding subset'","'retention-capped ≤10/ticket' and '≤50/ticket'"],"finding":"Critical thresholds — kappa gate (0.7), ticket-count floor (500), adjudication corpus floors (≥280 surfaced / ≥90 dropped / ≥50 double-label), and retention caps (≤10 / ≤50) — are all hardcoded as literals in the scripts and README with no configuration mechanism. These are explicitly research-calibration parameters expected to change as the corpus scales.","group_criteria":null,"group_id":null,"id":"fc69ac75947edf62f","impact":0.0,"is_primary":null,"location":"Steps 2–5 / `harnesses/mine_outcome_corpus.py`, `build_adjudication_corpus.py`, `kappa.py` / AC rows referencing the numeric floors","norm_id":"nd25139cfb2a835e9","priority":0.0,"reason":"low-validity","scenarios":["Corpus doubles to ~1000 tickets; the 500-floor is now trivially met and provides no signal. Researcher wants to raise kappa gate to 0.8 for a stricter publication standard; must hunt through three scripts to change one number."],"severity":"none","suggested_fix":"Add `--kappa-floor` (default 0.7) to `kappa.py` and `--ticket-floor` (default 500) to `mine_outcome_corpus.py`; document the defaults and rationale in the README.","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Confirm `harnesses/kappa.py` delegates to the existing `from rebar.llm.evals.eval import cohens_kappa` (or `judge_alignment`) rather than reimplementing Cohen's kappa a third time — cite the `src/rebar/llm/evals/eval.py:343` implementation as the canonical one.","cohort":["A1"],"criteria":["A1"],"decision":"dropped","drop_reason":null,"evidence":["`src/rebar/llm/evals/eval.py:343`: `def cohens_kappa(rater_a: list, rater_b: list) -> float:` — handles empty lists, degenerate-identical, equal-length guard","`tests/unit/test_eval.py:135-139`: `def test_cohens_kappa_perfect_and_chance()` — this function is tested and production-grade","`scripts/calibrate_completion_floor.py:46`: local `_kappa()` — already a second reimplementation, now the plan adds a third","Plan says 'committed `harnesses/kappa.py` computes Cohen's kappa' — the plan already imports `rebar.*` in other harnesses (Step 1 uses `rebar.llm.plan_review.sidecar.all_review_results`), so the import barrier doesn't apply"],"finding":"The plan introduces `harnesses/kappa.py` as a new committed script to compute Cohen's kappa, but the codebase already contains a production-grade `cohens_kappa()` function at `src/rebar/llm/evals/eval.py:343` (tested in `tests/unit/test_eval.py:135-139`) and a second standalone local implementation in `scripts/calibrate_completion_floor.py:46`. A third implementation is NIH duplication of existing functionality.","group_criteria":null,"group_id":null,"id":"fc5c1e15b63939ab8","impact":0.0,"is_primary":null,"location":"Step 4 / Scope bullet: `harnesses/kappa.py`","norm_id":"ncad549f0025ad939","priority":0.0,"reason":"low-validity","scenarios":["kappa.py could silently compute a subtly different result (e.g. handling of degenerate constant-label sequences) and disagree with the production function used elsewhere in the eval pipeline","A future bug fix to `cohens_kappa` in eval.py won't propagate to the standalone kappa.py"],"severity":"none","suggested_fix":"Replace the kappa.py body with: `from rebar.llm.evals.eval import cohens_kappa, judge_alignment` and call through to those, printing the result. This removes the NIH risk in ~3 lines.","tier":"LLM","validity":0.4286,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Verify that `rebar.llm.plan_review.sidecar.all_review_results` and `rebar.llm.completion_sidecar` exist at the stated import paths with the expected signatures (e.g. `all_review_results(ticket_id) -> list`) before committing scripts that depend on them.","cohort":["T1"],"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":["Plan states: 'Plan-review and completion sidecars are read through their clean public reader APIs (`rebar.llm.plan_review.sidecar.all_review_results`, `rebar.llm.completion_sidecar`), which are reducer-ignored and compaction-preserved.'","No import path verification or API contract is cited; the claim is asserted, not resolved."],"finding":"The plan asserts `rebar.llm.plan_review.sidecar.all_review_results` is a callable public reader API but does not verify it exists or has the required signature; if the module path or symbol name differs, the mining and adjudication scripts will fail silently or loudly at runtime rather than during plan review.","group_criteria":null,"group_id":null,"id":"fba0dfba11d3ee67a","impact":0.0,"is_primary":null,"location":"Step 1 (outcome corpus) and Step 3 (adjudication corpus) — 'read through their clean public reader APIs (`rebar.llm.plan_review.sidecar.all_review_results`, `rebar.llm.completion_sidecar`)'","norm_id":"n54296cac4f9eb03c","priority":0.0,"reason":"low-validity","scenarios":["The module path is `rebar.llm.plan_review.sidecar` but the actual symbol is named differently (e.g. `get_all_review_results`), causing an ImportError in both mining scripts.","The API exists but does not preserve compaction-retired events, making `review_round_count` undercounted and `had_persisted_review` false for some tickets that do have persisted reviews."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Resolve the exact event type name and schema discriminator for completion-verifier failures against the event model source (e.g. cite the relevant enum/schema file in the plan or in the mining script's docstring) before committing `mine_outcome_corpus.py`.","cohort":["T1"],"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":["Plan states the predicate as fact ('grounded in the event model') but offers no cross-reference to a schema file, enum definition, or test that confirms `COMPLETION_VERDICT` and `completion_verifier_fail_v1` as exact strings.","The adjacent STATUS-event predicate is similarly asserted without a code citation."],"finding":"The plan asserts `COMPLETION_VERDICT` events with `data.schema==\"completion_verifier_fail_v1\"` as the predicate for `completion_verifier_fail_count`, but neither the event type name `COMPLETION_VERDICT` nor the schema string `completion_verifier_fail_v1` is resolved against the actual event model; if the type or schema discriminator differs, this count silently returns 0 for all tickets.","group_criteria":null,"group_id":null,"id":"f81f9f519997298ba","impact":0.0,"is_primary":null,"location":"Step 1 — 'Exact per-count derivation' bullet: '`completion_verifier_fail_count` = number of `COMPLETION_VERDICT` events with `data.schema==\"completion_verifier_fail_v1\"`'","norm_id":"n0d025e2937e68ae4","priority":0.0,"reason":"low-validity","scenarios":["The actual event type is `COMPLETION_VERIFIER_VERDICT` or `VERIFIER_RESULT`; the mining script produces `completion_verifier_fail_count=0` for every ticket, making the §5 re-verification figures wrong.","The schema discriminator key is `data.type` not `data.schema`; same silent-zero outcome."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E4"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan asserts that advisory-overflow findings are identifiable in the flat sidecar `findings` list as a distinct 'dropped' subcategory ('dropped = rows carrying a drop_reason ... or in the advisory-overflow set'), but the codebase shows overflow findings carry `decision='advisory'` and `drop_reason=null` — identical to truly-surfaced advisory findings. The sidecar's flat `findings` list loses the structural bucket distinction (overflow vs advisory), so the plan's recipe for classifying them as 'dropped' has no discriminating field to filter on.","group_criteria":null,"group_id":null,"id":"ff9d9b2e0fd8aa320","impact":0.0,"is_primary":null,"location":"Step 3, Data source paragraph: 'surfaced = rows with decision ∈ {block, advisory} and no drop_reason; dropped = rows carrying a drop_reason (Pass-3 completion/novelty floor) or in the advisory-overflow set'","norm_id":"n0137e035a405edd5","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"In build_adjudication_corpus.py, identify overflow findings by reading both the per-finding `decision` and the sidecar-level `coverage.counts.advisory_surfaced` to infer the cap boundary, OR stamp overflow findings with an explicit `drop_reason='overflow'` in the sidecar payload so the flat list is self-describing. The plan should specify which approach the script must use.","tier":"LLM","validity":0.2143,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"`force_close (bool)` is listed in the outcome-corpus schema as derivable 'via the `rebar show` CLI,' but `force_close` is not a field in the reducer-derived ticket state (`ticket_state.schema.json` has no such property). The `--force-close` flag only appends a COMMENT event containing the literal prefix 'FORCE_CLOSE:'; `rebar show` will not surface it. The plan's stated derivation mechanism will silently produce `false` for every ticket.","group_criteria":null,"group_id":null,"id":"f9e02382e90b081b9","impact":0.0,"is_primary":null,"location":"Step 1 — Outcome-corpus schema, field `force_close (bool)` + 'Current-state fields are read via the `rebar show` CLI'","norm_id":"n9874dbbb40169e9f","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"In `mine_outcome_corpus.py`, after replaying git objects for a ticket, scan its COMMENT events for any body matching the pattern `^FORCE_CLOSE:` to set `force_close=True`; update the README schema table to note this field is derived from COMMENT event scanning, not from `rebar show`.","tier":"LLM","validity":0.2143,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"`completion_verifier_fail_count` and `review_round_count` are listed as outcome-corpus schema fields derivable 'via the `rebar show` CLI,' but neither field exists in the reducer's compiled ticket state (`ticket_state.schema.json`, `reducer/_processors.py`). Both are observable only by counting reducer-IGNORED sidecar events: `COMPLETION_VERDICT` (for completion fails) and `REVIEW_RESULT` (for review rounds). `rebar show` will return nothing for either field, silently producing 0 for every ticket.","group_criteria":null,"group_id":null,"id":"f8c3d5c36a3d85b55","impact":0.0,"is_primary":null,"location":"Step 1 — Outcome-corpus schema, fields `completion_verifier_fail_count (int)` and `review_round_count (int)` + 'Current-state fields are read via the `rebar show` CLI'","norm_id":"ne4396aeace20ebed","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"In `mine_outcome_corpus.py`, after the git-object scan, count `COMPLETION_VERDICT` events per ticket for `completion_verifier_fail_count` and `REVIEW_RESULT` events per ticket for `review_round_count`; these are already being scanned via `git rev-list --objects --all` + `git cat-file`, so no additional data source is needed.","tier":"LLM","validity":0.2143,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The Step 3 classification rule 'surfaced = rows with decision ∈ {block, advisory} and no drop_reason; dropped = rows carrying a drop_reason OR in the advisory-overflow set' is mechanically unimplementable from the sidecar's `findings[]` array: overflow findings are persisted with `decision='advisory'` and no `drop_reason`, identical to genuinely-surfaced advisory findings. `build_payload` pools all five buckets (blocking, advisory, overflow, indeterminate, dropped) into one `findings[]` array via `_slim()`, which faithfully copies each finding's `decision` field — but that field is set by `pass3_decide` (which outputs `'advisory'`, never `'overflow'`) before the advisory-cap split in `orchestrator.py:447`. No per-finding field distinguishes overflow from surfaced advisory in the persisted sidecar.","group_criteria":null,"group_id":null,"id":"fb5bfb5be2fd2aec3","impact":0.0,"is_primary":null,"location":"Step 3, 'Data source (grounded in sidecar.build_payload)' bullet; also AC #3 proving command","norm_id":"n4f581a58ea521dc5","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"Add a `source_bucket` field to `_slim()` in `build_payload` (values: 'blocking', 'advisory', 'overflow', 'indeterminate', 'dropped') and update Step 3's rule to use `source_bucket ∈ {'blocking','advisory'}` for surfaced and `source_bucket == 'overflow'` or `drop_reason is not null` for dropped. Alternatively, derive the boundary from `coverage.counts.advisory_surfaced` (surfaced = the first N advisory findings by priority) — but this approach must be stated in the plan.","tier":"LLM","validity":0.2143,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E4"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan asserts that 'reopen_count (int), force_close (bool), completion_verifier_fail_count (int), review_round_count (int)' are 'read via the `rebar show` CLI', but the `rebar show` output schema (ticket_state.schema.json) does not include these fields. Only `last_reopened_at` (a timestamp) appears as a reopen-related field; grep finds zero occurrences of `reopen_count`, `completion_verifier_fail_count`, or `review_round_count` anywhere in `src/rebar/`. These are derived counts that would need to be computed from event-history replay (the same git-object mining the script already does), not a simple `rebar show` read. If the script assumes `rebar show` returns these counts and they aren't there, the outcome corpus silently ships null/missing values for load-bearing schema fields.","group_criteria":null,"group_id":null,"id":"f748abab65d03e838","impact":0.0,"is_primary":null,"location":"Step 1 — 'Current-state fields … are read via the `rebar show` CLI' and Outcome-corpus schema: `reopen_count (int), force_close (bool), completion_verifier_fail_count (int), review_round_count (int)`","norm_id":"na207f6f900bc7337","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"Revise Step 1 to specify that these four counts are derived from the git-object event history (e.g., count STATUS events transitioning closed→open for reopen_count; scan for FORCE_CLOSE event type for force_close; count completion_verifier_fail sidecar events; count plan-review REVIEW_RESULT sidecar events per ticket for review_round_count) — and remove the claim that they come from `rebar show`.","tier":"LLM","validity":0.2143,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["T3"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan states that `reopen_count (int)`, `force_close (bool)`, `completion_verifier_fail_count (int)`, `review_round_count (int)`, and `had_persisted_review (bool)` are populated by reading 'current-state fields via the `rebar show` CLI', but the verified `ticket_state.schema.json` (the definitive shape of `rebar show` output) contains none of these fields. The compiled state exposes only `last_reopened_at` (a timestamp, not a count). All five fields must be derived from git-object event replay, not from `rebar show` — if `mine_outcome_corpus.py` queries `rebar show` for them, they will be silently absent/null.","group_criteria":null,"group_id":null,"id":"faf258579a09505fd","impact":0.0,"is_primary":null,"location":"Step 1 ('Current-state fields are read via the `rebar show` CLI') and outcome-corpus schema; AC2 (proving command / schema compliance)","norm_id":"nb03c47a03361277b","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"In Step 1, replace 'Current-state fields are read via the `rebar show` CLI' with 'Derived from git-object event replay: `reopen_count` = count of STATUS events with `closed→open` transitions; `force_close` = any CLOSE event carrying a `force_close_reason`; `completion_verifier_fail_count` = count of failed completion-verifier events; `review_round_count` = count of REVIEW_RESULT sidecar events per ticket; `had_persisted_review` = `review_round_count > 0`.' Use `rebar show` only for `ticket_type`, `level`, and other fields present in `ticket_state.schema.json`.","tier":"LLM","validity":0.2143,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["T3"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan asserts 'Current-state fields (reopen/force-close/verifier-fail/round counts) are read via the rebar show CLI,' but the ticket_state schema (ticket_state.schema.json) confirms rebar show does NOT emit reopen_count, force_close (bool), completion_verifier_fail_count, or review_round_count. Only `last_reopened_at` (a single timestamp) is in compiled state. The `force_close` fact lives in a git audit COMMENT event (not compiled state); `completion_verifier_fail_count` lives in the reducer-IGNORED COMPLETION_VERDICT sidecar; `reopen_count` and `review_round_count` are not derived fields in the reducer at all. An implementer following this plan will call `rebar show` expecting these four fields and get KeyError or None, silently producing a corpus with zeroed/null columns.","group_criteria":null,"group_id":null,"id":"f194efa4e548ea0c4","impact":0.0,"is_primary":null,"location":"What § Step 1 ('Current-state fields … are read via the rebar show CLI') and Outcome-corpus schema definition","norm_id":"n53c4331f22f01f28","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"For each of the four fields, use git-object event scanning (already available in the script) rather than rebar show: count STATUS events with current_status='closed' and a force_close_reason key for force_close; count STATUS open←closed transitions for reopen_count; count COMPLETION_VERDICT events with schema='completion_verifier_fail_v1' for completion_verifier_fail_count; count REVIEW_RESULT sidecar events per ticket for review_round_count. Update Step 1 and the README regeneration command accordingly.","tier":"LLM","validity":0.2143,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The sidecar's `findings[]` array also contains `indeterminate` findings (pooled by `build_payload` at line 476) with `decision='indeterminate'`, but Step 3's classification scheme (`surfaced = {block, advisory}; dropped = drop_reason or overflow`) never assigns indeterminate findings to either bin. Their treatment — include in neither, include in one, or exclude entirely — is unspecified, leaving `build_adjudication_corpus.py` without a rule for a real population of sidecar rows.","group_criteria":null,"group_id":null,"id":"fb9d90f8a7d79e52b","impact":0.67,"is_primary":null,"location":"Step 3, 'Data source (grounded in sidecar.build_payload)' bullet; adjudication-corpus schema","norm_id":"n51c2f5e2ccf6b4b3","priority":0.1436,"reason":"low-validity","scenarios":[],"severity":"major","suggested_fix":"Add: 'Findings with decision=indeterminate are excluded from the adjudication corpus (their non-surface is a verifier-failure artifact, not a gate suppression decision, so TP/FP labeling is not meaningful for calibration).'","tier":"LLM","validity":0.2143,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The `had_persisted_review` field is load-bearing for Step 3 (finding-adjudication corpus is restricted to `had_persisted_review=true` tickets) but Step 1 never specifies the derivation mechanism. Since `REVIEW_RESULT` is reducer-IGNORED and absent from `rebar show` output, the script cannot read it from compiled state. The plan leaves the implementation open to a silent all-false default.","group_criteria":null,"group_id":null,"id":"fb4e3ec31cfc6e4d7","impact":0.0,"is_primary":null,"location":"Step 1 — Outcome-corpus schema, field `had_persisted_review (bool)` + Step 3 description 'restricted to tickets with had_persisted_review=true'","norm_id":"n7360b37de44bf419","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Add to Step 1: 'had_persisted_review is derived from the git-object scan: true iff at least one REVIEW_RESULT-type event object is found for the ticket_id in the git object walk.'","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The outcome-corpus field `had_persisted_review` is defined in the schema but no derivation protocol is specified anywhere in the plan — the mining script section (Step 1) explains how to recover `reopen_count`, `force_close`, `completion_verifier_fail_count`, and `review_round_count` from git objects and `rebar show`, but is silent on how `had_persisted_review` is determined.","group_criteria":null,"group_id":null,"id":"fa545016277792f25","impact":0.0,"is_primary":null,"location":"Step 1 (What) — outcome-corpus schema; mine_outcome_corpus.py description","norm_id":"ned1be724c4960f50","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"had_persisted_review = True iff `git rev-list --objects --all | git cat-file --batch-check` yields at least one blob whose path matches `.tickets-tracker/<ticket_id>/*-REVIEW_RESULT.json`.","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"1e5afbffd0066b78","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":196.1,"llm_calls":30,"llm_ms":932044.3,"total_ms":932381.1,"verify_requests":39},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"e95e-1543-cac7-47b9","ticket_type":"story","verdict":"PASS","verified_at_sha":"5514923afecadcb6e646b335af4ec605605c4e96"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784161084228007001,"uuid":"468a14cb-a861-4d01-b519-68cc9c63bc2a"}