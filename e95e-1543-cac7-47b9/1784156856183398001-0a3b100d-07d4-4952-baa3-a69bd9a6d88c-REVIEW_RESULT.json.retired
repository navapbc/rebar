{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","data":{"coaching":[{"coaching":"Pin down panel composition and labeler recruitment process with a concrete worked example.","decision":"block","finding_refs":["f07305e3f5e72a600"],"move_id":"6","move_name":"specification by example","subject":"panel composition and labeler recruitment process"},{"coaching":"Plan how kappa double-labeling subset production workflow will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"block","finding_refs":["ff88e902f72348dc4","f71e42c0cb8f7ad70","fa1acb9fa51598b3c"],"move_id":"9","move_name":"plan the verification","subject":"kappa double-labeling subset production workflow"},{"coaching":"Test the riskiest assumption behind git object completeness after compaction first.","decision":"advisory","finding_refs":["f4499a8fb0372bf30","faa68c33f624967e7"],"move_id":"4","move_name":"riskiest-assumption test","subject":"git object completeness after compaction"},{"coaching":"Plan how pre-flight completeness probe for git mining will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["fa069593f0f56d44d"],"move_id":"9","move_name":"plan the verification","subject":"pre-flight completeness probe for git mining"},{"coaching":"Pin down post-claim-edit class enum value vocabulary with a concrete worked example.","decision":"advisory","finding_refs":["f6a014336d198aabf"],"move_id":"6","move_name":"specification by example","subject":"post-claim-edit class enum value vocabulary"},{"coaching":"Weigh at least one structural alternative for corpus_sample.py reuse versus portable convention.","decision":"advisory","finding_refs":["fb23a5307bc201315","fe077e6418a01af05"],"move_id":"5","move_name":"weigh alternatives","subject":"corpus_sample.py reuse versus portable convention"},{"coaching":"Record an ADR for mining script repository location decision — it reads like a one-way door.","decision":"advisory","finding_refs":["fce2c820b78c61d75"],"move_id":"8","move_name":"ADR / one-way-door","subject":"mining script repository location decision"},{"coaching":"Pin down finding-adjudication corpus schema fields with a concrete worked example.","decision":"advisory","finding_refs":["f61378de607c233db","fba405cb1124c0dbf","f8e7d351b9ff76127"],"move_id":"6","move_name":"specification by example","subject":"finding-adjudication corpus schema fields"},{"coaching":"Plan how AC2 deterministic re-derivation proving command will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f9c6e82f806c1f7a8","fd298c1100c592bd3"],"move_id":"9","move_name":"plan the verification","subject":"AC2 deterministic re-derivation proving command"},{"coaching":"Pin down corpus size floor and sampling tolerance bounds with a concrete worked example.","decision":"advisory","finding_refs":["fef0c4e372a8ef371"],"move_id":"6","move_name":"specification by example","subject":"corpus size floor and sampling tolerance bounds"},{"coaching":"Plan how mining script commit and correctness acceptance criteria will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["fe30474d3436f534f"],"move_id":"9","move_name":"plan the verification","subject":"mining script commit and correctness acceptance criteria"},{"coaching":"Run a quick pre-mortem on mining script error handling and idempotency risks: how could this plan fail?","decision":"advisory","finding_refs":["f75b15b2fa247026b"],"move_id":"3","move_name":"pre-mortem","subject":"mining script error handling and idempotency risks"},{"coaching":"Plan how overall acceptance-criteria measurability and completeness will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f607dd457c67f9209"],"move_id":"9","move_name":"plan the verification","subject":"overall acceptance-criteria measurability and completeness"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":17,"blocking":3,"dropped":8,"indeterminate":0},"det":{"P1":{"ac_items":4,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","ran":true,"references":0,"resolved":0,"status":"pass"},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":4,"blocking":false,"desc_chars":2340,"file_impact":1,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":4,"blocking":false,"name":"ac-quality","ran":true,"status":"fail","verify_commands_linted":0,"verify_lint_abstained":0},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":607,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":1,"name":"file-impact-coverage","ran":true,"status":"pass"}},"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":232.4,"llm_calls":30,"llm_ms":588026.1,"total_ms":588391.4,"verify_requests":27},"remediation":{"baseline":"sidecar","eligible":false,"reasons":{"code_unchanged":false,"plan_changed":false,"registry_unchanged":false,"sidecar_baseline":false,"within_window":false}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","F4","G5","T2","T4","T5b","T5d","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Identify the panel composition for double-labeling (minimum: state who constitutes the second rater — role, person, or recruitment method) so AC4's kappa computation can proceed without a blocking clarification.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"block","drop_reason":null,"evidence":["'panel-adjudicated TP/FP' — no panel composition (roles, count, qualifications) is specified","AC4 requires double-labeled subset but names no second labeler or recruitment process","An executing agent cannot begin the kappa computation without at least two rater identities"],"finding":"The 'panel' responsible for double-labeling and adjudication is never identified; an executor cannot recruit labelers or begin the kappa step without knowing who constitutes the second (and any additional) rater(s).","group_criteria":null,"group_id":null,"id":"f07305e3f5e72a600","impact":1.0,"is_primary":null,"location":"What section ('panel-adjudicated') and AC4 ('>=50-finding double-labeled subset reaches kappa >= 0.7')","norm_id":"na1ceced49620c8bc","priority":1.0,"reason":"high-priority+criterion-opted-in","scenarios":["Agent completes corpus construction but cannot start double-labeling because no second rater is identified","Executor assumes single-rater labeling, which makes the kappa gate mathematically impossible to compute"],"severity":"critical","suggested_fix":"Add a sentence such as: 'Panel: two human raters — the plan-review author and one independent reviewer (e.g. a second team member or the repo owner); the >=50-finding subset is assigned to both before either sees the other's labels.'","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"high","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add a concrete work step in the What/Scope sections for the kappa double-labeling: identify the two raters, specify how the >=50-finding stratified subset is drawn from the adjudication corpus, and name a committed script (following corpus_sample.py conventions) that computes and records Cohen's kappa.","cohort":["G6"],"criteria":["G6"],"decision":"block","drop_reason":null,"evidence":["AC #4: 'Inter-rater reliability on a >=50-finding double-labeled subset reaches kappa >= 0.7, recorded in the README'","What section describes: 'panel-adjudicated TP/FP, extending the code_review_adjudication.jsonl pattern' — one adjudication pass, not two independent passes","Scope section lists no deliverable for a double-labeling protocol, second-rater recruitment, or kappa computation script","The code_review_adjudication.jsonl precedent itself is a single-rater proxy ('first-pass proxy (tier/severity); held-out confirmation pending') — the pattern being extended does not include double-labeling"],"finding":"The mechanism for producing the kappa double-labeled subset is entirely absent from the plan body — the What and Scope sections describe only single-pass panel adjudication, but AC #4 requires an independent second-rater labeling of >=50 findings; the plan provides no work step, rater identification, sampling protocol, or script for this.","group_criteria":null,"group_id":null,"id":"ff88e902f72348dc4","impact":1.0,"is_primary":null,"location":"Acceptance Criteria — AC #4; What section ('panel-adjudicated TP/FP'); Scope section","norm_id":"n802aa7a2d6a94e37","priority":1.0,"reason":"high-priority+criterion-opted-in","scenarios":["Implementer produces a single-rater corpus, reaches the kappa AC, and discovers there is no second labeling to compute kappa against — the gate cannot be verified without restarting the adjudication work.","To unblock the gate, one person labels the 50-finding subset twice with a time delay and reports kappa — an inflation artifact that defeats the reliability measurement."],"severity":"critical","suggested_fix":"","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"high","internal_conflict":"high","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify the kappa calculation protocol co-located with AC#4: name the rater types (e.g., primary human + independent LLM-as-rater), the subset selection method (e.g., stratified by criterion), and the formula (e.g., Cohen's kappa on binary TP/FP).","cohort":["T8"],"criteria":["T8"],"decision":"block","drop_reason":null,"evidence":["AC#4: 'Inter-rater reliability on a >=50-finding double-labeled subset reaches kappa >= 0.7, recorded in the README; below 0.7 the labels are declared unusable'","The What section describes 'panel-adjudicated TP/FP' but names no panel members, no assignment protocol, and no tie-breaking rule.","Searching docs/ for 'second rater', 'annotator', 'panel adjudication', 'Cohen kappa', 'Fleiss' returns no results — no protocol document exists.","The >=50-finding subset selection strategy is absent; for a stratified corpus of ~400 findings, the subset could be drawn in ways that strongly affect the resulting kappa value."],"finding":"The kappa calculation protocol in AC#4 lacks a co-located decision rule: who the second rater is (human, LLM, or both), how the >=50-finding double-labeled subset is selected (random, stratified, adversarial), and which kappa formula (Cohen's, Fleiss's, weighted) is to be used are all unspecified.","group_criteria":null,"group_id":null,"id":"fa1acb9fa51598b3c","impact":1.0,"is_primary":null,"location":"AC#4 — 'inter-rater reliability on a >=50-finding double-labeled subset reaches kappa >= 0.7, recorded in the README'","norm_id":"n9fecf3887d9188b0","priority":1.0,"reason":"high-priority+criterion-opted-in","scenarios":["Two executors use different kappa formulas (Cohen's vs Fleiss's) and report incompatible values, one passing the 0.7 gate and one failing.","The double-labeled subset is convenience-sampled rather than stratified, inflating kappa by oversampling easy cases, leading to a spurious PASS.","A single executor labels the subset twice (same rater), trivially achieving kappa = 1.0 and defeating the validity gate."],"severity":"critical","suggested_fix":"","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"medium","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"high"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a work step in 'What'/'Scope' describing the double-labeling protocol for the >=50-finding subset required by AC #4 (who the two raters are, how the subset is drawn, and which tool/script computes kappa).","cohort":["COH","E1","T5d"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["AC #4: 'Inter-rater reliability on a >=50-finding double-labeled subset reaches kappa >= 0.7, recorded in the README'","What section only says: 'panel-adjudicated TP/FP' — no double-labeling step, no second rater, no protocol described","Scope section lists no task for producing the double-labeled subset or running kappa computation"],"finding":"AC #4 requires a >=50-finding double-labeled subset and a kappa >= 0.7 calculation, but the 'What' and 'Scope' sections describe no work step to produce this double-labeled subset — no mention of a second rater, labeling protocol, or tool — making AC #4 an orphan criterion with no corresponding described deliverable.","group_criteria":null,"group_id":null,"id":"f71e42c0cb8f7ad70","impact":1.0,"is_primary":null,"location":"Acceptance Criteria — AC #4; What section (panel-adjudicated description)","norm_id":"n9e346b5623bea4c9","priority":1.0,"reason":"default-advisory","scenarios":["Implementer produces a single-rater adjudication corpus with no double-labeled subset, ships it, and only realizes at gate time that kappa cannot be computed — the gate cannot be verified.","Panel composition and double-labeling protocol ambiguity causes the kappa gate to be gamed (one person labels twice with time delay) rather than providing genuine inter-rater reliability."],"severity":"critical","suggested_fix":"In the 'What' section, after 'panel-adjudicated TP/FP', add: 'A randomly stratified subset of >=50 findings is independently labeled by two raters (e.g. primary author + one named reviewer); Cohen's kappa is computed via a committed script (e.g. docs/experiments/plan-review-gate/kappa.py) and recorded in the README.' Mirror this in Scope as a deliverable.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"high","internal_conflict":"high","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a pre-flight feasibility probe to the mining script that verifies the required ticket event objects are reachable via `git rev-list --objects --all` BEFORE committing to this method; if the probe fails, document a concrete fallback (e.g., reconstructing from the rebar ticket API / show_ticket tool across all ~527 ticket IDs) and include it in the README's regeneration commands.","cohort":["T3"],"criteria":["T3"],"decision":"advisory","drop_reason":null,"evidence":["'the on-disk .tickets-tracker/ is compacted' — plan's own admission that the primary store is not traversable","'ephemeral prior artifacts may exist' — plan uses 'may', confirming uncertainty about the fallback","AC-1 requires 'exact regeneration commands' and AC-2 requires re-verification — both fail if git objects are GC'd","Evidence class: Partially-verified — `git rev-list --objects --all` is a valid git command surface, but its ability to recover this repo's specific compacted ticket history is Unverified and potentially Contradicted by the compaction acknowledgement"],"finding":"The plan's core data-recovery method (`git rev-list --objects --all` on the tickets branch) asserts it can re-derive §5 event history from git objects, but the plan itself states 'the on-disk .tickets-tracker/ is compacted' — if the tickets branch has been force-pushed, rebased, squash-merged, or subjected to `git gc` pruning unreachable objects, the historical event blobs may be permanently gone. The only named fallback ('ephemeral prior artifacts may exist at /Users/joeoakhart/.claude/jobs/e5b41784/tmp/') is explicitly uncertain and non-reproducible, leaving the AC-1 regeneration-command requirement and AC-2 re-verification with no achievable path if the objects are absent.","group_criteria":null,"group_id":null,"id":"f4499a8fb0372bf30","impact":1.0,"is_primary":null,"location":"What section: 'Re-derive the §5 event history from git objects across all refs of the tickets branch (git rev-list --objects --all + cat-file; the on-disk .tickets-tracker/ is compacted) - method in report §5; ephemeral prior artifacts may exist at /Users/joeoakhart/.claude/jobs/e5b41784/tmp/ but the corpus must be reproducible without them.'","norm_id":"n1c7c4814b551ad09","priority":0.8889,"reason":"default-advisory","scenarios":["The tickets branch was force-pushed or rebased at any point, making old event-blob commits unreachable and subject to GC pruning — `git rev-list --objects --all` returns no historic ticket state objects.","A `git gc --prune=now` or similar was run after compaction, permanently removing the blobs the plan needs to reconstruct the 505-ticket event timeline.","The regeneration commands committed in the README silently produce an empty or partial corpus on any clone that lacks the original objects, violating AC-1's reproducibility requirement."],"severity":"critical","suggested_fix":"Add a pre-flight step to the mining script: run `git rev-list --objects --all | git cat-file --batch-check | grep -c blob` and assert the count is plausible (e.g., > 5000 blobs). If it fails, switch to the rebar ticket-read API (already available in this repo) to reconstruct event history from live ticket state, and document both paths in the README.","tier":"LLM","validity":0.8889,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"high","divergent_implementation":"none","dod_uncertifiable":"medium","internal_conflict":"none","irreversible_without_rationale":"high","likelihood":"medium","prod_impact":"none","reversibility":"hard","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add a pre-flight completeness probe to the mining script (e.g., sample `git cat-file --batch-check` on a set of known intermediate commits across the tickets branch history and assert all objects are present) that fails loudly before producing the corpus, so incomplete-history is surfaced before the corpus is committed.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["Plan acknowledges: 'the on-disk .tickets-tracker/ is compacted'","Plan acknowledges: 'ephemeral prior artifacts may exist at /Users/joeoakhart/.claude/jobs/e5b41784/tmp/ but the corpus must be reproducible without them'","No pre-flight step is specified to assert that the required intermediate git objects are actually reachable before the full mining run commits to producing the corpus","AC #2 re-verifies the §5 headline claims (16/505 edits; 3-miss defect class) against the frozen corpus — if the frozen corpus is silently incomplete, AC #2 provides false assurance"],"finding":"The git-mining mechanism (git rev-list --objects --all + cat-file) has no pre-flight completeness probe, so a gc'd or pruned repo silently produces an incomplete outcome corpus that is then committed as 'frozen' ground truth — the re-verification step in AC #2 then passes against wrong labels.","group_criteria":null,"group_id":null,"id":"fa069593f0f56d44d","impact":0.67,"is_primary":null,"location":"What section: 'Re-derive the §5 event history from git objects across all refs of the tickets branch (git rev-list --objects --all + cat-file; the on-disk .tickets-tracker/ is compacted)'","norm_id":"n49518e7d8689b0bf","priority":0.5956,"reason":"default-advisory","scenarios":["git gc or a force-push has pruned intermediate blob/tree objects needed to reconstruct intermediate ticket states; the mining script silently under-counts edits and the corpus is committed with mislabeled rows, then declared 'frozen'.","The §5 headline claim of 16/505 post-claim edits is re-verified against the mined corpus, 'passes', and the discrepancy is never detected — downstream E2/E3/E6 experiments train on incorrect ground truth."],"severity":"major","suggested_fix":"In the Scope / mining script design, add an explicit 'object availability check' step: run `git rev-list --count tickets` and `git cat-file --batch-check` on a sampled set of known ticket-edit commits; if any are missing, halt with an actionable error ('gc may have pruned objects; run git fetch --unshallow or restore from the ephemeral artifacts') rather than producing an incomplete corpus.","tier":"LLM","validity":0.8889,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"medium","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Define the closed enum for 'post-claim-edit class' in the plan (e.g., {none, cosmetic, functional, revert, structural}) and include it in the README schema spec.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["AC#1 states: 'the outcome corpus is committed with one row per reviewed ticket carrying: post-claim-edit class, reopen count, force-close flag, completion-verifier FAIL count, review round count'","Searching all of docs/ for 'post-claim-edit class' returns zero matches outside the plan itself — no vocabulary is defined anywhere.","No README schema section in the plan pre-defines this enum; the plan says the README 'documents schema' but does not specify it inline."],"finding":"The 'post-claim-edit class' column required in the outcome corpus (AC#1) is an enum whose value vocabulary is never defined anywhere in the plan or referenced artifacts. An executor producing the corpus has no closed set of valid class labels to use.","group_criteria":null,"group_id":null,"id":"f6a014336d198aabf","impact":0.67,"is_primary":null,"location":"AC#1 — 'post-claim-edit class' column; What section — 'labeled with post-claim-edit class'","norm_id":"nc4d4d72c4324da27","priority":0.5863,"reason":"default-advisory","scenarios":["Two independent executors produce corpora with incompatible class labels (e.g., one uses {minor, major, structural} and another uses {cosmetic, functional, revert}), making inter-corpus comparison and the §5 re-verification impossible.","The kappa calculation in AC#4 is undermined if the post-claim-edit class values vary between raters."],"severity":"major","suggested_fix":"Add a 'Schema' subsection to the What or Scope section listing the exact allowed values for post-claim-edit class, e.g.: `post_claim_edit_class ∈ {none, cosmetic, functional, structural, revert}` with a one-sentence definition of each.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a pre-corpus probe step (e.g., `git rev-list --count --all` on the tickets branch and a sample `git cat-file` on a known intermediate commit) that asserts sufficient object coverage exists before the full mining run begins, so a failure surfaces early rather than producing a silently incomplete corpus.","cohort":["T2","T4","T7"],"criteria":["T2"],"decision":"advisory","drop_reason":null,"evidence":["'the on-disk .tickets-tracker/ is compacted'","'ephemeral prior artifacts may exist at /Users/joeoakhart/.claude/jobs/e5b41784/tmp/ but the corpus must be reproducible without them'","No spike or probe step is specified to confirm git object completeness before committing to the full corpus build."],"finding":"The plan's git-mining method (git rev-list --objects --all + cat-file on the tickets branch) is an unverified assumption about the git repo's object availability. The plan acknowledges the on-disk .tickets-tracker/ is compacted and that ephemeral artifacts 'may' exist, but does not include a pre-corpus probe confirming that git objects across all refs actually retain enough history to reconstruct the 16/505 edits and 3-miss defect-class events. If the repo has been gc'd, pruned, or force-pushed, the reconstruction silently produces incomplete or incorrect counts — and the corpus is committed with wrong labels.","group_criteria":null,"group_id":null,"id":"faa68c33f624967e7","impact":0.67,"is_primary":null,"location":"What section: 'Re-derive the §5 event history from git objects across all refs of the tickets branch (git rev-list --objects --all + cat-file; the on-disk .tickets-tracker/ is compacted)'","norm_id":"n8dffccab8fa6bce4","priority":0.5211,"reason":"default-advisory","scenarios":["git gc or a force-push has pruned intermediate blob/tree objects needed to reconstruct intermediate ticket states, causing the mining script to silently under-count edits and producing a corpus that mis-validates the §5 claims."],"severity":"major","suggested_fix":"Insert an AC-0 or 'Definition of Ready' step: run `git rev-list --objects --all -- .tickets-tracker/ | wc -l` and compare against an expected lower bound (derived from the known ~527 ticket count); if the count falls below threshold, the mining approach is declared infeasible and the plan documents an alternative source (e.g., the ephemeral /tmp/ snapshot or a manually reconstructed sample) before proceeding.","tier":"LLM","validity":0.7778,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"medium","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Clarify what 'reusing corpus_sample.py conventions' means: the new mining script must write output to a committed path under docs/experiments/plan-review-gate/runs/ (not a scratch dir), must not import the co-located `harness` module, and the plan should specify which conventions are being reused (e.g., JSON schema shape, rebar-CLI subprocess pattern).","cohort":["A1"],"criteria":["A1"],"decision":"advisory","drop_reason":null,"evidence":["corpus_sample.py line 20: `TMP = h.TMP` where harness.py line 5 is `TMP = os.path.expanduser('~/.claude/jobs/3ef65161/tmp')` — a machine-local ephemeral path","corpus_sample.py line 18: `import harness as h` — co-located experimental import, not a reusable module","AC1 requires 'exact regeneration commands' implying reproducibility on any machine, conflicting with scratch-dir output convention","'conventions' is undefined in the plan — schema? subprocess pattern? output location?"],"finding":"The plan instructs the mining script to 'reuse corpus_sample.py conventions,' but corpus_sample.py is an ephemeral experimental harness hard-wired to scratch-dir paths (TMP = ~/.claude/jobs/3ef65161/tmp via `import harness as h`) and has no importable interface — cargo-culting its output-to-scratch pattern into a committed, reproducibility-required corpus script would violate AC1's 'exact regeneration commands' requirement (regeneration would silently write to a non-existent or different scratch path on another machine).","group_criteria":null,"group_id":null,"id":"fb23a5307bc201315","impact":0.536,"is_primary":null,"location":"What section: 'A mining script committed alongside (docs/experiments/plan-review-gate/), reusing corpus_sample.py conventions.'","norm_id":"n6be21a10b46864f0","priority":0.469,"reason":"default-advisory","scenarios":["A downstream contributor runs the regeneration command on a different machine and the script silently writes to ~/.claude/jobs/3ef65161/tmp (nonexistent), producing no committed output and a confusing failure.","The scratch-dir pattern is copied but the harness import is not available outside the experiment directory, causing an ImportError at regeneration time."],"severity":"major","suggested_fix":"Replace 'reusing corpus_sample.py conventions' with a concrete statement: 'the script writes corpora directly to docs/experiments/plan-review-gate/runs/{outcome_corpus,adjudication_corpus}.jsonl, uses subprocess to call `rebar list`/`rebar show` (matching corpus_sample.py's rebar-CLI invocation pattern), and requires no external harness import.'","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Clarify the mining script's target directory: if it follows corpus_sample.py conventions it belongs in docs/experiments/plan-review-gate/harnesses/ (where harness.py is importable), not in the parent docs/experiments/plan-review-gate/.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["docs/experiments/plan-review-gate/harnesses/ contains corpus_sample.py, e4_agentic.py, analyze.py, analyze2.py, analyze3.py, analyze4.py, analyze_e4.py, analyze_r4.py, and all other mining/harness scripts.","docs/experiments/plan-review-gate/ (parent) contains only README.md, criteria/, eval/, g7-promotion-path.md, harnesses/, runs/.","Plan says 'alongside (docs/experiments/plan-review-gate/)' but corpus_sample.py — the named convention — lives at docs/experiments/plan-review-gate/harnesses/corpus_sample.py."],"finding":"The plan places the new mining script 'alongside' in docs/experiments/plan-review-gate/ but all existing mining scripts (corpus_sample.py, e4_agentic.py, analyze*.py, etc.) live under the harnesses/ subdirectory — the plan simultaneously says 'reusing corpus_sample.py conventions', which would imply harnesses/ placement. The target location is ambiguous and inconsistent with the established convention.","group_criteria":null,"group_id":null,"id":"fce2c820b78c61d75","impact":0.536,"is_primary":null,"location":"Scope section: 'A mining script committed alongside (docs/experiments/plan-review-gate/), reusing corpus_sample.py conventions.'","norm_id":"n14e35d88d2103614","priority":0.469,"reason":"default-advisory","scenarios":["A script placed in docs/experiments/plan-review-gate/ rather than harnesses/ would be outside the established harness convention and would not be discovered by tooling that imports harness.py (which harnesses/corpus_sample.py imports via 'import harness as h')."],"severity":"major","suggested_fix":"Change the Scope line to: 'A mining script committed at docs/experiments/plan-review-gate/harnesses/ (alongside corpus_sample.py), reusing corpus_sample.py conventions.'","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Replace 'reusing corpus_sample.py conventions' with an explicit statement of which conventions apply (e.g., output schema, JSONL format, stratification approach) or remove the reference if no conventions transfer.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["docs/experiments/plan-review-gate/harnesses/corpus_sample.py line 5: TMP = h.TMP → harness.py line 5: TMP = os.path.expanduser('~/.claude/jobs/3ef65161/tmp') — hardwired to a specific machine's scratch dir.","corpus_sample.py uses 'rebar list --status=...' subprocess calls against hardcoded local repo paths (/Users/joeoakhart/rebar, ~/snap-oakhart-manual/...) — none of which are relevant to git rev-list mining.","The plan's What section separately specifies the mining method: 'git rev-list --objects --all + cat-file' — a completely different input mechanism than corpus_sample.py's rebar CLI calls.","Searching docs/ for which specific conventions are meant (output format, sampling strategy, schema) yields no results."],"finding":"The plan instructs the mining script to 'reuse corpus_sample.py conventions,' but corpus_sample.py is confirmed to be hardwired to ephemeral scratch paths (TMP = ~/.claude/jobs/3ef65161/tmp) and uses rebar CLI calls against specific local repos — conventions that are entirely inapplicable to the new script's git-object mining task (git rev-list --objects --all + cat-file). The referenced 'conventions' are never named, making the instruction a pink-elephant antipattern.","group_criteria":null,"group_id":null,"id":"fe077e6418a01af05","impact":0.536,"is_primary":null,"location":"Scope section — 'A mining script committed alongside (docs/experiments/plan-review-gate/), reusing corpus_sample.py conventions.'","norm_id":"n446cbddda07fea85","priority":0.469,"reason":"default-advisory","scenarios":["An executor reads corpus_sample.py, copies its TMP path structure and rebar CLI invocations, and produces a non-reproducible script that only runs on one machine.","An executor spends time reconciling the incompatible input mechanisms and makes arbitrary choices about what 'conventions' means, producing an inconsistent script."],"severity":"major","suggested_fix":"Replace with: 'A mining script committed alongside, outputting JSONL with schema [ticket_id, field, old_value, new_value, git_commit, timestamp]; see corpus_sample.py for the stratification approach (type × level buckets) but note the input mechanism differs (git cat-file, not rebar CLI).'","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Either define the plan-review finding-adjudication schema explicitly (with TP/FP vocabulary distinct from the code-review block-worthiness vocabulary), or probe `code_review_adjudication.jsonl` fields against AC-3's TP/FP requirement and document how the mapping works in the README.","cohort":["E4"],"criteria":["E4"],"decision":"advisory","drop_reason":null,"evidence":["docs/experiments/code_review_adjudication.jsonl rows use: finding_id, criterion (code-review criteria like 'correctness,regression'), impact (float), validity (float), priority (float), adjudication ∈ {block-worthy, not-block-worthy, ambiguous}, evidence='first-pass proxy (tier/severity); held-out confirmation pending'","AC-3 requires: TP/FP label and rationale, stratified by plan-review criterion and decision","The existing file's adjudication vocabulary (block-worthy/not-block-worthy/ambiguous) maps to code-review blocking, not plan-review TP/FP correctness","The existing file's criteria field contains code-review criterion IDs (correctness, regression, security), not plan-review criterion IDs (E4, E1, F1, etc.)"],"finding":"The plan asserts the finding-adjudication corpus will follow 'the code_review_adjudication.jsonl pattern,' but the existing file's schema is specific to code-review decisions (fields: impact, validity, priority, norm_id, adjudication ∈ {block-worthy, not-block-worthy, ambiguous}; evidence says 'first-pass proxy (tier/severity); held-out confirmation pending'). Plan-review finding adjudication needs TP/FP labels with criterion and decision stratification — a structurally different vocabulary. The pattern-reuse claim is an assertion about schema compatibility that the existing file does not support.","group_criteria":null,"group_id":null,"id":"f61378de607c233db","impact":0.536,"is_primary":null,"location":"What section — 'extending the code_review_adjudication.jsonl pattern'; AC-3","norm_id":"n4b6d891fd01f9698","priority":0.402,"reason":"default-advisory","scenarios":["Implementer reuses the exact schema from code_review_adjudication.jsonl, producing a corpus whose adjudication labels mean block-worthiness rather than TP/FP, making E2/E3/E6 downstream consumers compute wrong precision/recall.","Schema mismatch goes undiscovered until the kappa computation in AC-4 fails because raters are labeling different things."],"severity":"major","suggested_fix":"Add a schema table to the plan (or the target README) that maps plan-review fields — finding_id, criterion (plan-review criterion id), decision (TP/FP), rationale — and explicitly states it is not the block-worthy vocabulary from code_review_adjudication.jsonl.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Resolve the schema conflict between 'TP/FP label' and 'code_review_adjudication.jsonl pattern': either define the new field vocabulary explicitly (e.g., `tp_fp ∈ {TP, FP}` added alongside adjudication, with a rule for ambiguous), or replace the pattern reference with a fully specified schema.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["AC#3: 'the finding-adjudication corpus is committed with ~300 surfaced + ~100 dropped findings … each with a TP/FP label and rationale, following the code_review_adjudication.jsonl pattern'","docs/experiments/derive_code_review_threshold.py lines 207-234 show code_review_adjudication.jsonl uses adjudication ∈ {block-worthy, not-block-worthy, ambiguous} with fields: finding_id, criterion, norm_id, criteria, impact, validity, priority, adjudication, tier, evidence.","docs/experiments/derive_code_review_threshold.md line 52: 'adjudication ∈ {block-worthy, not-block-worthy, ambiguous}'","TP/FP is a binary label — no rule is given for how 'ambiguous' maps, whether impact/validity/priority fields are retained, or whether the schema is extended vs replaced."],"finding":"The finding-adjudication corpus specifies 'TP/FP label' (AC#3) but claims to follow 'the code_review_adjudication.jsonl pattern,' which uses a three-value enum {block-worthy, not-block-worthy, ambiguous} — not binary TP/FP. The mapping between the existing pattern and the new binary label is never defined, creating a schema mismatch.","group_criteria":null,"group_id":null,"id":"fba405cb1124c0dbf","impact":0.536,"is_primary":null,"location":"AC#3 — 'each with a TP/FP label and rationale, following the code_review_adjudication.jsonl pattern'","norm_id":"n7b9d63682b36dd1f","priority":0.402,"reason":"default-advisory","scenarios":["An executor faithfully copies the code_review_adjudication.jsonl schema (three-value adjudication) and a consumer (E2/E3/E6/R1/R7) expecting binary TP/FP cannot parse the corpus.","An executor invents a TP/FP field alongside the existing adjudication field with an ad-hoc mapping for 'ambiguous', producing a schema incompatible with future executors."],"severity":"major","suggested_fix":"Add a schema table to the What section: fields = {finding_id, criterion, source (surfaced|dropped), tp_fp ∈ {TP, FP, ambiguous}, rationale, …retained fields from code_review_adjudication.jsonl}, and define 'ambiguous' handling (e.g., excluded from kappa calculation).","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"medium","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":null,"blocking_enabled":null,"checklist_item":"","cohort":null,"criteria":["P6"],"decision":"advisory","drop_reason":null,"evidence":["3 criterion line(s) bundle multiple deliverables with 'and' (split so each is independently verifiable)."],"finding":"Acceptance-criteria / definition-of-done quality issues.","group_criteria":null,"group_id":null,"id":"f607dd457c67f9209","impact":0.4,"is_primary":null,"location":"","norm_id":"ned06ebc801a522e3","priority":0.4,"reason":null,"scenarios":[],"severity":"minor","suggested_fix":"Split compound criteria, replace subjective terms with observable outcomes, and state how each is verified.","tier":"DET","validity":1.0,"verification":null},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] State a minimum floor for corpus size (e.g. 'at least 280 surfaced and at least 90 dropped findings') and specify stratification proportions per criterion (e.g. proportional to criterion frequency in the raw corpus) so the executor has a deterministic stopping rule.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"advisory","drop_reason":null,"evidence":["'stratified ~300 surfaced + ~100 dropped plan findings' — tilde-prefix with no minimum floor stated","Stratification dimensions for the sample (e.g. how many per criterion stratum) are also unspecified beyond 'stratified by criterion and decision'"],"finding":"The approximate corpus sizes ('~300 surfaced + ~100 dropped') have no stated floor or tolerance, leaving an executor uncertain whether 260 surfaced findings satisfies the AC or requires more sampling effort.","group_criteria":null,"group_id":null,"id":"fef0c4e372a8ef371","impact":0.44,"is_primary":null,"location":"Acceptance Criteria, AC3; What section","norm_id":"n5fad5ef259733426","priority":0.385,"reason":"default-advisory","scenarios":["Executor reaches 270 surfaced findings and halts, unsure whether to continue","Two executors independently reach different corpus sizes and downstream kappa results diverge"],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Resolve the schema mismatch: either (a) define the new TP/FP vocabulary explicitly and document how it maps to (or replaces) the existing {block-worthy, not-block-worthy, ambiguous} vocabulary, or (b) confirm the new corpus reuses the existing three-value schema and relabel AC #3's 'TP/FP' accordingly — commit the schema to the README before writing any corpus rows.","cohort":["T1"],"criteria":["T1"],"decision":"advisory","drop_reason":null,"evidence":["AC #3: 'each with a TP/FP label and rationale, following the code_review_adjudication.jsonl pattern'","docs/experiments/code_review_adjudication.jsonl schema: fields are {finding_id, criterion, impact, validity, priority, adjudication ∈ {block-worthy, not-block-worthy, ambiguous}, evidence, tier, norm_id, criteria} — no TP/FP field","docs/experiments/derive_code_review_threshold.md:52: adjudication ∈ {block-worthy, not-block-worthy, ambiguous}"],"finding":"The plan claims the finding-adjudication corpus will follow 'the code_review_adjudication.jsonl pattern' but specifies 'TP/FP label' — an unresolved schema mismatch. The existing pattern (docs/experiments/code_review_adjudication.jsonl, 161 rows) uses a three-value closed vocabulary {block-worthy, not-block-worthy, ambiguous} with no TP/FP field. The new corpus introduces a binary TP/FP schema for plan-review findings that is nowhere defined in or compatible with the prior pattern, so the 'following the … pattern' assertion is unverified.","group_criteria":null,"group_id":null,"id":"f8e7d351b9ff76127","impact":0.536,"is_primary":null,"location":"AC #3 — 'each with a TP/FP label and rationale, following the code_review_adjudication.jsonl pattern'","norm_id":"n914ab3cbe740393a","priority":0.335,"reason":"default-advisory","scenarios":["Executor picks up the existing JSONL schema and emits three-value labels instead of TP/FP, breaking E2/E3/E6/R1/R7 consumers that expect the binary TP/FP vocabulary.","Downstream scripts trained on block-worthy/ambiguous semantics misinterpret or fail to load the new corpus because the adjudication field has different cardinality and meaning."],"severity":"major","suggested_fix":"Add a 'Schema' subsection to the README and AC #3 that defines the adjudication field for the plan-review corpus (e.g., TP = block-worthy finding the review correctly surfaced; FP = not-block-worthy finding the review incorrectly surfaced), and record the mapping to the existing code_review vocabulary so downstream consumers can align.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a concrete proving command to AC2 — e.g. `python docs/experiments/plan-review-gate/mine_outcomes.py --verify-s5 | tee runs/s5_verification.txt` — and require the output artifact to be committed alongside the corpus so the re-derivation is reproducible.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["'the ticket comment records agreement or corrected numbers (16/505 edits; the 3-miss defect class on dc58/db7b/5886)' — no command cited","The What section mentions 'git rev-list --objects --all + cat-file' as a method but AC2 does not reference a script or its output artifact","No proving command exercises the derived count against the claimed figures"],"finding":"AC2 lacks a concrete proving command for the §5 re-derivation; its only evidence form is 'the ticket comment records agreement or corrected numbers,' which is not a deterministic in-session command and cannot be run to verify the outcome.","group_criteria":null,"group_id":null,"id":"f9c6e82f806c1f7a8","impact":0.44,"is_primary":null,"location":"Acceptance Criteria, AC2","norm_id":"n25a57fa9bc6d9fa6","priority":0.275,"reason":"default-advisory","scenarios":["Executor writes a comment on the ticket saying 'numbers confirmed' without actually running any derivation script","Reviewer cannot independently verify whether 16/505 is confirmed or corrected without re-running an undocumented command"],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Rewrite AC2 so its observable outcome distinguishes confirmation from correction: e.g. 'a committed `runs/s5_verification.txt` records the re-derived counts; if they differ from §5 by >2%, the README updates the headline numbers with a note explaining the discrepancy.'","cohort":["E2","E6","F1"],"criteria":["F1"],"decision":"advisory","drop_reason":null,"evidence":["'records agreement or corrected numbers' — both branches of the disjunction (confirming OR disconfirming the original claim) satisfy the criterion","A comment saying '16/505 confirmed' AND a comment saying '11/505 — original claim wrong' both satisfy the AC identically","No observable difference between a passing and a failing verification result"],"finding":"AC2 is vacuously satisfiable: 'the ticket comment records agreement OR corrected numbers' passes regardless of whether the re-derivation confirms or refutes §5's claims, making it unmeasurable as a quality gate.","group_criteria":null,"group_id":null,"id":"fd298c1100c592bd3","impact":0.44,"is_primary":null,"location":"Acceptance Criteria, AC2","norm_id":"n7930d4b97c455b75","priority":0.22,"reason":"default-advisory","scenarios":["An executor writes any number in the ticket comment and the AC is green regardless of accuracy","Downstream consumers (E2/E3/E6) receive a corpus whose provenance claim has not actually been validated"],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an AC (or extend AC #1) to verify that the mining script is committed at the declared path, executable, and that running it against the git objects reproduces the outcome corpus within a documented tolerance.","cohort":["COH","E1","T5d"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["Scope: 'A mining script committed alongside (docs/experiments/plan-review-gate/), reusing corpus_sample.py conventions'","None of the four ACs reference the mining script, its presence, or its executability"],"finding":"The mining script is an explicit deliverable named in 'Scope' ('A mining script committed alongside') but no AC verifies it is committed, runnable, or produces correct output — this deliverable is uncovered by any criterion.","group_criteria":null,"group_id":null,"id":"fe30474d3436f534f","impact":0.44,"is_primary":null,"location":"Scope section — 'A mining script committed alongside'; Acceptance Criteria (all four ACs)","norm_id":"nb992e526c2fb0a73","priority":0.22,"reason":"default-advisory","scenarios":["Implementer omits the script (relying on ad-hoc commands) and all four ACs still pass, leaving the corpus non-reproducible despite the plan's stated reproducibility goal."],"severity":"minor","suggested_fix":"Extend AC #1: '...the mining script at docs/experiments/plan-review-gate/ is committed, passes a smoke-run (e.g. python mining_script.py --dry-run exits 0), and the README documents the exact invocation to regenerate the outcome corpus from git objects alone.'","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify the mining script's error-handling contract: define a fallback/warning when git rev-list yields fewer tickets than expected, add an atomic write pattern (write to temp file, then rename), and make the script idempotent (overwrite, never append) so re-runs are safe.","cohort":["T5b","T5e","T9"],"criteria":["T5b"],"decision":"advisory","drop_reason":null,"evidence":["'the on-disk .tickets-tracker/ is compacted' — acknowledged data loss risk with no fallback","'ephemeral prior artifacts may exist … but the corpus must be reproducible without them' — no validation step if git objects are also missing","No mention of script exit codes, partial-write guards, or re-run safety."],"finding":"The mining script's error handling and idempotency on write are unspecified; the plan acknowledges git compaction ('the on-disk .tickets-tracker/ is compacted') and ephemeral prior artifacts that 'may exist' but gives no fallback if git rev-list yields incomplete data, and no behavior is defined for a partial or repeated script run.","group_criteria":null,"group_id":null,"id":"f75b15b2fa247026b","impact":0.33,"is_primary":null,"location":"What section ('Re-derive the §5 event history from git objects … the on-disk .tickets-tracker/ is compacted … ephemeral prior artifacts may exist at /Users/joeoakhart/.claude/jobs/e5b41784/tmp/ but the corpus must be reproducible without them')","norm_id":"n7c81c976f0234c1d","priority":0.2063,"reason":"default-advisory","scenarios":["git rev-list returns fewer objects than expected due to gc/compaction; the script silently produces an under-populated corpus that passes AC1 row-count checks.","Script crashes mid-write; the partial JSONL is committed and downstream consumers read corrupt data.","Script is re-run after a partial commit; it appends duplicate rows to the JSONL."],"severity":"minor","suggested_fix":"Write corpus output to a `.tmp` file and `os.replace()` it into the final path; emit a structured warning (and non-zero exit) if recovered ticket count falls below a configurable floor; document the expected ticket count range in the README.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Extract kappa gate threshold (0.7) and corpus-size targets (~300/~100 split, >=50 double-label set) into a configurable parameter block (e.g., a YAML/JSON config or script CLI flags) so they can be adjusted without editing AC prose or source.","cohort":["T5b","T5e","T9"],"criteria":["T5e"],"decision":"dropped","drop_reason":null,"evidence":["'Inter-rater reliability on a >=50-finding double-labeled subset reaches kappa >= 0.7'","'finding-adjudication corpus is committed with ~300 surfaced + ~100 dropped findings'","No mention of a config file or parameter that lets these numbers be adjusted without editing the ACs/script."],"finding":"The kappa >= 0.7 threshold and the ~300 surfaced / ~100 dropped finding counts are hardcoded in the ACs with no mechanism to make them configurable; these methodological thresholds are likely to evolve as the panel gains calibration data.","group_criteria":null,"group_id":null,"id":"f3cf1736f21cd5d73","impact":0.0,"is_primary":null,"location":"Acceptance Criteria — AC4 (kappa >= 0.7); AC3 (~300 surfaced + ~100 dropped)","norm_id":"na6f1169f6b515a89","priority":0.0,"reason":"low-validity","scenarios":["A second panel run with a different calibration strategy needs a different kappa cutoff; the script must be edited rather than re-invoked with a flag.","The corpus grows and the 300/100 split becomes inappropriate; there is no single place to change it."],"severity":"none","suggested_fix":"Add a config section at the top of the mining script (or a companion config.yaml) with keys like `kappa_gate: 0.70`, `surfaced_sample_size: 300`, `dropped_sample_size: 100`, `double_label_min: 50`; reference these in the README regeneration commands.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a `schema_version` field to each corpus file and capture the corpus-as-contract decision (field names, types, null semantics, and how consumers should handle missing fields) in an ADR or CLAUDE.md section, so downstream experiments E2/E3/E6/R1/R7 have a stable interface to pin against.","cohort":["T5b","T5e","T9"],"criteria":["T5e"],"decision":"dropped","drop_reason":null,"evidence":["'the finding-level TP/FP labels needed by E2/E3/E6 and R1/R7 need a committed, versioned corpus'","Plan specifies a 'versioned README' but no schema version field in the corpus files themselves.","No ADR or CLAUDE.md update is mentioned for this novel pipeline-contract decision."],"finding":"The plan introduces a shared corpus contract that E2/E3/E6/R1/R7 will consume, but no schema-versioning strategy, interface contract, or ADR is planned; a schema change in the corpus silently breaks all downstream dependents.","group_criteria":null,"group_id":null,"id":"f1dccaabc508c4be1","impact":0.0,"is_primary":null,"location":"Why section ('the finding-level TP/FP labels needed by E2/E3/E6 and R1/R7'); Scope section ('NO gate/source changes')","norm_id":"n05adf4bc8f0e3bd3","priority":0.0,"reason":"low-validity","scenarios":["E3 adds a new field to the adjudication schema; E2 silently reads stale/missing columns and produces wrong precision/recall numbers.","A future experiment adds a corpus field; the README is updated but no version bump signals downstream consumers to re-read."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Define corpus update ownership (single named owner or PR-gated process), specify an atomic write protocol for concurrent panel adjudication (e.g., per-rater files merged by a script, not direct JSONL appends), and document a version-bump procedure so downstream consumers know when to re-read the corpus.","cohort":["T5b","T5e","T9"],"criteria":["T9"],"decision":"dropped","drop_reason":null,"evidence":["'corrected numbers' implies post-freeze mutation is anticipated but no owner or change-control process is named.","Multiple panel raters writing to the same adjudication JSONL with no merge/atomic-write protocol mentioned.","No RETIRE or version-bump path: the corpus is called 'frozen' yet AC2 permits updates.","Downstream consumers (E2/E3/E6/R1/R7) are not stated to be tolerant of mid-experiment corpus updates."],"finding":"Post-freeze mutation ownership is undefined: AC2 explicitly allows 'corrected numbers' to be committed after freeze, but no ownership process, merge protocol, or concurrency guard is specified for panel adjudicators writing to the shared JSONL simultaneously or for post-freeze edits by downstream experiments.","group_criteria":null,"group_id":null,"id":"ff3617cc888438376","impact":0.33,"is_primary":null,"location":"Acceptance Criteria — AC2 ('the ticket comment records agreement or corrected numbers'); AC3 (adjudication corpus follows code_review_adjudication.jsonl pattern); What section ('panel-adjudicated')","norm_id":"n3c6a0dea7e73b190","priority":0.0413,"reason":"low-validity","scenarios":["Two raters submit adjudication entries simultaneously; the JSONL is corrupted or one rater's entries are silently overwritten.","E2 begins consuming the corpus while a correction is being committed; it reads a partially-written file mid-update.","A post-freeze correction changes a TP to FP; E3 has already cached the old label and does not re-read."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.125,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Verify that 'pastoral-aquatic-viper' names an existing (or explicitly planned) epic and add its rebar ticket ID or repo path to the plan so downstream consumers can be confirmed.","cohort":["E4"],"criteria":["E4"],"decision":"dropped","drop_reason":null,"evidence":["Grep for 'pastoral-aquatic-viper' across entire repo returns zero hits","No ticket, file, or reference with this name exists in the repo","Plan treats it as a live named epic whose gate rows depend on E1's output"],"finding":"The plan's anchor epic 'pastoral-aquatic-viper' does not exist anywhere in the repository. The Why section states 'Every gate row in epic pastoral-aquatic-viper adjudicates against ground truth that does not yet exist in frozen form,' treating this as a live, named epic. A full repo search returns zero hits for this slug, making the upstream dependency claim unverifiable and potentially fictitious.","group_criteria":null,"group_id":null,"id":"f0c2f67bc935eaa71","impact":0.0,"is_primary":null,"location":"Why section — 'Every gate row in epic pastoral-aquatic-viper adjudicates against ground truth'","norm_id":"n213d32cf48e5db8f","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":["The downstream gate rows described as depending on E1's corpus either don't exist yet or belong to a differently-named epic, meaning E1's scope may be misanchored.","E2/E3/E6/R1/R7 dependencies on E1's labeled corpus are premised on an epic that cannot be confirmed."],"severity":"none","suggested_fix":"Replace the informal slug with the rebar ticket ID of the gate epic and confirm its existence with `rebar show <id>` in the regeneration commands.","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"no","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Add the file path of the §5 report (or the specific experiment log/artifact) containing the 16/505 and 3/8-miss baseline figures to the plan, so AC-2 (re-verification) has a concrete, locatable reference to compare against.","cohort":["E4"],"criteria":["E4"],"decision":"dropped","drop_reason":null,"evidence":["Search for '16/505' across entire repo: zero hits","Search for 'dc58' across docs/: zero hits","Search for '5886' as a ticket reference in docs/experiments: zero hits","Search for '3/8' in docs/experiments: zero hits","No document with a §5 containing these statistics was found"],"finding":"The §5 headline claims (16/505 post-claim edits; 3-miss defect class on tickets dc58/db7b/5886) reference a report §5 that cannot be located in the repository. A search for '16/505', 'dc58', '5886' (as a ticket reference), and '3/8' in the docs/experiments tree returns zero hits. The plan's What section says 'method in report §5' without naming the file, and AC-2 requires re-verifying these exact numbers — but the source data to re-derive them is not findable from the plan.","group_criteria":null,"group_id":null,"id":"f398972ac843d628a","impact":0.0,"is_primary":null,"location":"What section — 'The §5 headline claims are re-verified against the frozen corpus'; AC-2","norm_id":"n1c52223e6e30c00f","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":["The corpus-mining script produces a different count than 16/505 and the discrepancy is unresolvable because the original §5 baseline is not in the repo.","The 3-miss defect class validation cannot be completed because the ticket IDs (dc58, 5886) and their prior review-round counts are not in any accessible data."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"no","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Identify and link R1/R7 (the named consumers of the finding-adjudication labels) — add their ticket IDs or experiment-plan section refs so the corpus schema can be confirmed to serve their actual input requirements.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":["Search for 'R1' and 'R7' across docs/experiments/ returns no matches.","E2/E3/E6 are grounded in docs/experiments/plan-review-validation-experiment-plan.md but R1/R7 are absent from that document.","ABSENCE: no ticket, ADR, experiment plan, or run file mentions R1 or R7 as experiment or ticket identifiers."],"finding":"R1 and R7 are named in the plan as consumers of the finding-adjudication corpus ('finding-level TP/FP labels needed by E2/E3/E6 and R1/R7') but these identifiers appear nowhere in the repository — not in docs, experiment plans, run outputs, or ticket data — leaving their nature and location unverifiable.","group_criteria":null,"group_id":null,"id":"f7ad9f3d49dcf7620","impact":0.0,"is_primary":null,"location":"What section: 'finding-level TP/FP labels needed by E2/E3/E6 and R1/R7'","norm_id":"ne749500b013b0085","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":["If R1/R7 are future tickets (depends_on targets not yet created), the corpus produced by this ticket may be incomplete for their actual requirements.","If R1/R7 are typos or renamed identifiers, the dependency claim is broken and the corpus may not be structured to serve those consumers correctly."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"no","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add a brief positive rationale in the Why or What section explaining why full panel adjudication (rather than the machine-first proxy of code_review_adjudication.jsonl) is required for this corpus — e.g., the kappa gate demands true inter-rater reliability that a single-proxy-rater corpus cannot provide.","cohort":["G6"],"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":["code_review_adjudication.jsonl rows carry: 'evidence: first-pass proxy (tier/severity); held-out confirmation pending' — the precedent is machine-first, not panel-first","The plan says it is 'extending the code_review_adjudication.jsonl pattern' but then specifies panel adjudication, which is structurally different from that pattern","No sentence in Why/What/Scope explains why the panel approach is chosen over the established proxy approach, despite the proxy approach being the documented precedent"],"finding":"The plan provides no positive rationale for choosing full panel adjudication over the machine-first-proxy approach already established by code_review_adjudication.jsonl (which uses a tier/severity proxy as a first pass, with held-out human confirmation deferred); this makes the elevated approach look arbitrary and leaves the implementer without guidance if the panel is unavailable.","group_criteria":null,"group_id":null,"id":"ff879253150cee1d3","impact":0.0,"is_primary":null,"location":"What section: 'panel-adjudicated TP/FP, extending the code_review_adjudication.jsonl pattern'","norm_id":"nf31fb2569dbd7bee","priority":0.0,"reason":"low-validity","scenarios":["Implementer, uncertain why panel adjudication was chosen over the proxy approach, falls back to the proxy (as in the precedent corpus) and ships single-rater machine labels — the kappa gate is then untestable."],"severity":"none","suggested_fix":"In the Why section, add one sentence: 'Panel (multi-rater) adjudication is required — not the machine-first proxy pattern used in code_review_adjudication.jsonl — because the kappa gate demands genuine inter-rater reliability as a validity signal; a single-rater proxy cannot produce a meaningful kappa.'","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a brief justification in the 'Why' or 'What' section for choosing human panel adjudication over (or in addition to) the existing deterministic automated proxy from derive_code_review_threshold.py, and consider whether the automated proxy can serve as a first-pass fallback if panel recruitment fails.","cohort":["T1"],"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":["Plan 'What' section: 'panel-adjudicated TP/FP, extending the code_review_adjudication.jsonl pattern'","docs/experiments/derive_code_review_threshold.py:23-24: 'The adjudication here is a transparent, deterministic FIRST-PASS proxy … the ticket permits a Sonnet-scored / held-out human adjudication for the final call'","The existing codebase explicitly documents the automated proxy as the primary mechanism and human adjudication as an optional confirmation step — the plan reverses this priority order without explanation."],"finding":"The plan introduces 'panel-adjudicated' human labeling as the adjudication mechanism for ~400 plan-review findings, but this is a novel departure from the established codebase pattern (a deterministic automated proxy in derive_code_review_threshold.py) and the plan provides no justification for why human panel adjudication is preferred over, or at least compared to, the existing automated approach.","group_criteria":null,"group_id":null,"id":"f122480c6292975fb","impact":0.0,"is_primary":null,"location":"What section — 'panel-adjudicated TP/FP, extending the code_review_adjudication.jsonl pattern'","norm_id":"n810aa85d40aca312","priority":0.0,"reason":"low-validity","scenarios":["If human panel adjudication is expensive or slow to recruit, the corpus freezing blocks E2/E3/E6/R1/R7 indefinitely — the plan has no fallback to the existing automated proxy.","The panel introduces inter-rater variance that the existing automated approach avoided; the kappa gate handles this partially but the plan does not consider whether the automated proxy could be the primary labeler with human spot-checking."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"d2c6b30e41116da5","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":232.4,"llm_calls":30,"llm_ms":588026.1,"total_ms":588391.4,"verify_requests":27},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"e95e-1543-cac7-47b9","ticket_type":"story","verdict":"BLOCK","verified_at_sha":"72bb4965e3781259f2b9791c8d3c67c23c7