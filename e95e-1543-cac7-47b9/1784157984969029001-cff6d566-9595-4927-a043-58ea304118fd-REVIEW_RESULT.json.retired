{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","data":{"coaching":[{"coaching":"Test the riskiest assumption behind rebar show output schema for derived fields first.","decision":"block","finding_refs":["f748abab65d03e838","f194efa4e548ea0c4"],"move_id":"4","move_name":"riskiest-assumption test","subject":"rebar show output schema for derived fields"},{"coaching":"Plan how pre-flight probe failure path AC coverage will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["faeb4424bbdc36ac6"],"move_id":"9","move_name":"plan the verification","subject":"pre-flight probe failure path AC coverage"},{"coaching":"Test the riskiest assumption behind git rev-list --count --objects flag interaction first.","decision":"advisory","finding_refs":["f40928129ab7bb121"],"move_id":"4","move_name":"riskiest-assumption test","subject":"git rev-list --count --objects flag interaction"},{"coaching":"Pin down post-claim window for reopened tickets with a concrete worked example.","decision":"advisory","finding_refs":["f935250fd40038cb5"],"move_id":"6","move_name":"specification by example","subject":"post-claim window for reopened tickets"},{"coaching":"Plan how blind-labeling enforcement mechanism for Rater B will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f88a4fd92094119c5"],"move_id":"9","move_name":"plan the verification","subject":"blind-labeling enforcement mechanism for Rater B"},{"coaching":"Pin down overlapping dropped semantics in source and decision fields with a concrete worked example.","decision":"advisory","finding_refs":["f99de1cbc026809dd"],"move_id":"6","move_name":"specification by example","subject":"overlapping dropped semantics in source and decision fields"},{"coaching":"Pin down had_persisted_review derivation protocol with a concrete worked example.","decision":"advisory","finding_refs":["fa545016277792f25","f08553e2341f69054"],"move_id":"6","move_name":"specification by example","subject":"had_persisted_review derivation protocol"},{"coaching":"Pin down multi-edit conflict resolution in post_claim_edit_class with a concrete worked example.","decision":"advisory","finding_refs":["f9616233171e6f6e5"],"move_id":"6","move_name":"specification by example","subject":"multi-edit conflict resolution in post_claim_edit_class"},{"coaching":"Plan how AC3 proving command concreteness will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f9a6e0d1e8c1d6e3d"],"move_id":"9","move_name":"plan the verification","subject":"AC3 proving command concreteness"},{"coaching":"Plan how README re-verification table machine-verifiability will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f286ae11c7070a897"],"move_id":"9","move_name":"plan the verification","subject":"README re-verification table machine-verifiability"},{"coaching":"State the concrete attestation evidence the [operator-attested] adjudicator rubric content and existence will require (a change id / vote outcome / timestamp), recorded on the ticket.","decision":"advisory","finding_refs":["f92e9d1498597c81b","fac228730921f4dbe","f4a95e06dab793b45"],"move_id":"14","move_name":"state attestation evidence","subject":"adjudicator rubric content and existence"},{"coaching":"Plan how rater_b field population process specification will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["fdccd6489e43a7229"],"move_id":"9","move_name":"plan the verification","subject":"rater_b field population process specification"},{"coaching":"Run a quick pre-mortem on LLM adjudicator call resilience and partial-state recovery: how could this plan fail?","decision":"advisory","finding_refs":["f6a67ce3a7738b013"],"move_id":"3","move_name":"pre-mortem","subject":"LLM adjudicator call resilience and partial-state recovery"},{"coaching":"Plan how adjudication corpus atomic-write pattern will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f1af2d49debc389f7"],"move_id":"9","move_name":"plan the verification","subject":"adjudication corpus atomic-write pattern"},{"coaching":"Weigh at least one structural alternative for hardcoded threshold constants versus configurable overrides.","decision":"advisory","finding_refs":["fea30ac342b3eef39"],"move_id":"5","move_name":"weigh alternatives","subject":"hardcoded threshold constants versus configurable overrides"},{"coaching":"Deliver outcome corpus and adjudication corpus release coupling with existing machinery first; make the ideal version a dependent follow-on ticket.","decision":"advisory","finding_refs":["f3b3510a96bae0692"],"move_id":"10","move_name":"foundation/enhancement split","subject":"outcome corpus and adjudication corpus release coupling"}],"coverage":{"counts":{"advisory_overflow":4,"advisory_surfaced":18,"blocking":1,"dropped":14,"indeterminate":0},"det":{"P1":{"ac_items":4,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","probed":11,"ran":true,"references":11,"resolved":0,"status":"pass","unresolved_or_abstained":11},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":4,"blocking":false,"desc_chars":8901,"file_impact":1,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":4,"blocking":false,"name":"ac-quality","ran":true,"status":"fail","verify_commands_linted":91,"verify_lint_abstained":90},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":2247,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":1,"name":"file-impact-coverage","ran":true,"status":"pass"}},"floored_criteria":["G5","T5e"],"floored_finding_ids":["fea30ac342b3eef39","f3b3510a96bae0692"],"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":226.9,"llm_calls":30,"llm_ms":847256.3,"total_ms":847623.4,"verify_requests":28},"narrowed":true,"remediation":{"baseline":"sidecar","eligible":true,"reasons":{"code_unchanged":true,"plan_changed":true,"registry_unchanged":true,"sidecar_baseline":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","F4","G5","T2","T4","T5b","T5d","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Verify whether `rebar show` output actually includes `reopen_count`, `force_close` (bool), `completion_verifier_fail_count`, and `review_round_count`; if not (as the schema suggests), specify how the mining script derives these counts from event-history replay rather than asserting they come from `rebar show`.","cohort":["E4"],"criteria":["E4"],"decision":"block","drop_reason":null,"evidence":["Plan text: 'Current-state fields (reopen/force-close/verifier-fail/round counts) are read via the `rebar show` CLI'","ticket_state.schema.json properties: ticket_id, ticket_type, title, status, priority, tags, assignee, claimed_session, parent_id, alias, description, author, created_at, env_id, comments, deps, file_impact, verify_commands, bridge_alerts, reverts, attestations, last_reopened_at, preconditions_summary — no reopen_count, force_close (bool), completion_verifier_fail_count, or review_round_count","grep 'reopen_count' in src/rebar: no matches","grep 'completion_verifier_fail_count' in src/rebar: no matches (completion_sidecar.py has SCHEMA='completion_verifier_fail_v1' event type, but no count field)","grep 'review_round_count' in src/rebar: no matches","force_close in src/rebar appears as a CLI option string, not a boolean field on the ticket state"],"finding":"The plan asserts that 'reopen_count (int), force_close (bool), completion_verifier_fail_count (int), review_round_count (int)' are 'read via the `rebar show` CLI', but the `rebar show` output schema (ticket_state.schema.json) does not include these fields. Only `last_reopened_at` (a timestamp) appears as a reopen-related field; grep finds zero occurrences of `reopen_count`, `completion_verifier_fail_count`, or `review_round_count` anywhere in `src/rebar/`. These are derived counts that would need to be computed from event-history replay (the same git-object mining the script already does), not a simple `rebar show` read. If the script assumes `rebar show` returns these counts and they aren't there, the outcome corpus silently ships null/missing values for load-bearing schema fields.","group_criteria":null,"group_id":null,"id":"f748abab65d03e838","impact":1.0,"is_primary":null,"location":"Step 1 — 'Current-state fields … are read via the `rebar show` CLI' and Outcome-corpus schema: `reopen_count (int), force_close (bool), completion_verifier_fail_count (int), review_round_count (int)`","norm_id":"na207f6f900bc7337","priority":1.0,"reason":"high-priority+criterion-opted-in","scenarios":["mine_outcome_corpus.py calls `rebar show <ticket_id>` and tries to read .reopen_count / .force_close / .completion_verifier_fail_count / .review_round_count from the JSON output — all four fields are absent, so the corpus rows carry null/missing values for these schema columns without any error.","Downstream E2/E3/E6 stories consume the corpus expecting integer counts and boolean flags; they receive nulls, silently corrupting the analysis."],"severity":"critical","suggested_fix":"Revise Step 1 to specify that these four counts are derived from the git-object event history (e.g., count STATUS events transitioning closed→open for reopen_count; scan for FORCE_CLOSE event type for force_close; count completion_verifier_fail sidecar events; count plan-review REVIEW_RESULT sidecar events per ticket for review_round_count) — and remove the claim that they come from `rebar show`.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"high","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"medium","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an AC (or a --dry-run --simulate-gc mode) that exercises the pre-flight probe's failure path: verify the script exits non-zero, prints the specified error message, and leaves no output file when the recovered ticket count is below the 500 floor.","cohort":["E5","G5"],"criteria":["E5"],"decision":"advisory","drop_reason":null,"evidence":["'if the recovered reviewed-ticket count falls below a floor of 500 (expected ~527), it halts with an actionable error (gc/pruned objects — history incomplete) and writes nothing'","AC1 proving command only tests: `python .../mine_outcome_corpus.py --dry-run` exits 0 and `wc -l runs/outcome_corpus.jsonl` ≥ 500","No AC covers the probe's failure branch: exit non-zero, correct error message, and zero bytes written to the output file","The probe is labeled '(mandatory)' in the plan, indicating it is the primary safety mechanism against silently truncated corpora"],"finding":"The pre-flight object-availability probe's failure path — halting with an error and writing nothing when the recovered-ticket count falls below 500 — has no AC coverage; only the happy path (--dry-run exits 0, wc -l ≥ 500) is proven.","group_criteria":null,"group_id":null,"id":"faeb4424bbdc36ac6","impact":1.0,"is_primary":null,"location":"## What, Step 1 (Pre-flight object-availability probe) and AC line 1 (Proving command: `--dry-run` exits 0, `wc -l` ≥ 500)","norm_id":"n408d59cc4a6fea0d","priority":1.0,"reason":"default-advisory","scenarios":["A gc'd or partially-pruned repo runs the script, the probe fires, but a bug causes it to continue anyway and write a truncated corpus — no AC would catch this regression.","The script exits non-zero but still writes a partial .tmp file that is not cleaned up — no AC verifies the 'writes nothing' guarantee."],"severity":"critical","suggested_fix":"Add to AC1: 'Proving command (failure path): run the script with a mocked/overridden count below 500 (e.g. `--max-objects 400` flag or a unit test patching the count) and assert exit code ≠ 0, the error message contains \"gc/pruned objects\", and `outcome_corpus.jsonl` does not exist.'","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Clarify the data source for `reopen_count`, `force_close`, `completion_verifier_fail_count`, and `review_round_count`: confirm whether these must be derived by event-scanning git objects (since they are not in `rebar show` compiled output) and update Step 1 and the regeneration-command description to reflect the actual data access method for each field.","cohort":["T3"],"criteria":["T3"],"decision":"advisory","drop_reason":null,"evidence":["Plan text: 'Current-state fields (reopen/force-close/verifier-fail/round counts) are read via the rebar show CLI.'","ticket_state.schema.json properties: only `last_reopened_at` for reopen-related state; no `reopen_count`, `force_close`, `completion_verifier_fail_count`, or `review_round_count` properties defined.","src/rebar/llm/completion_sidecar.py line 29: SCHEMA = 'completion_verifier_fail_v1' with explicit comment 'reducer-IGNORED' — meaning it does not enter compiled rebar show output.","src/rebar/_commands/transition_close.py lines 484-494: force_close is written as a COMMENT event via leaf.comment(), not as a STATUS or structured event that the reducer would compile into ticket state.","MISMATCH evidence class: the schema is in-repo and directly contradicts the plan's claim about rebar show surface."],"finding":"The plan asserts 'Current-state fields (reopen/force-close/verifier-fail/round counts) are read via the rebar show CLI,' but the ticket_state schema (ticket_state.schema.json) confirms rebar show does NOT emit reopen_count, force_close (bool), completion_verifier_fail_count, or review_round_count. Only `last_reopened_at` (a single timestamp) is in compiled state. The `force_close` fact lives in a git audit COMMENT event (not compiled state); `completion_verifier_fail_count` lives in the reducer-IGNORED COMPLETION_VERDICT sidecar; `reopen_count` and `review_round_count` are not derived fields in the reducer at all. An implementer following this plan will call `rebar show` expecting these four fields and get KeyError or None, silently producing a corpus with zeroed/null columns.","group_criteria":null,"group_id":null,"id":"f194efa4e548ea0c4","impact":1.0,"is_primary":null,"location":"What § Step 1 ('Current-state fields … are read via the rebar show CLI') and Outcome-corpus schema definition","norm_id":"n53c4331f22f01f28","priority":1.0,"reason":"default-advisory","scenarios":["mine_outcome_corpus.py calls `rebar show <ticket_id>` and attempts to read state['reopen_count']: KeyError; corpus rows get reopen_count=0 for all tickets regardless of actual reopens.","force_close detection via rebar show silently returns None/absent; all rows get force_close=False even for genuinely force-closed tickets, corrupting the ground-truth corpus.","completion_verifier_fail_count is unreadable from compiled state because COMPLETION_VERDICT is reducer-IGNORED; corpus column zeros out silently."],"severity":"critical","suggested_fix":"For each of the four fields, use git-object event scanning (already available in the script) rather than rebar show: count STATUS events with current_status='closed' and a force_close_reason key for force_close; count STATUS open←closed transitions for reopen_count; count COMPLETION_VERDICT events with schema='completion_verifier_fail_v1' for completion_verifier_fail_count; count REVIEW_RESULT sidecar events per ticket for review_round_count. Update Step 1 and the README regeneration command accordingly.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"medium","divergent_implementation":"high","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"medium","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Verify the pre-flight probe command: replace `git rev-list --count --objects --all` with two separate commands (e.g. `git rev-list --objects --all` piped through grep/awk to count genesis events, or `git cat-file --batch-check --batch-all-objects` to enumerate objects) so the floor check actually counts recovered ticket events rather than commits.","cohort":["T3"],"criteria":["T3"],"decision":"advisory","drop_reason":null,"evidence":["Plan text: 'the script runs git rev-list --count --objects --all and counts recovered ticket-genesis events; if the recovered reviewed-ticket count falls below a floor of 500 … it halts.'","git rev-list --count outputs a single integer (commit count) and exits; --objects adds per-object lines but --count suppresses them. The combination does not produce an iterable object list from which genesis events can be counted.","Unverified evidence class for the specific --count + --objects combination: no repo file confirms or denies, but git documentation and usage patterns make this a flag-level mismatch risk."],"finding":"The pre-flight probe uses `git rev-list --count --objects --all` to count recovered ticket-genesis events, but combining `--count` and `--objects` is a non-standard flag interaction: `--count` causes git rev-list to output only a single integer (the commit count) and suppresses the per-object lines that `--objects` would normally add. The result is a commit count, NOT an object/ticket count, making the '≥ 500 reviewed tickets recovered' floor comparison semantically wrong — it compares commit count to a ticket-row floor.","group_criteria":null,"group_id":null,"id":"f40928129ab7bb121","impact":0.85,"is_primary":null,"location":"What § Step 1 pre-flight: 'runs `git rev-list --count --objects --all` and counts recovered ticket-genesis events'","norm_id":"ne8bcf0206bebda54","priority":0.85,"reason":"default-advisory","scenarios":["Script runs `git rev-list --count --objects --all`, receives an integer (e.g. '3421') representing commit count, attempts to parse it as a list of ticket-genesis events, gets a wrong count or parse error, and either halts incorrectly on a healthy repo or passes incorrectly on a gc'd repo."],"severity":"critical","suggested_fix":"Use `git rev-list --objects --all | grep -c 'genesis\\|CREATE'` (or equivalent Python subprocess parsing) to count ticket-genesis events; or use `git cat-file --batch-check --batch-all-objects` to list all objects and filter. Drop `--count` from the rev-list invocation since it conflicts with per-object enumeration.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"broken_oracle","blast_radius":"local","debt_impact":"medium","divergent_implementation":"medium","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Clarify the `post_claim_edit_class` window rule for reopened tickets: specify whether the window is (a) per-round (each in_progress→close pair) with the taxonomy applied independently, (b) last round only, or (c) the full first-in_progress–to–final-close span with reopen-inserted edits explicitly labeled; document the chosen rule in the README alongside the `post_claim_edit_class` vocabulary.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["Plan defines window as 'iff its event timestamp falls between the ticket's first transition-into-`in_progress` and its close'","Plan's own schema includes `reopen_count (int)`, acknowledging multi-round tickets exist","rebar codebase: `src/rebar/reducer/_processors.py` line 316-322 records `last_reopened_at` and `closed->open` reopen transitions; `src/rebar/_lib_writes.py` exposes `reopen()` as a first-class operation","The persisted-review subset the plan focuses on (8 tickets) likely includes reopened tickets given the store has 527 reviewed tickets over time"],"finding":"The `post_claim_edit_class` classification window ('between the ticket's first transition-into-`in_progress` and its close') is under-specified for tickets with reopen_count > 0: a reopened ticket has multiple in_progress→closed cycles, so using only the 'first' transition-into-in_progress will misclassify edits that occurred in a later round (e.g. between second claim and second close) as outside the post-claim window, silently producing wrong `post_claim_edit_class` values for any multi-round ticket in the corpus.","group_criteria":null,"group_id":null,"id":"f935250fd40038cb5","impact":0.67,"is_primary":null,"location":"What, Step 1 — `post_claim_edit_class` definition; outcome-corpus schema `reopen_count` field","norm_id":"nf1c34b9ee405606c","priority":0.5863,"reason":"default-advisory","scenarios":["A ticket is claimed, has its description edited, is closed, then reopened, edited again, and closed again. The second edit falls after 'first in_progress' and before 'close' (the second close), so it IS captured — but only accidentally; the true intended window for round 2 is different.","A ticket is claimed, closed (no edit), reopened, edited, and closed again. The edit falls between first in_progress and second close, so it would be classified as post-claim — but it happened in round 2, not round 1, and a reviewer may dispute whether the §5.2 taxonomy applies to round-2 edits."],"severity":"major","suggested_fix":"Use per-round windows: for each (in_progress, close) event pair ordered by timestamp, classify edits that fall within that pair's interval; assign the most-specific edit class across all rounds for the row, or add a `rounds` sub-array if per-round detail is needed.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add an explicit step specifying that before Rater B labels any finding, the `tp_fp`, `rater_a`, and `rationale` fields are masked/omitted from the rows presented to Rater B (e.g. a separate `harnesses/blind_sample.py` that outputs a Rater-A-stripped view); document this masking in the README and AC#4.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["Plan: 'Rater B … re-labels a stratified-by-criterion ≥50-finding subset BLIND to Rater A's labels (populates `rater_b`)'","Adjudication-corpus schema: single `adjudication_corpus.jsonl` file with both `tp_fp` (Rater A's label) and `rater_b` (Rater B's label) in the same row","No step in 'What' or 'Scope' specifies stripping or masking `tp_fp`/`rater_a` fields before presenting corpus rows to Rater B","AC#4 proving command: 'python .../kappa.py runs/adjudication_corpus.jsonl' — single-file input implies Rater B sees Rater A's labels unless explicitly masked"],"finding":"The plan requires Rater B to label a 50-finding subset 'BLIND to Rater A's labels', but no mechanism is specified to prevent Rater B from seeing the `tp_fp` and `rater_a` fields already written into `adjudication_corpus.jsonl` by Rater A. If `kappa.py` or the Rater B invocation script reads the same JSONL file without stripping those fields before presenting findings to the Rater B LLM, the 'blind' requirement fails, and the kappa value is inflated by anchoring rather than measuring true independent agreement.","group_criteria":null,"group_id":null,"id":"f88a4fd92094119c5","impact":0.67,"is_primary":null,"location":"What, Step 4 — Double-label and compute inter-rater reliability; Rater B description","norm_id":"n3a7842d389eaa6b6","priority":0.5863,"reason":"default-advisory","scenarios":["Rater B LLM is given corpus rows that include `tp_fp: 'TP'` already set by Rater A; the model anchors on this and confirms the existing label, producing artificially high kappa.","kappa.py is a purely computational script that doesn't invoke Rater B at all, leaving it unclear when/how Rater B's blind labeling is actually performed — the sequencing is never specified."],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a co-located mapping table to the adjudication-corpus schema (Step 3 / README) that specifies the valid (source, decision) combinations and the TP/FP interpretation rule for each: e.g., clarify whether source=surfaced means 'emitted by the gate in the REVIEW_RESULT' or 'in the sampled surfaced set', and whether surfaced-but-then-completion-floored findings count as source=surfaced or source=dropped.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Schema: 'source ∈ {surfaced, dropped}, decision ∈ {block, advisory, dropped}'","The TP/FP definition in Step 3 only defines semantics for 'a surfaced finding' and 'a dropped finding', keyed on source — it does not address the case where source=surfaced but decision=dropped (a finding that was surfaced by the gate but then down-selected or removed before persisting)","The REVIEW_RESULT sidecar is known to contain 'dropped novel findings' and 'completion-floored findings' (docs/plan-review-gate.md lines 375-401), so such combinations are plausible in real data"],"finding":"The adjudication-corpus schema's `decision` field (`∈ {block, advisory, dropped}`) and `source` field (`∈ {surfaced, dropped}`) both contain the value `dropped` with different but overlapping semantics, and no processing protocol is co-located in the schema specifying how the two fields interact — specifically whether a row with `source=surfaced` may ever carry `decision=dropped`, and what the TP/FP semantics are for such a cross-combination.","group_criteria":null,"group_id":null,"id":"f99de1cbc026809dd","impact":0.67,"is_primary":null,"location":"Step 3 (What) — adjudication-corpus schema definition","norm_id":"ne5b3fb0cdd2fd297","priority":0.5863,"reason":"default-advisory","scenarios":["An executor sampling REVIEW_RESULT sidecars encounters findings recorded in the sidecar with drop_reason='novelty' — should these be source=surfaced or source=dropped? The plan's schema is ambiguous.","Rater A labels a source=surfaced / decision=dropped row as FP (spurious finding) while Rater B labels it TP (correctly dropped), because the protocol only defines TP/FP for the source dimension without accounting for the decision dimension"],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add an explicit derivation rule for `had_persisted_review` to Step 1 (e.g., 'True iff at least one REVIEW_RESULT event is recovered from git objects for this ticket_id via git cat-file, independently of rebar show') and add it to the README schema documentation.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Schema lists: '{ticket_id, ticket_type, level, post_claim_edit_class, reopen_count (int), force_close (bool), completion_verifier_fail_count (int), review_round_count (int), had_persisted_review (bool)}'","Step 1 states current-state fields are read via 'rebar show CLI' and history is recovered from 'git rev-list --objects --all + git cat-file', but never mentions which of these mechanisms populates had_persisted_review or what event type / CLI field to inspect","had_persisted_review is load-bearing: Step 3 explicitly samples findings 'from the persisted REVIEW_RESULT sidecars', so the entire adjudication corpus depends on this flag being correctly populated"],"finding":"The outcome-corpus field `had_persisted_review` is defined in the schema but no derivation protocol is specified anywhere in the plan — the mining script section (Step 1) explains how to recover `reopen_count`, `force_close`, `completion_verifier_fail_count`, and `review_round_count` from git objects and `rebar show`, but is silent on how `had_persisted_review` is determined.","group_criteria":null,"group_id":null,"id":"fa545016277792f25","impact":0.67,"is_primary":null,"location":"Step 1 (What) — outcome-corpus schema; mine_outcome_corpus.py description","norm_id":"ned1be724c4960f50","priority":0.5863,"reason":"default-advisory","scenarios":["An executor interprets had_persisted_review as 'rebar show returns a review_round_count > 0', another interprets it as 'at least one *-REVIEW_RESULT.json file exists on disk', producing different populations and a biased adjudication corpus","If had_persisted_review is incorrectly False for tickets with sidecars, Step 3 draws from a truncated population and the adjudication corpus floors fall short"],"severity":"major","suggested_fix":"had_persisted_review = True iff `git rev-list --objects --all | git cat-file --batch-check` yields at least one blob whose path matches `.tickets-tracker/<ticket_id>/*-REVIEW_RESULT.json`.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a conflict-resolution rule for multi-edit tickets to the post_claim_edit_class definition in Step 1 (e.g., a priority ordering among the 7 classes such that the highest-severity applicable class is assigned, or 'last-edit wins', or 'all classes are recorded in a post_claim_edit_classes[] array and post_claim_edit_class holds the most-severe').","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["'An edit is post-claim iff its event timestamp falls between the ticket's first transition-into-in_progress and its close' — this window may contain multiple edits","'exactly one per row' is stated as a constraint, but no tiebreaker rule or priority ordering among the 7 classes is given","The §5 report itself identifies 16 post-claim edits across 505 tickets, implying multi-edit cases may exist and need classification"],"finding":"The `post_claim_edit_class` field requires 'exactly one per row' from a 7-value closed vocabulary, but no conflict-resolution rule is specified for tickets with multiple post-claim edits that would each fall into different classes (e.g., a `cosmetic` edit followed by an `approach-change` edit within the same post-claim window).","group_criteria":null,"group_id":null,"id":"f9616233171e6f6e5","impact":0.67,"is_primary":null,"location":"Step 1 (What) — post_claim_edit_class definition; §5.2 taxonomy","norm_id":"n8ebad5fb44d98437","priority":0.5863,"reason":"default-advisory","scenarios":["A ticket has a cosmetic edit at T+1 and a scope-reduction edit at T+2 — the mining script has no rule for which class to assign, and two executors running the script will produce different classifications","Without a priority ordering (e.g., 'most impactful class wins'), the outcome corpus will have non-deterministic classifications for multi-edit tickets, making §5 re-verification non-reproducible"],"severity":"major","suggested_fix":"Add a priority ladder (e.g., premise-invalidated > approach-change > scope-reduction > ac-strengthened > plan-authored-post-claim > operator-attested-retag > cosmetic > none) so the most impactful class is always assigned when multiple edits occur.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Replace the prose proving command in AC3 with a concrete executable — e.g. `python -c \"import json,sys; rows=list(map(json.loads,open('runs/adjudication_corpus.jsonl'))); assert all(set(['source','tp_fp','rationale','criterion']).issubset(r) for r in rows); s=sum(r['source']=='surfaced' for r in rows); d=sum(r['source']=='dropped' for r in rows); assert s>=280 and d>=90, f'{s} surfaced {d} dropped'`.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["'a jq/python check' — no actual command text provided, unlike AC1 which gives `python .../mine_outcome_corpus.py --dry-run` and AC4 which gives `python .../kappa.py runs/adjudication_corpus.jsonl`"],"finding":"AC3's proving command is described in prose ('a jq/python check that every row has source, tp_fp, rationale and the surfaced/dropped counts meet the floor') rather than as a concrete executable command — this is defect-taxonomy issue #6 (prose assertion target) and leaves the exact check undefined.","group_criteria":null,"group_id":null,"id":"f9a6e0d1e8c1d6e3d","impact":0.55,"is_primary":null,"location":"AC3 — 'Proving command: a jq/python check that every row has `source`, `tp_fp`, `rationale` and the surfaced/dropped counts meet the floor.'","norm_id":"nf1065d277ee97137","priority":0.55,"reason":"default-advisory","scenarios":["Executor writes a one-line check that only tests `source` but silently skips `tp_fp` schema validation; the AC appears satisfied."],"severity":"major","suggested_fix":"","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a machine-verifiable README check to AC2's proving command, e.g. `grep -cE 'AGREES|CORRECTED-TO' docs/experiments/plan-review-gate/runs/README.md` returning ≥ 7 (one per named figure) alongside the `--verify-s5` run.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["The proving command runs a script and checks stdout; README content is a separate artifact with no stated machine verification.","ABSENCE: no `grep` / `jq` / schema check on README content is specified to confirm all 7 named figures are marked AGREES or CORRECTED-TO <n>"],"finding":"AC2's proving command (`--verify-s5` printing derived figures) only machine-verifies the script's stdout; the second half of the criterion — 'the README's re-verification table records, per figure, the derived value … marked AGREES or CORRECTED-TO <n> (no figure left as agreement OR corrected)' — is verifiable only by human inspection of a prose file, with no machine check.","group_criteria":null,"group_id":null,"id":"f286ae11c7070a897","impact":0.55,"is_primary":null,"location":"AC2 — 'Proving command: `python .../mine_outcome_corpus.py --verify-s5` prints the derived figures and **the table in README names each as agreeing or corrected** (no figure left as \"agreement OR corrected\")'","norm_id":"n4a0af4575e2468f2","priority":0.4813,"reason":"default-advisory","scenarios":["Executor runs --verify-s5, script prints figures, executor manually updates README but leaves one figure blank or writes 'TBD'; the proving command still exits 0."],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a required structure specification for both adjudication rubrics (adjudicate_rubric_a.md and adjudicate_rubric_b.md) to the plan — at minimum: required sections (criterion definition, TP boundary, FP boundary, ambiguous boundary, worked example per source type), the shared TP/FP vocabulary each must use, and the constraint that Rater B must apply the same semantic TP/FP boundary as Rater A while using independently-chosen examples and model.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Plan Step 4: 'Rater A (primary): an LLM adjudicator run with rubric harnesses/adjudicate_rubric_a.md' and 'Rater B (independent): a second LLM adjudicator with an independently-authored rubric harnesses/adjudicate_rubric_b.md'","Tool-verified: neither file exists anywhere under docs/experiments/plan-review-gate/harnesses/ — directory listing shows no adjudicate_rubric_a.md or adjudicate_rubric_b.md","No section of the plan defines the rubric's required sections, prompting structure, TP/FP boundary conditions, or format — only the output schema (TP/FP/ambiguous) is defined"],"finding":"adjudicate_rubric_a.md and adjudicate_rubric_b.md are referenced throughout Steps 4/5 and the Scope section as the contracts governing all LLM rater behavior, but neither file exists in the repo and neither has any content, structure, or decision rules defined anywhere in the plan. An executor has no specification from which to author them.","group_criteria":null,"group_id":null,"id":"f92e9d1498597c81b","impact":0.67,"is_primary":null,"location":"Step 4 (What) / Scope section: 'harnesses/adjudicate_rubric_a.md, adjudicate_rubric_b.md (new)'","norm_id":"n497af37526200424","priority":0.4188,"reason":"default-advisory","scenarios":["An executor creates rubric A with broad definitions and rubric B with narrow ones, producing systematically divergent labels and a failing kappa gate with no diagnostic path","Without a shared rubric structure, Rater B cannot guarantee it applies the same TP/FP boundary semantics as Rater A, making inter-rater agreement measurement invalid"],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":null,"blocking_enabled":null,"checklist_item":"","cohort":null,"criteria":["P6"],"decision":"advisory","drop_reason":null,"evidence":["4 criterion line(s) bundle multiple deliverables with 'and' (split so each is independently verifiable).","verify command `wc -l runs/outcome_corpus.jsonl` inspects output with `wc` but asserts nothing — add an exit-code or comparison (-q, [ \"$(...)\" -eq N ], jq -e) so a failure is observable"],"finding":"Acceptance-criteria / definition-of-done quality issues.","group_criteria":null,"group_id":null,"id":"f607dd457c67f9209","impact":0.4,"is_primary":null,"location":"","norm_id":"ned06ebc801a522e3","priority":0.4,"reason":null,"scenarios":[],"severity":"minor","suggested_fix":"Split compound criteria, replace subjective terms with observable outcomes, and state how each is verified.","tier":"DET","validity":1.0,"verification":null},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a minimum content specification for adjudicate_rubric_a.md and adjudicate_rubric_b.md to the plan (e.g., each rubric must define the TP/FP/ambiguous labels by referencing the README vocabulary, state the criterion scope it covers, and include at least two worked examples); require the README to record that both rubrics were reviewed against this spec before use.","cohort":["T2","T4","T7"],"criteria":["T7"],"decision":"advisory","drop_reason":null,"evidence":["'Rater A (primary): an LLM adjudicator run with rubric harnesses/adjudicate_rubric_a.md' — no content requirements stated","'a second LLM adjudicator with an independently-authored rubric harnesses/adjudicate_rubric_b.md' — 'independently authored' is the only specification","The README schema documentation requirements (schema, vocabularies, kappa, provenance) are detailed, but no parallel documentation requirement is stated for the rubric files themselves","ABSENCE: no rubric content checklist, no requirement that rubrics reference the §5.2 taxonomy or the closed tp_fp vocabulary, no review step before use"],"finding":"The two adjudicator rubric files (adjudicate_rubric_a.md and adjudicate_rubric_b.md) are new contract-defining artifacts that govern all LLM rater behavior and therefore the kappa outcome, but the plan specifies neither their required content/structure nor any quality-validation step before they are used — they are simply listed as new files with no doc standard applied to them.","group_criteria":null,"group_id":null,"id":"fac228730921f4dbe","impact":0.67,"is_primary":null,"location":"Scope section: 'harnesses/adjudicate_rubric_a.md, adjudicate_rubric_b.md, and kappa.py (new)'; Step 4","norm_id":"n74ac87070ba49f68","priority":0.335,"reason":"default-advisory","scenarios":["Rubrics omit the tp_fp TP/FP/ambiguous vocabulary definition, causing rater labeling to diverge from the corpus schema","Rubric B is so similar to Rubric A (or so vague) that kappa is artificially inflated, making the gate meaningless","Rubric content cannot be audited or reproduced because no structure requirement was committed alongside the files"],"severity":"major","suggested_fix":"In the Scope section, add: 'Each rubric must (a) reproduce or cite the tp_fp vocabulary from the README, (b) state which criterion ids it covers, and (c) include ≥2 worked canonical examples (one TP, one FP). The README records that both rubrics satisfy this spec.' This gives auditors a concrete artifact to check without over-specifying the rubric prose.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a named script (e.g. `harnesses/adjudicate_rater_b.py`) and its exact invocation command to the Scope section and README regeneration commands, making Rater B label ingestion into `adjudication_corpus.jsonl` fully specified and reproducible.","cohort":["T5b","T5e","T9"],"criteria":["T9"],"decision":"advisory","drop_reason":null,"evidence":["'Rater B (independent): a second LLM adjudicator with an independently-authored rubric harnesses/adjudicate_rubric_b.md ... re-labels a stratified-by-criterion ≥50-finding subset BLIND to Rater A's labels (populates rater_b)'","ABSENCE: no script name, invocation command, or ownership specification for Rater B label ingestion is given in the Scope section or ACs.","The Scope section lists adjudicate_rubric_b.md and kappa.py but no adjudicate_b.py or equivalent runner."],"finding":"The plan does not specify which script or process populates the `rater_b` field in `adjudication_corpus.jsonl`. Rater B's adjudication is described as a separate step with a different model and rubric, but there is no named script, invocation command, or ownership boundary that makes it clear how `rater_b` labels get written back into the corpus file.","group_criteria":null,"group_id":null,"id":"fdccd6489e43a7229","impact":0.536,"is_primary":null,"location":"Step 4 – Rater B (independent) / Scope: runs/adjudication_corpus.jsonl schema field `rater_b`","norm_id":"n44bdf4379d03b29b","priority":0.335,"reason":"default-advisory","scenarios":["An implementer writes Rater A output correctly but has no specified mechanism for Rater B; they improvise an ad-hoc process that writes rater_b labels in a different format, breaking kappa.py's expected schema.","The README's 'exact regeneration commands' omit the Rater B invocation, making the corpus non-reproducible."],"severity":"major","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add `had_persisted_review` to AC1's list of required fields verified by the proving command (e.g. extend the jq/python check to also assert this field is present on every row).","cohort":["COH","E1","T5d"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["Step 1 schema: `{ticket_id, ticket_type, level, post_claim_edit_class, reopen_count (int), force_close (bool), completion_verifier_fail_count (int), review_round_count (int), had_persisted_review (bool)}`","AC1 required fields list: 'carrying `post_claim_edit_class`, `reopen_count`, `force_close`, `completion_verifier_fail_count`, and `review_round_count`' — `had_persisted_review` absent","Step 3 draws from 'persisted REVIEW_RESULT sidecars' implying `had_persisted_review` filters the population"],"finding":"The `had_persisted_review` field is defined in the outcome-corpus schema (Step 1) and is load-bearing for Step 3 (finding-adjudication corpus is drawn from \"the persisted REVIEW_RESULT sidecars\"), but AC1's list of required fields omits it — an AC that doesn't check this field cannot confirm the corpus is complete.","group_criteria":null,"group_id":null,"id":"f08553e2341f69054","impact":0.0,"is_primary":null,"location":"Step 1 (schema definition) vs AC1 proving command","norm_id":"n952b0e91ca8f4d4e","priority":0.0,"reason":"default-advisory","scenarios":["An implementer passes AC1 but omits `had_persisted_review` from the corpus; Step 3's stratification silently breaks because the linking field is absent."],"severity":"none","suggested_fix":"In AC1, extend the proving command to `python -c \"import json,sys; rows=list(map(json.loads,open('runs/outcome_corpus.jsonl'))); assert all('had_persisted_review' in r for r in rows)\"` or equivalent jq, and add `had_persisted_review` to the enumerated field list.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an AC (or extend AC4) requiring that `harnesses/adjudicate_rubric_a.md` and `harnesses/adjudicate_rubric_b.md` are committed, non-empty, and explicitly reference the TP/FP vocabulary (e.g. `grep -q 'TP\\|FP' harnesses/adjudicate_rubric_{a,b}.md` exits 0).","cohort":["COH","E1","T5d"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["Scope: 'harnesses/adjudicate_rubric_a.md, adjudicate_rubric_b.md … (new)'","Step 4: 'Rater A … run with rubric harnesses/adjudicate_rubric_a.md'; 'Rater B … independently-authored rubric harnesses/adjudicate_rubric_b.md'","AC4 proving command: 'python .../kappa.py runs/adjudication_corpus.jsonl' — no check on rubric file existence or content"],"finding":"The Scope explicitly names `harnesses/adjudicate_rubric_a.md` and `harnesses/adjudicate_rubric_b.md` as new deliverables, but no AC verifies these files are committed (non-empty, referencing the correct TP/FP vocabulary). Step 4 depends on them being correct, but the proving commands only invoke `kappa.py` — a passing kappa run does not verify the rubric files exist or are coherent.","group_criteria":null,"group_id":null,"id":"f4a95e06dab793b45","impact":0.0,"is_primary":null,"location":"Scope section (harness file list) vs AC4 proving command","norm_id":"na27608466f59928f","priority":0.0,"reason":"default-advisory","scenarios":["Rubric files are committed as empty stubs or with the wrong vocabulary (block-worthy instead of TP/FP); kappa.py still passes because it only reads adjudication_corpus.jsonl; downstream E2/E3/E6 ingest rubrics that were never validated."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add retry/backoff for LLM adjudicator calls and a checkpoint/resume mechanism (e.g. skip already-labeled finding_ids on restart) so a mid-batch failure does not require a full re-run from scratch.","cohort":["T5b","T5e","T9"],"criteria":["T5b"],"decision":"advisory","drop_reason":null,"evidence":["Plan says 'Rater A (primary): an LLM adjudicator run with rubric...' and 'Rater B (independent): a second LLM adjudicator' with no mention of retry, timeout, backoff, or checkpointing.","ABSENCE: no checkpoint/resume mechanism is described for the ~300 + ~100 LLM labeling calls.","ABSENCE: no error-surfacing mechanism (log line, metric, exit code) for mid-batch LLM failures is specified."],"finding":"LLM adjudicator calls for Rater A and Rater B have no retry, backoff, timeout, or partial-state recovery specified. If an LLM call fails mid-batch (e.g. at finding 150 of 300), the plan provides no checkpoint or resume mechanism, leaving the adjudication corpus incomplete with no recovery path other than restarting from scratch.","group_criteria":null,"group_id":null,"id":"f6a67ce3a7738b013","impact":0.0,"is_primary":null,"location":"Step 4 – Double-label and compute inter-rater reliability / Scope: harnesses/adjudicate_rubric_a.md, adjudicate_rubric_b.md","norm_id":"nade790c0f300487f","priority":0.0,"reason":"default-advisory","scenarios":["Rater A fails at finding 150/300 due to a transient LLM API error; the script crashes with no partial output saved; the operator must restart from scratch with no visibility into which findings were already labeled.","Rater B's independent LLM model is rate-limited mid-batch; the ≥50-finding double-labeled subset is partially populated, silently undermining the kappa computation."],"severity":"none","suggested_fix":"In the adjudication harness, write each batch of LLM labels to an append-only `.jsonl` file incrementally (one line per finding, flushed immediately), and on startup skip any `finding_id` already present in the output file. Add exponential backoff (3 retries, 2/4/8 s) around each LLM call and surface failures as a non-zero exit with a count of failed rows.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Apply the same `.tmp` + `os.replace` atomic-write pattern to `adjudication_corpus.jsonl` (or use incremental append with a completion sentinel) so partial writes are never committed as ground truth.","cohort":["T5b","T5e","T9"],"criteria":["T5b","T9"],"decision":"advisory","drop_reason":null,"evidence":["outcome_corpus.jsonl: 'Output written atomically (.tmp + os.replace)'","ABSENCE: no equivalent atomic-write guarantee is stated for adjudication_corpus.jsonl."],"finding":"The `adjudication_corpus.jsonl` write path has no atomic-write pattern specified, unlike `outcome_corpus.jsonl` which explicitly uses `.tmp` + `os.replace`. If the adjudication script (or LLM loop) is interrupted mid-write, a partial/corrupt corpus file could be committed as ground truth.","group_criteria":null,"group_id":null,"id":"f1af2d49debc389f7","impact":0.0,"is_primary":null,"location":"Step 3 – Build the finding-adjudication corpus / Scope: runs/adjudication_corpus.jsonl","norm_id":"n057a0030ca23b744","priority":0.0,"reason":"default-advisory","scenarios":["LLM adjudication loop writes 200 of 400 rows then crashes; the partial file is committed; downstream kappa computation runs on a truncated corpus without detecting truncation."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify in the kappa.py description (Scope section) whether the Cohen's kappa implementation should be hand-rolled using only stdlib math (recommended, given the binary 2×2 case) or may import an explicit named library (e.g. `scipy.stats`), to prevent silent dependency creep into the experiment harness.","cohort":["A1"],"criteria":["A1"],"decision":"advisory","drop_reason":null,"evidence":["Plan says 'a committed script harnesses/kappa.py computes Cohen's kappa' with no mention of dependencies or implementation approach.","Grep of the entire harnesses/ directory finds no import of sklearn, scipy, or any stats library — all existing scripts use stdlib (json, os, re, subprocess, random).","resolve_symbol('cohen_kappa_score', 'sklearn.metrics') returned UNRESOLVED — sklearn is not installed in the experiment environment.","Cohen's kappa for a binary {TP, FP} contingency table is a straightforward 15-line formula requiring no external library."],"finding":"kappa.py's Cohen's kappa implementation leaves the dependency choice unspecified: Python stdlib has no Cohen's kappa, sklearn is not referenced anywhere in the experiment harness codebase, and a hand-rolled formula for binary {TP,FP} is ~10 lines. Without specifying 'use stdlib math only' or 'allowed to pip-install sklearn', an implementer could silently add a heavy ML library to what is otherwise a pure-stdlib experiment script.","group_criteria":null,"group_id":null,"id":"f0a65ffe900853955","impact":0.0,"is_primary":null,"location":"Step 4 / Scope section: 'harnesses/kappa.py (new)'; AC4 proving command: 'python .../kappa.py runs/adjudication_corpus.jsonl'","norm_id":"n0d8b10f4e1adf154","priority":0.0,"reason":"default-advisory","scenarios":["Implementer adds 'import sklearn' to kappa.py, inadvertently introducing a heavy dependency into the experiment harness, which the README explicitly says is not production code but is committed.","Implementer hand-rolls kappa with a subtle formula error (e.g. wrong expected-agreement computation) that silently accepts or rejects the kappa gate incorrectly."],"severity":"none","suggested_fix":"Add to the Scope bullet for kappa.py: 'implements Cohen's kappa inline using only stdlib `math` (no scipy/sklearn dependency) — the binary {TP, FP} 2×2 case reduces to: kappa = (p_o - p_e) / (1 - p_e) where p_o = observed agreement, p_e = expected agreement under independence.'","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Revise the pre-flight probe to count tickets covered by either a raw genesis event blob OR a committed SNAPSHOT object (i.e., count unique ticket directories recoverable from git history, not raw genesis-event blob count), so the floor check correctly distinguishes gc-lost tickets from compaction-folded ones.","cohort":["G6"],"criteria":["G6"],"decision":"advisory","drop_reason":null,"evidence":["Plan states: 'the on-disk `.tickets-tracker/` is compacted'","rebar compaction (`src/rebar/_commands/compact.py` lines 163–219) explicitly retires (renames) raw event files into SNAPSHOTs and commits the SNAPSHOT, removing the original event blobs from the git working tree","Pre-flight probe: 'counts recovered ticket-genesis events; if the recovered reviewed-ticket count falls below a floor of 500 … it halts'","The probe floor tests for raw-genesis-blob count, not for SNAPSHOT-covered ticket count"],"finding":"The pre-flight object-availability probe counts 'recovered ticket-genesis events' from `git rev-list --objects --all`, but the plan itself states 'the on-disk `.tickets-tracker/` is compacted' — meaning rebar's compaction has already folded raw genesis event blobs into SNAPSHOT objects and retired the originals. A compacted-but-complete corpus of 527 tickets will have far fewer recoverable raw genesis blobs than 527 (many are SNAPSHOT-absorbed), so the floor check of ≥500 raw genesis events will either false-halt on a healthy compacted corpus or silently pass on a partially gc'd one. The probe cannot distinguish 'objects genuinely lost to gc/pruning' from 'objects legitimately retired by compaction'.","group_criteria":null,"group_id":null,"id":"f5ad91e2166a4db30","impact":0.0,"is_primary":null,"location":"What, Step 1 — Pre-flight object-availability probe (mandatory)","norm_id":"n3b743e5a6b75c60f","priority":0.0,"reason":"default-advisory","scenarios":["100 of 527 tickets have been compacted; their genesis blobs are gone (absorbed into SNAPSHOTs). The probe counts 427 genesis events, falls below 500, and halts with 'gc/pruned objects — history incomplete' — a false halt on perfectly intact data.","A gc attack prunes 30 tickets' git objects entirely, but 497 remain plus many SNAPSHOTs. The probe counts 497 raw genesis blobs, passes the floor (≥500 with SNAPSHOT paths counted ambiguously), and ships a truncated corpus."],"severity":"none","suggested_fix":"Count unique ticket-directory names across all reachable tree objects (both raw event directories and SNAPSHOT-containing directories), then compare that total to the floor of 500, rather than counting individual genesis-event blobs.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Name the specific Python library (e.g. `sklearn.metrics.cohen_kappa_score` or `scipy.stats`) that `harnesses/kappa.py` will use to compute Cohen's kappa, confirm it is (or will be) present in the harness venv, and add it to the harness venv's requirements or setup instructions in the README.","cohort":["T1"],"criteria":["T1"],"decision":"advisory","drop_reason":null,"evidence":["Plan: 'a committed script harnesses/kappa.py computes Cohen's kappa on the binary {TP, FP} labels'","README.md: harnesses run 'against a venv with anthropic; many read inputs from a scratch dir'","Python stdlib has no cohen_kappa_score. sklearn.metrics.cohen_kappa_score and scipy are both UNRESOLVED in the installed environment.","No import or requirements statement for a kappa library appears anywhere in the plan or harness directory."],"finding":"The committed harnesses/kappa.py is specified to compute Cohen's kappa, but no Python library is named and the established harness venv is documented only as 'a venv with anthropic'. Python's stdlib contains no Cohen's kappa implementation; the candidates (sklearn.metrics.cohen_kappa_score, scipy.stats) are unresolved in the installed environment. This is an unverified capability assertion: the plan assumes a kappa library is available without naming or confirming it.","group_criteria":null,"group_id":null,"id":"f2532218bf2e15157","impact":0.0,"is_primary":null,"location":"Step 4 / Scope section — 'harnesses/kappa.py (new)'; docs/experiments/plan-review-gate/README.md (harnesses venv description)","norm_id":"naa791bc897a4e60e","priority":0.0,"reason":"default-advisory","scenarios":["Implementer runs `python harnesses/kappa.py …` and gets ImportError / NameError because neither sklearn nor scipy is installed in the anthropic-only venv.","Implementer writes a hand-rolled kappa formula that contains an off-by-one in the expected-agreement term, silently producing wrong kappa values that pass the 0.7 gate."],"severity":"none","suggested_fix":"Add `scikit-learn` (or `scipy`) to the harness venv requirements, reference it explicitly in the plan under Scope (e.g. 'kappa.py uses sklearn.metrics.cohen_kappa_score'), and update the README's regeneration commands to include the install step.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["T3"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The plan's core data-recovery method (`git rev-list --objects --all` on the tickets branch) asserts it can re-derive §5 event history from git objects, but the plan itself states 'the on-disk .tickets-tracker/ is compacted' — if the tickets branch has been force-pushed, rebased, squash-merged, or subjected to `git gc` pruning unreachable objects, the historical event blobs may be permanently gone. The only named fallback ('ephemeral prior artifacts may exist at /Users/joeoakhart/.claude/jobs/e5b41784/tmp/') is explicitly uncertain and non-reproducible, leaving the AC-1 regeneration-command requirement and AC-2 re-verification with no achievable path if the objects are absent.","group_criteria":null,"group_id":null,"id":"f4499a8fb0372bf30","impact":0.0,"is_primary":null,"location":"What section: 'Re-derive the §5 event history from git objects across all refs of the tickets branch (git rev-list --objects --all + cat-file; the on-disk .tickets-tracker/ is compacted) - method in report §5; ephemeral prior artifacts may exist at /Users/joeoakhart/.claude/jobs/e5b41784/tmp/ but the corpus must be reproducible without them.'","norm_id":"n1c7c4814b551ad09","priority":0.0,"reason":"default-advisory","scenarios":[],"severity":"none","suggested_fix":"Add a pre-flight step to the mining script: run `git rev-list --objects --all | git cat-file --batch-check | grep -c blob` and assert the count is plausible (e.g., > 5000 blobs). If it fails, switch to the rebar ticket-read API (already available in this repo) to reconstruct event history from live ticket state, and document both paths in the README.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] State a concrete authorship constraint for `adjudicate_rubric_b.md` — e.g. 'authored in a fresh session with no access to rubric_a.md' or 'derived from the raw criterion text without consulting rubric_a.md's wording' — so the executor knows what 'independently' requires.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"dropped","drop_reason":null,"evidence":["'independently-authored rubric `harnesses/adjudicate_rubric_b.md`' — no authorship constraint specified","ABSENCE: no statement of what 'independent' means operationally (different session, different operator, different prompt derivation)"],"finding":"Rater B's rubric (`adjudicate_rubric_b.md`) is described as 'independently-authored' but the plan never specifies WHO authors it or what 'independently' means operationally — is it the same LLM with different system-prompt instructions, a different operator, a human? An executor cannot proceed without guessing.","group_criteria":null,"group_id":null,"id":"ff50fc09ba5937bb6","impact":0.44,"is_primary":null,"location":"Step 4 — '**Rater B (independent):** a second LLM adjudicator with an independently-authored rubric `harnesses/adjudicate_rubric_b.md`'","norm_id":"nc411c97e0e615a31","priority":0.165,"reason":"low-validity","scenarios":["Executor writes rubric_b.md by copying rubric_a.md with minor edits; the independence claim is hollow but the plan provides no way to know this violates the intent."],"severity":"minor","suggested_fix":"Add to Step 4: 'Rubric B is authored from the raw criterion definitions in `docs/experiments/plan-review-gate/` without reading rubric_a.md; the authoring session starts after rubric_a.md is committed and the authoring prompt contains no reference to rubric_a.md's wording.'","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Replace 'e.g. a distinct Claude model id' with a concrete binding constraint or named default model for Rater B (e.g. 'claude-3-5-haiku for Rater B when Rater A uses claude-opus-4') so no executor choice is required.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"dropped","drop_reason":null,"evidence":["'e.g. a distinct Claude model id from Rater A' — 'e.g.' signals a suggestion, not a decision","ABSENCE: no concrete model id or at minimum a binding constraint (e.g. 'must differ in major version') is stated"],"finding":"The Rater B model is specified only by example ('e.g. a distinct Claude model id from Rater A'), leaving the executor to 'choose an appropriate X' — a placeholder decision rather than a stated default.","group_criteria":null,"group_id":null,"id":"f19f6b66f7b076c97","impact":0.33,"is_primary":null,"location":"Step 4 — 'a **different model** (e.g. a distinct Claude model id from Rater A)'","norm_id":"n34a0bfdfbd9209ab","priority":0.0825,"reason":"veto:absence-refuted","scenarios":["Executor uses the same Claude model version for both raters, satisfying the letter of 'distinct id' by appending a snapshot suffix; the independence of the two rater perspectives is compromised."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Rewrite AC4 to explicitly state two exit conditions: (A) kappa ≥ 0.7 → ticket passes, labels shipped as ground truth; (B) kappa < 0.7 → ticket is still closeable as a documented-failure outcome, but labels are NOT shipped and downstream E/R stories are blocked pending remediation — and update the checkbox text to reflect both valid outcomes.","cohort":["E2","E6","F1"],"criteria":["E6","F1"],"decision":"dropped","drop_reason":null,"evidence":["AC checkbox text: 'reaches Cohen's kappa ≥ 0.7 on the binary {TP, FP} labels'","Same AC body: 'if kappa < 0.7 the labels are declared unusable, kappa.py exits non-zero, and the README + ticket document the failed validity gate instead of shipping labels'","CONFLICT: the checkbox's success phrase is kappa ≥ 0.7 but the AC itself provides an alternate done-state for kappa < 0.7"],"finding":"AC4's kappa completion condition is contradictory: the checkbox requires 'reaches Cohen's kappa ≥ 0.7' as its success phrase, but the body of the same AC explicitly describes a kappa < 0.7 outcome as a valid, ticket-closeable result ('the labels are declared unusable … no labels are shipped … [documented] instead of shipping labels'). An executor cannot determine whether kappa < 0.7 constitutes a passing or failing ticket.","group_criteria":null,"group_id":null,"id":"f3acde5a225738ac2","impact":0.264,"is_primary":null,"location":"AC4 — 'Inter-rater reliability … reaches **Cohen's kappa ≥ 0.7** … if kappa < 0.7 the labels are declared unusable … and the README + ticket document the failed validity gate instead of shipping labels.'","norm_id":"n6f9ba5ae494dbf46","priority":0.099,"reason":"low-validity","scenarios":["Executor runs kappa.py, gets 0.61; kappa.py exits non-zero. Executor documents failure in README and ticket. Is the ticket closeable? The AC checkbox says 'reaches kappa ≥ 0.7', implying NO. The body implies YES. Executor is stuck."],"severity":"minor","suggested_fix":"Split AC4 into two checkboxes: 'AC4a: `kappa.py` is committed, runs without error, and prints a kappa value recorded in the README with both rater/model identities.' 'AC4b [operator-attested]: kappa ≥ 0.7 (labels shipped as ground truth) OR kappa < 0.7 (README + ticket record the failed gate and downstream E/R stories are placed on hold).'","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add a brief positive rationale in the plan (one sentence in Step 4 or the Why section) explaining why dual-LLM raters with different models were chosen (e.g., cost/speed/availability) and acknowledge the limitation (shared-provider bias), so implementers can make an informed trade-off and future stories can plan for a human-spot-check if kappa passes narrowly.","cohort":["G6"],"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":["Plan: 'Rater A (primary): an LLM adjudicator … Rater B (independent): a second LLM adjudicator … a different model (e.g. a distinct Claude model id from Rater A)'","No 'Why LLM-only raters' rationale anywhere in the plan (the Why section addresses corpus need, not rater design)","The example ('a distinct Claude model id') suggests both raters may be from the same Claude model family"],"finding":"The plan specifies two independent LLM raters with different models for adjudication but provides no positive rationale for why this rater architecture was chosen over human-in-the-loop adjudication (even partially). Without a stated rationale, implementers have no basis for questioning whether LLM-vs-LLM kappa is measuring the right thing — particularly since LLMs from the same provider family may share training data and systematic biases, making their 'independence' structurally weaker than a human rater.","group_criteria":null,"group_id":null,"id":"f35e3214fa0f3135f","impact":0.0,"is_primary":null,"location":"What, Step 4 — Double-label; 'Rater A (primary)' and 'Rater B (independent)' descriptions","norm_id":"n709389981fb1c4c1","priority":0.0,"reason":"low-validity","scenarios":["Two Claude models (e.g. Sonnet and Opus) agree on labels due to shared RLHF priors, yielding high kappa without genuine independent judgment — the corpus is declared usable ground truth but is actually LLM-consensus, not real ground truth.","A downstream story (E2/E3/E6/R1/R7) builds on the adjudication corpus and later discovers labels are systematically biased toward LLM-friendly criteria, undermining the whole calibration effort."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"no","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a brief justification (or prior-art note) for the LLM-only rater design — either cite published evidence that LLM-LLM kappa at ≥ 0.7 is sufficient for downstream use, or specify a human spot-check on a sample of the double-labeled subset to anchor the LLM agreement to an external correctness signal.","cohort":["T1"],"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":["Plan Step 4: 'Two independent LLM raters adjudicate … Rater A (LLM, rubric A) … Rater B (independent LLM, rubric B, different model…)'","No mention of human rater involvement or of published literature on LLM-LLM IRR validity.","AC #4 gate: 'Cohen's kappa ≥ 0.7 → labels are declared usable ground truth' — the gate relies entirely on the LLM-LLM kappa value.","ABSENCE: no justification for why LLM-LLM kappa at ≥ 0.7 is sufficient to declare labels 'usable ground truth' when shared model biases may inflate agreement."],"finding":"The plan designates two LLM instances as the sole 'independent raters' for inter-rater reliability without justifying this choice against the established alternative of human raters (or a human+LLM hybrid). LLM-LLM kappa is a novel methodological pattern with a known validity concern: two models from the same provider and family share systematic biases, so their pairwise kappa can overstate true label reliability relative to a human-anchored baseline. The plan's kappa ≥ 0.7 gate may pass even when the labels are not trustworthy ground truth. No prior-art consideration of LLM IRR limitations or human-rater alternatives appears in the plan.","group_criteria":null,"group_id":null,"id":"f20546fd500ee9ff9","impact":0.0,"is_primary":null,"location":"Step 4 — 'Double-label and compute inter-rater reliability'; AC #4","norm_id":"n20c0f7021fb75e3c","priority":0.0,"reason":"low-validity","scenarios":["Both LLMs systematically agree on a class of findings (e.g. always marking T1/T8 findings TP) not because the label is correct but because both share the same training-induced bias — kappa hits 0.8, corpus is declared usable, downstream E/R stories train on biased labels.","An auditor later challenges the ground-truth corpora; the plan provides no human-anchored validation to fall back on."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"no","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E2"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The 'panel' responsible for double-labeling and adjudication is never identified; an executor cannot recruit labelers or begin the kappa step without knowing who constitutes the second (and any additional) rater(s).","group_criteria":null,"group_id":null,"id":"f07305e3f5e72a600","impact":0.0,"is_primary":null,"location":"What section ('panel-adjudicated') and AC4 ('>=50-finding double-labeled subset reaches kappa >= 0.7')","norm_id":"na1ceced49620c8bc","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Add a sentence such as: 'Panel: two human raters — the plan-review author and one independent reviewer (e.g. a second team member or the repo owner); the >=50-finding subset is assigned to both before either sees the other's labels.'","tier":"LLM","validity":0.1667,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The mechanism for producing the kappa double-labeled subset is entirely absent from the plan body — the What and Scope sections describe only single-pass panel adjudication, but AC #4 requires an independent second-rater labeling of >=50 findings; the plan provides no work step, rater identification, sampling protocol, or script for this.","group_criteria":null,"group_id":null,"id":"ff88e902f72348dc4","impact":0.0,"is_primary":null,"location":"Acceptance Criteria — AC #4; What section ('panel-adjudicated TP/FP'); Scope section","norm_id":"n802aa7a2d6a94e37","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.1667,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The kappa calculation protocol in AC#4 lacks a co-located decision rule: who the second rater is (human, LLM, or both), how the >=50-finding double-labeled subset is selected (random, stratified, adversarial), and which kappa formula (Cohen's, Fleiss's, weighted) is to be used are all unspecified.","group_criteria":null,"group_id":null,"id":"fa1acb9fa51598b3c","impact":0.0,"is_primary":null,"location":"AC#4 — 'inter-rater reliability on a >=50-finding double-labeled subset reaches kappa >= 0.7, recorded in the README'","norm_id":"n9fecf3887d9188b0","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.1667,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E1"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"AC #4 requires a >=50-finding double-labeled subset and a kappa >= 0.7 calculation, but the 'What' and 'Scope' sections describe no work step to produce this double-labeled subset — no mention of a second rater, labeling protocol, or tool — making AC #4 an orphan criterion with no corresponding described deliverable.","group_criteria":null,"group_id":null,"id":"f71e42c0cb8f7ad70","impact":0.0,"is_primary":null,"location":"Acceptance Criteria — AC #4; What section (panel-adjudicated description)","norm_id":"n9e346b5623bea4c9","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"In the 'What' section, after 'panel-adjudicated TP/FP', add: 'A randomly stratified subset of >=50 findings is independently labeled by two raters (e.g. primary author + one named reviewer); Cohen's kappa is computed via a committed script (e.g. docs/experiments/plan-review-gate/kappa.py) and recorded in the README.' Mirror this in Scope as a deliverable.","tier":"LLM","validity":0.1667,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The git-mining mechanism (git rev-list --objects --all + cat-file) has no pre-flight completeness probe, so a gc'd or pruned repo silently produces an incomplete outcome corpus that is then committed as 'frozen' ground truth — the re-verification step in AC #2 then passes against wrong labels.","group_criteria":null,"group_id":null,"id":"fa069593f0f56d44d","impact":0.0,"is_primary":null,"location":"What section: 'Re-derive the §5 event history from git objects across all refs of the tickets branch (git rev-list --objects --all + cat-file; the on-disk .tickets-tracker/ is compacted)'","norm_id":"n49518e7d8689b0bf","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"In the Scope / mining script design, add an explicit 'object availability check' step: run `git rev-list --count tickets` and `git cat-file --batch-check` on a sampled set of known ticket-edit commits; if any are missing, halt with an actionable error ('gc may have pruned objects; run git fetch --unshallow or restore from the ephemeral artifacts') rather than producing an incomplete corpus.","tier":"LLM","validity":0.1667,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The 'post-claim-edit class' column required in the outcome corpus (AC#1) is an enum whose value vocabulary is never defined anywhere in the plan or referenced artifacts. An executor producing the corpus has no closed set of valid class labels to use.","group_criteria":null,"group_id":null,"id":"f6a014336d198aabf","impact":0.0,"is_primary":null,"location":"AC#1 — 'post-claim-edit class' column; What section — 'labeled with post-claim-edit class'","norm_id":"nc4d4d72c4324da27","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Add a 'Schema' subsection to the What or Scope section listing the exact allowed values for post-claim-edit class, e.g.: `post_claim_edit_class ∈ {none, cosmetic, functional, structural, revert}` with a one-sentence definition of each.","tier":"LLM","validity":0.1667,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["T2"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan's git-mining method (git rev-list --objects --all + cat-file on the tickets branch) is an unverified assumption about the git repo's object availability. The plan acknowledges the on-disk .tickets-tracker/ is compacted and that ephemeral artifacts 'may' exist, but does not include a pre-corpus probe confirming that git objects across all refs actually retain enough history to reconstruct the 16/505 edits and 3-miss defect-class events. If the repo has been gc'd, pruned, or force-pushed, the reconstruction silently produces incomplete or incorrect counts — and the corpus is committed with wrong labels.","group_criteria":null,"group_id":null,"id":"faa68c33f624967e7","impact":0.0,"is_primary":null,"location":"What section: 'Re-derive the §5 event history from git objects across all refs of the tickets branch (git rev-list --objects --all + cat-file; the on-disk .tickets-tracker/ is compacted)'","norm_id":"n8dffccab8fa6bce4","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"Insert an AC-0 or 'Definition of Ready' step: run `git rev-list --objects --all -- .tickets-tracker/ | wc -l` and compare against an expected lower bound (derived from the known ~527 ticket count); if the count falls below threshold, the mining approach is declared infeasible and the plan documents an alternative source (e.g., the ephemeral /tmp/ snapshot or a manually reconstructed sample) before proceeding.","tier":"LLM","validity":0.1667,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Expose the object-availability floor, kappa threshold, and sample-size floors as CLI arguments (with the current values as defaults) in `mine_outcome_corpus.py` and `kappa.py`, and document the defaults in the README so the values are configurable without source edits.","cohort":["T5b","T5e","T9"],"criteria":["T5e"],"decision":"advisory","drop_reason":"novelty","evidence":["'if the recovered reviewed-ticket count falls below a floor of 500... it halts'","'Floor for the AC: ≥280 surfaced and ≥90 dropped'","'kappa ≥ 0.7 → labels are declared usable ground truth'","ABSENCE: no mention of these values being CLI args (only --dry-run and --verify-s5 are named)."],"finding":"Key research thresholds (object-availability floor=500, kappa gate=0.7, sample floors ≥280 surfaced/≥90 dropped) are specified as hardcoded constants with no CLI-argument or config-file override path. These are experiment parameters explicitly expected to evolve (e.g. if the ticket population grows or the kappa target is revised for a different corpus).","group_criteria":null,"group_id":null,"id":"fea30ac342b3eef39","impact":0.0,"is_primary":null,"location":"Step 1 (floor 500), Step 3 (≥280/≥90), Step 5 (kappa ≥ 0.7) / AC lines 1, 3, 4","norm_id":"n1a5395243a724109","priority":0.0,"reason":"default-advisory","scenarios":["The ticket corpus grows to 700; the floor of 500 becomes misleading but requires a code edit to change rather than a CLI flag.","A follow-on experiment needs kappa ≥ 0.8; the researcher must edit kappa.py source rather than passing --kappa-threshold 0.8."],"severity":"none","suggested_fix":"Add `--min-ticket-floor N` (default 500) to `mine_outcome_corpus.py`, `--kappa-threshold K` (default 0.7) to `kappa.py`, and `--min-surfaced / --min-dropped` to the corpus sampler, matching the current defaults to the plan's hardcoded values.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Consider whether the outcome corpus (steps 1-2, unblocking E2/E3/E6) and the adjudication corpus + kappa gate (steps 3-5, unblocking R1/R7) are independently valuable enough to split into two child tickets, or explicitly document why they must ship together.","cohort":["E5","G5"],"criteria":["G5"],"decision":"advisory","drop_reason":"novelty","evidence":["Steps 1-2 produce `outcome_corpus.jsonl` and serve 'E2/E3/E6'","Steps 3-5 produce `adjudication_corpus.jsonl` + kappa and serve 'R1/R7'","The plan itself names both consumer groups: 'finding-level TP/FP labels needed by E2/E3/E6 and R1/R7'","Each artifact could be committed and consumed independently — releasing only the outcome corpus would unblock E2/E3/E6 while R1/R7 work proceeds in parallel"],"finding":"The ticket bundles two independently-releasable artifacts — the outcome corpus (unblocking E2/E3/E6) and the finding-adjudication corpus + kappa gate (unblocking R1/R7) — each serving a distinct downstream consumer, potentially warranting separate child stories.","group_criteria":null,"group_id":null,"id":"f3b3510a96bae0692","impact":0.0,"is_primary":null,"location":"## What (steps 1-2 vs. steps 3-5) and ## Scope","norm_id":"nef302171a7784f1e","priority":0.0,"reason":"default-advisory","scenarios":["If the kappa gate fails (kappa < 0.7), the outcome corpus work is already complete and usable, but both are held in one ticket and must be re-opened/re-worked together.","If the adjudication corpus sampling reveals a population too small (fewer than 90 dropped findings available), the outcome corpus — which is independently useful — is stalled."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"b35a6654290d8ae1","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":226.9,"llm_calls":30,"llm_ms":847256.3,"total_ms":847623.4,"verify_requests":28},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"e95e-1543-cac7-47b9","ticket_type":"story","verdict":"BLOCK","verified_at_sha":"72bb4965e3781259f2b9791c8d3c67c23c79e93d"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784157984969029001,"uuid":"cff6d566-9595-4927-a043-58ea304118fd"}