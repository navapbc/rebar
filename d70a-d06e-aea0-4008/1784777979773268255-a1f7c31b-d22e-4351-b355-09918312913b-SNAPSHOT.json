5519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"572fbf8b5a2fd3475544ce95b923d6b523508ea6e06cb408415f68487faf2b99","event_uuid":"da741d03-a5bc-4283-8e38-883ae7f535df","position":{"commit_sha":"04d7f6337177cf031babefbc25728ec213e0e595","position":"1784777589501238001-da741d03-a5bc-4283-8e38-883ae7f535df"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"59cba68c44b63275c14d3f566958940f01951e34d75ea3a93b8ac2e611f71f5c","event_uuid":"5227062d-008c-4aa8-a86e-bb6ad1541da6","position":{"commit_sha":"40c3faaaa68475c522b8fb19dca6fa0ae09a7b54","position":"1784777592270861001-5227062d-008c-4aa8-a86e-bb6ad1541da6"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"5ed7268d8577c45bb4c65e52927379fb502e2a860314a160203707f5c5b14afe","event_uuid":"b5098767-4e4b-4296-81ff-19d8c0646f69","position":{"commit_sha":"faa8ef49b8cec61a9d143e9a580c0627cbb62557","position":"1784777979773268254-b5098767-4e4b-4296-81ff-19d8c0646f69"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-218_agent","claim_remote_session":null,"claimed_session":"b07d4e18-e059-4f55-821a-9c0f549cbca9","comments":[],"created_at":1784776559438090001,"creation_channel":"cli","deps":[],"description":"## Problem\nUnder concurrent multi-agent work, review-plan completes its (billed) LLM review but fails to persist the signature, raising PlanReviewGenerationChanged with before==after head sha. Reproduces whenever ANY other ticket in the store is written (comment/claim/transition) during the review window. Makes require_plan_review_for_claim unreliable in exactly the parallel epic/child decomposition rebar promotes.\n\n## Root cause (confirmed by reading)\ngeneration.sign_manifest aborts when fresh != initial_generation (generation.py:133). PlanReviewGeneration is a frozen dataclass whose equality compares ALL fields, including (a) ticket_store_revision (the STORE-WIDE tracker HEAD sha) and (b) relation_snapshot, whose type PlanRelationSnapshot (relation_snapshot.py:56) compares ticket_states_by_id — the full state of EVERY ticket in the store. initial_generation is captured at review START; fresh at sign time (minutes later). Any commit to any ticket in the window changes both fields, forcing PlanReviewGenerationChanged even when before==after within the attempt.\n\n## Why it is a defect (not fail-closed by design)\nThe SIGNED manifest binds only own material + deps (file hashes) + related_material pins; the claim-time re-check compute_validity re-validates only those same subject/related scopes. The store-wide sign-time equality is therefore stricter than both what gets signed and what gets re-validated — it invalidates on differences that produce no change in the signed artifact.\n\n## Fix\nScope the generation equality to the subject's own material + direct related material (+ phase/floor) — the same scope the manifest binds. Exclude ticket_store_revision and ticket_states_by_id from PlanReviewGeneration identity (e.g. field(compare=False) or a scoped __eq__). Keep the within-attempt before/after head fence (it correctly guards a concurrent COMMIT during collection) but stop comparing the minutes-old store-wide baseline.\n\n## Acceptance criteria\n- Signing SUCCEEDS when an UNRELATED ticket is committed to the tracker between review-start (initial_generation) and sign time, provided the subject's own material and its direct related material are unchanged.\n- Signing still FAILS (PlanReviewGenerationChanged) when the SUBJECT's own material OR a direct child/prerequisite's material changed during the window.\n- The within-attempt before/after head fence is preserved.\n- A test simulates an unrelated concurrent tracker write during the window and asserts a signature is persisted; the pre-fix code path would raise PlanReviewGenerationChanged.\n\n## Verification\npytest concurrency test: unrelated write during window -> signed; subject/related write during window -> PlanReviewGenerationChanged.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/llm/plan_review/generation.py","reason":"scope PlanReviewGeneration equality to subject+related material, not store-wide"},{"path":"tests/unit/test_plan_review_generation_scope.py","reason":"RED: unrelated store churn must not abort signing"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","56c0-1d2f-f39c-4ac1"]],"parent_id":"","parent_status_uuid":"048976cd-bb72-4f36-a4d6-b95e78be7642","plan_review_phase":"execution","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"d70a-d06e-aea0-4008","ticket_type":"bug","title":"plan-review signing spuriously fails (PlanReviewGenerationChanged) under unrelated concurrent tracker writes","verify_commands":[]},"source_event_uuids":["d8401e5e-025b-4c68-9ea8-058a4e010431","4e2609b9-772b-45e5-9255-8473eef039fb","048976cd-bb72-4f36-a4d6-b95e78be7642","da741d03-a5bc-4283-8e38-883ae7f535df","5227062d-008c-4aa8-a86e-bb6ad1541da6","b5098767-4e4b-4296-81ff-19d8c0646f69"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784777979773268255,"uuid":"a1f7c31b-d22e-4351-b355-09918312913b"}