# syntax=docker/dockerfile:1
# ---------------------------------------------------------------------------
# rebar auto-lander image (epic f1fa / story S5).
#
# Builds the serial auto-lander loop (infra/autolander/loop.py): a single-instance
# daemon that polls Gerrit for the front submittable Autosubmit+1 change/chain and
# lands it (rebase-on-behalf + ancestor-atomic submit), writing a heartbeat + a
# read-only status endpoint. The build context is the REPO ROOT (see
# docker-compose.yml: build.context: ../..), so the whole package is available to
# `pip install .` AND the infra/autolander/ package is on the image.
#
# Unlike Dockerfile.reviewbot this image does NOT install the security scanners
# (gitleaks/semgrep) — the auto-lander never runs the code-review gate; it only reads
# Gerrit vote/label/submittability state and submits. Keeping the scanners out makes
# the image lean and the build fast.
#
# .dockerignore NOTE: the build context is the repo root, so the repo-root
# .dockerignore is what Docker honors (it already excludes .git, .venv, the ephemeral
# infra/compose/.env, __pycache__, etc.).
#
# python:3.12-slim is multi-arch and resolves to arm64 on the t4g (Graviton) box.
# ---------------------------------------------------------------------------
FROM python:3.12-slim

# Keep Python lean + predictable in a container.
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# git is needed at runtime: rebar's engine shells out to git for the event store.
# curl + ca-certificates: TLS trust for the HTTPS Gerrit REST calls the loop makes.
RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy the whole repo (the build context is the repo root) and install the package
# with the agents extra (the rebar.llm runtime + shared deps the loop links against).
COPY . /app
RUN pip install ".[agents]"

# The auto-lander package lives under infra/autolander/ (NOT inside the installed
# `rebar` package), so put infra/ on PYTHONPATH to make `import autolander` resolve.
ENV PYTHONPATH=/app/infra

# The read-only status endpoint the `land` command reads (S5). Published on host
# loopback for the HOST nginx /autolander/status proxy; single-sourced from the .env
# (AUTOLANDER_PORT, default 8080). Container port is fixed at 8080 (loop.py status_port).
ENV AUTOLANDER_PORT=8080
EXPOSE 8080

# ---------------------------------------------------------------------------
# HEALTHCHECK (S5d) — heartbeat-file liveness, NOT a Gerrit probe. The loop writes the
# current epoch seconds to <state_dir>/heartbeat once per tick (POLL_S=15s). Report
# UNHEALTHY when that file is missing or older than 90s (6 ticks), so the autoheal
# sidecar (docker-compose.yml) restarts a wedged/deadlocked loop. Deliberately does NOT
# reach Gerrit: a Gerrit outage must not make the lander look unhealthy (it should keep
# heartbeating and simply have nothing to land). start-period=60s gives the loop time to
# write its first heartbeat before failures count.
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=2 \
    CMD python -c "from autolander.loop import healthcheck_main; healthcheck_main()"

# ---------------------------------------------------------------------------
# Tickets-store entrypoint (bug dc33 / puny-earthy-wolf).
#
# The auto-lander annotates the rebar ticket named by a landed commit's `rebar-ticket:`
# trailer (loop.py: close_ticket_via_rebar). That write needs a writable, PUSHABLE rebar
# tickets store in the container — without one every annotation fails "ticket system not
# initialized" and the bot pages. Mirror the review-bot's data-capture entrypoint:
#   1. Configure a PER-URL (not --global) git credential helper for the tickets remote that
#      echoes username=x-access-token / password=$REVIEWBOT_TICKETS_PAT — REUSING the review-bot
#      PAT (already in the shared .env), so the fine-grained contents:write PAT never lands on
#      disk or inside a remote URL.
#   2. Materialize a PERSISTENT tickets worktree ONCE (a clone of the `tickets` branch onto the
#      mounted volume) so annotations auto-push (REBAR_SYNC_PUSH=always) instead of living in an
#      ephemeral dir.
#   3. Converge the (possibly freshly-cloned) worktree into a writable rebar store: repo-local
#      git identity + rebar's idempotent ensure-registry (the `.env-id` store marker gate).
# Everything is a no-op when REVIEWBOT_TICKETS_PAT is unset (the container still boots + lands;
# only the ticket annotation is inert). The live clone/push is a DEPLOY-STEP CANARY (needs the
# real SSM PAT + a running container), so it is NOT exercised by the in-repo unit tests. Never
# blocks boot.
ENV AUTOLANDER_TICKETS_DIR=/var/gerrit/site/autolander-tickets \
    AUTOLANDER_TICKETS_URL=https://github.com/navapbc/rebar.git
RUN set -eux; \
    { \
      echo '#!/bin/sh'; \
      echo 'set -e'; \
      echo 'if [ -n "${REVIEWBOT_TICKETS_PAT:-}" ]; then'; \
      echo '  git config --global "credential.${AUTOLANDER_TICKETS_URL}.helper" \'; \
      echo "    '!f() { echo username=x-access-token; echo \"password=\$REVIEWBOT_TICKETS_PAT\"; }; f'"; \
      echo '  git config --global "credential.${AUTOLANDER_TICKETS_URL}.useHttpPath" false'; \
      echo '  if [ ! -d "${AUTOLANDER_TICKETS_DIR}/.git" ]; then'; \
      echo '    git clone --single-branch --branch tickets "${AUTOLANDER_TICKETS_URL}" "${AUTOLANDER_TICKETS_DIR}" || \'; \
      echo '      echo "autolander: tickets worktree clone deferred (deploy canary)" >&2'; \
      echo '  fi'; \
      echo '  # Self-heal a BROKEN empty clone (bug dc33): a boot clone can fail silently and'; \
      echo '  # leave a repo with 0 commits that never recovers. Re-fetch it (best-effort).'; \
      echo '  if [ -d "${AUTOLANDER_TICKETS_DIR}/.git" ] && \'; \
      echo '     [ "$(git -C "${AUTOLANDER_TICKETS_DIR}" rev-list --count HEAD 2>/dev/null || echo 0)" = "0" ]; then'; \
      echo '    git -C "${AUTOLANDER_TICKETS_DIR}" fetch origin tickets && \'; \
      echo '      git -C "${AUTOLANDER_TICKETS_DIR}" reset --hard FETCH_HEAD || \'; \
      echo '      echo "autolander: tickets fetch deferred" >&2'; \
      echo '  fi'; \
      echo 'fi'; \
      echo '# Converge the (possibly freshly-cloned) tickets worktree into a writable rebar'; \
      echo '# store: repo-local git identity + the `.env-id` store marker via run_ensures.'; \
      echo '# Idempotent — a no-op when the clone is deferred or already converged; never boots-blocks.'; \
      echo 'if [ -d "${AUTOLANDER_TICKETS_DIR}/.git" ]; then'; \
      echo '  git -C "${AUTOLANDER_TICKETS_DIR}" config user.email joeoakhart+bot@navapbc.com || :'; \
      echo '  git -C "${AUTOLANDER_TICKETS_DIR}" config user.name RebarBotNava || :'; \
      echo "  python -c \"import sys; from rebar._store.ensures import run_ensures; [print(f'autolander-ensure: {o.id}: {o.status}', file=sys.stderr) for o in run_ensures(sys.argv[1])]\" \"\${AUTOLANDER_TICKETS_DIR}\" || \\"; \
      echo '    echo "autolander: tickets store ensure deferred (see logs)" >&2'; \
      echo 'fi'; \
      echo 'exec "$@"'; \
    } > /usr/local/bin/autolander-entrypoint.sh; \
    chmod +x /usr/local/bin/autolander-entrypoint.sh

# Run the serial auto-lander loop (through the tickets-store entrypoint above).
ENTRYPOINT ["/usr/local/bin/autolander-entrypoint.sh"]
CMD ["python", "-m", "autolander.loop"]
