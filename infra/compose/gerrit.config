# ---------------------------------------------------------------------------
# Gerrit site config — etc/gerrit.config (epic d251 / story S2).
#
# Seeded into the Gerrit site etc dir at /var/gerrit/etc/gerrit.config (the EBS-backed
# host path /var/gerrit/site/etc is bind-mounted to the container's /var/gerrit/etc;
# see docker-compose.yml). The official image auto-inits an empty site and reads this
# on boot. PoC posture: a single small arm64 box (t4g.large), nginx-terminated TLS in
# front, NoteDb (no ReviewDb in 3.x).
# ---------------------------------------------------------------------------

[gerrit]
	# Public origin — nginx terminates TLS and proxies to this Gerrit. Must match the
	# compose CANONICAL_WEB_URL env and the nginx server_name.
	canonicalWebUrl = https://rebar.solutions.navateam.com/
	# Where the git repos live, RELATIVE to the site dir (/var/gerrit/git). REQUIRED:
	# Gerrit dies on boot with "gerrit.basePath must be configured" if absent. We set
	# it explicitly (rather than relying on `init` to inject it) so re-seeding this
	# file from the repo on every compose-up cannot clobber it.
	basePath = git
	# Stable server identity used in NoteDb metadata. Pinned so it does not change
	# across container recreation (a regenerated serverId orphans prior NoteDb refs).
	serverId = fc71b410-f5b3-4446-8e2c-e56c4676521b

[httpd]
	# proxy-https: Gerrit listens plain HTTP on 8080 but KNOWS it sits behind an
	# HTTPS-terminating reverse proxy (nginx), so it builds https:// URLs and trusts
	# X-Forwarded-* headers. The container publishes 8080 to the host loopback.
	listenUrl = proxy-https://*:8080/
	# Thread cap — keep the HTTP worker pool small on the little box.
	maxThreads = 8
	# Emit an HTTP request log (logs/httpd_log) so the encoded-slash (%2F)
	# round-trip through nginx is observable end-to-end.
	requestLog = true

[sshd]
	# Gerrit's own SSH daemon (git-over-SSH), exposed directly on 29418 (NOT system
	# sshd, which is absent — admin is via SSM).
	listenAddress = *:29418
	# Thread caps to avoid OOM on the small box: cap total SSHD threads, and in
	# particular cap the per-connection BATCH threads (parallel clone/fetch workers)
	# at 2 so a multi-ref clone can't fan out and exhaust the 8 GiB box.
	threads = 4
	batchThreads = 2

[container]
	# JVM max heap. Sized for the 8 GiB box leaving room for the OS, the off-heap
	# git mmap budget (see [core] packedGitLimit), and the review-bot container.
	heapLimit = 2g
	# Explicit JDK home. REQUIRED: gerrit.sh auto-detects JAVA_HOME by walking up
	# from `java` looking for lib/tools.jar, which modern JDKs (9+) do NOT ship — so
	# the loop never terminates and gerrit.sh spins forever (`dirname .` -> `.`) and
	# never launches the JVM. Setting javaHome makes gerrit.sh use it directly. The
	# entrypoint's `init` writes this on a FRESH site; we pin it here too so re-seeding
	# this file from the repo cannot clobber it and re-trigger the spin.
	javaHome = /usr/lib/jvm/jre-21-openjdk
	# JVM module-access flags Gerrit needs on JDK 21 (the entrypoint adds these on a
	# fresh init; pinned here so a re-seed preserves them).
	javaOptions = -Djava.security.egd=file:/dev/./urandom
	javaOptions = --add-opens java.base/java.net=ALL-UNNAMED
	javaOptions = --add-opens java.base/java.lang.invoke=ALL-UNNAMED

[core]
	# OFF-HEAP mmap budget for packed git objects. This is DISTINCT from the 2g JVM
	# heap above: packedGitLimit caps the memory git uses to mmap packfiles, which
	# lives OUTSIDE the JVM heap. Sized against total box RAM (not the heap) — 1g of
	# mmap on top of the 2g heap stays comfortably within 8 GiB.
	packedGitLimit = 1g

[auth]
	# PoC ONLY: anyone can "become" any account (no real IdP). This enables headless
	# admin/bot bootstrap (creating the admin + the review-bot service account, SSH
	# keys, etc.) without an OAuth/LDAP provider. S3/S4a may refine to a real auth
	# type (OAuth/HTTP) once the bootstrap is done — do NOT leave this on a box that
	# holds anything sensitive.
	type = DEVELOPMENT_BECOME_ANY_ACCOUNT

[index]
	# Lucene is the on-box index (no external Elasticsearch). NoteDb is the default
	# and ONLY metadata store in Gerrit 3.x — there is no ReviewDb to configure.
	type = lucene

[receive]
	# Signed-push verification off for the PoC (no push-cert keyring provisioned).
	enableSignedPush = false
