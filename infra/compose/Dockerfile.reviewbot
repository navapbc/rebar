# syntax=docker/dockerfile:1
# ---------------------------------------------------------------------------
# rebar review-bot image (epic d251 / story S2).
#
# Builds the FastAPI webhook receiver (src/rebar/review_bot/app.py). The build
# context is the REPO ROOT (see docker-compose.yml: build.context: ../..), so the
# whole package is available to `pip install .`.
#
# .dockerignore NOTE: there is no infra/compose/.dockerignore here because the build
# context is the repo root, so a context-root `.dockerignore` (at the repo top) is
# what Docker honors. To keep the build context lean and avoid leaking secrets, add
# (or confirm) these entries in the REPO-ROOT .dockerignore:
#     .git
#     .venv
#     .tickets-tracker
#     infra/compose/.env        <- the ephemeral SSM-sourced secrets file (0600)
#     **/__pycache__
#     dist/  build/  *.egg-info
# (The .env is also git-ignored; excluding it from the build context as well keeps
# secrets out of image layers.)
#
# python:3.12-slim is multi-arch and resolves to arm64 on the t4g (Graviton) box.
# ---------------------------------------------------------------------------
FROM python:3.12-slim

# Keep Python lean + predictable in a container.
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# git is needed at runtime: rebar's engine shells out to git for the event store.
# curl + ca-certificates: fetch the gitleaks release binary below.
RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Security scanners for the code-review gate's WS5 fail-CLOSED detectors (epic b744 / WS5).
# engine_b resolves these off PATH (shutil.which); ABSENT -> abstain(no_tool) -> the gate
# fail-closes a coverage-gap BLOCK on EVERY change. Installed BEFORE `COPY . /app` so the
# (heavy) scanner layers cache across code rebuilds.
#   - gitleaks -> the `secret-detection` criterion (secrets). A standalone Go binary; the
#     latest release is resolved dynamically (arch-aware) to avoid a pinned-version 404.
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      arm64) gl_arch=arm64 ;; \
      amd64) gl_arch=x64 ;; \
      *) echo "unsupported arch for gitleaks: $arch" >&2; exit 1 ;; \
    esac; \
    ver="$(curl -fsSL https://api.github.com/repos/gitleaks/gitleaks/releases/latest \
      | grep -oE '"tag_name":[[:space:]]*"v[^"]+"' | head -1 | sed -E 's/.*"v([^"]+)".*/\1/')"; \
    test -n "$ver"; \
    curl -fsSL "https://github.com/gitleaks/gitleaks/releases/download/v${ver}/gitleaks_${ver}_linux_${gl_arch}.tar.gz" \
      -o /tmp/gitleaks.tgz; \
    tar -xzf /tmp/gitleaks.tgz -C /usr/local/bin gitleaks; \
    rm -f /tmp/gitleaks.tgz; \
    gitleaks version
#   - semgrep -> the `high-critical-security` criterion. engine_b prefers `opengrep` and falls
#     back to `semgrep` (a CLI-compatible fork; the bundled security_*.yaml rules are
#     semgrep-format). Installed in an ISOLATED venv + symlinked onto PATH so semgrep's deps
#     never conflict with rebar's [agents] runtime.
RUN python -m venv /opt/semgrep \
    && /opt/semgrep/bin/pip install --no-cache-dir semgrep \
    && ln -s /opt/semgrep/bin/semgrep /usr/local/bin/semgrep \
    && semgrep --version
# semgrep runs OFFLINE inside the gate over rebar's local rules: no telemetry, no network
# version check (both would add latency / a phone-home the gate must not depend on).
ENV SEMGREP_SEND_METRICS=off \
    SEMGREP_ENABLE_VERSION_CHECK=0

WORKDIR /app

# Copy the whole repo (the build context is the repo root) and install the package
# with the agents + reviewbot extras:
#   - reviewbot -> fastapi + uvicorn[standard] (the ASGI server)
#   - agents    -> the rebar.llm runtime the review kernel uses (S4b will exercise it)
COPY . /app
RUN pip install ".[agents,reviewbot]"

# Install the tickets-store ensure helper (bug desirous-judicial-hogget / d220) onto PATH
# so the entrypoint can converge a freshly-cloned single-branch `tickets` worktree into a
# writable rebar store on every boot. A fresh single-branch clone lacks a git identity and
# the git-ignored `.env-id` store marker, so writes would fail "ticket system not
# initialized" and emit_code_review_artifact would silently swallow it. Copied from /app.
RUN install -m 0755 /app/infra/scripts/reviewbot-ensure-tickets.sh /usr/local/bin/reviewbot-ensure-tickets.sh

# The receiver port is single-sourced from the .env (REVIEW_BOT_PORT). The default
# matches src/rebar/review_bot/app.py DEFAULT_PORT and the uvicorn --port below.
ENV REVIEW_BOT_PORT=8000
EXPOSE 8000

# ---------------------------------------------------------------------------
# Data-capture entrypoint (epic foliaged-merry-collie / story limestone-unethical-zebrafinch).
#
# Before the ASGI app starts, wire the reviewbot to PUSH the code_review artifact ticket events
# it emits to the shared tickets branch:
#   1. Configure a PER-URL (not --global) git credential helper for the tickets remote that echoes
#      username=x-access-token / password=$REVIEWBOT_TICKETS_PAT — so the fine-grained
#      contents:write PAT never lands on disk or inside a remote URL.
#   2. Materialize a PERSISTENT tickets worktree ONCE (a clone of the `tickets` branch onto the
#      mounted volume) so artifact writes accumulate + auto-push (REBAR_SYNC_PUSH=always) instead
#      of living in an ephemeral /tmp dir.
# Everything is a no-op when REVIEWBOT_TICKETS_PAT is unset (the container still boots + reviews;
# only the artifact push is inert). The live push is a DEPLOY-STEP CANARY — it needs the real SSM
# PAT + a running container, so it is NOT exercised by the in-repo unit tests.
ENV REVIEWBOT_TICKETS_DIR=/var/gerrit/site/reviewbot-tickets \
    REVIEWBOT_TICKETS_URL=https://github.com/navapbc/rebar.git
RUN set -eux; \
    { \
      echo '#!/bin/sh'; \
      echo 'set -e'; \
      echo 'if [ -n "${REVIEWBOT_TICKETS_PAT:-}" ]; then'; \
      echo '  git config --global "credential.${REVIEWBOT_TICKETS_URL}.helper" \'; \
      echo "    '!f() { echo username=x-access-token; echo \"password=\$REVIEWBOT_TICKETS_PAT\"; }; f'"; \
      echo '  git config --global "credential.${REVIEWBOT_TICKETS_URL}.useHttpPath" false'; \
      echo '  if [ ! -d "${REVIEWBOT_TICKETS_DIR}/.git" ]; then'; \
      echo '    git clone --single-branch --branch tickets "${REVIEWBOT_TICKETS_URL}" "${REVIEWBOT_TICKETS_DIR}" || \'; \
      echo '      echo "reviewbot: tickets worktree clone deferred (deploy canary)" >&2'; \
      echo '  fi'; \
      echo 'fi'; \
      echo '# Converge the (possibly freshly-cloned) tickets worktree into a writable'; \
      echo '# rebar store: repo-local git identity + the `.env-id` store marker. Idempotent'; \
      echo '# — a no-op when the clone is deferred or already converged; never blocks boot.'; \
      echo 'reviewbot-ensure-tickets.sh || \'; \
      echo '  echo "reviewbot: tickets store ensure deferred (see logs)" >&2'; \
      echo 'exec "$@"'; \
    } > /usr/local/bin/reviewbot-entrypoint.sh; \
    chmod +x /usr/local/bin/reviewbot-entrypoint.sh

# Run the ASGI app. Host 0.0.0.0 so the published container port is reachable from
# the host's nginx. Port is fixed to 8000 inside the container; the host-side port
# mapping (and nginx upstream) is what REVIEW_BOT_PORT drives in docker-compose.yml.
ENTRYPOINT ["/usr/local/bin/reviewbot-entrypoint.sh"]
CMD ["uvicorn", "rebar.review_bot.app:app", "--host", "0.0.0.0", "--port", "8000"]
