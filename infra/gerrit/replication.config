# ---------------------------------------------------------------------------
# replication.config — Gerrit `replication` plugin config for one-way push to
# GitHub. Story S5 (Gerrit -> GitHub replication).
#
# This file is pushed to the Gerrit site at `etc/replication.config` (NOT to a
# project's refs/meta/config) and is read by the bundled `replication` plugin.
# Apply it with infra/gerrit/setup-replication.sh.
#
# CONTRACT (one-way door — see docs/adr/0010-gerrit-github-replication.md):
#   - Gerrit is the SOLE writer of github.com/navapbc/rebar; GitHub history is
#     append-only / fast-forward only.
#
# Why each knob is set the way it is:
#   - push refspecs have NO leading '+'  -> NON-FORCE. A non-fast-forward update
#     (rewritten/diverged history) is REJECTED rather than clobbering GitHub. This
#     is the core safety property.
#   - projects = rebar is REQUIRED. The `url` hardcodes ONE repo and contains no
#     ${name} placeholder, so without an explicit `projects` filter this remote
#     would match EVERY Gerrit project and try to push all of them to the single
#     GitHub repo. Pinning projects = rebar scopes the remote to just our project.
#   - mirror = false -> NON-destructive. A mirror would PRUNE refs on GitHub that
#     are absent in Gerrit (a destructive `git push --mirror`); we never want that.
#   - replicatePermissions = false -> refs/meta/config is NEVER pushed, so Gerrit
#     ACLs, group files, and (critically) the webhook URL token embedded in
#     refs/meta/config do NOT leak to GitHub. ADR-0014 explicitly DEPENDS on this
#     staying false (the inbound-webhook token's "not replicated off-box"
#     property). Do not flip this to true.
#   - explicit refspecs (refs/heads/main + refs/tags/* + refs/changes/*). The
#     published main branch, release tags, AND per-patchset change refs reach
#     GitHub; META refs (refs/meta/*) are STILL never pushed (replicatePermissions
#     = false, below). refs/changes/* was added for CI (epic 1fa8 / ADR-0021): the
#     gerrit-to-platform GitHub Actions run fetches the exact patchset via
#     checkout-gerrit-change-action, which reads GERRIT_REFSPEC from this mirror
#     (and falls back to fetching straight from Gerrit on replication lag). The
#     refspec is deliberately scoped to refs/changes/* — NOT a wildcard refs/*,
#     which would also replicate refs/meta/config and leak the webhook token.
#   - timeout / replicationMaxRetries -> FINITE retries; a persistently failing
#     push gives up instead of retrying forever (the failure is then alarmed, S5
#     monitoring_s5.tf, by grepping the replication_log for max-retry/REJECTED).
#   - replication.eventsDirectory is set HERE (in replication.config), NOT in
#     gerrit.config: the plugin only honours eventsDirectory from its OWN config
#     file and IGNORES it in gerrit.config. A persisted events queue makes the
#     replication crash-safe (queued pushes survive a Gerrit restart).
#
# The SSH identity used to push (deploy key + known_hosts + ssh config) is
# materialised by infra/gerrit/materialize-deploy-key.sh into the gerrit user's
# ~/.ssh (/var/gerrit/.ssh in the container). The plugin shells out to `git push`
# which uses that SSH config to authenticate as the GitHub deploy key.
# ---------------------------------------------------------------------------

[gerrit]
	autoReload = true
	replicateOnStartup = false
[remote "github"]
	url = git@github.com:navapbc/rebar.git
	projects = rebar
	push = refs/heads/main:refs/heads/main
	push = refs/tags/*:refs/tags/*
	# CI (epic 1fa8 / ADR-0021): mirror per-patchset change refs so GitHub Actions can
	# fetch the change under test. NON-force (no leading '+'); scoped to refs/changes/*
	# so refs/meta/* is never included. Gerrit rewrites patchsets rarely; the
	# checkout-gerrit-change-action gerrit-url fallback covers replication lag/misses.
	push = refs/changes/*:refs/changes/*
	# Feature-branch CI (epic 88ab / S2-S3): gerrit-to-platform dispatches the `verify`
	# workflow via GitHub `workflow_dispatch` with ref = refs/heads/{GERRIT_BRANCH}
	# (g2p helpers.py; there is NO branch filter — dispatch is branch-agnostic). But
	# workflow_dispatch REQUIRES that ref to EXIST on the GitHub mirror to resolve the
	# workflow file, so WITHOUT this line a change targeting refs/heads/feature/* would
	# dispatch against a non-existent GitHub ref -> 422/no-op -> the feature-branch story
	# change gets LLM-Review but NEVER Verified, and can never satisfy the two-vote gate
	# (verified live on Gerrit 3.14.1: change 198 on feature/s3-ci got LLM-Review+1 and
	# NO CI run). Replicating feature/* makes the dispatch ref resolve so CI runs. The
	# refspec is scoped to feature/* (NOT a wildcard refs/heads/* or refs/*) so no other
	# branches — and never refs/meta/* — are exposed. Feature branches on the mirror are
	# TRANSIENT (deleted after the merge-back lands); mirror = false below means their
	# deletion in Gerrit does NOT auto-prune them on GitHub — the S6 stale-branch inventory
	# + the merge-back cleanup handle GitHub-side feature-branch teardown.
	push = refs/heads/feature/*:refs/heads/feature/*
	mirror = false
	replicatePermissions = false
	timeout = 60
	replicationMaxRetries = 3
[replication]
	eventsDirectory = data/replication
