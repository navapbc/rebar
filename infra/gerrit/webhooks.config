# ---------------------------------------------------------------------------
# webhooks.config — TEMPLATE for the Gerrit `webhooks` plugin remote config.
# Story S4a (review-bot identity + event plumbing).
#
# THIS IS A COMMITTED TEMPLATE — it carries NO real secret. The literal
# `__BOT_TOKEN__` placeholder below is substituted with the bot's HTTP token
# (read from SSM `/rebar/prod/gerrit-bot-token`) by `service-user.sh`, which then
# pushes the rendered file to the rebar project's `refs/meta/config` ref. That
# ref is the ONLY place the `webhooks` plugin reads remote config from — it does
# NOT read this file from the working tree or the site dir.
#
# The `webhooks` plugin has NO HMAC request signing, so the URL-embedded token is
# only a SECONDARY, bounded-exposure control. The PRIMARY inbound control is that
# webhook delivery is INTERNAL: the URL targets the review-bot container DIRECTLY
# over the private docker compose network (`http://review-bot:8000/webhook`), so a
# webhook never traverses the public internet/nginx at all. The receiver's host
# port is loopback-bound (127.0.0.1:8000) and port 8000 is NOT open in the security
# group, so the receiver is unreachable from the internet except via nginx `/review/`
# (which S4b's receiver gates on the token). See ADR-0014.
# ---------------------------------------------------------------------------
[remote "review-bot"]
	# Internal compose-network address (gerrit container -> review-bot container).
	url = http://review-bot:8000/webhook?token=__BOT_TOKEN__
	event = patchset-created
	connectionTimeout = 3000
	maxTries = 3
	retryInterval = 5000
	# Plain HTTP on the trusted private network; no TLS to verify on the internal hop.
	sslVerify = false
