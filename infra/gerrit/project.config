# rebar project refs/meta/config (epic d251 / story S3).
#
# Pushed to refs/meta/config of the `rebar` project by setup-project.sh. Declarative:
# the whole file is the desired state of the project's access + label + submit rules.
#
# THE GATE (integrity rule): a change is submittable ONLY when the deterministic
# LLM-Review vote is MAX and there are no unresolved comments. The label itself is
# advisory (function = NoBlock — a blocking label function is REJECTED on 3.14.1);
# blocking comes from the submit-requirement below. The label-LLM-Review vote
# permission is granted ONLY to Service Users (the bot, S4) + Administrators, so a
# regular developer cannot cast LLM-Review and bypass the gate.

[project]
	description = rebar — Gerrit-gated source of truth; replicated read-only to GitHub.

[access "refs/heads/*"]
	# Developers create changes (push to refs/for/*) via All-Projects defaults; they
	# may NOT vote LLM-Review. Only Service Users (the review bot) and Administrators
	# can cast the deterministic vote.
	label-LLM-Review = -1..+1 group Service Users
	label-LLM-Review = -1..+1 group Administrators

[access "refs/for/refs/heads/*"]
	# Registered users may push changes for review (explicit so the rebar project is
	# self-contained even if All-Projects defaults change).
	push = group Registered Users

[label "LLM-Review"]
	# NoBlock: required on 3.14.1 (a blocking function is rejected). The submit
	# requirement does the blocking.
	function = NoBlock
	value = -1 Blocked by LLM review
	value = 0 No score
	value = +1 Approved by LLM review
	defaultValue = 0
	# Carry the vote ONLY across a true no-op re-upload (e.g. commit-message-only
	# amend): NO_CODE_CHANGE pins the parent tree. We deliberately do NOT include
	# TRIVIAL_REBASE — that copies the vote even when the base moved (byte-identical
	# diff, different base), certifying a tree the LLM never reviewed. A real rebase
	# therefore drops the vote and forces a fresh review (safe default for a gate).
	copyCondition = changekind:NO_CODE_CHANGE

[submit-requirement "LLM-Review"]
	description = Deterministic LLM code review must pass (MAX) and no unresolved comments.
	# This is the SINGLE code-review vote in v1 (no human Code-Review / CI Verified yet
	# — follow-on epic 1fa8). It is what actually blocks submit.
	submittableIf = label:LLM-Review=MAX AND -has:unresolved
	canOverrideInChildProjects = false

[submit-requirement "Code-Review"]
	# DISABLE the inherited All-Projects Code-Review submit requirement on rebar: in v1
	# the bot's LLM-Review is the SOLE gate (no human Code-Review). applicableIf=is:false
	# makes this requirement never apply here, so a change is submittable on LLM-Review
	# alone — exactly what the bot-only submit flow (S4b/S7) needs. Re-introducing a
	# human Code-Review vote is the follow-on epic 1fa8.
	applicableIf = is:false
	submittableIf = is:true
	canOverrideInChildProjects = false
