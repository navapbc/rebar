# rebar project refs/meta/config (epic d251 / story S3).
#
# Pushed to refs/meta/config of the `rebar` project by setup-project.sh. Declarative:
# the whole file is the desired state of the project's access + label + submit rules.
#
# THE GATE (integrity rule): a change is submittable when BOTH deterministic votes
# are MAX and there are no unresolved comments — (a) LLM-Review (the review bot) and
# (b) Verified (CI, via gerrit-to-platform -> GitHub Actions; epic 1fa8). Both labels
# are advisory (function = NoBlock — a blocking label function is REJECTED on 3.14.1);
# blocking comes from the submit-requirements below. Each label's vote permission is
# granted ONLY to Service Users (the bots) + Administrators, so a regular developer
# cannot cast either vote and bypass the gate.
#
# LANDING AUTHORIZATION (separate, orthogonal control): the two labels above gate
# *readiness* (quality/CI); the `Submit` ACL below gates *who may perform the merge*.
# Submit is restricted to the `Contributors` group + Administrators, so ANY GitHub user
# may still push to refs/for/* to PROPOSE a change, but only an authorized contributor
# (or an admin) can LAND one — even a change with both votes at MAX cannot be submitted
# by a non-contributor. This is the documented Gerrit Contributor/Developer split (the
# Go model); it does not touch the label/submit-requirement wiring above.
#
# ROLLOUT (COMPLETE): the `Verified` submit-requirement shipped INACTIVE
# (applicableIf = is:false) so the config was safe to deploy before the CI voter was
# proven — the label recorded CI votes without blocking submit. Epic 1fa8 story S6 has
# now ACTIVATED it (the applicableIf line is deleted below) after the gerrit-to-platform
# voter was proven end-to-end, closing the "gate enforced but no voter" window. The
# effective gate is now the full two-vote AND (LLM-Review=MAX AND Verified=MAX).

[project]
	description = rebar — Gerrit-gated source of truth; replicated read-only to GitHub.

# DCO enforcement (epic breaded-ammonitic-elephant): the server rejects any push to
# refs/for/* whose commits lack a Signed-off-by trailer — the Developer Certificate of
# Origin, enforced in Gerrit itself and requiring no extra infrastructure (see CONTRIBUTING.md
# "Sign your work (DCO)"). This key is inheritable/per-project (not site-only).
# ROLLBACK: set `requireSignedOffBy = false` (or delete this section) and re-run
# setup-project.sh — that script overwrites project.config on every run, so a manual
# refs/meta/config edit would be silently reverted; always change it here.
[receive]
	requireSignedOffBy = true

[access "refs/heads/*"]
	# Developers create changes (push to refs/for/*) via All-Projects defaults; they
	# may NOT vote LLM-Review. Only Service Users (the review bot) and Administrators
	# can cast the deterministic vote.
	label-LLM-Review = -1..+1 group Service Users
	label-LLM-Review = -1..+1 group Administrators
	# CI casts Verified (epic 1fa8) as a Service User (the gerrit-to-platform SSH
	# service account, story S4); developers may NOT vote Verified, same as LLM-Review.
	label-Verified = -1..+1 group Service Users
	label-Verified = -1..+1 group Administrators
	# (The Autosubmit label ACL and the rebase(-on-behalf) grant were REMOVED by ADR 0047:
	# the serial auto-lander is retired, and `main` now uses Rebase-If-Necessary so Gerrit
	# rebases server-side at submit — no client-side rebase-on-behalf grant and no Autosubmit
	# opt-in label are needed. Back-out: restore both grants + the [label "Autosubmit"] block
	# and re-run setup-project.sh. See ADR 0047 / epic d4de.)
	# LANDING AUTHORIZATION (contributor gate): restrict the Submit action to authorized
	# contributors + Administrators. exclusiveGroupPermissions = submit makes Gerrit
	# IGNORE the inherited All-Projects `submit` grant on matching refs and honour ONLY
	# the two rules below (the same exclusive-override technique used for pushMerge). So a
	# non-contributor CANNOT submit (land) a change even with both gate votes at MAX; they
	# may still push to refs/for/* to PROPOSE. Admins always retain submit (the override
	# path). The `Contributors` group is created + its membership converged by
	# setup-project.sh (initial members = Administrators + $CONTRIBUTOR_MEMBERS).
	# Back-out: delete these three submit lines to restore the inherited All-Projects
	# submit grant (all Registered Users); re-run setup-project.sh to push refs/meta/config.
	exclusiveGroupPermissions = submit
	submit = group Contributors
	submit = group Administrators

[access "refs/for/refs/heads/*"]
	# Registered users may push changes for review (explicit so the rebar project is
	# self-contained even if All-Projects defaults change). This ALSO covers ordinary
	# (non-merge) story changes pushed for review to a feature branch
	# (refs/for/refs/heads/feature/<name>) — only the MERGE-commit push is restricted
	# to feature-branch-drivers below (pushMerge).
	push = group Registered Users

# --- Feature-branch flow (epic 88ab / S1 — bored-tag-sale; see ADR 0025) ---------------
# Three permission TYPES bound to the named group `feature-branch-drivers` (created +
# resolved by setup-project.sh): Create Reference + Delete Reference on the feature/*
# namespace, and Push Merge Commit on the two review namespaces where merge changes land
# (the merge-back into main, and catch-up merges into a feature branch). A regular
# developer is NOT in the group, so cannot create/delete feature branches or push a merge
# commit for review — enforced natively by Gerrit (a refusal is recorded in Gerrit's
# sshd/httpd audit log; the bot is not in this path).
[access "refs/heads/feature/*"]
	create = group feature-branch-drivers
	delete = group feature-branch-drivers

[access "refs/for/refs/heads/main"]
	# Push Merge Commit for the --no-ff merge-back change into main. EXCLUSIVE: All-Projects
	# grants pushMerge on refs/for/* to Registered Users, so without marking this permission
	# exclusive the inherited grant would let ANY registered user push a merge change here.
	# exclusiveGroupPermissions makes Gerrit IGNORE the inherited pushMerge on matching refs
	# and honour ONLY the rule below — so a non-member merge push is refused (verified live).
	exclusiveGroupPermissions = pushMerge
	pushMerge = group feature-branch-drivers

[access "refs/for/refs/heads/feature/*"]
	# Push Merge Commit for catch-up merges of main INTO a feature branch. Exclusive for the
	# same reason as refs/for/refs/heads/main above (override the inherited refs/for/* grant).
	exclusiveGroupPermissions = pushMerge
	pushMerge = group feature-branch-drivers

[label "LLM-Review"]
	# NoBlock: required on 3.14.1 (a blocking function is rejected). The submit
	# requirement does the blocking.
	function = NoBlock
	value = -1 Blocked by LLM review
	value = 0 No score
	value = +1 Approved by LLM review
	defaultValue = 0
	# Carry the LLM-Review vote across every re-upload that leaves the REVIEWED DIFF
	# unchanged (ADR 0041; extends ADR 0025's carry to TRIVIAL_REBASE):
	#   - NO_CODE_CHANGE          — a commit-message-only amend (tree identical).
	#   - MERGE_FIRST_PARENT_UPDATE — a feature-branch re-merge onto a moved first parent;
	#     the reviewed auto-merge delta is unchanged (epic 88ab / S1).
	#   - TRIVIAL_REBASE          — a CONFLICT-FREE rebase onto a newer `main` whose diff
	#     (including context lines) is byte-identical to the prior patch set. This is a
	#     non-conflicting "update from main that does not alter the change under review",
	#     so the LLM's judgment of the DIFF still holds and re-review is pure friction.
	# Any real edit, or a rebase that needed conflict resolution, is REWORK → the vote
	# DROPS and a fresh review is forced.
	#
	# Why this is safe (the diff-vs-tree asymmetry; GerriScary / CVE-2025-1568 posture):
	# the LLM-Review vote certifies the change's DIFF, which TRIVIAL_REBASE proves
	# unchanged — so it may carry. The Verified vote certifies the INTEGRATED TREE, which a
	# rebase onto new `main` DOES change — so Verified's copyCondition stays strict
	# (NO_CODE_CHANGE only, below), and CI RE-RUNS against the new tree. Thus a
	# rebase-to-tip under the Fast-Forward-Only submit type (ADR 0040) re-runs ONLY CI, not
	# the LLM review — cutting the FFO rebase-treadmill cost. This mirrors Gerrit's own
	# default for its Code-Review label (which carries on TRIVIAL_REBASE). Accepted
	# residual: the LLM reasoned against the old base and won't re-flag a semantic
	# regression the rebase pulls in from `main` — but that is integration correctness,
	# which the strict, re-running Verified vote covers. Supersedes ADR 0025's deliberate
	# TRIVIAL_REBASE exclusion for THIS label; Verified's exclusion is UNCHANGED.
	copyCondition = changekind:NO_CODE_CHANGE OR changekind:MERGE_FIRST_PARENT_UPDATE OR changekind:TRIVIAL_REBASE

[label "Verified"]
	# CI vote (epic 1fa8), cast by gerrit-to-platform's GitHub Actions run via SSH.
	# NoBlock for the same 3.14.1 reason as LLM-Review; the submit-requirement blocks.
	function = NoBlock
	value = -1 CI failed
	value = 0 No score / not yet verified
	value = +1 CI passed
	defaultValue = 0
	# Carry across a no-op re-upload (NO_CODE_CHANGE) AND a conflict-free rebase
	# (TRIVIAL_REBASE) — the ADR-0047 relaxation. Under Rebase-If-Necessary main, Gerrit
	# rebases a single change server-side at submit; carrying Verified across that trivial
	# rebase lets it submit WITHOUT re-running integration CI. This is safe against content
	# injection (TRIVIAL_REBASE means the diff is unchanged — only the base moved, so a
	# stale vote cannot ride onto altered content, the CVE-2025-1568/GerriScary concern);
	# it deliberately accepts the bounded SEMANTIC-conflict risk (two individually-green
	# changes that break only once combined), whose detector is the post-merge main CI
	# (test.yml on push) + manual revert. NOT MERGE_FIRST_PARENT_UPDATE: a feature-branch
	# re-merge produces a genuinely new merged tree, so it still DROPS Verified and RE-RUNS
	# CI (the ADR-0025 asymmetry is preserved; only single-change trivial rebase is relaxed).
	# Back-out: set copyCondition = changekind:NO_CODE_CHANGE (ADR-0040 strict carry).
	copyCondition = changekind:NO_CODE_CHANGE OR changekind:TRIVIAL_REBASE

[submit-requirement "LLM-Review"]
	description = Deterministic LLM code review must pass (MAX) and no unresolved comments.
	# One of the TWO independent gate votes (the other is Verified/CI, epic 1fa8).
	submittableIf = label:LLM-Review=MAX AND -has:unresolved
	canOverrideInChildProjects = false

[submit-requirement "Verified"]
	description = CI (build/test/lint/typecheck via GitHub Actions) must pass (MAX).
	# The SECOND independent gate vote (epic 1fa8). Together with LLM-Review the
	# effective gate is: label:LLM-Review=MAX AND label:Verified=MAX AND -has:unresolved.
	#
	# ACTIVATED (epic 1fa8 story S6): the gerrit-to-platform CI voter is proven end-to-end
	# (a Verified+1 was cast by the GitHub Actions run via SSH), so the rollout-safety
	# `applicableIf = is:false` line is DELETED — this requirement now applies, and the
	# effective gate is the full two-vote AND: label:LLM-Review=MAX AND label:Verified=MAX
	# AND -has:unresolved. Re-add `applicableIf = is:false` to fall back to advisory CI.
	submittableIf = label:Verified=MAX
	canOverrideInChildProjects = false

[submit-requirement "Code-Review"]
	# DISABLE the inherited All-Projects Code-Review submit requirement on rebar: in v1
	# the bot's LLM-Review is the SOLE gate (no human Code-Review). applicableIf=is:false
	# makes this requirement never apply here, so a change is submittable on LLM-Review
	# alone — exactly what the bot-only submit flow (S4b/S7) needs. Re-introducing a
	# human Code-Review vote is the follow-on epic 1fa8.
	applicableIf = is:false
	submittableIf = is:true
	canOverrideInChildProjects = false

[submit]
	# REBASE IF NECESSARY (ADR 0047; supersedes the ADR-0040 Fast-Forward-Only pin, which
	# itself superseded the ADR-0025 merge-if-necessary pin). When a change is a fast-forward
	# Gerrit submits it directly; otherwise Gerrit REBASES it onto the current main tip and
	# submits the result server-side, atomically, under its own lock. So a change no longer
	# goes non-submittable merely because main advanced beneath it — the author does NOT
	# hand-rebase in the common (non-conflicting) case; Gerrit integrates. The author rebases
	# by hand ONLY on a textual merge conflict Gerrit cannot resolve.
	#
	# The R5 relaxation (ADR 0047 decision 1): under FFO a client-side rebase minted a new
	# patch set that DROPPED Verified and RE-RAN CI on the exact merged tree. Server-side
	# Rebase-If-Necessary submits the rebased tree WITHOUT re-running integration CI — both
	# gate votes carry across a conflict-free rebase (LLM-Review already did; Verified now
	# does too, changekind:TRIVIAL_REBASE added to its copyCondition below). This accepts a
	# bounded, rare SEMANTIC-conflict risk (two individually-green changes that break only
	# once combined); the compensating detector is the EXISTING post-merge main CI (test.yml
	# on push), with a MANUAL revert on the rare red — no auto-revert. See ADR 0047 and
	# infra/runbooks/main-red-post-merge.md.
	#
	# Back-out (one line): set `action = fast forward only` to restore the ADR-0040 FFO
	# behaviour (and revert Verified's copyCondition to NO_CODE_CHANGE-only, above). Re-run
	# setup-project.sh to push refs/meta/config.
	action = rebase if necessary
	mergeContent = true
