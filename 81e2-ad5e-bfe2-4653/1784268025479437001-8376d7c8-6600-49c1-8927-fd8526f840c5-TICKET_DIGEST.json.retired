-8","schema":"ticket_digest_v1"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"TICKET_DIGEST","timestamp":1784268025479437001,"uuid":"8376d7c8-6600-49c1-8927-fd8526f840c5"}