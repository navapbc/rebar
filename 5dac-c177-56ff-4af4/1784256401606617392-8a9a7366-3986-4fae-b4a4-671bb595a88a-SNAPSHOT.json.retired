84254057620856001-f269e42c-f00d-4166-b42b-07adcfb78655"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"78fabe9e0de1bdaa35525efac8342ff4a88a6abea54b0277b27ee0c61e58dba1","event_uuid":"a156a309-52f7-415e-9dbb-cdbb8b4c525e","position":{"commit_sha":null,"position":"1784255080022576001-a156a309-52f7-415e-9dbb-cdbb8b4c525e"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"bbbdc5e986c7398d19771186522d24bb7592f87a062c7b75843ae6ab0b8e5437","event_uuid":"0634e659-68c9-48da-99ee-997253c89c39","position":{"commit_sha":null,"position":"1784256041929202001-0634e659-68c9-48da-99ee-997253c89c39"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"33e01a80ed06bfd1ad946d8353e4e4cb2adb4ab3d8fda946cbde064fb92ab486","event_uuid":"c91a165f-3b44-4444-aa74-31342f3fd2e7","position":{"commit_sha":null,"position":"1784256253149869001-c91a165f-3b44-4444-aa74-31342f3fd2e7"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"873964ac2e481c1e1e3c7b7e1704071a8ff957a49fdbdec5f4d1b14e7c95da80","event_uuid":"cd71273a-e8ca-4812-9211-216b0fa5a3f7","position":{"commit_sha":null,"position":"1784256253487391001-cd71273a-e8ca-4812-9211-216b0fa5a3f7"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"41dc35c7739b3879359a434842fd229e100648d3c3b6a82d04f7b42254bf820a","event_uuid":"d5043758-299e-4442-a419-f5acea47f7b7","position":{"commit_sha":null,"position":"1784256401606617391-d5043758-299e-4442-a419-f5acea47f7b7"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-212_agent","claim_remote_session":null,"claimed_session":"0598b281-0286-4b2c-891c-cc5b4c94ba24","comments":[],"created_at":1784143866501226001,"creation_channel":"unknown","deps":[],"description":"## Why\nReport §5.2 found 4/8 tickets with persisted reviews were CAUGHT-BUT-IGNORED: the gate\nraised the right advisory, but the author applied it only AFTER claim — advisory latency,\nnot blindness. Authors defer advisories because nothing ranks which surviving advisories are\nworth applying *now* vs safe to defer. A deterministic triage of the round's surviving\nadvisories is pure coaching (the reviewer never writes the plan) and carries no detection\nrisk, so per the epic gate table it ships first with **no eval gate** — validated post-ship by\ndogfooding via R7's advisory-application-latency metric.\n\n## What\nAdd a **deterministic advisory-triage stage** to the Pass-4 coach path of the plan-review\ngate. It runs AFTER Pass-3 has decided findings and split them into blocking vs surviving\n(advisory), and it partitions the round's surviving **advisory** findings into two buckets —\n`apply-now` and `defer` — using ONLY fields already recorded on each decided finding. It emits\nNO new LLM judgment (no model call) and no free prose; it renders from a locked format, so the\nsame decided-finding set produces byte-identical output.\n\n**Output shape (structured, returned — not persisted).** The stage produces a structured\n`triage` array, one entry per surviving advisory finding:\n`{\"id\": str, \"criteria\": list[str], \"priority\": float, \"block_threshold\": float,\n\"bucket\": \"apply-now\"|\"defer\", \"reason\": str}` (`reason` is `\"\"` for `apply-now`). This array\nis attached to the returned verdict as a **top-level key `verdict[\"triage\"]`** — the\n`plan_review_verdict` output schema has `additionalProperties: true`, so it validates with no\nschema change — so the agent sees it at review time. It is **NOT** added to the persisted\n`REVIEW_RESULT` sidecar:\n`sidecar.build_payload` enumerates coaching-note fields explicitly, and R7's dogfood metrics\nderive advisory *application* from post-claim outcomes joined to findings by `criteria`, not\nfrom a stored triage stamp — so persistence is unnecessary and `build_payload` stays unchanged.\nNo Markdown, no config flag.\n\n**Mechanism choice (rationale).** It is NOT an entry in the Pass-4 `MOVE_REGISTRY` (in\n`passes.py`, re-exported by `orchestrator.py`). The registry schema\n(`review_kernel/coach.py` `MOVE_REGISTRY_SCHEMA`) is a *per-finding* `{subject}`-placeholder\ntemplate the LLM fills; a single `{subject}` substitution cannot express a ranked two-bucket\nsplit across all surviving advisories. So the triage is a small pure function on the\nplan-review Pass-4 path — blast radius stays inside plan-review; the shared kernel coach\nmechanism and its notes are unchanged.\n\n**The ranking rule (fully specified, grounded in real fields).** Every decided finding carries\n`priority` (= `validity × impact`, float in [0,1], always present — `review_kernel/decide.py`,\nand set to 0.4 for DET-tier advisories in `orchestrator.py`). `block_threshold` is present on\nLLM-decided findings (resolved by `decide.py`; 0.60 via plan-review's `criteria_routing.json`\nrouting, not `decide.py`'s 0.95 `DEFAULT_BLOCK_THRESHOLD`); DET-tier advisories\nstamped by `partition_findings` (`orchestrator.py`) do **not** carry it, so `triage_advisories`\nreads it as `f.get(\"block_threshold\", DEFAULT_BLOCK_THRESHOLD)` — the 0.95 default applies when\nabsent (already imported in `passes.py`), under which a DET advisory (priority 0.4) buckets\n`defer`. No other field is used — there is NO \"remediation-mode carryover status\" field on\nPass-4 findings.\n\n- **Bucketing.** An advisory is `apply-now` iff `priority >= block_threshold - APPLY_NOW_MARGIN`\n  (it came within the margin of blocking → highest value to apply now); else `defer`.\n  `APPLY_NOW_MARGIN` is a named module constant, default **0.10**.\n- **Ordering (total, deterministic → byte-identical).** The `triage` array is sorted by\n  `priority` DESC, then by `criteria[0]` (the first element of the finding's `criteria` list;\n  a finding with empty `criteria` sorts last via a fixed sentinel `\"~\"`) ASC, then by `id` ASC.\n- **Defer reason.** Built only from the finding's own numbers, e.g.\n  `deferred: priority 0.32 is 0.28 below its 0.60 block line` — fixed words + recorded numbers,\n  no LLM prose, non-prescriptive.\n- **Eligibility.** Only findings with `decision == \"advisory\"` are triaged. Blocking findings\n  must be remediated regardless and are excluded (this is why R6 is advisory-only).\n\n## Scope\n- `src/rebar/llm/plan_review/passes.py` — the deterministic `triage_advisories(surviving)` pure\n  function (bucketing + ordering + defer-reason via a locked format) and the `APPLY_NOW_MARGIN`\n  constant.\n- `src/rebar/llm/plan_review/workflow_ops.py` — in the `plan_review_coach` step (the sole live\n  verdict-assembly path; the older bespoke `_run_passes` path was retired in epic\n  solid-timer-unison), invoke `triage_advisories` on the surviving advisory findings and set\n  `verdict[\"triage\"]` before the closing `validate_structured(verdict, _OUTPUT_SCHEMA)` return.\n  The two `gate_dispatch.py` recovery paths (`_recover_plan_review_coach_failure`,\n  `_recover_plan_review_verify_failure`) assemble DEGRADED verdicts when a pass fails and have no\n  decided advisories to triage, so they are out of scope — a recovered verdict simply omits\n  `triage`. No other returned-result consumer changes.\n- `tests/unit/test_plan_review_triage.py` — unit tests (see ACs).\n- `docs/plan-review-gate.md` — document the triage stage, ranking rule, and R7 dogfood\n  expectation.\n- NOT touched: `sidecar.py` / the `plan_review_result_v2` schema (triage is returned, not\n  persisted) and `review_kernel/coach.py` (kernel mechanism unchanged).\n\n## Acceptance Criteria\n- [ ] `triage_advisories` returns byte-identical output across two runs on the same fixed\n      advisory set, and every `reason` string matches the locked format (only fixed tokens +\n      recorded numeric fields — no LLM/prescriptive prose). Proving command:\n      `python -m pytest tests/unit/test_plan_review_triage.py -k determinism -q`.\n- [ ] Boundary bucketing: an advisory with `priority == block_threshold - APPLY_NOW_MARGIN` is\n      `apply-now`; one epsilon below is `defer` (parametrized). Proving command:\n      `python -m pytest tests/unit/test_plan_review_triage.py -k boundary -q`.\n- [ ] The `triage` array is ordered by `priority` DESC, then `criteria[0]` ASC (empty→`\"~\"`),\n      then `id` ASC — a test with deliberate priority ties and a multi-element / empty\n      `criteria` pins the exact order. Proving command:\n      `python -m pytest tests/unit/test_plan_review_triage.py -k ordering -q`.\n- [ ] Only `decision == \"advisory\"` findings appear in the array; blocking findings are\n      excluded, and every surviving advisory appears exactly once (including advisories that\n      mapped to no coach move). Proving command:\n      `python -m pytest tests/unit/test_plan_review_triage.py -k advisory_only -q`.\n- [ ] Integration: the returned plan-review verdict carries the `triage` array as top-level\n      `verdict[\"triage\"]`, equal to `triage_advisories(surviving)` for that run (a test drives the\n      `plan_review_coach` step with fixture findings and asserts `verdict[\"triage\"]`).\n      Proving command: `python -m pytest tests/unit/test_plan_review_triage.py -k integration -q`.\n- [ ] `docs/plan-review-gate.md` documents the triage stage, its ranking rule (the\n      `APPLY_NOW_MARGIN` default, the ordering, and the defer-reason format), and the R7 dogfood\n      expectation. Proving command:\n      `grep -q \"APPLY_NOW_MARGIN\" docs/plan-review-gate.md && grep -q \"apply-now\" docs/plan-review-gate.md && grep -q \"defer\" docs/plan-review-gate.md && grep -q \"R7\" docs/plan-review-gate.md`.\n- [ ] Landed through Gerrit directly in the packaged Pass-4 coach path — no config flag;\n      `make lint && make typecheck && make test` green.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/llm/plan_review/passes.py","reason":"triage_advisories pure fn + APPLY_NOW_MARGIN"},{"path":"src/rebar/llm/plan_review/workflow_ops.py","reason":"attach verdict[triage] in coach step"},{"path":"tests/unit/test_plan_review_triage.py","reason":"triage unit+integration tests"},{"path":"docs/plan-review-gate.md","reason":"triage stage + ranking rule docs"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","6982-2e75-f8fa-43b9"]],"parent_id":"6982-2e75-f8fa-43b9","parent_status_uuid":"c91a165f-3b44-4444-aa74-31342f3fd2e7","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"5dac-c177-56ff-4af4","ticket_type":"story","title":"R6: advisory-triage coaching move (pass-4 registry, ship-first)","verify_commands":[]},"source_event_uuids":["5bf93b2f-7ee8-4b8b-b45a-6ca5feceae38","79727a2e-642d-4ee3-a758-7b6c17aa963e","f342e3df-384f-48ba-abb9-b162949c8ddc","f92409ea-cf8c-45bb-808d-2ff40b7bfddd","018045c5-6c65-438d-8981-8e9a52c00823","c9dd2449-753f-4693-8355-71a777acb71c","f269e42c-f00d-4166-b42b-07adcfb78655","a156a309-52f7-415e-9dbb-cdbb8b4c525e","0634e659-68c9-48da-99ee-997253c89c39","c91a165f-3b44-4444-aa74-31342f3fd2e7","cd71273a-e8ca-4812-9211-216b0fa5a3f7","d5043758-299e-4442-a419-f5acea47f7b7"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784256401606617392,"uuid":"8a9a7366-3986-4fae-b4a4-671bb595a88a"}