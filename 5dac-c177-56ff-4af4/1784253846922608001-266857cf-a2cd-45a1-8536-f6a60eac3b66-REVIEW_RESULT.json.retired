will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f85ed4c8def0127a7","f5cb5b13e52c9b66d"],"move_id":"9","move_name":"plan the verification","subject":"recovery path triage omission verification"},{"coaching":"Plan how bespoke orchestrator path parity verification will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["ff81001278594554b"],"move_id":"9","move_name":"plan the verification","subject":"bespoke orchestrator path parity verification"},{"coaching":"Record an ADR for triage bucket vocabulary contract anchoring — it reads like a one-way door.","decision":"advisory","finding_refs":["fa7cef50600f2796f"],"move_id":"8","move_name":"ADR / one-way-door","subject":"triage bucket vocabulary contract anchoring"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":5,"blocking":4,"dropped":11,"indeterminate":0},"det":{"P1":{"ac_items":7,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","probed":6,"ran":true,"references":6,"resolved":3,"status":"pass","unresolved_or_abstained":3},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":7,"blocking":false,"desc_chars":7011,"file_impact":4,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":7,"blocking":false,"name":"ac-quality","ran":true,"status":"pass","verify_commands_linted":78,"verify_lint_abstained":77},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":1769,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":4,"name":"file-impact-coverage","ran":true,"status":"pass"}},"floored_criteria":["E3","G1G2","T8"],"floored_finding_ids":["f5ce9479f3ad6c89a","f0e5e9d8dbf09b2c0","f85ed4c8def0127a7","f5cb5b13e52c9b66d","fa7cef50600f2796f"],"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":229.4,"llm_calls":29,"llm_ms":627313.6,"total_ms":627685.1,"verify_requests":35},"narrowed":true,"remediation":{"baseline":"sidecar","eligible":true,"reasons":{"code_unchanged":true,"plan_changed":true,"registry_unchanged":true,"sidecar_baseline":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","G5","T2","T4","T5a","T5b","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Fix all occurrences of `plan_review_coach_notes` in the Scope and AC sections to the actual registered step name `plan_review_coach` (the `plan_review_coach` function in `workflow_ops.py` is where `verdict` is assembled and `validate_structured` is called).","cohort":["E4"],"criteria":["E4"],"decision":"block","drop_reason":null,"evidence":["workflow_ops.py: @register_step('plan_review_coach', ...) — the actual registered step name","plan-review.yaml lines 200-203, 280-283: 'uses: plan_review_coach' — the YAML refers to plan_review_coach","plan-review.yaml lines 192-195, 271-275: 'id: coach_notes' is the YAML's inner prompt step (not a registered uses-op)","Search for 'plan_review_coach_notes' returns zero matches across the entire codebase"],"finding":"The Scope section names the injection point as 'the `plan_review_coach_notes` step' (and the AC integration test also references 'the `plan_review_coach_notes` step'), but no such step exists in the codebase. The actual registered step is `plan_review_coach` (`@register_step('plan_review_coach', ...)` in `workflow_ops.py`). The YAML uses an inner step called `coach_notes` (a prompt step, not a uses-op) and the uses-op step is `plan_review_coach`.","group_criteria":null,"group_id":null,"id":"f1c8af0e6fdb40279","impact":0.85,"is_primary":null,"location":"Scope > workflow_ops.py bullet: 'in the `plan_review_coach_notes` step'; AC > Integration AC bullet: 'a test drives the `plan_review_coach_notes` step'","norm_id":"n16102321b8824ab5","priority":0.85,"reason":"high-priority+criterion-opted-in","scenarios":["Implementer looks for `plan_review_coach_notes` in the codebase, finds nothing, and is confused about where to inject the triage call.","The AC integration test targets the wrong function/step, so the test never actually exercises the code path where triage must be injected."],"severity":"critical","suggested_fix":"Replace 'the `plan_review_coach_notes` step' with 'the `plan_review_coach` step (the `plan_review_coach` function in `workflow_ops.py`)' in both the Scope bullet and the integration AC proving description.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"broken_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"medium","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"medium","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Correct all references to `plan_review_coach_notes` in the Scope section and AC5 to the actual step name `plan_review_coach` (registered at `workflow_ops.py:472`).","cohort":["G1G2"],"criteria":["G1G2"],"decision":"block","drop_reason":null,"evidence":["Plan Scope: 'in the `plan_review_coach_notes` step, invoke `triage_advisories` on the surviving advisory findings'","AC5: 'a test drives the `plan_review_coach_notes` step with fixture findings'","workflow_ops.py:472: @register_step('plan_review_coach', ...) — no 'plan_review_coach_notes' step exists anywhere in the file or the codebase"],"finding":"The plan names `plan_review_coach_notes` as the step to modify in `workflow_ops.py` and as the target of the integration AC, but no such step exists. The actual registered step is `plan_review_coach` (registered at `workflow_ops.py:472` via `@register_step('plan_review_coach', ...)`). The plan uses the wrong step name throughout the Scope section and AC5.","group_criteria":null,"group_id":null,"id":"f178965903537f536","impact":0.85,"is_primary":null,"location":"Scope section ('in the `plan_review_coach_notes` step') and AC5 ('a test drives the `plan_review_coach_notes` step')","norm_id":"nacf2916b2fc3abd8","priority":0.85,"reason":"high-priority+criterion-opted-in","scenarios":["A developer following the plan edits the wrong function or creates a new misnamed step, breaking the workflow.","The integration test targets a non-existent step name, fails to find it, and either errors out or silently tests the wrong path."],"severity":"critical","suggested_fix":"Replace every occurrence of `plan_review_coach_notes` with `plan_review_coach` in the Scope and AC5 descriptions.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"broken_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"medium","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"medium","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Specify the fallback behavior for `triage_advisories` when a surviving advisory finding lacks a `block_threshold` field (DET-tier advisories from `partition_findings` never carry it): either document a fixed fallback value (e.g., use plan-review's 0.60 posture), explicitly exclude DET-tier findings (checked via `finding.get('tier') == 'DET'`), or update `partition_findings` to stamp `block_threshold` on DET findings too.","cohort":["G6"],"criteria":["G6"],"decision":"block","drop_reason":null,"evidence":["Plan states: 'block_threshold (the criterion blocking waterline; always set on the decided finding — decide.py, 0.60 under plan-review's routing, DEFAULT_BLOCK_THRESHOLD=0.95 otherwise)'","orchestrator.py `partition_findings` stamps DET advisories as: `{**f, 'id': ..., 'decision': 'advisory', 'severity': 'minor', 'priority': 0.4, 'validity': 1.0, 'impact': 0.4, 'tier': 'DET'}` — no `block_threshold` key","`pass3_decide` in review_kernel/decide.py DOES always stamp `block_threshold` on LLM-tier findings, but DET findings never pass through `pass3_decide`","ABSENCE: the plan provides no fallback value for `finding.get('block_threshold')` returning `None` on a DET advisory"],"finding":"The plan asserts 'block_threshold (the criterion blocking waterline; always set on the decided finding — decide.py)' as a universal invariant, but DET-tier advisory findings stamped by `partition_findings` in orchestrator.py carry only {priority, validity, impact, severity, tier} — they have NO `block_threshold` field. The `triage_advisories` bucketing formula (`priority >= block_threshold - APPLY_NOW_MARGIN`) is therefore undefined for DET-tier advisories, and the plan specifies no fallback for a missing `block_threshold`.","group_criteria":null,"group_id":null,"id":"fcea00bd2cd9fb183","impact":0.85,"is_primary":null,"location":"What > The ranking rule / Mechanism choice rationale; src/rebar/llm/plan_review/orchestrator.py `partition_findings` (lines 398-450)","norm_id":"n9b600b769c2ca337","priority":0.85,"reason":"high-priority+criterion-opted-in","scenarios":["Any plan-review run where DET-tier advisories survive into the `surfaced` bucket (e.g., a P3/P4 DET advisory finding) — `triage_advisories` calls `block_threshold - APPLY_NOW_MARGIN` on a `None` value, raising TypeError at runtime","Even if None is handled with a silent default, the bucket assignment for DET advisories is unspecified: should they use 0.60 (plan-review posture), 0.95 (DEFAULT_BLOCK_THRESHOLD), or be excluded from triage entirely?"],"severity":"critical","suggested_fix":"In the ranking-rule section, add: 'A finding without a `block_threshold` field (e.g., a DET-tier advisory) uses the plan-review gate posture default of 0.60 as its fallback, matching the threshold the LLM criteria are judged against.' This keeps DET advisories triageable without introducing a new field on the DET findings or changing `partition_findings`.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"low","divergent_implementation":"medium","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"medium","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify how `triage_advisories` handles advisory findings that lack a `block_threshold` field (DET-tier advisories from `partition_findings` carry no such field) — either define a fallback constant, exclude DET-tier findings from triage, or stamp `block_threshold` onto DET advisories in `partition_findings`.","cohort":["T1"],"criteria":["T1"],"decision":"block","drop_reason":null,"evidence":["Plan: 'block_threshold (the criterion blocking waterline; always set on the decided finding — decide.py, 0.60 under plan-review's routing, DEFAULT_BLOCK_THRESHOLD=0.95 otherwise)'","orchestrator.py partition_findings (lines 412-424): DET advisory findings are minted with {priority: 0.4, validity: 1.0, impact: 0.4, tier: 'DET'} — no `block_threshold` key","decide.py pass3_decide: always includes `block_threshold` in its return dict — but DET-tier advisories never pass through this function","ABSENCE: `block_threshold` is not stamped on DET-tier findings anywhere in the partition or floor code"],"finding":"The plan asserts that `block_threshold` is 'always set on the decided finding — decide.py, 0.60 under plan-review's routing, DEFAULT_BLOCK_THRESHOLD=0.95 otherwise' — making this a grounding fact `triage_advisories` can rely on for bucketing. However, DET-tier advisory findings (P4, P6, P7, P9, and project DET criteria advisories) are minted by `partition_findings` in `orchestrator.py` with hardcoded `priority: 0.4` but NO `block_threshold` field, because they bypass `pass3_decide` entirely. Only LLM-tier findings go through `pass3_decide`, which always echoes back `block_threshold`. The bucketing rule `priority >= block_threshold - APPLY_NOW_MARGIN` would silently fail (e.g. `None - 0.10` raises a TypeError) or produce wrong results for every DET-tier advisory finding in the triage input.","group_criteria":null,"group_id":null,"id":"f448f91cb54cbacca","impact":0.85,"is_primary":null,"location":"## What — 'The ranking rule (fully specified, grounded in real fields)' + src/rebar/llm/plan_review/orchestrator.py partition_findings (lines 412-424)","norm_id":"nbcd62eefe4a481d3","priority":0.85,"reason":"high-priority+criterion-opted-in","scenarios":["A plan with P6 AC/DD quality findings (advisory, DET-tier) goes to triage: triage_advisories receives a finding dict with no `block_threshold` key; `finding.get('block_threshold') - APPLY_NOW_MARGIN` raises TypeError or silently buckets incorrectly.","A plan with project DET-criterion advisories (non-blocking DET matches on undeclared files) similarly carries no block_threshold into the triage function."],"severity":"critical","suggested_fix":"In `partition_findings`, add `'block_threshold': DEFAULT_BLOCK_THRESHOLD` (or a DET-specific sentinel like `1.0`) to the DET advisory finding shape, so `triage_advisories` always has a numeric `block_threshold` to compare against. Alternatively, in `triage_advisories`, fall back to `DEFAULT_BLOCK_THRESHOLD` when the field is absent: `bt = f.get('block_threshold', DEFAULT_BLOCK_THRESHOLD)`.","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"low","divergent_implementation":"medium","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"medium","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Correct the block_threshold characterization: plan-review criteria have thresholds of 0.60, 0.70, 0.75, AND 0.95 (not uniformly 0.60); verify that APPLY_NOW_MARGIN=0.10 produces sensible apply-now bucket sizes across the full threshold distribution (especially for the dominant 0.95 criteria where apply-now requires priority >= 0.85).","cohort":["E4"],"criteria":["E4"],"decision":"advisory","drop_reason":null,"evidence":["criteria_routing.json: F1 block_threshold=0.60, F4 block_threshold=0.95, G3 block_threshold=0.95, G4 block_threshold=0.95, E1 block_threshold=0.95, E4 block_threshold=0.60, G6 block_threshold=0.70, T5 block_threshold=0.70, A4 block_threshold=0.70","Plan quote: '0.60 under plan-review's routing, DEFAULT_BLOCK_THRESHOLD=0.95 otherwise'","The actual plan-review threshold distribution spans 0.60/0.70/0.75/0.95 — NOT a single 0.60 value"],"finding":"The plan asserts 'block_threshold (the criterion blocking waterline; always set on the decided finding — decide.py, 0.60 under plan-review's routing, DEFAULT_BLOCK_THRESHOLD=0.95 otherwise)'. The description '0.60 under plan-review's routing' is factually wrong: `criteria_routing.json` shows plan-review criteria with block_threshold values of 0.60 (F1, E4, A3, T8, T9), 0.70 (G6, T5, A4), 0.75 (G6-variant), and 0.95 (F4, G3, G4, E1, E2, E3, etc.) — the majority are 0.95, not 0.60.","group_criteria":null,"group_id":null,"id":"fec3d7e43f1bd9ef5","impact":0.85,"is_primary":null,"location":"What > The ranking rule — 'block_threshold (the criterion blocking waterline; always set on the decided finding — decide.py, 0.60 under plan-review's routing, DEFAULT_BLOCK_THRESHOLD=0.95 otherwise)'","norm_id":"nce4da235930ccb35","priority":0.7438,"reason":"default-advisory","scenarios":["A developer reading the plan to tune APPLY_NOW_MARGIN uses the wrong mental model (assumes block_threshold=0.60 uniformly), potentially setting a margin that over-promotes or under-promotes advisories for the majority of criteria that actually use 0.95.","Test authors calibrate boundary tests against threshold=0.60 when the most common plan-review threshold is 0.95, producing tests that don't cover the dominant case."],"severity":"critical","suggested_fix":"Replace '0.60 under plan-review's routing' with 'ranging from 0.60 to 0.95 depending on the criterion (see criteria_routing.json); verified against each finding's own recorded block_threshold field'. Re-evaluate whether APPLY_NOW_MARGIN=0.10 is the right default given that the majority of criteria use block_threshold=0.95.","tier":"LLM","validity":0.875,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"low","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Extend the docs AC proving command to also grep for the ordering rule, the defer-reason format token (e.g. `'deferred: priority'`), and the R7 dogfood expectation so the command cannot pass while those items are absent.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["AC text: 'document the triage stage, its ranking rule (the APPLY_NOW_MARGIN default, the ordering, and the defer-reason format), and the R7 dogfood expectation'","Proving command only: `grep -q \"APPLY_NOW_MARGIN\" docs/plan-review-gate.md && grep -q \"apply-now\" docs/plan-review-gate.md`","Ordering, defer-reason format string (e.g. 'deferred: priority'), and R7 are not checked"],"finding":"The docs AC proving command (`grep -q 'APPLY_NOW_MARGIN' ... && grep -q 'apply-now' ...`) verifies only two string presences but the AC prose requires documenting four additional items: the ordering rule, the defer-reason format, and the R7 dogfood expectation — the command silently passes even if those are absent from the doc.","group_criteria":null,"group_id":null,"id":"ff02f553b91e80f73","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — 'docs/plan-review-gate.md documents…' bullet and its Proving Command","norm_id":"nda1a1fd5a0792ba3","priority":0.55,"reason":"default-advisory","scenarios":["Executor documents only the margin constant and the bucket name labels, CI grep passes, but ordering and defer-reason format are undocumented — the AC is green but the criterion is not met"],"severity":"major","suggested_fix":"Replace the single proving command with: `grep -q 'APPLY_NOW_MARGIN' docs/plan-review-gate.md && grep -q 'apply-now' docs/plan-review-gate.md && grep -q 'deferred: priority' docs/plan-review-gate.md && grep -q 'R7' docs/plan-review-gate.md && grep -q 'criteria\\[0\\]' docs/plan-review-gate.md`","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add `orchestrator.py` explicitly to the Scope section (or state it requires no change and explain why) so the executor has an unambiguous scope boundary.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"advisory","drop_reason":null,"evidence":["'the bespoke orchestrator path is updated symmetrically for parity' (body, parenthetical)","Scope section lists: `passes.py`, `workflow_ops.py`, test file, docs — `orchestrator.py` absent"],"finding":"The body states 'the bespoke orchestrator path is updated symmetrically for parity' but `orchestrator.py` does not appear in the Scope section — an executor cannot determine whether modifying `orchestrator.py` is in or out of scope for this ticket.","group_criteria":null,"group_id":null,"id":"f1fd158d980899ca3","impact":0.536,"is_primary":null,"location":"What section, paragraph starting 'in the `plan_review_coach_notes` step'; Scope section (lists `workflow_ops.py` but not `orchestrator.py`)","norm_id":"n1b715ce1a3389554","priority":0.402,"reason":"default-advisory","scenarios":["Executor skips orchestrator.py change (body implies it) and the two paths diverge post-ship","Executor changes orchestrator.py (correctly inferred) but no AC covers it, leaving it unverified"],"severity":"major","suggested_fix":"Add a scope bullet: `src/rebar/llm/plan_review/orchestrator.py` — invoke `triage_advisories` on the surviving advisory findings and attach `verdict[\"triage\"]` before returning, mirroring the `workflow_ops.py` change.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add to the `docs/plan-review-gate.md` AC (or the doc section itself) an explicit requirement to document the `triage` array entry JSON schema (all six fields and their types/value-sets), and extend the grep check or add a doc coverage test to verify it is present.","cohort":["T2","T5e","T7"],"criteria":["T7"],"decision":"advisory","drop_reason":null,"evidence":["AC grep check covers only two string literals, not the triage entry JSON structure","Plan defines the output shape as: `{\"id\": str, \"criteria\": list[str], \"priority\": float, \"block_threshold\": float, \"bucket\": \"apply-now\"|\"defer\", \"reason\": str}` but does not scope this schema into the doc AC","Agent consumers of `verdict[\"triage\"]` are not covered by any existing schema (additionalProperties: true bypasses validation) and have no documented contract to program against"],"finding":"The doc AC only greps for 'APPLY_NOW_MARGIN' and 'apply-now' in docs/plan-review-gate.md, but does not require the JSON shape of the new `verdict[\"triage\"]` array entries to be documented. The triage array is a new agent-facing contract (fields: id, criteria, priority, block_threshold, bucket, reason) and consumers need the schema to interpret it correctly.","group_criteria":null,"group_id":null,"id":"f036fe2099cde3df5","impact":0.55,"is_primary":null,"location":"Scope / docs/plan-review-gate.md AC: `grep -q \"APPLY_NOW_MARGIN\" docs/plan-review-gate.md && grep -q \"apply-now\" docs/plan-review-gate.md`","norm_id":"n7053484890a08066","priority":0.3438,"reason":"default-advisory","scenarios":["An agent or downstream step reads verdict[\"triage\"] and must guess field names/types","A future contributor adds a triage field and doesn't know which fields are stable vs internal","R7 instrumentation reads triage entries and silently misreads field semantics"],"severity":"major","suggested_fix":"Extend the doc AC to: `grep -q 'APPLY_NOW_MARGIN' docs/plan-review-gate.md && grep -q 'apply-now' docs/plan-review-gate.md && grep -q 'block_threshold' docs/plan-review-gate.md` — and add a prose table or code block in plan-review-gate.md listing the six triage entry fields with types and semantics.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an AC (or extend AC5) that verifies the bespoke orchestrator path also attaches `verdict[\"triage\"]` equal to `triage_advisories(surviving)`, so the 'symmetrically for parity' Scope claim has a covering criterion.","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["Scope: 'the bespoke orchestrator path is updated symmetrically for parity'","AC5: 'a test drives the plan_review_coach_notes step with fixture findings and asserts verdict[\"triage\"]' — orchestrator path not mentioned"],"finding":"The Scope section describes a second implementation site — 'the bespoke orchestrator path is updated symmetrically for parity' — but no AC verifies this update. AC5 (integration) only drives `plan_review_coach_notes`; there is no test or verification step for the bespoke orchestrator path also attaching `verdict[\"triage\"]`. This is described work with no covering criterion.","group_criteria":null,"group_id":null,"id":"ff81001278594554b","impact":0.33,"is_primary":null,"location":"Scope section (workflow_ops.py bullet) vs AC5","norm_id":"n8619f8600cd80bb7","priority":0.2475,"reason":"default-advisory","scenarios":["An implementer updates workflow_ops.py's plan_review_coach_notes path but omits the orchestrator path update, and all ACs still pass green — the described parity requirement goes unverified."],"severity":"minor","suggested_fix":"Extend AC5: 'Integration: both the plan_review_coach_notes step AND the bespoke orchestrator path attach verdict[\"triage\"] equal to triage_advisories(surviving) for that run.' Add a corresponding parametrized test case in test_plan_review_triage.py that exercises the orchestrator code path.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Either expose APPLY_NOW_MARGIN as an environment variable / config key (with the 0.10 default preserved), or add a note in the plan acknowledging the deploy-to-tune tradeoff is acceptable and explaining why config-driven override is not needed at this stage.","cohort":["T2","T5e","T7"],"criteria":["T5e"],"decision":"dropped","drop_reason":null,"evidence":["'APPLY_NOW_MARGIN is a named module constant, default 0.10' — hardcoded in source","'validated post-ship by dogfooding via R7's advisory-application-latency metric' — explicit acknowledgment that the value will be empirically evaluated and potentially changed","No mention of env-var, config file, or runtime override path for APPLY_NOW_MARGIN"],"finding":"APPLY_NOW_MARGIN is defined as a module-level constant (default 0.10) and the plan explicitly states R7 will validate it post-ship via the advisory-application-latency metric — meaning it is a threshold expected to evolve. A named module constant requires a code deploy to adjust, creating friction for data-driven tuning after R7 results arrive.","group_criteria":null,"group_id":null,"id":"f9f8ae4f932671bee","impact":0.0,"is_primary":null,"location":"What / Mechanism: 'APPLY_NOW_MARGIN is a named module constant, default 0.10' + Why: 'validated post-ship by dogfooding via R7's advisory-application-latency metric'","norm_id":"nf47d035058192707","priority":0.0,"reason":"low-validity","scenarios":["R7 dogfood shows 0.10 margin miscalibrates the apply-now/defer split; changing it requires a code review + deploy cycle rather than a config update","Ops/ML team wants to A/B test two margin values; no mechanism exists without forking or deploying separate code versions"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Correct the claim that MOVE_REGISTRY is 're-exported by `orchestrator.py`' — `orchestrator.py` does not re-export it; it is only in `passes.py`.","cohort":["E4"],"criteria":["E4"],"decision":"dropped","drop_reason":null,"evidence":["passes.py lines 729-811: MOVE_REGISTRY defined here, confirmed","Grep of orchestrator.py for 'MOVE_REGISTRY': no matches","Grep of orchestrator.py for 'move_registry': no matches","orchestrator.py imports: 'from . import registry' and 'from .det_floor import PlanContext' — no passes re-exports"],"finding":"The plan states that MOVE_REGISTRY is 'in `passes.py`, re-exported by `orchestrator.py`'. The MOVE_REGISTRY is confirmed in `passes.py`, but `orchestrator.py` does NOT re-export it — a full search of `orchestrator.py` for 'MOVE_REGISTRY', 'move_registry', and 'load_move' returns zero matches.","group_criteria":null,"group_id":null,"id":"f586f940a8b5f012f","impact":0.0,"is_primary":null,"location":"What > Mechanism choice: 'It is NOT an entry in the Pass-4 MOVE_REGISTRY (in `passes.py`, re-exported by `orchestrator.py`)'","norm_id":"n65b103567d2197a5","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":["A developer looking for the MOVE_REGISTRY re-export in orchestrator.py as a call site wastes time searching for it, or incorrectly assumes an import in a consumer they haven't found.","Minor but could mislead plan authors about the module dependency graph."],"severity":"none","suggested_fix":"Change 'in `passes.py`, re-exported by `orchestrator.py`' to 'in `passes.py`'.","tier":"LLM","validity":0.4286,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"no","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The test file is placed at `tests/test_plan_review_triage.py` but every existing plan-review unit test lives under `tests/unit/` (e.g., `tests/unit/test_plan_review.py`, `tests/unit/test_plan_review_novelty.py`, `tests/unit/test_plan_review_convergence.py`). The plan's path drops the `unit/` subdirectory, so the file will be created i