{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","author_sig":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","data":{"coaching":[{"coaching":"Plan how verification of bespoke orchestrator triage path will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"block","finding_refs":["fc19e5a047566bf67","ffac0b48dcb311134","f12875d15a8e1f695"],"move_id":"9","move_name":"plan the verification","subject":"verification of bespoke orchestrator triage path"},{"coaching":"Test the riskiest assumption behind existence of the bespoke orchestrator path first.","decision":"advisory","finding_refs":["f88815b375def9bf1"],"move_id":"4","move_name":"riskiest-assumption test","subject":"existence of the bespoke orchestrator path"},{"coaching":"Pin down docs AC coverage of four required items with a concrete worked example.","decision":"advisory","finding_refs":["f6c596c8276b4933c","ff02f553b91e80f73"],"move_id":"6","move_name":"specification by example","subject":"docs AC coverage of four required items"},{"coaching":"Pin down defer-reason locked format template string with a concrete worked example.","decision":"advisory","finding_refs":["fd88cf9a3d0e01997"],"move_id":"6","move_name":"specification by example","subject":"defer-reason locked format template string"},{"coaching":"Weigh at least one structural alternative for MOVE_REGISTRY naming vs standalone function choice.","decision":"advisory","finding_refs":["f34ad51fbff255cc9"],"move_id":"5","move_name":"weigh alternatives","subject":"MOVE_REGISTRY naming vs standalone function choice"},{"coaching":"Plan how integration AC oracle independence and correctness will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f598e3df0a0df7e49"],"move_id":"9","move_name":"plan the verification","subject":"integration AC oracle independence and correctness"},{"coaching":"Plan how absent block_threshold AC for DET-tier advisories will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f185c37b32f2c414f"],"move_id":"9","move_name":"plan the verification","subject":"absent block_threshold AC for DET-tier advisories"},{"coaching":"Test the riskiest assumption behind actual block_threshold field provenance in decide.py first.","decision":"advisory","finding_refs":["f5f85da2aac75de6a","fec3d7e43f1bd9ef5"],"move_id":"4","move_name":"riskiest-assumption test","subject":"actual block_threshold field provenance in decide.py"},{"coaching":"Plan how triage propagation through failure-recovery bypass paths will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["fa9ce76136d3bbe07"],"move_id":"9","move_name":"plan the verification","subject":"triage propagation through failure-recovery bypass paths"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":8,"blocking":1,"dropped":15,"indeterminate":0},"det":{"P1":{"ac_items":7,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","probed":6,"ran":true,"references":6,"resolved":3,"status":"pass","unresolved_or_abstained":3},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":7,"blocking":false,"desc_chars":7293,"file_impact":4,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":7,"blocking":false,"name":"ac-quality","ran":true,"status":"pass","verify_commands_linted":84,"verify_lint_abstained":83},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":1839,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":4,"name":"file-impact-coverage","ran":true,"status":"pass"}},"floored_criteria":["E3","E5","T8"],"floored_finding_ids":["fd88cf9a3d0e01997","f34ad51fbff255cc9","f598e3df0a0df7e49","f185c37b32f2c414f"],"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":238.4,"llm_calls":29,"llm_ms":622707.1,"total_ms":623055.0,"verify_requests":38},"narrowed":true,"remediation":{"baseline":"sidecar","eligible":true,"reasons":{"code_unchanged":true,"plan_changed":true,"registry_unchanged":true,"sidecar_baseline":true,"within_window":true}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","G5","T2","T4","T5a","T5b","T5e","T6","T7","T9","hedge"]}},"findings":[{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add an AC (or extend AC5) that exercises the bespoke orchestrator path and asserts `verdict[\"triage\"]` is present and equal to `triage_advisories(surviving)` for that path, verifying the claimed symmetry.","cohort":["COH","E1","T4"],"criteria":["E1","COH"],"decision":"block","drop_reason":null,"evidence":["Scope: 'the bespoke orchestrator path is updated symmetrically for parity'","AC5: 'a test drives the plan_review_coach step with fixture findings and asserts verdict[\"triage\"]'","No AC references the bespoke orchestrator path or asserts parity between the two paths"],"finding":"The Scope section declares 'the bespoke orchestrator path is updated symmetrically for parity' as a deliverable, but no AC verifies that the bespoke orchestrator path actually sets verdict[\"triage\"] — the integration AC only exercises the plan_review_coach step via workflow_ops.py.","group_criteria":null,"group_id":null,"id":"fc19e5a047566bf67","impact":1.0,"is_primary":null,"location":"Scope section ('the bespoke orchestrator path is updated symmetrically for parity') vs AC5 ('drives the plan_review_coach step with fixture findings')","norm_id":"nbba12f3707251a4e","priority":1.0,"reason":"high-priority+criterion-opted-in","scenarios":["An implementer updates workflow_ops.py but forgets or incorrectly updates the bespoke orchestrator path; all ACs pass green but the orchestrator path silently omits verdict[\"triage\"] — the claimed parity is unverified."],"severity":"critical","suggested_fix":"Add an AC: 'Parity: the bespoke orchestrator path also sets verdict[\"triage\"] equal to triage_advisories(surviving); a test drives that path with the same fixture findings and asserts the triage array matches. Proving command: pytest tests/unit/test_plan_review_triage.py -k orchestrator_parity -q.'","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Clarify or remove the 'bespoke orchestrator path is updated symmetrically for parity' clause in Scope — the bespoke _run_passes coach path was retired (WS1); if a second live coach path still exists, name it explicitly (file + function); if not, remove this clause.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["orchestrator.py line 51-52: 'The bespoke _run_passes that invoked it here was retired in epic solid-timer-unison (WS1).'","No `run_review`, `_run_passes`, or pass4/coach function found in orchestrator.py via grep.","The only active coach assembly is in workflow_ops.py plan_review_coach (line 483), called through the gates/plan-review.yaml workflow."],"finding":"The plan's Scope section refers to updating 'the bespoke orchestrator path ... symmetrically for parity,' but the bespoke _run_passes/coach path was retired in epic solid-timer-unison (WS1). No separate live bespoke coach path exists in orchestrator.py — the only active coach path runs through the workflow step `plan_review_coach` in workflow_ops.py. This edit target is either ghosted (refers to retired code) or unresolvably ambiguous.","group_criteria":null,"group_id":null,"id":"f88815b375def9bf1","impact":0.85,"is_primary":null,"location":"Scope section: 'the bespoke orchestrator path is updated symmetrically for parity'","norm_id":"nd4be0324fd0b0e4d","priority":0.6611,"reason":"default-advisory","scenarios":["The implementer wastes time looking for a 'bespoke orchestrator coach path' to update that does not exist, or incorrectly touches orchestrator.py, adding dead code."],"severity":"critical","suggested_fix":"Remove the clause 'the bespoke orchestrator path is updated symmetrically for parity' from Scope, since the only active coach assembly path is workflow_ops.plan_review_coach. If parity with recovery paths is intended, call that out explicitly (see next finding).","tier":"LLM","validity":0.7778,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"low","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Extend the docs proving command to also check for the defer-reason format token and R7 mention, e.g. add `&& grep -q 'deferred: priority' docs/plan-review-gate.md && grep -q 'R7' docs/plan-review-gate.md`.","cohort":["E2","E6","F1"],"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":["AC text: 'document the triage stage, its ranking rule (the APPLY_NOW_MARGIN default, the ordering, and the defer-reason format), and the R7 dogfood expectation'","Grep command only checks two substrings; 'defer-reason format', 'ordering', and 'R7' are not asserted"],"finding":"The docs AC proving command (`grep -q \"APPLY_NOW_MARGIN\" ... && grep -q \"apply-now\" ...`) checks only two string tokens but the AC text requires the documentation to cover four distinct items: the triage stage, the ranking rule (APPLY_NOW_MARGIN default AND ordering), the defer-reason format, and the R7 dogfood expectation — the command would pass if only APPLY_NOW_MARGIN and 'apply-now' appear anywhere in the file.","group_criteria":null,"group_id":null,"id":"f6c596c8276b4933c","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — docs AC: '`grep -q \"APPLY_NOW_MARGIN\" docs/plan-review-gate.md && grep -q \"apply-now\" docs/plan-review-gate.md`'","norm_id":"n2fe276add7d02e29","priority":0.55,"reason":"default-advisory","scenarios":["An executor writes a one-sentence blurb containing 'APPLY_NOW_MARGIN' and 'apply-now' and the AC passes, with ordering rules and defer-reason format undocumented."],"severity":"major","suggested_fix":"Replace with: `grep -q 'APPLY_NOW_MARGIN' docs/plan-review-gate.md && grep -q 'apply-now' docs/plan-review-gate.md && grep -q 'deferred: priority' docs/plan-review-gate.md && grep -q 'R7' docs/plan-review-gate.md`","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E6"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The docs AC proving command (`grep -q 'APPLY_NOW_MARGIN' ... && grep -q 'apply-now' ...`) verifies only two string presences but the AC prose requires documenting four additional items: the ordering rule, the defer-reason format, and the R7 dogfood expectation — the command silently passes even if those are absent from the doc.","group_criteria":null,"group_id":null,"id":"ff02f553b91e80f73","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — 'docs/plan-review-gate.md documents…' bullet and its Proving Command","norm_id":"nda1a1fd5a0792ba3","priority":0.55,"reason":"default-advisory","scenarios":[],"severity":"major","suggested_fix":"Replace the single proving command with: `grep -q 'APPLY_NOW_MARGIN' docs/plan-review-gate.md && grep -q 'apply-now' docs/plan-review-gate.md && grep -q 'deferred: priority' docs/plan-review-gate.md && grep -q 'R7' docs/plan-review-gate.md && grep -q 'criteria\\[0\\]' docs/plan-review-gate.md`","tier":"LLM","validity":1.0,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Add orchestrator.py (or passes.py:pass4_coach + any direct finalize_verdict callers) to the Scope section and specify exactly where triage_advisories is called on the bespoke path to satisfy the 'symmetric parity' assertion.","cohort":["E4"],"criteria":["E4"],"decision":"advisory","drop_reason":null,"evidence":["Plan What section: 'the bespoke orchestrator path is updated symmetrically for parity'","Plan Scope section: lists 'src/rebar/llm/plan_review/passes.py', 'src/rebar/llm/plan_review/workflow_ops.py', 'tests/unit/test_plan_review_triage.py', 'docs/plan-review-gate.md' — orchestrator.py absent","passes.py:839 — pass4_coach is the bespoke entry point used by the orchestrator path, separate from workflow_ops.py:plan_review_coach","workflow_ops.py:483-540 — plan_review_coach is the workflow-ops path; the two paths produce the same verdict type but via different code"],"finding":"The plan asserts 'the bespoke orchestrator path is updated symmetrically for parity' but the Scope section does NOT list orchestrator.py or the bespoke passes.py:pass4_coach entry point as a file to be changed. The bespoke path (passes.py:pass4_coach → review_kernel.coach, called by orchestrator.py) is a separate call site from workflow_ops.py:plan_review_coach, and has its own verdict-assembly flow. Without an explicit scope entry for it, the symmetry claim is unverifiable from the plan — and if the bespoke path is not updated, the triage array will silently be absent on runs through that path.","group_criteria":null,"group_id":null,"id":"ffac0b48dcb311134","impact":0.85,"is_primary":null,"location":"What section ('the bespoke orchestrator path is updated symmetrically for parity') vs. Scope section (lists only passes.py, workflow_ops.py, tests, docs)","norm_id":"ncfecbe746b802e8a","priority":0.5312,"reason":"default-advisory","scenarios":["A run through the bespoke orchestrator (e.g., production_batch_runner.py or direct rebar.llm.plan_review calls) would return a verdict without verdict['triage'], silently breaking the claimed parity and leaving the agent without triage data on that path."],"severity":"critical","suggested_fix":"In the Scope section, add an entry for the bespoke path: e.g., 'src/rebar/llm/plan_review/orchestrator.py or passes.py:pass4_coach — invoke triage_advisories on the surviving advisory findings and attach the result to the verdict before returning, symmetric with the workflow_ops path.' Also add a corresponding integration AC that drives the bespoke path.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Name the bespoke path (`passes.pass4_coach`) explicitly in Scope and add an AC proving that the bespoke path also produces/passes through a `triage` result (or document it as explicitly out-of-scope if the bespoke path is test-only and intentionally left without triage).","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":null,"evidence":["Plan Scope: 'src/rebar/llm/plan_review/passes.py — the deterministic `triage_advisories(surviving)` pure function … and the `APPLY_NOW_MARGIN` constant.' No mention of modifying `pass4_coach`.","Code: `passes.pass4_coach` at passes.py:839 is the bespoke unit-test-only coach path, confirmed by its docstring: 'NOTE (8086): the live path is the workflow ops; this bespoke entry is unit-test-only'.","Plan AC5 (integration): only drives `plan_review_coach` (workflow_ops step) — no AC covers `pass4_coach`.","ABSENCE: no AC or scope line pins what 'symmetrically for parity' means for `pass4_coach`."],"finding":"The Scope says 'the bespoke orchestrator path is updated symmetrically for parity' but never names the file or function. Code confirms the bespoke path is `passes.pass4_coach` (in `passes.py`) — but `passes.py` is listed in Scope only for `triage_advisories` and `APPLY_NOW_MARGIN`, not for modifying `pass4_coach`. No AC verifies the bespoke path sets `verdict['triage']`.","group_criteria":null,"group_id":null,"id":"f12875d15a8e1f695","impact":0.85,"is_primary":null,"location":"Scope section ('bespoke orchestrator path is updated symmetrically for parity') / `src/rebar/llm/plan_review/passes.py:839` (`pass4_coach`)","norm_id":"nc3c1c3af8a53208a","priority":0.5312,"reason":"default-advisory","scenarios":["Executor modifies `workflow_ops.plan_review_coach` correctly but leaves `passes.pass4_coach` untouched; unit tests that exercise the bespoke path see no `triage` key; the plan's parity guarantee is unverifiable."],"severity":"critical","suggested_fix":"","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"missing_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Correct the 'block_threshold (decide.py, 0.60 under plan-review's routing)' claim to accurately reflect that block_threshold varies per-criterion (0.60–0.95 per criteria_routing.json) and that decide.py's DEFAULT_BLOCK_THRESHOLD is 0.95, which is the fallback only for DET findings lacking the field.","cohort":["E4"],"criteria":["E4"],"decision":"advisory","drop_reason":null,"evidence":["review_kernel/decide.py:53 — DEFAULT_BLOCK_THRESHOLD = 0.95","criteria_routing.json:10 — F1 block_threshold: 0.6","criteria_routing.json:100,253,539,648,726,755,866 — multiple other thresholds (0.6, 0.7, 0.75) in the routing config","Plan: 'triage_advisories reads it as f.get(\"block_threshold\", DEFAULT_BLOCK_THRESHOLD) — the 0.95 default applies when absent (already imported in passes.py)'"],"finding":"The plan asserts 'block_threshold is present on LLM-decided findings (decide.py, 0.60 under plan-review's routing)' — but decide.py's DEFAULT_BLOCK_THRESHOLD is 0.95, and the 0.60 threshold is defined only in criteria_routing.json (for criteria like F1). The parenthetical attribution '(decide.py, 0.60 under plan-review's routing)' conflates two separate sources: decide.py sets 0.95 as the default and the routing config sets 0.60 for some criteria. This matters because triage_advisories uses f.get('block_threshold', DEFAULT_BLOCK_THRESHOLD) where DEFAULT_BLOCK_THRESHOLD=0.95, meaning many LLM-decided findings (those from criteria with block_threshold=0.60) will carry 0.60 on the finding object — so the fallback to 0.95 is rarely triggered for LLM findings. The plan's claim that 'a DET advisory (priority 0.4) buckets defer' relies on the 0.95 default, which is correct only for DET findings. For LLM findings from low-threshold criteria (0.60), apply-now becomes priority >= 0.50 (0.60 - 0.10), not 0.85 — a different triage behavior than the reader might infer from the plan's narrative.","group_criteria":null,"group_id":null,"id":"f5f85da2aac75de6a","impact":0.0,"is_primary":null,"location":"What section — 'The ranking rule' paragraph: 'block_threshold is present on LLM-decided findings (decide.py, 0.60 under plan-review's routing)'","norm_id":"n6dce137c1c8767d5","priority":0.0,"reason":"default-advisory","scenarios":["An LLM-decided advisory from criterion F1 (block_threshold=0.60) with priority=0.55 would be 'apply-now' (0.55 >= 0.60-0.10=0.50), but a reader of the plan might not realize this since the plan presents 0.60 as the plan-review routing default rather than one of many per-criterion values.","The worked example in the plan ('DET advisory (priority 0.4) buckets defer') is correct but the framing of 0.60 as the canonical plan-review block_threshold is misleading — many criteria use 0.95."],"severity":"none","suggested_fix":"Revise the ranking-rule paragraph to: 'block_threshold is stamped on each LLM-decided finding by pass3_over_findings (sourced from criteria_routing.json — ranges from 0.60 to 0.95 by criterion); DET-tier advisories do not carry it, so triage_advisories reads it as f.get(\"block_threshold\", DEFAULT_BLOCK_THRESHOLD) where DEFAULT_BLOCK_THRESHOLD=0.95 (the kernel default, imported in passes.py).'","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Enumerate gate_dispatch.py's `_recover_plan_review_coach_failure` and `_recover_plan_review_verify_failure` in the Scope (or NOT-touched list with explicit rationale for why triage absence is acceptable on recovery paths).","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["gate_dispatch.py line 287: `_recover_plan_review_coach_failure` calls `orchestrator.finalize_verdict(pctx, parts, coaching=[], coverage=coverage, ...)` and returns the result directly — no triage step.","gate_dispatch.py line 385: `_recover_plan_review_verify_failure` similarly calls finalize_verdict and returns without triage.","Plan Scope: gate_dispatch.py is not mentioned in touched or not-touched files."],"finding":"Two verdict-assembly bypass paths in gate_dispatch.py — `_recover_plan_review_coach_failure` (line 287) and `_recover_plan_review_verify_failure` (line 331) — both call `orchestrator.finalize_verdict` directly and return a plan_review_verdict WITHOUT going through `plan_review_coach`. Neither is enumerated in the Scope or NOT-touched list. Verdicts produced via these recovery paths will silently omit `verdict[\"triage\"]`, creating inconsistent agent-visible output.","group_criteria":null,"group_id":null,"id":"fa9ce76136d3bbe07","impact":0.0,"is_primary":null,"location":"Scope section (NOT touched list) / src/rebar/llm/workflow/gate_dispatch.py lines 287-388","norm_id":"n71b8fe7fbe07e9c7","priority":0.0,"reason":"default-advisory","scenarios":["On a coach-step failure (which is treated as non-fatal), the recovered verdict is returned to the agent without a triage key, breaking the guarantee that 'the agent sees it at review time.'","On a verify-step failure (Pass-1 findings preserved unverified), same omission."],"severity":"none","suggested_fix":"Either add gate_dispatch.py to Scope with a note that recovery paths emit an empty `triage: []` (since surviving advisories may not be deterministically available in mid-tail recovery), or explicitly state in the plan that triage is absent on recovery verdicts and that this is intentional/acceptable.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E4"],"decision":"advisory","drop_reason":null,"evidence":[],"finding":"The plan asserts 'block_threshold (the criterion blocking waterline; always set on the decided finding — decide.py, 0.60 under plan-review's routing, DEFAULT_BLOCK_THRESHOLD=0.95 otherwise)'. The description '0.60 under plan-review's routing' is factually wrong: `criteria_routing.json` shows plan-review criteria with block_threshold values of 0.60 (F1, E4, A3, T8, T9), 0.70 (G6, T5, A4), 0.75 (G6-variant), and 0.95 (F4, G3, G4, E1, E2, E3, etc.) — the majority are 0.95, not 0.60.","group_criteria":null,"group_id":null,"id":"fec3d7e43f1bd9ef5","impact":0.0,"is_primary":null,"location":"What > The ranking rule — 'block_threshold (the criterion blocking waterline; always set on the decided finding — decide.py, 0.60 under plan-review's routing, DEFAULT_BLOCK_THRESHOLD=0.95 otherwise)'","norm_id":"nce4da235930ccb35","priority":0.0,"reason":"default-advisory","scenarios":[],"severity":"none","suggested_fix":"Replace '0.60 under plan-review's routing' with 'ranging from 0.60 to 0.95 depending on the criterion (see criteria_routing.json); verified against each finding's own recorded block_threshold field'. Re-evaluate whether APPLY_NOW_MARGIN=0.10 is the right default given that the majority of criteria use block_threshold=0.95.","tier":"LLM","validity":0.7143,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add `src/rebar/llm/plan_review/orchestrator.py` (or whichever file hosts the bespoke orchestrator path) as an explicit Scope bullet naming the exact function to update, so the executor has a complete file list.","cohort":["E2","E6","F1"],"criteria":["E2"],"decision":"dropped","drop_reason":null,"evidence":["'the bespoke orchestrator path is updated symmetrically for parity' — no file or function is listed in the Scope bullets for this second update","orchestrator.py is mentioned in the Mechanism section but is absent from the Scope file list"],"finding":"The Scope section says 'the bespoke orchestrator path is updated symmetrically for parity' but does not name the file or function, leaving the executor to infer the location from a passing mention in the Mechanism section.","group_criteria":null,"group_id":null,"id":"ff0b2efd708d776c3","impact":0.264,"is_primary":null,"location":"Scope bullet: `src/rebar/llm/plan_review/workflow_ops.py` paragraph, phrase 'the bespoke orchestrator path is updated symmetrically for parity'","norm_id":"n0e8415b20a6d4d3b","priority":0.132,"reason":"veto:absence-refuted","scenarios":["An executor implementing only `workflow_ops.py` misses the orchestrator path update, shipping inconsistent behavior between the two plan-review code paths."],"severity":"minor","suggested_fix":"Add a Scope line: `src/rebar/llm/plan_review/orchestrator.py — in the bespoke plan-review orchestration path (function name X), call triage_advisories on surviving advisories and set verdict[\"triage\"] before returning, mirroring the workflow_ops change.`","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add the bespoke orchestrator file path (the file that gets 'updated symmetrically') to the ## Scope section so the change surface is fully enumerated.","cohort":["T2","T5e","T7"],"criteria":["T5e","T7"],"decision":"dropped","drop_reason":null,"evidence":["Plan scope lists: passes.py, workflow_ops.py, tests/unit/test_plan_review_triage.py, docs/plan-review-gate.md","Plan body says: 'the bespoke orchestrator path is updated symmetrically for parity' — no file path given","ABSENCE: no file name for the bespoke orchestrator path appears in the Scope section"],"finding":"The 'bespoke orchestrator path is updated symmetrically for parity' modifies an unnamed file not listed in the Scope section, creating a gap between the plan's stated scope and the actual change surface.","group_criteria":null,"group_id":null,"id":"ff03559388ba8a932","impact":0.264,"is_primary":null,"location":"## Scope — 'workflow_ops.py' bullet; ## What — 'the bespoke orchestrator path is updated symmetrically for parity'","norm_id":"n88beaef8d0f10d40","priority":0.132,"reason":"veto:absence-refuted","scenarios":["A reviewer or implementer misses the orchestrator file change because it isn't in scope","The bespoke path diverges from workflow_ops.py behavior post-ship because it was overlooked during implementation"],"severity":"minor","suggested_fix":"Add a bullet to ## Scope, e.g.: `src/rebar/llm/plan_review/orchestrator.py` — invoke `triage_advisories` on surviving advisory findings and set `verdict['triage']` before returning, mirroring the workflow_ops.py change.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Either document that APPLY_NOW_MARGIN intentionally requires a code change to update (and explain why that is acceptable given R7 cadence), or promote it to an environment/config variable so R7 calibration can be applied without a redeploy.","cohort":["T2","T5e","T7"],"criteria":["T5e"],"decision":"dropped","drop_reason":null,"evidence":["'APPLY_NOW_MARGIN is a named module constant, default 0.10'","'validated post-ship by dogfooding via R7's advisory-application-latency metric'","AC7: 'no config flag' — explicitly rules out runtime configuration","ABSENCE: no plan to update the constant via a config file or environment variable when R7 data arrives"],"finding":"APPLY_NOW_MARGIN is a hardcoded module constant with no config/env override, yet the plan acknowledges it will be calibrated by R7 dogfood data — meaning the first calibration cycle requires a code change and redeploy rather than a config update.","group_criteria":null,"group_id":null,"id":"ffd81b4aac3c8a90a","impact":0.0,"is_primary":null,"location":"## What — 'APPLY_NOW_MARGIN is a named module constant, default 0.10'; ## Acceptance Criteria — AC7 'no config flag'","norm_id":"n349553bf3fd98d6c","priority":0.0,"reason":"low-validity","scenarios":["R7 data shows 0.10 is too tight or too loose; a calibration PR is needed for what amounts to a threshold change","The constant is updated inconsistently across environments (e.g., test fixtures still use 0.10 while prod needs 0.15)"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add the `triage` key (its type, shape, and presence guarantee) to the `_OUTPUT_SCHEMA` definition's inline comment or docstring, and/or to CLAUDE.md / a consumer-facing reference, so downstream code and agents can discover it without reading the internal gate doc.","cohort":["T2","T5e","T7"],"criteria":["T7"],"decision":"dropped","drop_reason":null,"evidence":["'the plan_review_verdict output schema has additionalProperties: true, so it validates with no schema change'","'NOT touched: sidecar.py / the plan_review_result_v2 schema'","ABSENCE: no mention of updating _OUTPUT_SCHEMA docstring, CLAUDE.md, or any agent-facing contract document to describe the new triage key","AC grep command only checks plan-review-gate.md"],"finding":"The plan adds `verdict['triage']` as a new top-level key to the returned plan-review verdict object — a contract change for downstream consumers (the agent, any code that inspects the verdict) — but no consumer-facing schema documentation (e.g., output schema docstring, CLAUDE.md, or schema comment) is updated to surface this new field; only the internal `plan-review-gate.md` is updated.","group_criteria":null,"group_id":null,"id":"f71987fef7060af8f","impact":0.0,"is_primary":null,"location":"## What — 'This array is attached to the returned verdict as a top-level key verdict[\"triage\"]'; ## Scope — docs/plan-review-gate.md","norm_id":"nd14a58284479e4ba","priority":0.0,"reason":"low-validity","scenarios":["A developer consuming the verdict dict doesn't know triage is available and re-implements the ranking logic","The schema's additionalProperties:true silently accepts triage but provides no discoverability; agents and future maintainers won't know to look for it without reading the internal doc"],"severity":"none","suggested_fix":"In `_OUTPUT_SCHEMA` (or wherever it is defined), add a comment: `# 'triage': list[TriageEntry] — present on every returned verdict; see docs/plan-review-gate.md for schema and bucketing rules.`","tier":"LLM","validity":0.4286,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Address the `_recover_plan_review_coach_failure` path in `gate_dispatch.py`: either call `triage_advisories` on the recovered `parts['surfaced']` set before returning the degraded verdict, or explicitly document that `verdict['triage']` is absent on coach-failure recovery paths and ensure all consumers treat it as optional (`verdict.get('triage', [])`). Add an AC or note covering this case.","cohort":["G6"],"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":["Plan scope: 'workflow_ops.py — in the plan_review_coach step, invoke triage_advisories … set verdict[\"triage\"] before the closing validate_structured(verdict, _OUTPUT_SCHEMA) return (the bespoke orchestrator path is updated symmetrically for parity). No other returned-result consumer changes.'","gate_dispatch.py line ~189: `recovered = _recover_plan_review_coach_failure(rec, cfg, error=res.error)` — this path calls `finalize_verdict` + `validate_structured` directly, never entering `plan_review_coach`","Plan claim: 'the agent sees it at review time' — unconditional, but the recovery path contradicts this","Integration AC only: 'drives the plan_review_coach step with fixture findings and asserts verdict[\"triage\"]' — no recovery-path test"],"finding":"The coach-failure recovery path (`_recover_plan_review_coach_failure` in `gate_dispatch.py`) bypasses `plan_review_coach` entirely and assembles a verdict via `finalize_verdict` + `validate_structured` directly — without ever calling `triage_advisories`. This means the returned verdict will lack `verdict['triage']` when Pass-4 fails but Pass-3 succeeded. The plan states 'the agent sees it at review time' unconditionally and scopes the change only to `plan_review_coach` and the bespoke `pass4_coach`, with no mention of this recovery path. The integration AC only tests the normal coach path, leaving the recovery-path gap undetected.","group_criteria":null,"group_id":null,"id":"fa9d1f67fa232c086","impact":0.0,"is_primary":null,"location":"Scope section / `src/rebar/llm/workflow/gate_dispatch.py` `_recover_plan_review_coach_failure`","norm_id":"ne2f8722693d3c899","priority":0.0,"reason":"low-validity","scenarios":["The Pass-4 coach prompt step fails (e.g. LLM refuses, structured-output contract violation) but Pass-3 succeeded — the gate_dispatch recovery path returns a verdict dict without `verdict['triage']`, while the agent or R7 consumer may expect it unconditionally.","An agent consuming the verdict keys the coaching decision logic on `verdict.get('triage') or []` and silently skips triage for a real review where advisories were ranked."],"severity":"none","suggested_fix":"In the Scope section, add `src/rebar/llm/workflow/gate_dispatch.py` — in `_recover_plan_review_coach_failure`, call `triage_advisories(parts['surfaced'])` and attach the result as `verdict['triage']` before the `validate_structured` return, paralleling the `plan_review_coach` change. Alternatively, explicitly document that triage is absent when coaching fails and note that consumers must use `verdict.get('triage', [])`.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Engage directly with the parent SotA §R6's recommended mechanism (a MOVE_REGISTRY coaching note prompting the author to triage) vs. this plan's auto-triage function: explain why *performing* the triage mechanically is expected to reduce advisory latency better than (or in addition to) *coaching* the author to triage, and address whether the two approaches are composable.","cohort":["T1"],"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":["Parent SotA §R6: 'Add a move to the registry (rendered deterministically, like all moves): \"Triage each surviving advisory into the plan before claiming: apply it, or record a one-line deferral rationale in the description\"'","Plan's Mechanism choice: 'It is NOT an entry in the Pass-4 MOVE_REGISTRY ... a single {subject} substitution cannot express a ranked two-bucket split across all surviving advisories'","coach.py MOVE_REGISTRY template mechanism is per-finding {subject} substitution — confirmed by code; but the parent's recommendation is a coaching note, not a triage algorithm","The plan never explains why mechanical triage (doing it for the author) is preferable to coached triage (prompting the author to do it) in terms of advisory-latency reduction"],"finding":"The plan's justification for diverging from the parent SotA's R6 mechanism conflates two different problems. The parent (docs/research/task-decomposition-sota-2026.md §R6) recommends a MOVE_REGISTRY coaching note that *prompts the author to triage* advisories ('Triage each surviving advisory into the plan before claiming'). The plan argues the MOVE_REGISTRY 'cannot express a ranked two-bucket split across all surviving advisories' — which is true, but is a strawman: the parent's recommended move doesn't perform the triage mechanically, it coaches the author to perform it. The plan never directly compares the two mechanisms' expected effects on advisory latency, nor explains why auto-triage outperforms (or complements) an author-directed coaching note, nor whether the two approaches are composable. The parent approach remains a viable alternative that was not genuinely weighed.","group_criteria":null,"group_id":null,"id":"fae2dc2fce13dbb5e","impact":0.0,"is_primary":null,"location":"What / Mechanism choice section","norm_id":"n108cc2db40854d6d","priority":0.0,"reason":"low-validity","scenarios":["If the root cause of advisory latency is author motivation/habit (not lack of knowing which advisory to apply), auto-triage may not help while a well-placed coaching note would. The plan ships without evaluating this.","The parent's coaching-note approach and the plan's auto-triage approach may be complementary; the plan doesn't consider whether both should be implemented."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify the fallback behavior for `verdict['triage']` when `_recover_plan_review_coach_failure` fires (e.g., emit `[]` via `triage_advisories([])` or omit the key with a documented intent), and add `gate_dispatch.py` to Scope if it requires modification.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Plan Scope: lists only `passes.py`, `workflow_ops.py`, `tests/`, and `docs/` — `gate_dispatch.py` is absent.","Plan What: 'the agent sees it at review time' — but the recovery path emits a valid `plan_review_verdict` WITHOUT going through `plan_review_coach`.","Code: `_recover_plan_review_coach_failure` at gate_dispatch.py:287 calls `finalize_verdict` + `validate_structured('plan_review_verdict')` directly; no `triage` key is set.","ABSENCE: no plan text specifies behavior of `verdict['triage']` when the coach step fails and recovery runs."],"finding":"The coach-failure recovery path (`_recover_plan_review_coach_failure` in `gate_dispatch.py`) calls `orchestrator.finalize_verdict` and `validate_structured` directly — bypassing `plan_review_coach` entirely — so the returned verdict never receives a `verdict['triage']` key on that path. The plan specifies no fallback, and `gate_dispatch.py` is not listed in Scope.","group_criteria":null,"group_id":null,"id":"f95c8923a4f8cd449","impact":0.0,"is_primary":null,"location":"Scope section / `src/rebar/llm/workflow/gate_dispatch.py:287` (`_recover_plan_review_coach_failure`)","norm_id":"nc739df728510b74c","priority":0.0,"reason":"low-validity","scenarios":["Pass-4 coach LLM call fails (e.g. model timeout); the recovery path fires and emits a verdict without `verdict['triage']`; the agent sees no triage — the 'advisory-triage coaching move' silently evaporates on coach failure."],"severity":"none","suggested_fix":"In `_recover_plan_review_coach_failure`, after `finalize_verdict`, add `verdict['triage'] = triage_advisories(list(parts.get('surfaced') or []))` before `validate_structured`; add a line to Scope noting the recovery path is updated symmetrically.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["E4"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The Scope section names the injection point as 'the `plan_review_coach_notes` step' (and the AC integration test also references 'the `plan_review_coach_notes` step'), but no such step exists in the codebase. The actual registered step is `plan_review_coach` (`@register_step('plan_review_coach', ...)` in `workflow_ops.py`). The YAML uses an inner step called `coach_notes` (a prompt step, not a uses-op) and the uses-op step is `plan_review_coach`.","group_criteria":null,"group_id":null,"id":"f1c8af0e6fdb40279","impact":0.0,"is_primary":null,"location":"Scope > workflow_ops.py bullet: 'in the `plan_review_coach_notes` step'; AC > Integration AC bullet: 'a test drives the `plan_review_coach_notes` step'","norm_id":"n16102321b8824ab5","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":[],"severity":"none","suggested_fix":"Replace 'the `plan_review_coach_notes` step' with 'the `plan_review_coach` step (the `plan_review_coach` function in `workflow_ops.py`)' in both the Scope bullet and the integration AC proving description.","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"no","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan names `plan_review_coach_notes` as the step to modify in `workflow_ops.py` and as the target of the integration AC, but no such step exists. The actual registered step is `plan_review_coach` (registered at `workflow_ops.py:472` via `@register_step('plan_review_coach', ...)`). The plan uses the wrong step name throughout the Scope section and AC5.","group_criteria":null,"group_id":null,"id":"f178965903537f536","impact":0.0,"is_primary":null,"location":"Scope section ('in the `plan_review_coach_notes` step') and AC5 ('a test drives the `plan_review_coach_notes` step')","norm_id":"nacf2916b2fc3abd8","priority":0.0,"reason":"veto:cited-reference-inaccurate","scenarios":[],"severity":"none","suggested_fix":"Replace every occurrence of `plan_review_coach_notes` with `plan_review_coach` in the Scope and AC5 descriptions.","tier":"LLM","validity":0.2857,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"no","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan asserts 'block_threshold (the criterion blocking waterline; always set on the decided finding — decide.py)' as a universal invariant, but DET-tier advisory findings stamped by `partition_findings` in orchestrator.py carry only {priority, validity, impact, severity, tier} — they have NO `block_threshold` field. The `triage_advisories` bucketing formula (`priority >= block_threshold - APPLY_NOW_MARGIN`) is therefore undefined for DET-tier advisories, and the plan specifies no fallback for a missing `block_threshold`.","group_criteria":null,"group_id":null,"id":"fcea00bd2cd9fb183","impact":0.0,"is_primary":null,"location":"What > The ranking rule / Mechanism choice rationale; src/rebar/llm/plan_review/orchestrator.py `partition_findings` (lines 398-450)","norm_id":"n9b600b769c2ca337","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"In the ranking-rule section, add: 'A finding without a `block_threshold` field (e.g., a DET-tier advisory) uses the plan-review gate posture default of 0.60 as its fallback, matching the threshold the LLM criteria are judged against.' This keeps DET advisories triageable without introducing a new field on the DET findings or changing `partition_findings`.","tier":"LLM","validity":0.1875,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"","cohort":null,"criteria":["T1"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The plan asserts that `block_threshold` is 'always set on the decided finding — decide.py, 0.60 under plan-review's routing, DEFAULT_BLOCK_THRESHOLD=0.95 otherwise' — making this a grounding fact `triage_advisories` can rely on for bucketing. However, DET-tier advisory findings (P4, P6, P7, P9, and project DET criteria advisories) are minted by `partition_findings` in `orchestrator.py` with hardcoded `priority: 0.4` but NO `block_threshold` field, because they bypass `pass3_decide` entirely. Only LLM-tier findings go through `pass3_decide`, which always echoes back `block_threshold`. The bucketing rule `priority >= block_threshold - APPLY_NOW_MARGIN` would silently fail (e.g. `None - 0.10` raises a TypeError) or produce wrong results for every DET-tier advisory finding in the triage input.","group_criteria":null,"group_id":null,"id":"f448f91cb54cbacca","impact":0.0,"is_primary":null,"location":"## What — 'The ranking rule (fully specified, grounded in real fields)' + src/rebar/llm/plan_review/orchestrator.py partition_findings (lines 412-424)","norm_id":"nbcd62eefe4a481d3","priority":0.0,"reason":"veto:absence-refuted","scenarios":[],"severity":"none","suggested_fix":"In `partition_findings`, add `'block_threshold': DEFAULT_BLOCK_THRESHOLD` (or a DET-specific sentinel like `1.0`) to the DET advisory finding shape, so `triage_advisories` always has a numeric `block_threshold` to compare against. Alternatively, in `triage_advisories`, fall back to `DEFAULT_BLOCK_THRESHOLD` when the field is absent: `bt = f.get('block_threshold', DEFAULT_BLOCK_THRESHOLD)`.","tier":"LLM","validity":0.1875,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Replace the illustrative English example in the 'Defer reason' spec with a formal template string (e.g., the exact f-string) and specify the numeric precision/rounding rule so AC1's test can assert against the canonical format.","cohort":["T8"],"criteria":["T8"],"decision":"advisory","drop_reason":"novelty","evidence":["Plan quote: 'Built only from the finding's own numbers, e.g. `deferred: priority 0.32 is 0.28 below its 0.60 block line` — fixed words + recorded numbers, no LLM prose, non-prescriptive.'","The gap value (0.28) is derived as `block_threshold - priority`; neither the rounding precision (2 decimal places? `round(x,2)`? `:.2f`?) nor the exact token ordering is formalized.","AC1 proving command: `pytest -k determinism` — but the test can only verify byte-identity across two runs of the SAME implementation, not that the implementation matches a spec.","ABSENCE: no formal template string (e.g., `f'deferred: priority {priority:.2f} is {gap:.2f} below its {block_threshold:.2f} block line'`) appears anywhere in the plan."],"finding":"The defer-reason 'locked format' is specified only by a single English illustration (`deferred: priority 0.32 is 0.28 below its 0.60 block line`) — no formal template string, no precision rule, and no rounding specification. AC1 asserts 'every `reason` string matches the locked format' but provides no machine-checkable reference format for the test to compare against.","group_criteria":null,"group_id":null,"id":"fd88cf9a3d0e01997","impact":0.536,"is_primary":null,"location":"What section ('Defer reason') / AC1 ('every `reason` string matches the locked format')","norm_id":"n210ed4f35d9d7fbf","priority":0.3829,"reason":"default-advisory","scenarios":["Two implementors independently write `triage_advisories`; one uses `:.2f` and the other uses `:.4f` rounding — both pass AC1's determinism test but produce different outputs; the 'locked format' is not actually locked across implementations."],"severity":"major","suggested_fix":"Add to the plan: `reason = f\"deferred: priority {priority:.2f} is {block_threshold - priority:.2f} below its {block_threshold:.2f} block line\"` and note that all floats are formatted to 2 decimal places.","tier":"LLM","validity":0.7143,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Correct the plan title's parenthetical from '(pass-4 registry)' to something like '(pass-4 coach path, pre-registry)' or '(pass-4 standalone stage)' to match the documented mechanism choice.","cohort":["E3","G5","T6"],"criteria":["E3"],"decision":"advisory","drop_reason":"novelty","evidence":["Title: 'advisory-triage coaching move (pass-4 registry, ship-first)'","Plan body: 'It is NOT an entry in the Pass-4 MOVE_REGISTRY (in passes.py, re-exported by orchestrator.py).'","The parenthetical '(pass-4 registry)' directly contradicts the chosen implementation mechanism."],"finding":"The plan title names '(pass-4 registry)' implying the implementation registers an entry in MOVE_REGISTRY, but the plan body explicitly rejects MOVE_REGISTRY and ships a standalone pure function instead. A reader (or agent) relying on the title for context will expect a registry-entry implementation.","group_criteria":null,"group_id":null,"id":"f34ad51fbff255cc9","impact":0.264,"is_primary":null,"location":"Plan title: 'R6: advisory-triage coaching move (pass-4 registry, ship-first)' vs. Mechanism Choice section","norm_id":"na80e5e835f239b79","priority":0.132,"reason":"default-advisory","scenarios":["An agent reading only the title/summary may scaffold a MOVE_REGISTRY entry rather than a standalone pure function, producing wrong implementation structure.","A reviewer assessing conformance to the title will flag the implementation as non-conforming when it is actually correct."],"severity":"minor","suggested_fix":"Rename to: 'R6: advisory-triage coaching move (pass-4 coach path, ship-first)' — dropping 'registry' since the plan explicitly avoids the MOVE_REGISTRY.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"low","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Replace the integration AC's tautological assertion (`verdict[\"triage\"] == triage_advisories(surviving)`) with an assertion against a hardcoded expected triage array computed from known fixture findings, so the test actually validates correctness of bucket assignment and wiring.","cohort":["E5"],"criteria":["E5"],"decision":"advisory","drop_reason":"novelty","evidence":["\"a test drives the `plan_review_coach` step with fixture findings and asserts `verdict[\\\"triage\\\"]` equal to `triage_advisories(surviving)` for that run\"","The AC compares the live result against a call to the function under test on the same input — this is definitionally tautological; a hardcoded expected triage array derived from known fixture values is required to be a meaningful behavioral test."],"finding":"The integration AC specifies asserting `verdict[\"triage\"]` equal to `triage_advisories(surviving)` for the same run — this is a tautological self-authored oracle that proves nothing about correctness; both sides call the same function on the same data, so the test passes even if triage_advisories is completely wrong.","group_criteria":null,"group_id":null,"id":"f598e3df0a0df7e49","impact":0.0,"is_primary":null,"location":"Acceptance Criteria — Integration AC: 'a test drives the `plan_review_coach` step with fixture findings and asserts `verdict[\"triage\"]` equal to `triage_advisories(surviving)` for that run'","norm_id":"n618f1c1d2f5b15d8","priority":0.0,"reason":"default-advisory","scenarios":["triage_advisories produces wrong bucket assignments — the integration test still passes because both sides of the assertion are wrong in the same way","plan_review_coach wires the wrong surviving-advisory subset into triage_advisories — the test still passes"],"severity":"none","suggested_fix":"Define a small fixture of 2–3 findings with known priority/block_threshold values, compute the expected triage array by hand, and assert `verdict[\"triage\"] == expected_triage` — separately verify that `plan_review_coach` passes the correct surviving-advisory subset by checking the array length and ids match the fixture's advisory-only findings.","tier":"LLM","validity":0.7143,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add parametrized test cases to `test_plan_review_triage.py` covering (a) a finding with no `block_threshold` field (DET-tier scenario, should use DEFAULT_BLOCK_THRESHOLD=0.95 and bucket to `defer` at priority 0.4) and (b) `triage_advisories([])` returning an empty list.","cohort":["E5"],"criteria":["E5"],"decision":"advisory","drop_reason":"novelty","evidence":["\"DET-tier advisories stamped by `partition_findings` (`orchestrator.py`) do **not** carry it, so `triage_advisories` reads it as `f.get(\\\"block_threshold\\\", DEFAULT_BLOCK_THRESHOLD)` — the 0.95 default applies when absent\"","No AC parametrizes or otherwise tests a finding that is missing the `block_threshold` field — all ACs use implicit full-field findings.","The plan also notes the empty-surviving-advisory-list case is possible (a round with no surviving advisories) with no AC for `triage_advisories([])`."],"finding":"No AC covers the `triage_advisories` behavior when `block_threshold` is absent from a finding — a scenario the plan explicitly specifies as real (DET-tier advisories stamped by `partition_findings` do not carry `block_threshold`) — leaving the `f.get(\"block_threshold\", DEFAULT_BLOCK_THRESHOLD)` fallback path untested.","group_criteria":null,"group_id":null,"id":"f185c37b32f2c414f","impact":0.0,"is_primary":null,"location":"Acceptance Criteria (all ACs) vs. Mechanism section: 'DET-tier advisories stamped by `partition_findings` (`orchestrator.py`) do **not** carry it, so `triage_advisories` reads it as `f.get(\"block_threshold\", DEFAULT_BLOCK_THRESHOLD)`'","norm_id":"n847c2b29a95ddedc","priority":0.0,"reason":"default-advisory","scenarios":["A DET-tier advisory is present in the surviving set — the wrong bucket is assigned if the fallback is misimplemented, but no test catches it","A round completes with zero surviving advisories — `triage_advisories([])` raises or returns unexpected output with no test catching it"],"severity":"none","suggested_fix":"In the boundary or advisory_only parametrized test, include a finding dict without a `block_threshold` key and assert the bucket is `defer` (priority 0.4 < 0.95 − 0.10 = 0.85); add a one-liner test `assert triage_advisories([]) == []`.","tier":"LLM","validity":0.75,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"f37e85ad73a91bb4","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":238.4,"llm_calls":29,"llm_ms":622707.1,"total_ms":623055.0,"verify_requests":38},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"5dac-c177-56ff-4af4","ticket_type":"story","verdict":"BLOCK","verified_at_sha":"43d1545237745f4666dcc13c81587c824251e51d"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784254698163027001,"uuid":"50ae2125-0139-4ad9-8d22-b501192a33cf"}