25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"5f842e5deeb79baf36a7b1dbf66b849c188c23cc4bb430a65301afd446515817","event_uuid":"740a18ff-759a-49bc-81a2-46596fcc0177","position":{"commit_sha":null,"position":"1784239636379671001-740a18ff-759a-49bc-81a2-46596fcc0177"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"1df20b1fcf135fc8bc194c16578a410e9c4adeba2c3dcd1f97498ff37a5a5329","event_uuid":"8e70eb7e-3330-47f4-9eaa-eb91c0dd0964","position":{"commit_sha":null,"position":"1784239971388950001-8e70eb7e-3330-47f4-9eaa-eb91c0dd0964"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"87df4c52cdfab500087f7829001e82f00e28ab859f7f8c932f9980f53e2fa5bf","event_uuid":"c43cb72a-f93a-4262-b6f2-c555e4d9d063","position":{"commit_sha":null,"position":"1784240285679592780-c43cb72a-f93a-4262-b6f2-c555e4d9d063"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"903322164eaf7ca82a53c36b16c0c50f550b3d66b97b98df987a1abf431de122","event_uuid":"dfe9f8ae-6b44-4a19-8d61-bb4e0ab84a52","position":{"commit_sha":null,"position":"1784256514287289001-dfe9f8ae-6b44-4a19-8d61-bb4e0ab84a52"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-211_agent","claim_remote_session":null,"claimed_session":"e533bbc2-be02-4c77-890b-73fde9abf109","comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"ENFORCE_SINCE ANCHOR DECIDED (for the 8d39 flip to consume verbatim): 8dcef776c3dd9e68935b74b82137e1ffd8f04f10\n\nRationale: an EXISTING tickets-branch commit (a gate-exempt session_log marker, so the boundary commit itself carries no enforceable event), chosen AFTER the pre-flip validation window confirmed write-signing is live across ALL active writers — local (global build kickstarted to main 43d1545 + venv), CI reconciler (signs via its own inline seam), Gerrit review-bot (LINK via append_event), the enrich drain (TICKET_DIGEST/DONE_ENRICH signed), the completion verifier (COMPLETION_VERDICT signed), and the previously-blocking concurrent agent session 5c2eef83 (now writing SIGNED STATUS after updating its build). Semantics (verify_authorship._is_enforced: git merge-base --is-ancestor <anchor> <commit>): every event whose introducing commit is a STRICT ancestor of the anchor is grandfathered (all ~5100 pre-signing historical + mixed-build unsigned events); the anchor commit and its descendants are enforced (all newly-signed). rebar.toml is NOT modified by this story (8d39 writes enforce_since once). AC1 verification (verify-identity --all --require-authenticated --since 8dcef776c3dd9e68935b74b82137e1ffd8f04f10 exits 0) running.","timestamp":1784256514287289001}],"created_at":1784226824784773001,"deps":[],"description":"## Why\n\nFlipping `identity.require_authenticated` with a wrong or self-referential `enforce_since`\nwould either fail the gate on legitimate historical unsigned events, or be impossible to pin\n(the boundary cannot be the flip commit — the flip is a code commit on `main`, whereas\n`enforce_since` is a ref on the `tickets` tracker branch, and it must exist *before* it is\nreferenced). This story remediates the grandfathering check and **decides** the boundary\nanchor; it does **not** write it (the atomic-flip story 8d39 writes `enforce_since` exactly\nonce, so there is no double-write).\n\n## What\n\n- **Verify the grandfathering logic** in `src/rebar/_commands/verify_authorship.py` and\n  `src/rebar/_config_schema.py`: `_is_enforced(commit_sha, since_ref, tracker)`\n  (`verify_authorship.py:262-282`) enforces an event iff its introducing commit is `since_ref`\n  or a descendant (`git merge-base --is-ancestor <since_ref> <commit>` exit 0), fail-closed;\n  `grandfathered = not enforced` is emitted per non-verified event (`:500-521`); the run exits\n  non-zero iff `required` and `enforced_not_verified > 0` (`:464`, `:542-559`). `enforce_since`\n  is the `identity.enforce_since` config key (`_config_schema.py:336-342`, coerced `_as_str`\n  `:580`), overridable by `--since` / `REBAR_IDENTITY_ENFORCE_SINCE` (`verify_authorship.py:465`).\n- **Add a regression test** (`tests/unit/test_identity_enforce_since_grandfather.py`) that closes the\n  coverage gaps the held-out oracle leaves: drive the boundary through the **config/env path**\n  (`identity.enforce_since` / `REBAR_IDENTITY_ENFORCE_SINCE`), not just the `--since` flag, and\n  assert per-event `grandfathered` flags in a **single mixed store**. It builds one temp store\n  with a pre-boundary unsigned event AND a post-boundary unsigned/forged in-scope event, sets\n  the boundary between them, and asserts: overall exit non-zero (post-boundary enforced), the\n  pre-boundary entry has `grandfathered: true`, the post-boundary entry `grandfathered: false`;\n  plus a second store with only the pre-boundary unsigned event asserting exit 0. Uses the\n  established harness (`repo` fixture, `_keypair`, forge recipe, in-process\n  `verify_authorship.cli`). Proving command: `make test` (the new test passes).\n- **Decide and document the enforcement-boundary anchor**: an **existing** `tickets`-branch\n  commit at which write-signing is confirmed live across **all** writers (local 79da, CI 4dc0,\n  Gerrit-side 1a51). Method: after those three stories confirm signing, choose the anchor as a\n  `tickets`-branch commit that **every** pre-signing unsigned event strictly precedes — i.e. a\n  commit introduced *after* signing is live across all writers (so all unsigned history is a\n  strict ancestor → grandfathered, and every event at/after the anchor is signed). Verify with\n  `rebar verify-identity --all --require-authenticated --since <candidate>` exit 0 (zero\n  enforced-unverified events); if any event at/after the candidate is unverified, advance the\n  candidate past it (or fix that writer) and re-check. Record the chosen 40-hex SHA + rationale\n  on this ticket for 8d39 to consume verbatim.\n\n## Scope\n\nThe grandfathering boundary check + a regression test + the boundary decision/rationale.\nWriting `enforce_since` into `rebar.toml` and the flag flip both belong to 8d39 — this story\ndoes **not** modify `rebar.toml` (verified: the change touches only the new test file under\n`tests/`). `file_impact`: the new test file.\n\n## Acceptance Criteria\n\n- [ ] **The chosen anchor grandfathers all pre-signing history.** Every event whose introducing\n      commit is a **strict ancestor** of the anchor is grandfathered; the **anchor commit itself\n      and its descendants are enforced** (`_is_enforced` uses `git merge-base --is-ancestor\n      <anchor> <commit>`, which exits 0 when `commit == anchor`, so the anchor commit is\n      enforced). The anchor must therefore be a commit that **every** pre-signing unsigned event\n      strictly precedes. Proving command:\n      `rebar verify-identity --all --require-authenticated --since <anchor>` exits 0 (zero\n      enforced, non-verified events).\n- [ ] **A regression test asserts both directions.** A synthetic **unsigned** event before the\n      boundary PASSES (grandfathered, gate exit 0) and a new unsigned/forged in-scope event\n      after the boundary FAILS (enforced, non-zero) — driven via the `identity.enforce_since`\n      config/env path and asserting the per-event `grandfathered` flag. Proving command:\n      `make test` runs green (and the specific new test:\n      `pytest tests/unit/test_identity_enforce_since_grandfather.py -q` exits 0).\n- [ ] **The anchor is chosen and recorded; `rebar.toml` is untouched.** Let `A` = the decided\n      40-hex boundary SHA (an **existing** `tickets`-branch commit, NOT the flip commit).\n      Proving commands: `git -C .tickets-tracker cat-file -t \"$A\"` prints `commit` (the anchor\n      exists on the tickets branch); a comment on this ticket records `A` + its rationale\n      (`rebar show 8d91-5103-ae1b-44a7 | jq -e --arg s \"$A\" '[.comments[].body]|any(contains($s))'`\n      exits 0); and `git diff --stat origin/main..HEAD -- rebar.toml` shows no change (this\n      story's change touches only the new test file).","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_commands/verify_authorship.py","reason":"grandfathering logic verified (_is_enforced, exit path)"},{"path":"src/rebar/_config_schema.py","reason":"enforce_since config plumbing"},{"path":"tests/unit/test_identity_enforce_since_grandfather.py","reason":"the new regression test"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","dc09-6565-cf85-4aea"]],"parent_id":"dc09-6565-cf85-4aea","parent_status_uuid":"6e7a1351-3efc-42d5-b294-9649dbdf8da1","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"8d91-5103-ae1b-44a7","ticket_type":"story","title":"Verify and repin identity.enforce_since so pre-flip events are grandfathered","verify_commands":[]},"source_event_uuids":["c5921f57-ace6-4297-acc0-8de35ec2b433","0f0ed287-d239-4c01-9281-b196e7a3ae8d","6c086210-eff6-46eb-9c60-c3d1220b4622","03839f79-694a-4c82-a3fe-1ae2c45c49e1","d9287133-d212-4c92-b9e9-96a923164e7c","dfbe7378-2c61-4f00-b1a8-94f6f38aeae0","996db446-d969-4da6-9de2-142eef0d1286","740a18ff-759a-49bc-81a2-46596fcc0177","8e70eb7e-3330-47f4-9eaa-eb91c0dd0964","6e7a1351-3efc-42d5-b294-9649dbdf8da1","f851ac14-41a1-46ea-9d3b-1fa007a56a03","c43cb72a-f93a-4262-b6f2-c555e4d9d063","dfe9f8ae-6b44-4a19-8d61-bb4e0ab84a52"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784256514287289002,"uuid":"ffa66ee8-ceee-4559-a155-d8a4cd45ec4c"}