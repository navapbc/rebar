{"author":"Joe Oakhart","author_email":"joeoakhart@navapbc.com","data":{"compacted_at":1784346125557109001,"compiled_state":{"alias":"dedicated-married-ptarmigan","assignee":"","attestations":{"plan-review":{"algorithm":"sshsig","author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","envelope":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.opcert.v1+json\", \"signatures\": [{\"keyid\": \"ade0f2ef-51cc-45a2-bb97-c09846cd3df5\", \"sig\": \"\"}]}","head_sha":"ba2fb1dd4fd2cfb3c464cecbb17b66854f446a8b","key_id":null,"kind":"plan-review","manifest":["plan-review: PASS","ticket: 8d91-5103-ae1b-44a7","material: 9b0d62ae6ea31b55","model: claude-sonnet-4-6","runner: pydantic_ai","blocking: 0","advisory: 4","rebar-version: 0.8.0 (ba2fb1dd4)","regver: b293b9a55de591cc","verified-at-sha:6b25dbead186639a436b1d5faf7cb03e99001efc","dep 9a229c6a1b259a9d6f8f0c59b1f8949ac4e56c26c7fbaf1027202244ad046fc6 src/rebar/_commands/verify_authorship.py","dep 506332bfe57d303af0934f7f83f3e4296d16c1b0b750003871a48b7569831ddf src/rebar/_config_schema.py","dep absent tests/unit/test_identity_enforce_since_grandfather.py"],"material_fingerprint":"9b0d62ae6ea31b55","merged_log_commit":"6b25dbead186639a436b1d5faf7cb03e99001efc","principal":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","signature":null,"signed_at":1784239971388605000}},"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","authorship":{"signed":9,"unsigned":8},"authorship_ledger":[{"content_hash":"08a96c8234deeeebfc256a64ac2426049f47b1f182a381fd5e76cd647f515219","event_uuid":"1019cab3-79dd-4a98-a341-5b521fd6b531","position":{"commit_sha":"faf055c87a637b98d6edd85fc0ea29798b0e723a","position":"1784238101244786001-1019cab3-79dd-4a98-a341-5b521fd6b531"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"d69192e52539a0937f6af03877132d5df31d2a54349ceae17cd28b4617ef41ac","event_uuid":"996db446-d969-4da6-9de2-142eef0d1286","position":{"commit_sha":"8d4dfeb92982fa4ace62bf31a06d155ba8f1bc2a","position":"1784238786368036001-996db446-d969-4da6-9de2-142eef0d1286"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"476b358bb64fd6707345480572e6d4b3c27709d7a80763ee78a25e94603cce8c","event_uuid":"9289462e-db04-46ea-8b12-ee3bdde505b7","position":{"commit_sha":"fcea2d0f194442aab125fad4761d7cf516d85df5","position":"1784239143254078001-9289462e-db04-46ea-8b12-ee3bdde505b7"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"5f842e5deeb79baf36a7b1dbf66b849c188c23cc4bb430a65301afd446515817","event_uuid":"740a18ff-759a-49bc-81a2-46596fcc0177","position":{"commit_sha":"6c0352fae4c825d8c70312130b9dd1868ce522fc","position":"1784239636379671001-740a18ff-759a-49bc-81a2-46596fcc0177"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"dce5029193d0f23ecbc9b6e9fe2090092ac4b5188f3ae17d1386473e3fcdf76c","event_uuid":"9844adf1-3860-4880-aa2a-63eff76d6547","position":{"c