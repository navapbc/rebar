AAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"c6ae572735dfb7de8a49f4398f20d78e3acd26ed20346992152fc54206b35ec2","event_uuid":"2fca5a45-ef36-4274-b9b8-da926ea160cd","position":{"commit_sha":"433995507915c56475b6c3acf0083f8d0e3898bf","position":"1784653112489715376-2fca5a45-ef36-4274-b9b8-da926ea160cd"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"0c73cf46feeefd36d92edc0510e8262c0ae5692ce6c963fa12b355f3fcbd30fd","event_uuid":"08805a72-7cd2-45f6-9e00-423bba58c334","position":{"commit_sha":"215b836bc2b18603e1eef7ec1952c10095a98d5f","position":"1784653296604360001-08805a72-7cd2-45f6-9e00-423bba58c334"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":null,"claim_remote_session":null,"claimed_session":null,"comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"REBAR-DEBUG DIAGNOSIS (2026-07-21)\n\nReproduced on current origin/main: open task count=2, open story count=35, but --type=task,story count=0.\n\nRoot cause: src/rebar/_engine_support/reads_cli.py passes the entire --type value through as one string. src/rebar/reducer/_filters.py applies match_predicate(..., \"type\", \"eq\", type_filter), so \"task,story\" is treated as one impossible ticket type. Unlike status/priority/tag paths, no CSV normalization or set-membership predicate exists. The list help also advertises only a singular type.\n\nMinimal corrective seam: parse type CSV once at the query boundary, filter by membership with OR semantics across CLI/library parity, document the syntax, and add an interface regression asserting the union plus single-type backward compatibility.\n\nNo code changed during this diagnostic run.","timestamp":1784653296604360001}],"created_at":1784582967214058001,"creation_channel":"cli","deps":[],"description":"`rebar list --type=<t>` only matches a single type. Passing a comma-separated list (e.g. `--type=task,story`) returns `[]` (no matches) rather than the union of the two types.\n\nContrast with --status, --priority, --has-tag, and --without-tag, whose help text explicitly documents comma-separated OR semantics. --type silently does not, so a caller expecting OR semantics gets an empty result with no error — the most confusing failure mode.\n\nAcceptance criteria:\n- `rebar list --status=open --type=task,story` returns the union of open tasks and open stories (not []).\n- Behavior matches the OR semantics already used by --status/--priority/--has-tag.\n- --type help text documents the comma-separated OR behavior.\n- Unit/interface test covers the multi-type case.\n\nRepro:\n  rebar list --status=open --type=task,story   # -> [] today; should be union\n  rebar list --status=open --type=task          # -> N tasks\n  rebar list --status=open --type=story          # -> M stories\n\nDiscovered while listing parentless open task/story tickets (had to query each type separately and merge with jq).","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[],"parent_id":null,"parent_status_uuid":"1c6b4e81-4a9f-4839-933e-3df927ee05a0","preconditions_summary":{"status":"pre-manifest"},"priority":3,"reverts":[],"status":"in_progress","tags":["cli","list"],"ticket_id":"5055-26a9-a0c7-4683","ticket_type":"bug","title":"list --type does not accept a comma-separated list of types","verify_commands":[]},"source_event_uuids":["3ebaa5db-6fba-4a96-a7ec-b87f77b0f0e4","1c6b4e81-4a9f-4839-933e-3df927ee05a0","dc61f18e-951c-4ddc-82c6-71e956b84676","2fca5a45-ef36-4274-b9b8-da926ea160cd","08805a72-7cd2-45f6-9e00-423bba58c334"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784653296604360002,"uuid":"e049d02a-5374-4f4d-8de6-4f5a4c865200"}