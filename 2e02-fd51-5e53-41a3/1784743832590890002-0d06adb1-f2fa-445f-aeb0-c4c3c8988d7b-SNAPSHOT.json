oad\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"17bbbb55ec621d75a3e4f89de56d5fb3d91050b1a78dab93db1b08de5e2fab63","event_uuid":"df7ed45c-5dff-47b8-9243-0cb795c307e5","position":{"commit_sha":"43fb3a7e2fcf9bd424e6ecec36f27cad18c86d76","position":"1784743832253275001-df7ed45c-5dff-47b8-9243-0cb795c307e5"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"2b41e17c4f8623862fed7efaabb8da37b71579fcf6ba669c5b49b216c714d507","event_uuid":"15a3ecd8-8628-4985-868b-1b7f7dc57a64","position":{"commit_sha":"43fb3a7e2fcf9bd424e6ecec36f27cad18c86d76","position":"1784743832590890001-15a3ecd8-8628-4985-868b-1b7f7dc57a64"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-217_agent","claim_remote_session":null,"claimed_session":"8bacf5df-1e8b-4a65-9e59-597bfeb19e5f","comments":[],"created_at":1784743189359611001,"creation_channel":"cli","deps":[],"description":"# Refresh exact-pinned dev tooling: zizmor + ruff\n\nBump two exact `==` pins in `pyproject.toml`'s `[dev]` extra to current, un-yanked releases.\n\n## Why\n- **zizmor 1.27.0 is YANKED** for GHSA-f42p-wjw5-97qh (Moderate, CWE-532): 1.27.0 prints\n  GitHub tokens (`GH_TOKEN`/`GITHUB_TOKEN`/`ZIZMOR_GITHUB_TOKEN`) to stderr under `-v`/debug\n  logging. Only 1.27.0 is affected; the fix is 1.28.0. rebar's `make lint` invokes `zizmor\n  release.yml` with no verbose flag, so there is no live exposure, but pinning exactly to a\n  security-yanked release is fragile (a stricter resolver / pruned cache can fail installs).\n- **ruff 0.15.19 -> 0.15.22**: routine patch refresh to stay current on the format/lint pin\n  (exact-pinned for local<->CI parity). No yank/security; grouped here as a low-risk sibling.\n\n## Plan\n1. `pyproject.toml`: change the pin line `zizmor==1.27.0` -> `zizmor==1.28.0`.\n2. `pyproject.toml`: change the pin line `ruff==0.15.19` -> `ruff==0.15.22`.\n3. Reinstall the dev extra so the worktree venv has the new tools.\n4. Run `make lint`; if the newer ruff reformats anything, apply `ruff format` and include the\n   diff so CI format-check stays green. Run `make typecheck`.\n5. One commit, `rebar-ticket` trailer + DCO sign-off; push to Gerrit; land after\n   `LLM-Review +1` AND `Verified +1`.\n\nNote: the pin comment block above zizmor does not mention a specific version string, so no\ncomment edit is required — only the pin line itself changes.\n\n## Acceptance Criteria\n- [ ] `pyproject.toml` pins `zizmor==1.28.0` — verify: `grep -c 'zizmor==1.28.0' pyproject.toml` returns 1 and `grep -c 'zizmor==1.27.0' pyproject.toml` returns 0.\n- [ ] `pyproject.toml` pins `ruff==0.15.22` — verify: `grep -c 'ruff==0.15.22' pyproject.toml` returns 1 and `grep -c 'ruff==0.15.19' pyproject.toml` returns 0.\n- [ ] `make lint` exits 0 in the worktree venv (ruff check + format-check + zizmor + actionlint).\n- [ ] `make typecheck` exits 0 in the worktree venv.\n- [ ] `git diff --name-only origin/main` lists only `pyproject.toml` (plus any file ruff-format rewrote), no unrelated files.\n- [ ] [operator-attested] The change is merged to `main` via Gerrit with `LLM-Review +1` and `Verified +1` (evidence: the merged change's Gerrit vote record; out-of-session).","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"pyproject.toml","reason":"Bump zizmor==1.27.0->1.28.0 and ruff==0.15.19->0.15.22 exact pins in the [dev] extra and refresh the stale 1.27.0 pin comment"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[],"parent_id":null,"parent_status_uuid":"df7ed45c-5dff-47b8-9243-0cb795c307e5","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"2e02-fd51-5e53-41a3","ticket_type":"task","title":"Bump zizmor 1.27.0->1.28.0 (yanked/GHSA) and ruff 0.15.19->0.15.22","verify_commands":[]},"source_event_uuids":["6a97832f-6c42-47c4-8da2-be78a7084854","2afa976b-8c86-4b7e-9574-9f29feec1ea4","645a55cd-0e04-43e5-9bde-ef59cc188737","f1048fa2-a4db-4406-a157-1dc9b3614006","8615c602-6302-49e3-ac8e-509795847cc7","df7ed45c-5dff-47b8-9243-0cb795c307e5","15a3ecd8-8628-4985-868b-1b7f7dc57a64"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784743832590890002,"uuid":"0d06adb1-f2fa-445f-aeb0-c4c3c8988d7b"}