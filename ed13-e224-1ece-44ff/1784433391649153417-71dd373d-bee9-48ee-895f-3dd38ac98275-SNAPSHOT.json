e3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"6bd00a99d2add862945ea953d0683805a4f3628efd48441e42782b15714a9819","event_uuid":"ab2889e3-e646-48d3-8590-b8f27b80b2a2","position":{"commit_sha":"d35e7f86331d90720a4965839feaf73da5eff1a9","position":"1784433157461300001-ab2889e3-e646-48d3-8590-b8f27b80b2a2"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"455d37c0e911dec879c2aebbb3f9b14541c294ccaf234284289d82fff9fb60e9","event_uuid":"6f1b56d6-dbd7-423e-8e40-b5b14fe634a8","position":{"commit_sha":"f8e1d9df0ef22ac618c74bd62851e7e8df216704","position":"1784433391649153416-6f1b56d6-dbd7-423e-8e40-b5b14fe634a8"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-214_agent","claim_remote_session":null,"claimed_session":"6e3fbad8-702f-4987-ad70-cc88122eea43","comments":[],"created_at":1784416767932856001,"creation_channel":"cli","deps":[],"description":"## What\nPersist a bounded bug-classification enum at close, replacing today's validated-then-discarded free-text `--reason`. Adds a REQUIRED `--class` param to `transition` for bug closes and folds `close_class` into reduced ticket state so it survives and is queryable, with the vocabulary that feeds the classification metrics.\n\n## Files\n- `src/rebar/_commands/transition.py` — parse a new `--class <value>` flag in `_parse_flags` (alongside `--reason`).\n- `src/rebar/_commands/txn.py` — validate the enum for bug closes (replacing `bug_close_reason_ok` at the transition_core guard, ~line 221-232) and write `close_class` into `status_data`.\n- `src/rebar/_commands/transition_close.py` — CRITICAL: the `_completion_precheck` guard at line ~121 also calls `txn.bug_close_reason_ok(reason)`; update it to accept a valid `close_class` (or skip the reason pre-check when `close_class` is supplied). Thread `close_class` through the close path.\n- `src/rebar/reducer/_processors.py` — CRITICAL: `process_status` only folds a fixed set of keys; add a `_fold_close_class(state, data)` helper (mirroring `_fold_claimed_session`) that sets `state['close_class'] = data['close_class']` on a `*->closed` edge, called in BOTH the fork-winner and normal-update branches — otherwise `close_class` never surfaces into reduced state and `rebar show` cannot see it.\n- `src/rebar/schemas/ticket_state.schema.json` — add optional `close_class`.\n- `src/rebar/_cli/help/transition.txt`, `docs/ticket-model.md`, `docs/user-guide.md` — document the enum.\n- `tests/interfaces/lifecycle/test_bug_close_class.py` — new.\n\n## Approach\nThe bug-close reason is required today but never persisted (`txn.py` validates then drops it), so replacing it with a bounded, folded enum is friction-neutral-to-negative and turns wasted input into a hard signal. `--class` is REQUIRED on bug close (mirrors the old required `--reason`): omitting it exits nonzero with a message listing the allowed values. Because `status_data` keys are not auto-surfaced, the enum only reaches `rebar show` via an explicit `_fold_close_class` fold — the exact-parallel of `_fold_claimed_session`. The guard lives at two sites (`txn.py` transition_core AND `transition_close.py` `_completion_precheck`), both updated. Closed MECE vocabulary with an escape + hygiene values: `regression`, `plan_defect`, `env_integration`, `flaky`, `preexisting`, `not_a_bug`, `duplicate`, `escalated`, `undetermined`. `escalated` preserves today's Escalated branch; the rest refine Fixed. Additive/optional schema field (readers tolerate absence); back-out = stop requiring/writing it.\n\n## Tests\n- CLI (real subprocess): closing a bug with `--class regression` persists and surfaces `close_class=regression`; omitting `--class` exits nonzero; an invalid class is rejected; `undetermined` is accepted.\n\n## Acceptance Criteria\n- [ ] `tests/interfaces/lifecycle/test_bug_close_class.py` passes: `rebar transition <bug> in_progress closed --class regression` exits 0 and `rebar show <bug> --output json | jq -e '.close_class==\\\"regression\\\"'` matches (proving the fold reaches reduced state).\n- [ ] closing a bug with NO `--class` exits nonzero AND the captured stderr names at least one allowed value (asserts `exit != 0` AND `result.stderr` contains an enum value name, e.g. the string `regression`) — so the \"message names the allowed values\" UX claim is actually measured, not just the exit code.\n- [ ] a value outside the enum is rejected with a nonzero exit — CLI test asserts exit != 0.\n- [ ] closing with `--class undetermined` succeeds (escape value) — CLI test asserts exit 0.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_commands/transition.py","reason":"--class flag"},{"path":"src/rebar/_commands/txn.py","reason":"validate + write close_class"},{"path":"src/rebar/_commands/transition_close.py","reason":"_completion_precheck guard + thread"},{"path":"src/rebar/reducer/_processors.py","reason":"_fold_close_class into reduced state"},{"path":"src/rebar/schemas/ticket_state.schema.json","reason":"optional close_class"},{"path":"src/rebar/_cli/help/transition.txt","reason":"doc"},{"path":"docs/ticket-model.md","reason":"doc"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","86ac-086a-20ad-4327"]],"parent_id":"86ac-086a-20ad-4327","parent_status_uuid":"4e1be718-d5c2-4e9e-a517-7a6e096e66b5","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":["metrics","schema"],"ticket_id":"ed13-e224-1ece-44ff","ticket_type":"task","title":"Persist a bug close --class enum (replacing the discarded reason)","verify_commands":[]},"source_event_uuids":["794bfb4e-4e2e-4863-9d21-895169b9566d","215f8444-843c-45b4-b542-b6e1cc54fa63","06b39b33-d4f4-475a-a894-a1ca98dc7429","bbbd5c52-25f6-482e-b28c-aba95cb9608d","8b86a98e-7383-48cb-bbd1-ab21b4b1fef7","331927f5-2c60-49d0-814b-a5c53629c69c","4e1be718-d5c2-4e9e-a517-7a6e096e66b5","ab2889e3-e646-48d3-8590-b8f27b80b2a2","6f1b56d6-dbd7-423e-8e40-b5b14fe634a8"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784433391649153417,"uuid":"71dd373d-bee9-48ee-895f-3dd38ac98275"}