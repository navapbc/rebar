resolution defect, then passed on the first complete run after the fix landed, with all cases firing/not-firing as expected at stability 1.0."]},"digest_hash_version":1,"model":"claude-opus-4-8","schema":"ticket_digest_v1"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"TICKET_DIGEST","timestamp":1784259703800866001,"uuid":"83c93de9-3d90-4787-8c4d-22bd3616e4d3"}