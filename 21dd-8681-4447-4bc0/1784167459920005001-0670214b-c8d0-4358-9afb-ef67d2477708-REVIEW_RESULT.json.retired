f_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Resolve the AC 15 proof command: either add `tests/unit/test_project_portability_criterion.py` to the plan's Scope with a description of what it must contain, or remove it from the `pytest` invocation and rely solely on `tests/unit/test_project_portability_eval.py`.","cohort":["E4"],"criteria":["E4"],"decision":"dropped","drop_reason":null,"evidence":["Search for 'test_project_portability_criterion' returns zero hits in tests/unit/.","The plan's Scope section names only `tests/unit/test_project_portability_eval.py` — `test_project_portability_criterion.py` is never mentioned anywhere else in the plan.","AC 15 proof command: '.venv/bin/pytest -q tests/unit/test_project_portability_criterion.py tests/unit/test_project_portability_eval.py' requires the file to exist to pass.","Cache entries at .rebar/cache/plan-review/21dd-*/64bd40cb*.json and 1822eb01*.json independently flagged the same gap in prior review runs."],"finding":"`tests/unit/test_project_portability_criterion.py` is referenced as a proof artifact in AC 15 but does not exist in the codebase and is out of scope for this plan.","group_criteria":null,"group_id":null,"id":"f543d33ba7e96ac51","impact":0.0,"is_primary":null,"location":"Acceptance Criteria, AC 15: 'Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_criterion.py tests/unit/test_project_portability_eval.py`'","norm_id":"nf1a6030682de2587","priority":0.0,"reason":"veto:absence-refuted","scenarios":["When the implementer runs the AC 15 proof command, pytest will fail with a 'file not found' error because `test_project_portability_criterion.py` is not created by this plan.","A reviewer checking completion gate AC 15 cannot attest it because the required test file does not exist and is not in scope to create."],"severity":"none","suggested_fix":"If `test_project_portability_criterion.py` is a pre-existing file authored by the dependency ticket (`immune-floury-toad`), state that explicitly with 'Exists from dependency ticket' rather than implying this plan creates it. If it doesn't exist there either, remove it from the proof command and prove the rubric-marker AC via `test_project_portability_eval.py` instead.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Clarify whether `tests/unit/test_project_portability_criterion.py` is provided by the dependency ticket (and state this explicitly), or remove it from the AC 15 pytest invocation and replace it with the file that IS in scope (`test_project_portability_eval.py` alone).","cohort":["G1G2"],"criteria":["G1G2"],"decision":"dropped","drop_reason":null,"evidence":["Scope section names only `tests/unit/test_project_portability_eval.py`; `test_project_portability_criterion.py` is absent.","Filesystem search for `test_project_portability_criterion` returns only cache/plan-review JSON hits (prior review comments flagging this same issue), never a source file.","No section of the plan describes creating or modifying `test_project_portability_criterion.py`.","The file's absence means AC 15's pytest invocation will fail immediately at collection time if this ticket is implemented as written."],"finding":"`tests/unit/test_project_portability_criterion.py` is referenced in the final AC (AC 15) as a required proof artifact, but this file does not exist in the repository, is absent from the plan's Scope section, and is never described as something this ticket creates.","group_criteria":null,"group_id":null,"id":"f3fa5abe725046fb7","impact":0.0,"is_primary":null,"location":"Acceptance Criteria — final bullet: 'Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_criterion.py tests/unit/test_project_portability_eval.py`'","norm_id":"ne26079a0530235cf","priority":0.0,"reason":"veto:absence-refuted","scenarios":["Implementer runs the AC 15 proof command and pytest aborts with a 'no such file' collection error before running any tests.","The dependency ticket ('criterion-integration child') may own this file, but the plan never states that — leaving AC 15 unverifiable until both tickets ship."],"severity":"none","suggested_fix":"Change the AC 15 proof command to `.venv/bin/pytest -q tests/unit/test_project_portability_eval.py` (the only test file in this ticket's scope), and add a note that `test_project_portability_criterion.py` is a prerequisite delivered by the dependency ticket `immune-floury-toad`.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Clarify the gold_set label vocabulary and its purpose: if kappa judge-alignment is intended, add a cross-family llm-judge scorer and specify 'useful'/'not_useful' labels consistent with existing gold_sets; if the gold_set is purely documentary, state that explicitly so the AC test is honest about what it proves.","cohort":["G6"],"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":["Plan specifies: 'a non-empty input plus a matching finding or pass label'","Existing plan-review-finder.eval.yaml gold_set uses labels: 'useful'/'not_useful' aligned to llm-judge kappa","validate_dataset_and_gold only checks that 'input' and 'label' fields are non-empty — no label-vocabulary enforcement","The spec declares only one deterministic scorer (emits_valid_findings) and no llm-judge scorer, so judge_alignment() cannot run on this gold_set","calibrate_criterion() computes kappa over fire/no-fire expected/observed vectors (not gold_set labels) — the gold_set kappa mechanism is separate and unused without a judge"],"finding":"The gold_set label vocabulary specified in the Approach ('finding' or 'pass' label) is inconsistent with existing gold_sets in the codebase (which use 'useful'/'not_useful' for llm-judge kappa alignment), and since the spec declares only one deterministic scorer with no llm-judge, the gold_set serves no kappa-alignment function — making it structurally present but semantically inert. The plan doesn't explain what the gold_set labels will be used for or how kappa will be computed.","group_criteria":null,"group_id":null,"id":"f9c7327806129fa86","impact":0.33,"is_primary":null,"location":"Approach section — gold_set specification; AC: 'Every gold entry carries a non-empty input plus the expected label'","norm_id":"n8a9ea2e68c55a417","priority":0.1237,"reason":"veto:cited-reference-inaccurate","scenarios":["Implementer writes gold entries with 'finding'/'pass' labels; validate_eval_spec passes (labels are non-empty); but there is no judge scorer to consume them — the gold_set is dead weight and the AC is satisfiable with any non-empty label strings","A later maintainer adds a judge scorer and inherits mismatched label vocabulary, breaking kappa alignment"],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"no","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Add a brief positive rationale to the Approach for why a standalone project-criterion override file (rather than tagged cases in the existing finder corpus) is the right structure — e.g., isolation of the portability corpus, enabling dedicated override-resolution testing, and avoiding coupling generic finder eval metrics to a project-specific axis.","cohort":["G6"],"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":["Plan text: 'Use the existing project eval override path proven by src/rebar/llm/eval_specs/README.plan-review.md'","No explanation of why a dedicated override file is preferable to tagging portability cases into plan-review-finder.eval.yaml with 'criterion: project.portability'","Absence of a 'why it fits' rationale for the chosen approach shape"],"finding":"The Approach provides no positive rationale for why a standalone `.rebar/evals/plan-review-project-portability.eval.yaml` override file is the right shape — it only cites that the override path 'is proven by' the README. The plan should state WHY this structure fits (e.g., isolation of project-criterion corpus from the generic finder eval, per-criterion override resolution testing, avoiding metric coupling).","group_criteria":null,"group_id":null,"id":"fa90fc645f045136f","impact":0.0,"is_primary":null,"location":"Approach section — first paragraph","norm_id":"n3d225588a7eaee89","priority":0.0,"reason":"low-validity","scenarios":["An implementer encountering the plan without codebase context cannot distinguish a deliberate structural decision from an arbitrary one, making future changes (e.g., merging portability cases into the finder) harder to evaluate"],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Either add `tests/unit/test_project_portability_criterion.py` to the Scope (and describe what it tests) or replace AC 15's prove command with one that uses only in-scope files; if the file belongs to a dependency ticket, name that dependency explicitly.","cohort":["G6"],"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":["AC 15: 'Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_criterion.py tests/unit/test_project_portability_eval.py`'","Scope section lists: 'tests/unit/test_project_portability_eval.py' only","test_project_portability_criterion.py is not mentioned in the Scope, Approach, or any other section of this plan","Cache findings already flagged this: 'AC 15's proving command references tests/unit/test_project_portability_criterion.py, a file that does not appear in the Scope section'"],"finding":"The final AC (AC 15) proves its assertion using `tests/unit/test_project_portability_criterion.py`, a test file that does not appear anywhere in the plan's Scope section (which lists only `tests/unit/test_project_portability_eval.py`). The plan provides no story for how or when this file is created — it may belong to a sibling ticket (immune-floury-toad), but that dependency is implicit, not stated.","group_criteria":null,"group_id":null,"id":"f687cf6bc9d6dabdc","impact":0.0,"is_primary":null,"location":"Acceptance Criteria — AC 15; Scope section","norm_id":"nd4d39f4ec0f2492b","priority":0.0,"reason":"veto:absence-refuted","scenarios":["Implementer completes all in-scope work but cannot run AC 15's prove command because test_project_portability_criterion.py doesn't exist","If the file is created by a dependency ticket, the dependency relationship is not declared in the Dependencies section"],"severity":"none","suggested_fix":"If test_project_portability_criterion.py is delivered by the immune-floury-toad criterion-authoring ticket, add that ticket to the Dependencies section and note AC 15 depends on it. Alternatively, change the prove command to use only `tests/unit/test_project_portability_eval.py`.","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Confirm that the model string `anthropic:claude-sonnet-4-6` is a valid, available Anthropic API identifier (e.g. by cross-checking Anthropic's model list or substituting the already-verified `anthropic:claude-opus-4-8` used in existing packaged evals) before committing the eval spec.","cohort":["T3"],"criteria":["T3"],"decision":"dropped","drop_reason":null,"evidence":["Approach states: 'model: anthropic:claude-sonnet-4-6'","Existing packaged spec `plan-review-finder.eval.yaml` line 11: 'model: anthropic:claude-opus-4-8' — a different snapshot format","No repo file confirms the claude-sonnet-4-6 snapshot name is accepted by the Anthropic API","Evidence class: Unverified — the specific model surface is new relative to what the existing evals use"],"finding":"The model string `anthropic:claude-sonnet-4-6` used in the eval spec is an external Anthropic API snapshot whose exact identifier is unverified from repo sources. Existing packaged eval specs use `anthropic:claude-opus-4-8`; no repo file confirms `claude-sonnet-4-6` is a valid/available API model name. If the snapshot string is wrong or the model is unavailable, the operator-attested live-run AC silently fails with an API error rather than a calibration result.","group_criteria":null,"group_id":null,"id":"faecdf69b09b390a2","impact":0.0,"is_primary":null,"location":"Approach section, model field: `model: anthropic:claude-sonnet-4-6`; also AC line: `Prove with .venv/bin/rebar criteria eval project.portability --runs 3 --output json`","norm_id":"nfaca84c2fef26f1a","priority":0.0,"reason":"low-validity","scenarios":["The live `rebar criteria eval project.portability --runs 3 --output json` call returns an API model-not-found error, leaving the operator-attested AC permanently unattestable without a model name fix."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.3333,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Clarify in the Approach which kappa computation fulfills the `>= 0.70` threshold: state explicitly whether it is `calibrate_criterion`'s Cohen κ over the 8 fire/no-fire expected-vs-observed labels (requires no judge), or a `judge_alignment()` kappa over the gold_set (requires an llm-judge scorer), and align the eval spec's scorer list accordingly.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Plan: 'The release threshold is recall 1.0, false-accept rate 0.0, agreement: 1.0, per-case stability >= 0.6666666667, and Cohen kappa >= 0.70'","Plan: 'The eval spec declares one deterministic emits_valid_findings scorer' — no llm-judge scorer is mentioned","calibrate_criterion (eval.py:484-485) returns kappa = cohens_kappa(expected, observed) — this is fire/no-fire agreement kappa, not judge-vs-gold","judge_alignment() (eval.py:362-375) computes judge-vs-gold kappa and requires a judge producing labels — but no judge is in the spec","The gold_set labels 'finding'/'pass' match ISF/G7 convention and imply judge alignment, yet no judge is defined to produce labels for comparison"],"finding":"The plan specifies 'Cohen kappa >= 0.70' as a release threshold but never defines which kappa computation this refers to — `calibrate_criterion` computes kappa as the fire/no-fire agreement between expected and observed labels (not a judge-vs-gold kappa), yet the gold_set in this eval spec carries `finding`/`pass` labels that imply a judge-alignment kappa. The eval spec has only one scorer (`emits_valid_findings`) with no llm-judge, so `judge_alignment()` is never invoked. The kappa source is ambiguous: is it `calibrate_criterion`'s Cohen κ over 8 fire/no-fire cases, or a separate judge-alignment computation?","group_criteria":null,"group_id":null,"id":"f60021c53fff22230","impact":0.44,"is_primary":null,"location":"Approach section — 'The release threshold is … Cohen kappa >= 0.70'; gold_set definition; 'one deterministic emits_valid_findings scorer'","norm_id":"n6a0faeb01e5c47ef","priority":0.165,"reason":"low-validity","scenarios":["An implementer computes kappa from calibrate_criterion (8 cases, fire/no-fire agreement) and reports it — with 4 must-fire + 4 must-not-fire perfect cases, kappa = 1.0 >= 0.70, threshold trivially met.","An implementer reads 'kappa' as requiring judge_alignment() over gold_set and tries to wire a judge — but no judge is in the spec, so they must add one, contradicting 'one deterministic scorer'."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"yes","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["E6"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"AC 9's git diff proving command restricts the diff to a specific set of paths, so it cannot prove the negative claim that no OTHER file outside those paths was modified by calibration; the command returns an empty or single-file result even when unrelated files were also changed, silently passing the check.","group_criteria":null,"group_id":null,"id":"f1cc5bb62978002ab","impact":0.0,"is_primary":null,"location":"Acceptance Criteria — AC 9: 'Any calibration-driven edit touches only...'","norm_id":"nd667b5afab869d14","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"```bash\n# Passes only when no calibration-scoped file outside the prompt was touched\ngit diff --name-only origin/main...HEAD \\\n  | grep -E '^(\\.rebar/prompts/|src/rebar/llm/|\\.rebar/criteria_routing\\.json)' \\\n  | grep -v 'plan-review-project-portability\\.md' \\\n  && echo 'FAIL: unexpected file touched' && exit 1 || echo 'PASS'\n```","tier":"LLM","validity":0.25,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"","cohort":null,"criteria":["G7"],"decision":"dropped","drop_reason":null,"evidence":[],"finding":"The parent's AC for indigoid-unmystic-serpent explicitly requires a test key '-k finding_contract' ('proves every must-fire case yields the four-part finding contract … Verify: .venv/bin/pytest -q tests/unit/test_project_portability_eval.py -k finding_contract'). The leaf never specifies or creates a test named 'finding_contract'; its closest AC uses '-k counterexample_metadata', which checks that four metadata fields are non-empty but does not prove the finding itself carries the four-part contract (citation, alternate shape, causal mechanism, observable breakage). The parent AC is unrepresented in the leaf.","group_criteria":null,"group_id":null,"id":"f2c4dfaa4c9dcd06b","impact":0.0,"is_primary":null,"location":"Leaf Acceptance Criteria — 'counterexample_metadata' AC; Parent AC 'indigoid-unmystic-serpent proves every must-fire case yields the four-part finding contract'","norm_id":"n6080806c183cfee5","priority":0.0,"reason":"low-validity","scenarios":[],"severity":"none","suggested_fix":"Add a leaf AC: '[ ] Every must-fire case's inline `input` plan includes language that would produce a finding carrying all four parts of the contract (plan citation, alternate client shape, causal mechanism, observable breakage). Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_eval.py -k finding_contract`.' Then implement the corresponding test.","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"na","cited_reference_accurate":"na","claims_absence":"no","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"insufficient","no_existing_mitigation":"insufficient","no_viable_alternative_explanation":"insufficient","path_reachable":"insufficient","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}}],"impact_model_version":"plan-v3","material_fingerprint":"1604b73666da1a78","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":197.4,"llm_calls":28,"llm_ms":553026.1,"total_ms":553354.0,"verify_requests":23},"model":"claude-sonnet-4-6","regver":"b293b9a55de591cc","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"21dd-8681-4447-4bc0","ticket_type":"story","verdict":"PASS","verified_at_sha":"22d4c788abd591690c4b4efbf94abe3ceba7294f"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784167459920005001,"uuid":"0670214b-c8d0-4358-9afb-ef67d2477708"}