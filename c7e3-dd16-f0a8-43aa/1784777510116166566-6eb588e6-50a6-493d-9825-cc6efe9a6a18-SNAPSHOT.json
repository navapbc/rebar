AAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"3b678f8ba30a2eab17fd624ab8330df20d8e8555d177327948094643b48e9397","event_uuid":"2cef8a9e-43d1-4671-809b-0df9f87e8c6f","position":{"commit_sha":"9687d739a3c96cccc08312bc2dbde330f629b8a0","position":"1784777348963303001-2cef8a9e-43d1-4671-809b-0df9f87e8c6f"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"1c2dffe4b5e9b241dd18d6262e11ae8ab8e5eb0540c6d0d46cda277bba796178","event_uuid":"ec295312-49cf-4cff-9a05-040a98d7b49a","position":{"commit_sha":"721bb47a206db16a93aef430b850bb08f2eb3968","position":"1784777354403544001-ec295312-49cf-4cff-9a05-040a98d7b49a"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"c580470529255ec36f056ad4356b596b0485ed935996a15cf67f3279b448a280","event_uuid":"caf8da15-656c-41c8-a158-2f3bf06ba866","position":{"commit_sha":"1724dd93d120ede14e504b1222a92324236a71d4","position":"1784777510116166565-caf8da15-656c-41c8-a158-2f3bf06ba866"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-218_agent","claim_remote_session":null,"claimed_session":"b07d4e18-e059-4f55-821a-9c0f549cbca9","comments":[],"created_at":1784776527067355001,"creation_channel":"cli","deps":[],"description":"## Problem\nIn a consumer repo (rebar installed, no rebar docs/ tree), every coaching deep-link in review-plan output points to a nonexistent local file, so the documented 'follow the link to understand the criterion you failed' affordance is dead out of the box.\n\n## Root cause (confirmed against installed v0.10.0)\nconfig.plan_review_docs_url() defaults to (repo_root()/'docs'/'plan-review-criteria-guide.md').as_uri() = file://<consumer-repo>/docs/plan-review-criteria-guide.md when REBAR_DOCS_URL is unset. orchestrator coaching builds guide_url from that base. src/rebar/config.py:67-74; orchestrator ~line 578. (The 'rebar explain' COMMAND was separately fixed in c2bfbe217 by packaging guides; the deep-link URL default was not.)\n\n## Fix\nDefault plan_review_docs_url to a canonical published URL (the upstream hosted docs for the criteria guide) rather than a consumer-repo file:// path, still overridable by REBAR_DOCS_URL. Links then resolve for consumers by default.\n\n## Acceptance criteria\n- With REBAR_DOCS_URL unset and cwd a consumer repo (no docs/ tree), plan_review_docs_url() returns a canonical http(s) URL, not a file:// path under the consumer repo.\n- REBAR_DOCS_URL still overrides.\n- A unit test asserts the default is a canonical hosted URL (not file://); asserting the old file:// default would FAIL.\n\n## Verification\npytest asserting the default scheme is http(s) and anchors resolve as <url>#<criterion-id>.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/config.py","reason":"default deep-link base URL to canonical hosted docs, not consumer file://"},{"path":"tests/unit/test_plan_review_docs_url.py","reason":"RED: default is a hosted URL, not file://"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","56c0-1d2f-f39c-4ac1"]],"parent_id":"","parent_status_uuid":"587bed85-9cc7-4d02-af63-8a3c48beb8d0","plan_review_phase":"execution","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"c7e3-dd16-f0a8-43aa","ticket_type":"bug","title":"plan-review coaching deep-links resolve to a file:// path in the consuming repo (dead for consumers)","verify_commands":[]},"source_event_uuids":["ae776fb3-eb2d-40ef-9d96-97050e705fcf","106100a4-1d1e-42e9-b124-b7485e42dd25","587bed85-9cc7-4d02-af63-8a3c48beb8d0","2cef8a9e-43d1-4671-809b-0df9f87e8c6f","ec295312-49cf-4cff-9a05-040a98d7b49a","caf8da15-656c-41c8-a158-2f3bf06ba866"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784777510116166566,"uuid":"6eb588e6-50a6-493d-9825-cc6efe9a6a18"}