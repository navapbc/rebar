AAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"502788e88c370b937d380f9104f4312a37bcc976dbf3fbfbe2a21391aef69953","event_uuid":"a3b54df1-1e56-4253-9856-c8ae3a94cb5d","position":{"commit_sha":"3b1d4e43599c1acdde3d43b637119aba6408ccec","position":"1784323967864534001-a3b54df1-1e56-4253-9856-c8ae3a94cb5d"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"c760451d8f037b0c5d209937697ed7413ac108d63c717666b81f2f64680eb374","event_uuid":"900dfc3b-fa65-4288-bc6a-d837ae8922d2","position":{"commit_sha":"070f6a166df9767f9e6c462fcfb4713861010f22","position":"1784324696887006252-900dfc3b-fa65-4288-bc6a-d837ae8922d2"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-212_agent","claim_remote_session":null,"claimed_session":"55c70753-24a8-4b2d-90cb-dd5398675082","comments":[],"created_at":1784315464791562001,"creation_channel":"cli","deps":[],"description":"## Why / Summary\n\nOutbound comment sync is non-idempotent: `get_comments()` fetches only the FIRST\nPAGE of a Jira issue's comments, so the dedup in `_diff_comments` re-posts every\nlocal comment outside that page on every reconcile pass. Over time this inflated 13\nJira issues to the 5000-comment hard cap (local truth: 22-76 comments each); once\ncapped, further comment adds fail `COMMENTS_PER_ISSUE_LIMIT_EXCEEDED` — and because\nacli returns exit 0 on that FAILURE, the failure is swallowed as a silent no-op.\n\n## Root cause (proven)\n\n`get_comments()` in BOTH `src/rebar/_engine/rebar_reconciler/acli_cli_ops.py:516`\nand `src/rebar/_engine/rebar_reconciler/acli.py:653` invokes\n`acli jira workitem comment list --key <k> --json` with NO `--paginate` and NO\n`--limit`. acli defaults to `--limit 50`, `--order +created` (oldest first), so the\ncall returns only the 50 OLDEST comments — despite both docstrings claiming \"Get all\ncomments.\" Runtime-verified against REB-155: response `{isLast:false, maxResults:50,\nstartAt:0, total:5000}`, 50 returned. `_diff_comments`\n(`outbound_comments.py`) then compares each local comment against only those 50\nbodies and re-emits any not present as an \"add\".\n\n## Reproduction Steps\n\n1. A Jira issue bound to a rebar ticket has > 50 comments, and the local ticket's\n   comments are not all within the oldest-50 page.\n2. Run a reconcile pass (or call `_diff_comments` with a live client whose\n   `get_comments` returns page 1 only).\n3. Observe: `_diff_comments` emits \"add\" mutations for local comments already present\n   in Jira (beyond page 1) — Expected: 0 adds for an already-mirrored ticket.\n\n- Expected: a steady-state pass emits **0** comment \"add\" mutations for a ticket\n  whose comments are already mirrored to Jira, regardless of Jira comment count.\n- Actual: it re-emits the comments not on Jira's oldest-50 page every pass.\n\n## Acceptance Criteria\n\n- [ ] `get_comments()` returns the COMPLETE comment set for an issue (paginates all\n      pages), in both `acli_cli_ops.py` and `acli.py`. Proving command:\n      a unit test builds a fake acli that returns 3 pages (e.g. 50+50+20=120) and\n      asserts `get_comments` returns all 120 — fails on the current single-page code.\n- [ ] `_diff_comments` emits 0 \"add\" mutations when every local comment is already\n      present in Jira but only beyond page 1. Proving command: unit test with a\n      >50-comment Jira snapshot where the matching local comment is comment #75 —\n      asserts empty mutation list; RED on current code.\n- [ ] The full reconciler unit suite passes: `make test` (or\n      `pytest tests/unit/rebar_reconciler -q`).\n- [ ] No new external dependency introduced; change is confined to the two\n      `get_comments` call sites (+ tests).\n\n## Notes\n\nFix = add `--paginate` (acli ignores `--limit` when paginating) OR loop startAt\nuntil `isLast`. Prefer `--paginate` for parity with `acli`'s own pagination.\nThis is P1 of epic 58b0. The 13 capped Jira issues need a separate data cleanup\n(sibling ticket) AFTER this fix deploys, else the buggy reconciler re-inflates them.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_engine/rebar_reconciler/acli_cli_ops.py","reason":"get_comments must paginate all pages"},{"path":"src/rebar/_engine/rebar_reconciler/acli.py","reason":"AcliClient.get_comments must paginate all pages"},{"path":"tests/unit/rebar_reconciler/test_outbound_comments.py","reason":"new/updated tests for pagination + dedup at page boundary"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","58b0-104b-777c-4227"]],"parent_id":"58b0-104b-777c-4227","parent_status_uuid":"72141305-baa7-47c3-b0f9-c32123d9f5e6","preconditions_summary":{"status":"pre-manifest"},"priority":1,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"1f3d-cb66-d3fc-4356","ticket_type":"bug","title":"get_comments fetches only page 1 -> non-idempotent comment re-posting inflates Jira to 5000-comment cap","verify_commands":[]},"source_event_uuids":["96e2247c-5b96-41c8-8ecc-cbc6e1dace42","dab23369-5766-4b11-b0bb-581564984c7c","72141305-baa7-47c3-b0f9-c32123d9f5e6","a3b54df1-1e56-4253-9856-c8ae3a94cb5d","900dfc3b-fa65-4288-bc6a-d837ae8922d2"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784324696887006253,"uuid":"0235ce26-95e5-4abc-931f-8087db6b2eed"}