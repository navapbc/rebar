{"author":"Joe Oakhart","author_email":"joeoakhart@navapbc.com","data":{"compacted_at":1784346173712495001,"compiled_state":{"alias":null,"assignee":"","attestations":{"completion-verifier":{"algorithm":"sshsig","author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","envelope":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.opcert.v1+json\", \"signatures\": [{\"keyid\": \"ade0f2ef-51cc-45a2-bb97-c09846cd3df5\", \"sig\": \"\"}]}","head_sha":"a02752c03162b508896c60ca94ad13d25d4cdc81","key_id":null,"kind":"completion-verifier","manifest":["completion-verifier: PASS","ticket: jira-reb-1003","model: anthropic:claude-sonnet-4-6","runner: pydantic_ai","rebar-version: 0.8.0 (a02752c03)","material: 0e789e23eb55f644","verified-at-sha:a02752c03162b508896c60ca94ad13d25d4cdc81"],"material_fingerprint":"0e789e23eb55f644","merged_log_commit":"a02752c03162b508896c60ca94ad13d25d4cdc81","principal":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","signature":null,"signed_at":1784269271005418000},"plan-review":{"algorithm":"sshsig","author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","envelope":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.opcert.v1+json\", \"signatures\": [{\"keyid\": \"ade0f2ef-51cc-45a2-bb97-c09846cd3df5\", \"sig\": \"\"}]}","head_sha":"b0ac25447203d864463408c933497f21bc1f8dbf","key_id":null,"kind":"plan-review","manifest":["plan-review: PASS","ticket: jira-reb-1003","material: 0e789e23eb55f644","model: claude-sonnet-4-6","runner: pydantic_ai","blocking: 0","advisory: 1","rebar-version: 0.7.1 (b0ac25447)","regver: b293b9a55de591cc","verified-at-sha:22d4c788abd591690c4b4efbf94abe3ceba7294f","dep absent .rebar/criteria_routing.json","dep absent .rebar/evals/plan-review-project-portability.eval.yaml","dep absent .rebar/plan_review_moves.json","dep absent .rebar/prompts/plan-review-project-portability.md","dep f8582a65f833877bf78d3502459802829da75dc2348afa417870ffcf519a1a4f docs/plan-review-gate.md","dep absent tests/unit/test_project_portability_coaching.py","dep absent tests/unit/test_project_portability_criterion.py","dep absent tests/unit/test_project_portability_docs.py","dep absent tests/unit/test_project_portability_eval.py"],"material_fingerprint":"0e789e23eb55f644","merged_log_commit":"22d4c788abd591690c4b4efbf94abe3ceba7294f","principal":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","signature":null,"signed_at":1784169274566166000}},"author":"reconciler","authorship":{"signed":6,"unsigned":31},"authorship_ledger":[{"content_hash":"13a7488beeb5bb1ec46bcb28df774674fb03c570d4ec74c96090800f35c27ac2","event_uuid":"9012e34e-cd70-4e39-a8ba-dd5eea3737de","position":{"commit_sha":"991b2280232b435bdd77f3989d5c3cac746fa86f","position":"1784230463431319259-9012e34e-cd70-4e39-a8ba-dd5eea3737de"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"0ae379e19cdcbfdac37e46c1115ce7b34bd807c7cc8e1f57ec7f38ca0c41c002","event_uuid":"626ea6f8-3d11-42f8-ab37-686edb8a6edb","position":{"commit_sha":"03447cd7bdcae6946bc3e0db1678f672df774323","position":"1784249577425754001-626ea6f8-3d11-42f8-ab37-686edb8a6edb"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"2d8281fd3f3765cca4c5365aa810759051cd87d3f1bea15ad17b3987f22a5392","event_uuid":"204e5840-5f11-48f9-bff6-abb5302bbfc5","position":{"commit_sha":"b699d502629383e283a55d704f9ffec1352983cd","position":"1784252942322495574-204e5840-5f11-48f9-bff6-abb5302bbfc5"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"e93ae4ccee112a194e652c3321496c499673897f4449e3e3cc149229d1b79981","event_uuid":"8173d3f1-99bd-4e43-bd5e-aa8f945325bb","position":{"commit_sha":"6f0d4d2c5589a2663969ac5c4f98e5f573871ada","position":"1784268920069058001-8173d3f1-99bd-4e43-bd5e-aa8f945325bb"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"fd709a28521e2ba808b52ad1b5aa66c8d0589327c0dc42854c3fc8f7470c310f","event_uuid":"8b296b1a-fbbc-4ced-b638-b85a452342f4","position":{"commit_sha":"47c1dc10b134c2421d3128bed197c4473fdd4dae","position":"1784268967214862001-8b296b1a-fbbc-4ced-b638-b85a452342f4"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"76bbd6f7ff4c96b8fee50f436615a975e747d4f3c416e14d0647fb32ed56f48b","event_uuid":"7266a401-7455-498a-b32f-c887b5b5a4bc","position":{"commit_sha":"5788091ee787d598055fb693dd62b6b6cdcb4fb6","position":"1784269260423686001-7266a401-7455-498a-b32f-c887b5b5a4bc"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"324e4d68cdbdf6cdfafac1098b009f0a7b2221a8ded674d45aed14b734e75894","event_uuid":"7452486c-d30c-44e3-bb33-67fc10fa041b","position":{"commit_sha":"48196577af21826154573c827dcca2703ef9daab","position":"1784269268971321001-7452486c-d30c-44e3-bb33-67fc10fa041b"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"9b4ad1e3494e6c01ec122a57fb6a2564d8b7575cf3a313d98650da4492898f89","event_uuid":"a71ed1ee-ae35-4248-80eb-f991094655e3","position":{"commit_sha":"2ce0fd5a23b343f94fcdba8099931296a4bd2b6e","position":"1784269271005732001-a71ed1ee-ae35-4248-80eb-f991094655e3"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"9561b4c8fac9bd8c581f71b465e951ee645ce4b410457a0bb661c5b33fed3ea2","event_uuid":"3537acf1-47e4-4d7b-80ee-b7b04ee0c06d","position":{"commit_sha":"8af8dfc40db49e3aa3d11e71efec621b5ed72573","position":"1784269447876231001-3537acf1-47e4-4d7b-80ee-b7b04ee0c06d"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"26ed51dcb1c7f255017d6f6a9be31659f46164c016caff435cb0387735adca29","event_uuid":"8d30e8a1-abb5-48c6-bee9-5bce4d8ebb7a","position":{"commit_sha":"db19e43f44fb049d1ef34349c82a5c743378c197","position":"1784269450496401001-8d30e8a1-abb5-48c6-bee9-5bce4d8ebb7a"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-212_agent","claim_remote_session":null,"claimed_session":"5c2eef83-9ceb-4320-ad07-f54047bb7399","comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Plan-review round 1 PASS advisories applied before claim: split compound acceptance criteria into atomic observable checks; replaced the weak rebar-show experiment oracle with an [operator-attested] evidence contract requiring worktree, branch, base SHA, exact commands, assertions, output, and timestamp. The dropped ADR advisory was not adopted because ADR 0015 and ADR 0017 already document the extension-boundary rationale; this epic adds the requested dogfood example rather than duplicating those decisions.","timestamp":1784162365274380001},{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"EXPERIMENT PASS — project Pass-1 criterion + Pass-4 coaching wiring mechanically confirmed.\n\nTimestamp: 2026-07-16T00:50:08Z\nWorktree: /Users/joeoakhart/rebar-jira-reb-1003-portability\nBranch: experiment/jira-reb-1003-portability\nBase SHA: b0ac25447203d864463408c933497f21bc1f8dbf (current origin/main at experiment start)\nProduction code changes: none; all experiment artifacts are uncommitted.\n\nExact commands:\n1. .venv/bin/python experiments/jira_reb_1003_portability_wiring.py\n2. .venv/bin/python -m pytest -q tests/unit/test_criteria_overlay.py::test_mvp_end_to_end_activated_project_criterion_surfaces_finding tests/unit/test_plan_review.py::test_load_move_registry_merges_project_extensions\n\nTemporary project inputs:\n- .rebar/criteria_routing.json: project.portability, exec=1-TURN, facet=project-invariants, applies_at.scope=[container,leaf], default_posture=blocking, block_threshold=0.9, activated.\n- .rebar/prompts/plan-review-project-portability.md: contract-bearing project criterion prompt.\n- .rebar/plan_review_moves.json: project-portability move with applies_when=[project.portability].\n\nAssertions proven by the experiment:\n- registry.effective_criteria contains project.portability;\n- registry.load_criteria resolves its project prompt;\n- route_criteria plus ProductionBatchRunner._project_criteria include it for both leaf and container contexts;\n- the real ProductionBatchRunner project fan-in reports [project.portability] and surfaces one injected finding;\n- passes.load_move_registry loads project-portability;\n- review_kernel.applicable_moves excludes the move for trigger F1 and includes it for trigger project.portability;\n- review_kernel.coach deterministically renders: Rework the Gerrit landing workflow so it remains portable across supported rebar client shapes; keep project-specific behavior in project configuration or an explicit extension boundary.\n- existing generic project-criterion fan-in and project-move loader tests pass (2 passed in 0.41s).\n\nStructured experiment output summary:\nexperiment=PASS; routed_scopes={container:true,leaf:true}; project_fan_in=[project.portability]; surfaced_findings=1; move_loaded=project-portability; restricted_to=project.portability.\n\nImplementation decisions confirmed:\n- Use the routing values above; Pass 1 discovers, Pass 2 adjudicates, Pass 3 decides.\n- Map the counterexample contract to existing P1 fields: location=plan citation; finding=assumption+causal mechanism; scenarios=alternate client shape+observable breakage; evidence=plan quote+grounding facts.\n- Keep the coaching move project-specific; do not add a generic core move.\n- Put the dogfood documentation in a separate subsection outside the built-in move table parsed by test_move_registry_matches_docs_table.\n- The experiment was a prerequisite: a failure would have blocked implementation pending seam repair or plan revision. It passed, so no seam remediation is required.","timestamp":1784163010229966001},{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"FINAL PLANNING STATUS: Signed plan-review PASS on current material fingerprint 7983a75fbd33d8bc at origin/main b0ac25447; clarity-check PASS (7, threshold 5); check-ac PASS (12 items); quality-check PASS; plan-review signature certified. The sole remaining P6 advisory is a lexical hit on the word \"properly\" in sequencing prose plus a compound-line heuristic. It was not adopted because the two relevant negative outcomes are already separate, observable ACs: omission_is_not_a_finding and configured_specialization_is_portable. Rewording would not change implementation guidance. The fresh experiment worktree has been returned to a clean origin/main state after recording evidence; no production code was committed. The epic remains in_progress because implementation is intentionally outstanding.","timestamp":1784163136119470001},{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Decomposed the implementation into four scoped child stories with explicit acceptance-criterion ownership, file-impact metadata, DD-level proving commands, and dependency links. The completed worktree experiment remains parent-level evidence. Delivery graph: immune-floury-toad -> {truthful-specified-silverfish, indigoid-unmystic-serpent} -> taurine-catchable-kakarikis.","timestamp":1784164176178638001},{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Applied the final graph-review advisories at the roll-up level: ACs now verify the resolved prompt's finding threshold and both non-finding clauses; the eval contract is anchored to exactly PORT-F1..F4 plus PORT-N1..N4; the calibration branch states no-edit-on-first-pass and prompt-only instruction/contrast-example edits on a threshold miss. Child plans remain unchanged and signed.","timestamp":1784168754867985001},{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"[operator-attested] LIVE CALIBRATION of project.portability (indigoid-unmystic-serpent) — PASS on the first complete run, meeting every release threshold.\n\nCommand: .venv/bin/rebar criteria eval project.portability --runs 3 --output json\nModel: anthropic:claude-sonnet-4-6 (pinned in .rebar/evals/plan-review-project-portability.eval.yaml)\nRuns (epochs): 3 over all 8 dataset cases (PORT-F1..F4 must-fire + PORT-N1..N4 must-not-fire) = 24 model calls, all succeeded (no timeout/API error/partial).\nUTC: started 2026-07-17T03:19:50Z, completed 2026-07-17T03:24:23Z.\nWorktree: /Users/joeoakhart/rebar-jira-reb-1003; base origin/main cb0f8ec3b (includes the landed eval-resolution fix, bug 2340, Gerrit change 751 MERGED) + stack head a02752c03.\n\nAggregate metrics: n_fire=4, n_nofire=4, recall=1.0, false_accept=0.0, agreement=1.0, Cohen kappa=1.0, per-case stability min=1.0 mean=1.0.\nRequired thresholds: recall 1.0 (MET), false_accept 0.0 (MET), agreement 1.0 (MET), per-case stability >= 2/3 (MET, 1.0), kappa >= 0.70 (MET, 1.0).\n\nPer-case (expected_fire / observed_fire / stability): PORT-F1 fire/fire/1.0; PORT-F2 fire/fire/1.0; PORT-F3 fire/fire/1.0; PORT-F4 fire/fire/1.0; PORT-N1 no-fire/no-fire/1.0; PORT-N2 no-fire/no-fire/1.0; PORT-N3 no-fire/no-fire/1.0; PORT-N4 no-fire/no-fire/1.0.\n\nThis same attestation is recorded on child ticket 21dd-8681-4447-4bc0 (indigoid-unmystic-serpent). The live-eval command was previously blocked by bug 2340 (namespaced project criteria failed to resolve in the eval path); that fix landed on main independently (change 751) and this stack was rebased onto it, unblocking the run.","timestamp":1784268967214862001}],"created_at":1783801564523754782,"creation_channel":"jira","creation_channel_inferred":true,"deps":[{"link_uuid":"626ea6f8-3d11-42f8-ab37-686edb8a6edb","relation":"relates_to","target_id":"9a20-1190-3362-4b3b"}],"description":"## Context\n\nRebar is a reusable ticket, reconciliation, and review-gate system consumed through several harnesses and deployed into projects with very different stacks, repository shapes, platforms, and execution environments. Development of rebar itself happens primarily in a Python repository on macOS through current agent harnesses, which creates a risk that a technically plausible plan silently bakes rebar-project assumptions into reusable behavior.\n\nRepresentative failures include a core `rebar landing` command that encodes this repository Gerrit policy, Python-only review rules that fail to apply to a Next.js client, macOS-specific dependencies, and operations that assume the process starts inside a local project checkout. The review must catch concrete incompatibilities without requiring every plan to contain generic portability prose.\n\n## Why\n\nRebar maintainers need an early, high-recall warning when a proposed plan would break a supported client shape. Downstream clients need project-specific policy to remain in project configuration while reusable mechanisms remain usable across harnesses, target projects, platforms, execution venues, and project-location models. Dogfooding the existing project-criterion and project-coaching seams also provides a real example for client authors.\n\n## What\n\nAdd one activated project plan-review criterion, `project.portability`, through `.rebar/criteria_routing.json` and `.rebar/prompts/plan-review-project-portability.md`. It runs in Pass 1 at both container and leaf scope. It does not adjudicate validity, impact, severity, or disposition; existing Pass 2 and Pass 3 do that without modification.\n\nThe finder may emit a portability finding only when it supplies all four elements:\n\n- a citation to the explicit plan detail or mechanism carrying the assumption;\n- a materially different supported client shape;\n- the causal mechanism by which that shape fails; and\n- a specific, observable breakage scenario that Pass 2 can verify.\n\nThe compatibility counterexample matrix is:\n\n- Harness: Python library, CLI, and remote MCP clients, without assumptions specific to Claude Code, Codex, or another development harness.\n- Target project: Ruby, Python, Java, Next.js, .NET, and atypical layouts such as Terraform subprojects inside a monorepo.\n- Platform and venue: macOS, Windows, Linux, and BSD across CI, servers, and developer workstations.\n- Project location and access: in-checkout current working directory, explicitly located workspace, and server execution outside the target checkout without assuming unrestricted local filesystem access.\n\nSilence about portability is not a finding. If the reviewer cannot construct the cited, concrete counterexample, it emits no finding. Project-specific behavior is allowed when it remains project configuration rather than leaking into reusable core behavior.\n\nAdd one project-specific Pass-4 move in `.rebar/plan_review_moves.json`, applicable only when `project.portability` survives review:\n\n- id: `project-portability`\n- name: `restore rebar portability`\n- applies_when: `[\"project.portability\"]`\n- template: `Rework {subject} so it remains portable across supported rebar client shapes; keep project-specific behavior in project configuration or an explicit extension boundary.`\n\nThe existing Pass-4 applicability filter, move picker, subject validator, and deterministic renderer remain unchanged. No generic core coaching move is added.\n\n## Approach and sequencing\n\nThe fresh-worktree experiment is complete and recorded on this epic. It mechanically proved criterion activation for leaf and container plans, `ProductionBatchRunner` project fan-in, project move loading, criterion-scoped applicability, and deterministic rendering against current `origin/main`. The temporary experiment files were removed; implementation remains outstanding.\n\nDelivery is decomposed into four bounded children:\n\n1. `immune-floury-toad` activates and integrates the Pass 1 finder.\n2. After the finder lands, `truthful-specified-silverfish` adds project-scoped Pass 4 coaching while `indigoid-unmystic-serpent` independently calibrates the live criterion against balanced positive and negative cases.\n3. After coaching and calibration land, `taurine-catchable-kakarikis` documents the final project extension pattern and runs repository-wide regression gates.\n\nThis approach uses the existing project extension seams instead of changing the generic four-pass kernel. It directly demonstrates the intended boundary, gives live semantics a separate calibration gate, limits blast radius, and preserves Pass 2 and Pass 3 behavior.\n\n## Child delivery map\n\n- `immune-floury-toad` — owns routing, activation, prompt resolution, leaf/container fan-in, rubric structure, false-positive instructions, and overlay-absent integration coverage.\n- `truthful-specified-silverfish` — owns only the `project-portability` move, its criterion-scoped applicability, deterministic rendering, and proof that no generic core move changes.\n- `indigoid-unmystic-serpent` — owns the balanced live eval corpus, four-part positive findings, must-not-fire boundaries, and repeat-run thresholds. If the first complete run meets every threshold, it makes no prompt edit. On a threshold miss, it may reword finder instructions or contrast examples only in `.rebar/prompts/plan-review-project-portability.md`; criterion id, routing, output schema, Pass 2, and Pass 3 remain unchanged.\n- `taurine-catchable-kakarikis` — owns the client-facing dogfood documentation, parser-safe placement outside the built-in move table, and final lint/typecheck/test verification.\n- The completed worktree experiment remains parent-level operator evidence because it de-risks the whole decomposition and is not remaining implementation work.\n\nThe dependency graph is `immune-floury-toad -> {truthful-specified-silverfish, indigoid-unmystic-serpent} -> taurine-catchable-kakarikis`.\n\n## Scope\n\nIn scope:\n\n- Rebar-project Pass-1 criterion configuration, prompt, and activation.\n- Rebar-project Pass-4 move configuration restricted to `project.portability`.\n- Offline wiring experiment in a fresh worktree.\n- Focused positive, negative, leaf, container, routing, and rendering tests.\n- A balanced live evaluation corpus with repeat-run release thresholds.\n- Documentation of the project configuration as an example for clients.\n\nOut of scope:\n\n- Remediating existing portability debt discovered by the criterion.\n- Adding `rebar landing` or other rebar-project workflow policy to reusable core.\n- A generic built-in coaching move.\n- Changes to Pass 2 validity/impact adjudication or Pass 3 deterministic decisions.\n- Guaranteeing that every existing rebar feature already supports every matrix cell.\n\n## Success Criteria\n\n- The rebar project owns and activates `project.portability`, and the production Pass-1 routing includes it for both container and leaf plans.\n- The project move loads through the production registry, is offered only for findings carrying `project.portability`, and renders the locked project template.\n- A balanced three-run evaluation demonstrates the four named failures `PORT-F1` through `PORT-F4` while producing no finding for `PORT-N1` through `PORT-N4`.\n- Existing plan-review behavior remains unchanged when a client has no project overlay or project move file.\n- The experiment evidence and implementation documentation show client authors how the two project extension seams compose.\n\n## Acceptance Criteria\n\n- [ ] `immune-floury-toad` activates `project.portability` with `exec: 1-TURN`, `facet: project-invariants`, `applies_at.scope: [container, leaf]`, `default_posture: blocking`, and `block_threshold: 0.9`. Verify: `.venv/bin/pytest -q tests/unit/test_project_portability_criterion.py -k criterion_activation`\n- [ ] `immune-floury-toad` proves the resolved rubric contains the finding threshold plus the exact silence and project-configuration non-finding rules. Verify: `.venv/bin/pytest -q tests/unit/test_project_portability_criterion.py -k \"prompt_resolution or finding_threshold or omission_guard or project_configuration_guard\"`\n- [ ] `immune-floury-toad` proves both leaf and container plans route through production project fan-in. Verify: `.venv/bin/pytest -q tests/unit/test_project_portability_criterion.py -k \"leaf_routing or container_routing or production_fan_in\"`\n- [ ] `indigoid-unmystic-serpent` proves the corpus contains exactly `PORT-F1` through `PORT-F4`, each with a gold four-part note: plan citation, alternate client shape, causal mechanism, plus observable breakage. Verify: `.venv/bin/pytest -q tests/unit/test_project_portability_eval.py -k \"balanced_corpus or finding_contract\"`\n- [ ] `indigoid-unmystic-serpent` proves a plan with no portability discussion is a must-not-fire case. Verify: `.venv/bin/pytest -q tests/unit/test_project_portability_eval.py -k negative_boundaries`\n- [ ] `indigoid-unmystic-serpent` proves specialization behind project configuration or an explicit extension boundary is a must-not-fire case. Verify: `.venv/bin/pytest -q tests/unit/test_project_portability_eval.py -k negative_boundaries`\n- [ ] [operator-attested] `indigoid-unmystic-serpent` records three live eval runs over `PORT-F1`–`PORT-F4` plus `PORT-N1`–`PORT-N4` with recall `1.0`, false-accept rate `0.0`, agreement `1.0`, per-case stability of at least two of three, and Cohen kappa of at least `0.70`. Verify: `.venv/bin/rebar criteria eval project.portability --runs 3 --output json`\n- [ ] `truthful-specified-silverfish` proves the `project-portability` move applies only when `project.portability` survives review. Verify: `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k \"applies_to_portability or ignores_empty_triggers or ignores_unrelated_findings\"`\n- [ ] `truthful-specified-silverfish` proves the move deterministically renders the locked project template and does not add a generic core move. Verify: `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k \"deterministic_render or project_owned_only\"`\n- [ ] [operator-attested] The completed fresh-`origin/main` worktree experiment proves criterion activation through Pass-1 fan-in plus project-move applicability/rendering. Evidence on this epic names the worktree, branch, base SHA, commands, assertions, output, and timestamp.\n- [ ] `immune-floury-toad` proves overlay-absent plan-review behavior remains green. Verify: `.venv/bin/pytest -q tests/unit/test_criteria_overlay.py tests/unit/workflow/test_production_batch_runner.py`\n- [ ] `taurine-catchable-kakarikis` documents the exact project criterion and project move composition outside the built-in move table. Verify: `.venv/bin/pytest -q tests/unit/test_project_portability_docs.py`\n- [ ] `taurine-catchable-kakarikis` proves repository lint, type checks, and tests pass. Verify: `make lint && make typecheck && make test`\n","env_id":"reconciler","file_impact":[{"path":".rebar/criteria_routing.json","reason":"activate and route the rebar-project portability criterion"},{"path":".rebar/prompts/plan-review-project-portability.md","reason":"define and calibrate the Pass 1 portability rubric"},{"path":".rebar/plan_review_moves.json","reason":"define the scoped project portability coaching move"},{"path":".rebar/evals/plan-review-project-portability.eval.yaml","reason":"calibrate concrete failures and false-positive boundaries"},{"path":"tests/unit/test_project_portability_criterion.py","reason":"verify criterion integration"},{"path":"tests/unit/test_project_portability_coaching.py","reason":"verify coaching integration"},{"path":"tests/unit/test_project_portability_eval.py","reason":"verify evaluation contract"},{"path":"tests/unit/test_project_portability_docs.py","reason":"verify documentation content and placement"},{"path":"docs/plan-review-gate.md","reason":"document the client-facing dogfood example"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["relates_to","9a20-1190-3362-4b3b"]],"parent_id":null,"parent_status_uuid":"7452486c-d30c-44e3-bb33-67fc10fa041b","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"closed","tags":["imported:reconciler-bootstrap"],"ticket_id":"jira-reb-1003","ticket_type":"epic","title":"Guard rebar plans against project-shaped portability assumptions","verify_commands":[{"command":".venv/bin/pytest -q tests/unit/test_project_portability_criterion.py","dd_id":"dd-criterion","dd_text":"Project criterion activation, routing, prompt resolution, and boundaries pass"},{"command":".venv/bin/pytest -q tests/unit/test_project_portability_coaching.py","dd_id":"dd-coaching","dd_text":"Project coaching loading, applicability, and rendering pass"},{"command":".venv/bin/pytest -q tests/unit/test_project_portability_eval.py","dd_id":"dd-eval-structure","dd_text":"The balanced evaluation corpus and finding contract are valid"},{"command":".venv/bin/rebar criteria eval project.portability --runs 3 --output json","dd_id":"dd-eval-live","dd_text":"The live project criterion meets its repeat-run release thresholds"},{"command":".venv/bin/pytest -q tests/unit/test_project_portability_docs.py","dd_id":"dd-docs","dd_text":"The client-facing dogfood example is complete and parser-safe"},{"command":".venv/bin/pytest -q tests/unit/test_criteria_overlay.py tests/unit/workflow/test_production_batch_runner.py","dd_id":"dd-regression","dd_text":"Overlay absence and production fan-in remain compatible"},{"command":"make lint && make typecheck && make test","dd_id":"dd-gates","dd_text":"Repository lint, typecheck, and tests pass"}]},"source_event_uuids":["6244f5e1-246a-4505-a7a4-0e430b0c2d72","aa3482c3-f3e0-4418-994f-76ab5d497981","4af2f187-5fca-48ea-98eb-ca543412afb5","792de264-d8c0-4182-b909-b986a7a45bc4","aafded35-1d6c-4598-af79-91a8c5092db6","7cc926d3-de7b-4597-b56b-40254359e50f","81580042-0c84-4074-8573-8dcdd50a70ff","0a9a28b8-591b-422e-87ad-c420c1e5f26d","ff2001da-b4ed-4bc2-9622-e504b51aa461","0c7392c2-4f2e-43b5-8c7b-f5ee80b67d4d","96e4e780-4f08-4512-9068-79f730351d8a","b6102d29-ed78-4ae8-9e05-2717d2268e3b","37c78eaa-da9c-403f-8c07-234f1d5e4d70","1d51345c-19dd-4df1-91e5-b0c2944c7535","cc9d6425-ac35-424f-a291-b42976fd5d52","7376ee00-c771-46c9-8d04-f33a75c88ec3","437a27e8-8785-43a7-9e94-1a8052131f22","0ee7802e-fefd-4042-9590-dab98375a5fa","e3675785-f7c6-40aa-804e-318fd1f63405","d30e4168-7c89-423c-b071-5de10fd784dc","8de4de20-bfcd-44d6-a6fc-2f92a56d052b","d51cc041-6e7b-44aa-9805-9b412995c330","216a5c7b-4a2d-4f93-bd6c-0e9f928b6953","2c09e27e-d8cc-473c-9a2f-d685fe8a4ba3","20cbeb74-3a87-4924-bae8-326b4e8eab61","fbac9cac-ed3e-4ef5-a7c1-5042ed9deb5a","0c34833f-9553-4a08-992f-7e5073fabf81","ec2be7dc-96db-4a7f-8503-7b5242e97a92","b2de431d-fd98-4366-a223-e06efee6c0cc","183d05a3-da21-4789-b5eb-5273173c695f","96ab4734-1d14-4151-b1bf-09064f0570be","04ac87cc-c687-482e-8c20-e4a3ba1bd696","9012e34e-cd70-4e39-a8ba-dd5eea3737de","2e8c8009-8472-4b70-8868-df82e57becd8","626ea6f8-3d11-42f8-ab37-686edb8a6edb","3cfd9e86-c690-4f88-8dee-5eb169be2d30","becfd112-087f-4930-b55b-6a5d34919820","204e5840-5f11-48f9-bff6-abb5302bbfc5","8173d3f1-99bd-4e43-bd5e-aa8f945325bb","8b296b1a-fbbc-4ced-b638-b85a452342f4","7266a401-7455-498a-b32f-c887b5b5a4bc","7452486c-d30c-44e3-bb33-67fc10fa041b","a71ed1ee-ae35-4248-80eb-f991094655e3","3537acf1-47e4-4d7b-80ee-b7b04ee0c06d","8d30e8a1-abb5-48c6-bee9-5bce4d8ebb7a"]},"env_id":"","event_type":"SNAPSHOT","timestamp":1784346173712495001,"uuid":"5c6067ef-5a36-4f5d-8a74-0ea8448bdc3d"}