d\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"0e5ab9ea30f71cbaddd3c2b09afcb4858f2be11e47f4387e6da83ccba97825ca","event_uuid":"07161536-efe5-43c8-b0a3-23a9c913e746","position":{"commit_sha":"116a14e6f6f92fc1c7e963fe7084860d303b677b","position":"1784747387399560001-07161536-efe5-43c8-b0a3-23a9c913e746"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"8cca1deb6e8aaf5406f441f19fbd3b873664f9b27df3df5218edd4cefd536cb9","event_uuid":"211fbf37-98f9-4282-927a-0429b56b02da","position":{"commit_sha":"116a14e6f6f92fc1c7e963fe7084860d303b677b","position":"1784747387698200001-211fbf37-98f9-4282-927a-0429b56b02da"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"29bc3ffb007a492f868d0176a674edeea7296d9a62cb11545ee1cb3eff859ede","event_uuid":"21102bfc-1907-4cb1-83dc-ea4e55a93d73","position":{"commit_sha":"d1060e1183b1feeb1b26a937517afecf02ec7ccb","position":"1784747688593754001-21102bfc-1907-4cb1-83dc-ea4e55a93d73"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"783cf8fefdbd4d7332644b218680288effcd2ed997d6ddf293e5ad10ea645759","event_uuid":"cd94b9a1-0a03-45db-a359-fe7afa2468f8","position":{"commit_sha":"e24f6d04818577ae2b232f46ab15b55605bc0eaf","position":"1784747773289682696-cd94b9a1-0a03-45db-a359-fe7afa2468f8"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-217_agent","claim_remote_session":null,"claimed_session":"d96ad199-666f-460a-8d48-9e7792e1af7e","comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Implemented (staged locally, not yet pushed to Gerrit).\n\nRoot cause: explain_guide/explain_criterion read guide markdown via config.repo_root()/docs/, which resolves to the CONSUMING project's git toplevel — absent in any installed rebar → missing-file. Fixed by matching the OSS convention (verified against PyPA / scientific-python guide / certifi): runtime-needed data lives in-package, read via importlib.resources (same pattern rebar already uses for criteria_routing.json).\n\nChanges:\n- Moved both prose guides to src/rebar/_guides/{writing-a-passing-plan,passing-code-review}.md (canonical) + __init__.py. Hatchling ships them in the wheel (guarded by new test_wheel_ships_author_guides).\n- AUTHOR_GUIDES: dict[str,str] of bare filenames; explain_guide(name) resolves via resources.files('rebar._guides'), dropped repo_root_path param.\n- explain_criterion renders the section from the packaged registry via _guide_section_body (installable; overlay project criteria still resolve via load_criteria repo_root). Removed the repo-root missing-file state.\n- docs/ copies are thin pointers so existing links resolve. Dev/CI machinery (regenerate/validate_criteria_guide, coach guide_url deep-link) unchanged.\n- Tests updated to assert repo-root independence across CLI/MCP/library; added packaging tests.\n\nVerified: with REBAR_ROOT=<dir without docs/>, rebar explain plan|review|F1 all exit 0; library + MCP-shape calls succeed; both guides present as packaged resources and in the built wheel. make lint + make typecheck pass; explain/engine_dir suites green (23 passed). registry.py 714 LOC (< 800 cap).\n\nRemaining: route through Gerrit (LLM-Review + Verified) before closing — not done (awaiting go-ahead).","timestamp":1784747688593754001}],"created_at":1784746248020741001,"creation_channel":"cli","deps":[],"description":"## Problem\n`rebar explain plan` / `explain review` (and `explain <criterion-id>`) read their guide\nmarkdown from `config.repo_root(...)/docs/...`. `repo_root` resolves to the *consuming\nproject's* git toplevel (or cwd), never the rebar install. So when rebar is installed as a\nlibrary/CLI/MCP and run against another project, the `docs/` tree is absent and every\n`explain` guide lookup fails with missing-file. A client hit exactly this (\"the author guide\nlives in the rebar source repo, not this project\").\n\n## Goal\nMake the plan-authoring guide (writing-a-passing-plan.md) and code-authoring guide\n(passing-code-review.md) accessible through rebar's CLI, MCP, and Python library surfaces from\nany installation, matching the established OSS convention for runtime-needed data files:\nthe canonical copy lives *inside* the import package, read via `importlib.resources` (the same\npattern rebar already uses for `criteria_routing.json`).\n\n## Approach\n1. Move the two prose guides to `src/rebar/_guides/writing-a-passing-plan.md` and\n   `src/rebar/_guides/passing-code-review.md` (canonical, in-package) and add\n   `src/rebar/_guides/__init__.py`. Hatchling ships all files under `src/rebar`, so they land\n   in the wheel automatically.\n2. Change `AUTHOR_GUIDES` from `dict[str, tuple[str, ...]]` (path components under `docs/`) to\n   `dict[str, str]` mapping guide name -> bare filename, e.g.\n   `{\"plan\": \"writing-a-passing-plan.md\", \"review\": \"passing-code-review.md\"}`.\n   `explain_guide(name)` resolves via `resources.files(\"rebar._guides\") / AUTHOR_GUIDES[name]`\n   and drops the `repo_root_path` parameter (resolution is repo-root independent). Unknown name\n   still raises `ExplainError(\"unknown-id\", ...)`; a genuinely absent packaged resource raises\n   `ExplainError(\"missing-file\", ...)`.\n3. `explain_criterion(id)` renders the section directly from the packaged registry via the\n   existing `_guide_section_body(criterion)` (the same content `regenerate_criteria_guide`\n   builds the doc from) instead of reading `docs/plan-review-criteria-guide.md`. Overlay\n   project criteria still resolve via `load_criteria(repo_root=repo_root_path)`; unknown-id and\n   malformed-registry states are preserved; the repo-root missing-file state is removed.\n4. Leave `docs/writing-a-passing-plan.md` and `docs/passing-code-review.md` as thin pointer\n   files to the in-package canonical source so existing links (docs/README.md, AGENTS.md)\n   resolve.\n5. Keep the dev/CI machinery unchanged: `regenerate_criteria_guide`, `validate_criteria_guide`,\n   `_guide_path`, and the Pass-4 coach deep-links to the docs anchor.\n\n## Acceptance Criteria\n- [ ] With `REBAR_ROOT` set to a directory containing no `docs/`, `rebar explain plan`,\n      `rebar explain review`, and `rebar explain <criterion-id>` (e.g. F1) each exit 0 and print\n      the guide/section (installability guarantee).\n- [ ] The library calls `registry.explain_guide(\"plan\"|\"review\")` and\n      `registry.explain_criterion(\"F1\", repo_root_path=<dir-without-docs>)` return the content\n      without raising (no dependency on repo-root `docs/`).\n- [ ] The MCP `explain_criterion` tool returns `{criterion_id, section}` for a guide name and a\n      criterion id under the same repo-root-independent condition.\n- [ ] Both guides are present as packaged resources: `resources.files(\"rebar._guides\")` contains\n      `writing-a-passing-plan.md` and `passing-code-review.md`.\n- [ ] `docs/writing-a-passing-plan.md` and `docs/passing-code-review.md` still exist as pointer\n      files (existing links do not 404).\n- [ ] `make lint` and `make typecheck` pass; `tests/unit/test_plan_review_explain.py` passes,\n      updated to assert repo-root independence instead of the old \"missing-file when the repo\n      has no docs\" behavior, plus a test that both guides are packaged.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_guides/writing-a-passing-plan.md","reason":"canonical in-package guide (moved from docs/)"},{"path":"src/rebar/_guides/passing-code-review.md","reason":"canonical in-package guide (moved from docs/)"},{"path":"src/rebar/_guides/__init__.py","reason":"make _guides a package for importlib.resources"},{"path":"src/rebar/llm/plan_review/registry.py","reason":"explain_guide/explain_criterion resolve via importlib.resources / packaged registry"},{"path":"docs/writing-a-passing-plan.md","reason":"thin pointer to in-package canonical"},{"path":"docs/passing-code-review.md","reason":"thin pointer to in-package canonical"},{"path":"tests/unit/test_plan_review_explain.py","reason":"assert repo-root independence instead of missing-file-from-repo-root"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[],"parent_id":null,"parent_status_uuid":"07161536-efe5-43c8-b0a3-23a9c913e746","plan_review_phase":"execution","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"bea1-b3c7-7733-46f6","ticket_type":"task","title":"explain guides accessible from any install (package the author guides)","verify_commands":[]},"source_event_uuids":["8dbc449f-1a3f-435e-9523-d7333dd1c505","4d9e28de-63ef-4fe5-bd0b-5bf7f158f3dd","8e382f36-2bd0-4698-9c31-ac0f34d2451c","96441c11-f6f8-47cd-bd6d-4cfeb2598536","07161536-efe5-43c8-b0a3-23a9c913e746","211fbf37-98f9-4282-927a-0429b56b02da","21102bfc-1907-4cb1-83dc-ea4e55a93d73","cd94b9a1-0a03-45db-a359-fe7afa2468f8"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784747773289682697,"uuid":"8cbc5dc7-a728-4eca-8330-633008ebbe93"}