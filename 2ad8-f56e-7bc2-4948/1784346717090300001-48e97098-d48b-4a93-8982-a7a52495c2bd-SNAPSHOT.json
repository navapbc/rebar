ef-51cc-45a2-bb97-c09846cd3df5","signature":null,"signed_at":1784166537744750000}},"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","authorship":{"signed":3,"unsigned":12},"authorship_ledger":[{"content_hash":"aa3cc48ae795be34767a8f42ba9b7c556e6a2978588a05f78626080c377f94d8","event_uuid":"7725fdf3-a6c0-4a17-b6b8-b71666cda284","position":{"commit_sha":"3d13ee8b2d426d3fb048fb073821fc381a7682d7","position":"1784254193728369268-7725fdf3-a6c0-4a17-b6b8-b71666cda284"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"a865895435b8cfe006d827cc1084ab568452aedbb713618130612d070f8eb83e","event_uuid":"e7cdf4ce-066e-4642-ba3d-c1cf1d8bb1ef","position":{"commit_sha":"c4d8269a91be54a92b3a9d7cba1abd60033f4a86","position":"1784263074852239001-e7cdf4ce-066e-4642-ba3d-c1cf1d8bb1ef"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"8883d4b9a4fbc31570bb2effd7289d95d7dfcd93eb9f42b4c220f0698758e6b7","event_uuid":"702a1667-b216-4b0c-bc97-b4c4e8df1421","position":{"commit_sha":"102e388e0678df0a2215000ce2737c065b3fcbc3","position":"1784263080692178001-702a1667-b216-4b0c-bc97-b4c4e8df1421"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"a8176b801b4b224df77dbb90cd5d97a44bc8bfa9462aab1932c5bb5c6b5e143f","event_uuid":"e9a02c0c-fcca-4a39-906e-ffaeb26399c8","position":{"commit_sha":"1f1962bf6da5bd9d63a19e0606e9ca2310dfa0ce","position":"1784263081423894001-e9a02c0c-fcca-4a39-906e-ffaeb26399c8"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-212_agent","claim_remote_session":null,"claimed_session":"5c2eef83-9ceb-4320-ad07-f54047bb7399","comments":[{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Pre-review grounding tightened the story against passes.load_move_registry, review_kernel.applicable_moves, and the real existing tests. Replaced the nonexistent regression test path, split the move definition and applicability into atomic ACs, and recorded the exact JSON contract plus experiment evidence.","timestamp":1784166196906906001},{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","body":"Retyped from story to task after the final scheduling audit: next-batch intentionally skips childless stories as planning containers. Scope, acceptance criteria, file impact, proving commands, dependencies, and title are unchanged; this ticket is the implementation leaf it was already planned to be.","timestamp":1784169407371521001}],"created_at":1784164044169718001,"creation_channel":"unknown","deps":[{"link_uuid":"b2000f67-6a13-4975-84d5-065b90cd8ac0","relation":"depends_on","target_id":"3863-a783-b38f-4c8a"}],"description":"## Why\n\nA valid portability finding needs a productive Pass 4 response, but the proposed generic core move was rejected. The coaching behavior therefore belongs in project configuration and must remain invisible to unrelated criteria.\n\n## What\n\nAdd the project-specific `project-portability` coaching move and focused tests for loading, applicability, and deterministic rendering.\n\n## Scope\n\nIn scope:\n\n- `.rebar/plan_review_moves.json`\n- `tests/unit/test_project_portability_coaching.py`\n- Pass 4 coaching for `project.portability` findings\n\nOut of scope:\n\n- generic core coaching moves\n- changes to built-in move definitions\n- Pass 1, Pass 2, or Pass 3 behavior\n- documentation and live criterion calibration\n\n## Approach\n\nUse the existing best-effort project move overlay proven by the fresh-worktree experiment. `.rebar/plan_review_moves.json` is a JSON object keyed by move id. Add exactly:\n\n- key `project-portability`\n- `name: restore rebar portability`\n- `template: Rework {subject} so it remains portable across supported rebar client shapes; keep project-specific behavior in project configuration or an explicit extension boundary.`\n- `applies_when: [project.portability]`\n\n`src/rebar/llm/plan_review/passes.py::load_move_registry` merges this file over a copy of the built-in registry with `strict=False`. `src/rebar/llm/review_kernel/coach.py::applicable_moves` admits the move only when its trigger intersects the surviving findings. `coach` then validates a bounded noun-phrase subject and renders the locked template deterministically. This project-owned composition is sufficient; no generic core move or kernel change is needed.\n\nThe established prior-art tests are `tests/unit/test_plan_review.py::test_load_move_registry_merges_project_extensions` and `tests/unit/test_plan_review.py::test_move_registry_matches_docs_table`. The parent epic experiment at `2026-07-16T00:50:08Z` proved the proposed id loads, remains excluded for trigger `F1`, becomes applicable for `project.portability`, and renders the locked sentence.\n\n## Dependencies\n\nDepends on the criterion-integration child because the move trigger must use the final activated criterion id.\n\n## Test Strategy\n\nLoad the real project move registry, query applicability with representative trigger sets, and render the move through the normal coaching path.\n\n## Acceptance Criteria\n\n- [ ] The project registry loads a move keyed `project-portability`. Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k move_id`.\n- [ ] The loaded move name equals `restore rebar portability`. Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k move_name`.\n- [ ] The loaded move template equals the exact sentence specified in this plan. Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k move_template`.\n- [ ] The loaded move declares only `project.portability` in `applies_when`. Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k move_trigger`.\n- [ ] The move is applicable for the trigger set `{project.portability}`. Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k applies_to_portability`.\n- [ ] The move is absent for an empty trigger set. Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k ignores_empty_triggers`.\n- [ ] The move is absent for the unrelated trigger set `{F1}`. Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k ignores_unrelated_findings`.\n- [ ] Rendering the subject `the Gerrit landing workflow` produces the exact locked sentence. Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k deterministic_render`.\n- [ ] Loading the project move leaves the packaged `MOVE_REGISTRY` mapping unchanged. Prove with `.venv/bin/pytest -q tests/unit/test_project_portability_coaching.py -k project_owned_only`.\n- [ ] Existing project move loading plus the built-in documentation-table invariant remain green. Prove with `.venv/bin/pytest -q tests/unit/test_plan_review.py -k move_registry`.\n","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":".rebar/plan_review_moves.json","reason":"define the project-scoped portability coaching move"},{"path":"tests/unit/test_project_portability_coaching.py","reason":"verify move loading, applicability, and rendering"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["depends_on","3863-a783-b38f-4c8a"],["parent","jira-reb-1003"]],"parent_id":"jira-reb-1003","parent_status_uuid":"702a1667-b216-4b0c-bc97-b4c4e8df1421","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"closed","tags":["plan-review","portability","coaching"],"ticket_id":"2ad8-f56e-7bc2-4948","ticket_type":"task","title":"Add scoped portability coaching","verify_commands":[{"command":".venv/bin/pytest -q tests/unit/test_project_portability_coaching.py","dd_id":"DD-1","dd_text":"Project coaching loading, applicability, isolation, and rendering are covered"},{"command":".venv/bin/pytest -q tests/unit/test_plan_review.py -k move_registry","dd_id":"DD-2","dd_text":"Existing project move loading and built-in documentation parity remain compatible"}]},"source_event_uuids":["7a859e14-f9c3-4239-a71d-4afcb654eb10","04e723f5-269f-468b-8731-c72fd1806ccc","20f0d271-19c0-4245-adba-c0b56f8c4b39","b2000f67-6a13-4975-84d5-065b90cd8ac0","3cdbcde3-b5cb-4380-98df-a4743e956cb3","b5e1e9db-0316-45ec-9577-0cdc30775f13","7c241297-0dc3-4b48-912a-83dfa4f1ebf6","33931134-ae9a-47a5-9526-910ee4cf30ee","8dd1e7b5-4912-4cd5-b60b-ea143d7ca32e","18b3b6bd-c81a-4c96-ae6d-eae2d62f947c","639f21f2-3893-4922-b2b9-0ae19b9a8277","f9e84639-1941-4fdd-a9b8-7e21637521f9","5d416367-5a22-4746-8022-b44d04c9d483","bac50c0d-ecc6-490e-8553-8efb77939c87","9eccbb08-3f3e-4328-8015-ee330d77539a","7725fdf3-a6c0-4a17-b6b8-b71666cda284","e7cdf4ce-066e-4642-ba3d-c1cf1d8bb1ef","702a1667-b216-4b0c-bc97-b4c4e8df1421","e9a02c0c-fcca-4a39-906e-ffaeb26399c8"]},"env_id":"","event_type":"SNAPSHOT","timestamp":1784346717090300001,"uu