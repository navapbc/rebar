TE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"12538e52c30a59b81dd4d86d85bbaeb098f5eabf5a8321394b7424b418a597f6","event_uuid":"4d097a42-1af9-4251-8218-cf73e361128f","position":{"commit_sha":"0f6ccdd8376562501c81abd021840992f6b1c404","position":"1784483077266114001-4d097a42-1af9-4251-8218-cf73e361128f"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"5453b4ac8957bb1e5c02da499f7ed6db926a909d1837be4ab3f53308abc201c5","event_uuid":"58e14902-ef7e-4d29-b0fd-f3138ad8ca24","position":{"commit_sha":"59a940e2f9909a94114c03ff2da549bf382777a1","position":"1784483283737172001-58e14902-ef7e-4d29-b0fd-f3138ad8ca24"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"c080ab05e8cec699e58aa25fb842943dc014fa1cc645a9e7d51b22e845c0fcff","event_uuid":"ff05cc5c-465b-4a19-9eff-244ccae5e9ec","position":{"commit_sha":"e18691772a22391f37fb4646823f6275f3fc787b","position":"1784483453321056001-ff05cc5c-465b-4a19-9eff-244ccae5e9ec"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"fd3590065abe4b3faa9e05dca2fabf1ad9a6b86888c446e584056024b19e51b4","event_uuid":"de914102-39e4-44eb-8bb8-1120158aa50d","position":{"commit_sha":"e18691772a22391f37fb4646823f6275f3fc787b","position":"1784483454392547001-de914102-39e4-44eb-8bb8-1120158aa50d"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-215_agent","claim_remote_session":null,"claimed_session":"7e896944-eea2-4c6c-a857-bd17dad2ef90","comments":[],"created_at":1784483061549013001,"creation_channel":"cli","deps":[],"description":"## What\n\nMove the strict eval-spec discipline check — currently an inline Python step in the\n`Prompt Eval` GitHub Actions workflow (`.github/workflows/prompt-eval.yml`) — into a\nunit test that runs in the default pytest suite, and remove the now-redundant inline step.\n\nThe check: for every packaged `src/rebar/llm/eval_specs/*.eval.yaml`, `validate_eval_spec(spec)`\nmust be clean, and every dataset-bearing spec must additionally pass `validate_eval_spec(spec,\nstrict=True)` (registered scorers + balanced dataset + non-empty gold_set).\n\n## Why (necessity)\n\nThe `Verified` Gerrit vote is assembled by `gerrit-verify.yaml`, whose `vote` job aggregates\n`build-and-test`, `optionality`, `golden-path`, and `verify-identity`. It does NOT reference\n`prompt-eval.yml`, so the strict validation does not gate `Verified` and does not block a Gerrit\nsubmit. Concrete evidence: three advisory plan-review specs (asserted-capability, decomp-shape,\nnecessity) each shipped a `dataset` with no `gold_set` and MERGED green (Verified +1) while the\nstandalone Prompt Eval workflow was red — the defect only reddened a non-gating workflow after\nthe fact (fixed in bug d37b). The strict glob-validation lives ONLY in the inline CI script; no\nunit test covers it (the existing `test_new_eval_specs.py` enumerates a hardcoded 3-spec tuple,\nso new specs are never checked). The default suite (`pytest -m \"not integration and not external\"`)\nruns in both `_build-and-test.yml` callers, so a test there blocks `Verified` pre-merge.\n\n## Scope\n\n- Add a glob-based test to `tests/unit/test_eval_scorers.py` (which already globs all packaged\n  specs and runs in the default suite) mirroring the inline CI logic exactly.\n- Remove the redundant \"Validate every packaged eval spec\" inline step from `prompt-eval.yml`\n  (the offline job still runs `test_eval_scorers.py`); update the header comment for accuracy.\n- No production/library code changes.\n\n## Acceptance Criteria\n\n- [ ] A unit test in `tests/unit/test_eval_scorers.py` globs every packaged eval spec and asserts\n      `validate_eval_spec(spec)` is clean, plus `validate_eval_spec(spec, strict=True)` clean for\n      every dataset-bearing spec; it is collected by the default (non-integration, non-external) suite.\n- [ ] The redundant inline validation step is removed from `.github/workflows/prompt-eval.yml`.\n- [ ] The new test fails if any dataset-bearing packaged spec lacks a gold_set (verified by a\n      local red→green check), and passes on current `main`.\n- [ ] `make lint` and the eval test suite pass; the `Prompt Eval` and `Verified` gates are green.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"tests/unit/test_eval_scorers.py","reason":"add glob-based strict eval-spec validation test (gating, runs in default suite)"},{"path":".github/workflows/prompt-eval.yml","reason":"remove the redundant inline strict-validation step now covered by the unit test"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[],"parent_id":null,"parent_status_uuid":"ff05cc5c-465b-4a19-9eff-244ccae5e9ec","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"1a5f-6f5d-6673-40b4","ticket_type":"task","title":"Gate eval-spec strict validation via a unit test (not only the standalone Prompt Eval workflow)","verify_commands":[]},"source_event_uuids":["c85e3a2f-8eba-42f9-a208-f9cd9820d159","4d097a42-1af9-4251-8218-cf73e361128f","58e14902-ef7e-4d29-b0fd-f3138ad8ca24","ff05cc5c-465b-4a19-9eff-244ccae5e9ec","de914102-39e4-44eb-8bb8-1120158aa50d"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784483454392547002,"uuid":"2ad4a1e0-77d3-4d23-b896-efbdc61d8afb"}