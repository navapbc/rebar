25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"f57e69956b91e92b7d6d23e3a0662150f67fe4d3e98fa829483183abb6a48ee8","event_uuid":"c8d87c59-7639-4699-a911-c5aef5706435","position":{"commit_sha":"45bf19579ecc3a4fcbe1dc4623be01a5267e68c8","position":"1784453197566326461-c8d87c59-7639-4699-a911-c5aef5706435"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-214_agent","claim_remote_session":null,"claimed_session":"6e3fbad8-702f-4987-ad70-cc88122eea43","comments":[],"created_at":1784416860225678001,"creation_channel":"cli","deps":[{"link_uuid":"143666d7-6d0b-4c9a-9b58-276b7abbfeb1","relation":"depends_on","target_id":"c085-6d11-d68d-422a"},{"link_uuid":"b2146a1f-2b83-4c6a-afcc-eb21bb3fb89e","relation":"depends_on","target_id":"3275-b164-2e9b-4e66"}],"description":"## What\nAn OPTIONAL, isolated adapter that harvests coverage % and CI-health (run status, duration, red->green recovery, flake/recheck rate) from GitHub Actions run history and persists them as labeled snapshots into the going-forward store, so those trends stop depending on GHA's short log-retention window. The core command does not depend on this adapter.\n\n## Files\n- `src/rebar/metrics/adapters/github_actions.py` — new isolated adapter: parse a GHA run's coverage (anchored word-boundary grep for the pytest-cov `TOTAL` line in the run-log tail) and CI-health from run-metadata JSON (status/conclusion, duration, and — across a fail->pass pair — a red->green recovery interval; recheck/flake rate from repeated runs on one commit).\n- `scripts/harvest_gha.py` — new: pull recent `test.yml` run logs + run metadata (via `gh`/the Actions API), run them through the adapter, and append labeled snapshots to the snapshot store. This SCRIPT is the persistence path (run locally/by a maintainer), NOT the CI workflow.\n- `tests/unit/metrics/test_gha_adapter.py` — new.\n\n## Snapshot store path & why NOT the CI workflow\nSnapshots are written via `src/rebar/metrics/snapshot.py` to the git-tracked **`.rebar/metrics-snapshots.ndjson`** (the established store path — `reports/` is gitignored; do NOT use it). **The `.github/workflows/test.yml` is deliberately NOT edited to commit snapshots**: the CI workflow runs with `permissions: contents: read` and CI checkouts are ephemeral, so it cannot commit a file back to the repo, and committing from CI is out of scope and fragile. Instead the harvester reads coverage/CI-health from the GHA API/run-logs after the fact and writes the tracked snapshots itself — which is exactly what removes the dependency on the retention window. (The coverage `TOTAL` line is already emitted to the run log by the existing pytest-cov step, so no workflow change is needed for the harvester to read it.)\n\n## Approach\nCI runs on GitHub Actions; coverage is in the run-log tail and CI-health in the run metadata, but only within a short retention window — so the harvester captures that window into the durable `.rebar` store. To keep the harness portable, the GHA source is an isolated adapter the core command never imports; a parallel adapter could target another CI. Log parsing is anchored (word-boundary grep for the coverage `TOTAL` line). Emitted snapshots carry `source=\"snapshot\"` (or a CI-health-specific label) so they sit in the going-forward series. Additive and optional.\n\n## Tests\n- Unit (fixture log text + run-metadata JSON — no network): the adapter extracts the coverage % from a fixture log tail and computes a red->green recovery interval from two fixture runs; the emitted record carries the snapshot label. The core-command isolation is asserted by scanning the core module source for an adapter import.\n\n## Acceptance Criteria\n- [ ] `tests/unit/metrics/test_gha_adapter.py` passes: a fixture `test.yml` coverage log yields the parsed coverage % (`assert pct == 84.2`) and two fixture runs (fail then pass) yield the expected red->green recovery duration.\n- [ ] `scripts/harvest_gha.py` writes the harvested coverage/CI-health as snapshots to `.rebar/metrics-snapshots.ndjson` (the tracked store), verified by a test feeding it fixture run data (adapter output stubbed/injected) and reading the snapshots back via `read_snapshots` — proving the persistence path and the correct store path (NOT `reports/`).\n- [ ] the portability guard holds: a unit test asserts the CORE metrics modules (`src/rebar/metrics/registry.py` and `src/rebar/metrics/__init__.py`) do not import the GHA adapter (and the future `_commands/metrics.py` from 9a5a is held to the same rule).","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/metrics/adapters/github_actions.py","reason":"isolated adapter"},{"path":"scripts/harvest_gha.py","reason":"harvest script"},{"path":".github/workflows/test.yml","reason":"append coverage snapshot step"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["depends_on","3275-b164-2e9b-4e66"],["depends_on","c085-6d11-d68d-422a"],["parent","86ac-086a-20ad-4327"]],"parent_id":"86ac-086a-20ad-4327","parent_status_uuid":"e4a36966-0a96-46dd-8318-403111de4448","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":["metrics","backfill"],"ticket_id":"1f77-f8c0-bfae-4a79","ticket_type":"task","title":"GitHub-Actions coverage + CI-health harvest adapter (optional, isolated)","verify_commands":[]},"source_event_uuids":["21347ded-6806-4b04-9606-d2e7879935c9","f9f9271d-f897-44f3-b9d3-d8b2594cb50a","143666d7-6d0b-4c9a-9b58-276b7abbfeb1","b2146a1f-2b83-4c6a-afcc-eb21bb3fb89e","e311ecaa-acd6-47a9-a968-66768a25d811","e34c01ef-bb2d-4d1e-9