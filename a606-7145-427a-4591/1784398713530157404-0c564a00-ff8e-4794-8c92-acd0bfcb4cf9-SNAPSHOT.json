AC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"42c94af2858aeafdea85c80b1ae2a2f9511d7f4daed6f7552e60331d5de269b6","event_uuid":"707885ec-ec42-4b08-9374-75c9e95bf550","position":{"commit_sha":"c49cf216560f307106882b70b4e961e22a6f49c0","position":"1784396774801863001-707885ec-ec42-4b08-9374-75c9e95bf550"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"49bf150d4539c7d84d7381a09e440d83dec7d54792fc6a26525df4a209ca5804","event_uuid":"a2e82d3b-9406-4707-b153-588dd0ee427d","position":{"commit_sha":"e8fe4cf34a39ac99eca73a0a0b376621c9fe12f1","position":"1784398713530157403-a2e82d3b-9406-4707-b153-588dd0ee427d"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-214_agent","claim_remote_session":null,"claimed_session":"e1dc6410-25d7-406a-b015-01c40c9fa16a","comments":[],"created_at":1784396305244640001,"creation_channel":"cli","deps":[],"description":"## Why\n\n`src/rebar/_engine/rebar_reconciler/outbound_differ.py` is 855 LOC, over the 800 module-size soft cap and grandfathered on the allowlist (ceiling 862). Graduate it off the allowlist by extracting the cohesive assignee-resolution cluster along the seam docs/architecture.md records for this file (identity-mapping fast-path + 3-tuple /user/search assignee-resolution + `_USER_SEARCH_METHODS` -> `outbound_assignee.py`).\n\n## What\n\nExtract the identity-mapping / assignee-resolution cluster (a genuine call-cluster: `_resolve_assignee_account_id` -> `_bootstrap_account_id_via_user_search` / `_identity_jira_account_id` / `_identity_email`, plus the `_USER_SEARCH_METHODS` constant) into a new leaf module `outbound_assignee.py` (same package). It is a leaf: it imports `rebar._commands.identity` lazily inside its functions and nothing from `outbound_differ`. This mirrors the three existing sibling extractions (`outbound_comments.py`, `outbound_fields.py`, `outbound_links.py`).\n\n`outbound_differ.py` imports the 5 moved symbols back from `outbound_assignee` and RE-EXPORTS them (`# noqa: F401`) so `outbound_differ.<symbol>` keeps resolving — load-bearing for `_bootstrap_account_id_via_user_search` (tests/unit/rebar_reconciler/test_identity_264f_resolve.py) and for the internal `_resolve_assignee_account_id` call. `_rebar_env` and everything else STAY. Pure refactor, no behavior change.\n\nThen graduate the file off the gate: remove its row from `.github/module-size-allowlist.txt` AND `.github/module-size-ceilings.txt`, and delete its `docs/architecture.md` remedy row.\n\n## Acceptance Criteria\n\n- [ ] `outbound_assignee.py` exists, is between 100 and 800 LOC, contains the moved assignee cluster (verify: `wc -l src/rebar/_engine/rebar_reconciler/outbound_assignee.py`)\n- [ ] `outbound_differ.py` is <= 800 LOC (verify: `wc -l src/rebar/_engine/rebar_reconciler/outbound_differ.py`)\n- [ ] `outbound_differ.py` is absent from BOTH `.github/module-size-allowlist.txt` and `.github/module-size-ceilings.txt`, and its `docs/architecture.md` remedy row is deleted (verify: `! grep outbound_differ .github/module-size-allowlist.txt .github/module-size-ceilings.txt`)\n- [ ] `tests/unit/test_module_size_contract.py` passes\n- [ ] The reconciler suite is green with no behavior change (verify: `pytest tests/unit/rebar_reconciler -q`)\n- [ ] Back-compat: `outbound_differ._bootstrap_account_id_via_user_search` and `outbound_differ._resolve_assignee_account_id` still resolve as module attributes (re-exported)\n\n## Notes\nLanded as its own Gerrit change (LLM-Review +1 AND Verified +1) before close. Mechanical/behavior-preserving refactor, so E5 testing-plan is not-applicable (existing reconciler tests are the oracle).","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_engine/rebar_reconciler/outbound_assignee.py","reason":"new leaf module holding the extracted assignee-resolution cluster"},{"path":"src/rebar/_engine/rebar_reconciler/outbound_differ.py","reason":"shrink below 800 LOC; import+re-export moved symbols"},{"path":".github/module-size-allowlist.txt","reason":"remove outbound_differ.py membership row"},{"path":".github/module-size-ceilings.txt","reason":"remove outbound_differ.py ceiling row"},{"path":"docs/architecture.md","reason":"delete outbound_differ.py remedy row"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","716f-b917-9fc8-41f5"]],"parent_id":"716f-b917-9fc8-41f5","parent_status_uuid":"60bcef06-c46f-4e2c-a541-5e38f8eae121","preconditions_summary":{"status":"pre-manifest"},"priority":1,"reverts":[],"status":"in_progress","tags":["module-size"],"ticket_id":"a606-7145-427a-4591","ticket_type":"story","title":"Split outbound_differ.py: extract assignee resolution into outbound_assignee.py","verify_commands":[]},"source_event_uuids":["4a158df5-ea29-4d50-9c72-25be97e5320f","01f185be-9459-48f8-8a0d-8ec663fe634a","8df653bf-5240-491f-8cb3-c03f6bac193d","60bcef06-c46f-4e2c-a541-5e38f8eae121","707885ec-ec42-4b08-9374-75c9e95bf550","a2e82d3b-9406-4707-b153-588dd0ee427d"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784398713530157404,"uuid":"0c564a00-ff8e-4794-8c92-acd0bfcb4cf9"}