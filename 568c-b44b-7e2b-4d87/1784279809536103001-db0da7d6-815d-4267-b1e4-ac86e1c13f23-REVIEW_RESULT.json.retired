{"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","author_sig":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","data":{"coaching":[{"coaching":"Plan how fsck detection and repair seam for missing provenance will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["fea361104b6dd9fc7","f4d9d6a38d23c15a5"],"move_id":"9","move_name":"plan the verification","subject":"fsck detection and repair seam for missing provenance"},{"coaching":"Pin down downgrade-window affected ticket enumeration mechanism with a concrete worked example.","decision":"advisory","finding_refs":["f81a216e6fca2abb6"],"move_id":"6","move_name":"specification by example","subject":"downgrade-window affected ticket enumeration mechanism"},{"coaching":"Plan how acceptance criteria completeness and provability will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f607dd457c67f9209","fb31d57252c4e7a07"],"move_id":"9","move_name":"plan the verification","subject":"acceptance criteria completeness and provability"},{"coaching":"Plan how concurrency regression test scope versus stated coverage will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f4a8ea932d4fb648a"],"move_id":"9","move_name":"plan the verification","subject":"concurrency regression test scope versus stated coverage"},{"coaching":"Plan how schema contract test files and their required updates will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["f0c274b3a8909977e"],"move_id":"9","move_name":"plan the verification","subject":"schema contract test files and their required updates"},{"coaching":"Plan how unlisted test file affected by rebuild changes will be verified in-session — restate any deferred or unobservable success target as an observable proxy.","decision":"advisory","finding_refs":["fd787e6f08883126c"],"move_id":"9","move_name":"plan the verification","subject":"unlisted test file affected by rebuild changes"}],"coverage":{"counts":{"advisory_overflow":0,"advisory_surfaced":9,"blocking":0,"dropped":11,"indeterminate":0},"det":{"P1":{"ac_items":7,"blocking":false,"clarity_score":7,"name":"readiness-shape","ran":true,"status":"pass"},"P2":{"blocking":false,"name":"resolution","ran":true,"references":0,"resolved":0,"status":"pass"},"P3":{"blocking":false,"name":"package-existence","packages":0,"ran":true,"status":"pass"},"P4":{"ac_items":7,"blocking":false,"desc_chars":7932,"file_impact":9,"name":"oversize","ran":true,"status":"pass"},"P5":{"blocking":false,"children":0,"name":"task-dag","ran":true,"status":"pass"},"P6":{"ac_items":7,"blocking":false,"name":"ac-quality","ran":true,"status":"fail","verify_commands_linted":4,"verify_lint_abstained":4},"P7":{"blocking":false,"destructive_hits":[],"name":"destructive-sniff","ran":true,"status":"pass"},"P8":{"blocking":false,"budget_tokens":868000,"name":"reviewability","plan_tokens":1997,"ran":true,"status":"pass"},"P9":{"applicable":true,"blocking":false,"file_impact":9,"name":"file-impact-coverage","ran":true,"status":"pass"}},"llm_ran":true,"metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":221.9,"llm_calls":29,"llm_ms":622801.3,"total_ms":623154.4,"verify_requests":24},"remediation":{"baseline":"sidecar","eligible":false,"reasons":{"code_unchanged":false,"plan_changed":false,"registry_unchanged":false,"sidecar_baseline":false,"within_window":false}},"routing":{"agent_tier":["A1","E4","G1G2","G6","G7","T1","T10","T11","T13","T14","T3","T5c","T8","removal-rationale"],"single_turn":["COH","E1","E2","E3","E5","E6","F1","G5","T12","T2","T4","T5b","T5e","T6","T7","T9","hedge","project.portability"]}},"findings":[{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] In the fsck.py section, explicitly specify the new detection condition needed in `_check_snapshot` or `_scan` (e.g. a `PROVENANCE_MISSING` finding type) that fires when a SNAPSHOT's `compiled_state` lacks `creation_channel` but the ticket's retained `.retired` CREATE event carries it, so `--repair-snapshots` can trigger a rebuild for that case.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["fsck.py _check_snapshot (lines 276-330): only inspects source_event_uuids consistency and pre-snapshot orphan events — no compiled_state content check","_scan() rebuildable guard (line 203): 'any(\"SNAPSHOT_INCONSISTENT\" in f or \"ORPHAN_EVENT\" in f for f in findings)' — no third term for creation_channel absence","Plan states: 'detect an old-style SNAPSHOT missing recorded provenance when a retained CREATE carries it'"],"finding":"The fsck.py change described — 'detect an old-style SNAPSHOT missing recorded provenance when a retained CREATE carries it and route --repair-snapshots through the existing rebuild seam' — requires new detection logic in _check_snapshot (or _scan) that reads the SNAPSHOT's compiled_state for an absent creation_channel and cross-references the retired CREATE. The existing --repair-snapshots path routes only on SNAPSHOT_INCONSISTENT or ORPHAN_EVENT findings (structural UUID checks); it has no hook for semantic content absence. This is non-trivial new behavior not enumerated as a distinct behavioral hunk.","group_criteria":null,"group_id":null,"id":"fea361104b6dd9fc7","impact":0.85,"is_primary":null,"location":"Files section: src/rebar/_commands/fsck.py / AC5","norm_id":"n013b3fb3d9b99abf","priority":0.6611,"reason":"default-advisory","scenarios":["A SNAPSHOT produced during a downgrade window will have creation_channel absent in compiled_state, but no existing fsck check will flag it as SNAPSHOT_INCONSISTENT or ORPHAN_EVENT, so --repair-snapshots will silently skip it rather than triggering a rebuild."],"severity":"critical","suggested_fix":"","tier":"LLM","validity":0.7778,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"low","divergent_implementation":"medium","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"medium","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a new detection rule to `_check_snapshot` (or the fsck check loop) that surfaces a `PROVENANCE_MISSING` (or similar) finding when a SNAPSHOT's `compiled_state` lacks `creation_channel` but the ticket directory contains a `.retired` CREATE with the field, so the existing `--repair-snapshots` trigger in fsck.py:203 can route it to `rebuild_snapshot_from_full_log`.","cohort":["T3"],"criteria":["T3"],"decision":"advisory","drop_reason":null,"evidence":["fsck.py:203: `rebuildable = any(\"SNAPSHOT_INCONSISTENT\" in f or \"ORPHAN_EVENT\" in f for f in findings)` — trigger is structural, not field-content based","_check_snapshot (fsck.py:276-330) checks source_event_uuids consistency and orphan events only; it does not inspect compiled_state fields","Plan says 'existing fsck --repair-snapshots seam' but the seam's entry condition does not cover missing provenance fields","Partially-verified: --repair-snapshots flag and rebuild_snapshot_from_full_log exist and work; the specific detection surface for missing-creation_channel is unverified/absent"],"finding":"The plan asserts that a SNAPSHOT missing `creation_channel` in its `compiled_state` can be 'detected and repaired from its retained CREATE through the existing fsck --repair-snapshots seam,' but the existing seam trigger (fsck.py:203) fires only when `SNAPSHOT_INCONSISTENT` or `ORPHAN_EVENT` findings are present — both of which are structural positional/orphan checks that would NOT fire for a structurally valid SNAPSHOT that simply omits provenance fields. A new detection branch must be added to `_check_snapshot` or the `fsck` check loop to surface this missing-field condition before `--repair-snapshots` can route it to `rebuild_snapshot_from_full_log`.","group_criteria":null,"group_id":null,"id":"f4d9d6a38d23c15a5","impact":0.85,"is_primary":null,"location":"Files section: src/rebar/_commands/fsck.py — 'detect an old-style SNAPSHOT missing recorded provenance when a retained CREATE carries it and route --repair-snapshots through the existing rebuild seam'; AC5: 'A simulated old-style SNAPSHOT missing creation_channel is detected and repaired from its retained CREATE through the existing fsck --repair-snapshots seam.'","norm_id":"nb687832978524c4b","priority":0.6611,"reason":"default-advisory","scenarios":["A legacy SNAPSHOT that is structurally valid (correct source_event_uuids, no orphans) but was written before creation_channel existed will produce no SNAPSHOT_INCONSISTENT or ORPHAN_EVENT findings, so --repair-snapshots will silently skip it even when a retained CREATE has the provenance data.","AC5's test for 'rollback_recovery' would fail or require the test itself to inject a synthetic SNAPSHOT_INCONSISTENT finding to force the repair path, obscuring whether the real seam extension was implemented."],"severity":"critical","suggested_fix":"","tier":"LLM","validity":0.7778,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"yes","evidence_entails_finding":"yes","impact_follows_necessarily":"yes","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"low","divergent_implementation":"medium","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"high","prod_impact":"medium","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Update the rollback schema-state matrix to explicitly name `rebar fsck --repair-snapshots` as the automated mechanism for detecting and repairing old-code SNAPSHOTs missing `creation_channel` (replacing or supplementing the manual 'record affected ticket IDs' instruction), and confirm that the fsck detection criterion covers the case where a retained CREATE carries the field but the SNAPSHOT does not.","cohort":["T11"],"criteria":["T11"],"decision":"advisory","drop_reason":null,"evidence":["Plan quote: 'before a full binary downgrade, operators stop every scheduled or manual rebar compact invocation. If the pause is violated, they record the affected ticket IDs from downgrade-window compaction activity'","Plan quote (fsck.py scope): 'detect an old-style SNAPSHOT missing recorded provenance when a retained CREATE carries it and route --repair-snapshots through the existing rebuild seam'","ABSENCE: the rollback matrix does not state that fsck --repair-snapshots IS the mechanism to enumerate and repair affected tickets, leaving a gap between the operational instruction and the automated detection path","Post-rollback schema state for scenario 2 (old-code compaction of creation-bearing CREATEs): SNAPSHOT lacks creation_channel, CREATE is .retired — the field is absent from SNAPSHOT-only replay until rebuild, and without automated enumeration an operator may not know which tickets need rebuilding"],"finding":"The rollback matrix instructs operators to 'record the affected ticket IDs from downgrade-window compaction activity' as a manual step, but specifies no mechanism, log, or automated tool to enumerate which tickets were compacted by old-code during the downgrade window. The fsck.py scope item (detect old-style SNAPSHOT missing creation_channel and route --repair-snapshots) is the correct automated mechanism, but it is not explicitly connected to the rollback guidance — the rollback section reads as though ID-recording is an operator responsibility with no enforcement. If an operator fails to record the IDs (or never runs fsck), the absence of creation_channel from affected SNAPSHOTs silently persists in SNAPSHOT-only replay until manually discovered.","group_criteria":null,"group_id":null,"id":"f81a216e6fca2abb6","impact":0.67,"is_primary":null,"location":"What section — rollback schema-state matrix (third bullet); Files — src/rebar/_commands/fsck.py","norm_id":"n51a97f28bcd05afc","priority":0.4188,"reason":"default-advisory","scenarios":["Operator violates the compact pause during a downgrade window; old-code compaction runs on tickets with creation_channel; operator fails to manually record the affected IDs; creation_channel is silently absent from those SNAPSHOTs indefinitely","Long-running deployment with many tickets: operator cannot feasibly enumerate affected tickets by hand; without fsck surfacing the condition, the gap is invisible"],"severity":"major","suggested_fix":"In the rollback matrix, replace or augment 'they record the affected ticket IDs from downgrade-window compaction activity' with: 'after re-deploying the new binary, run `rebar fsck --repair-snapshots` — the fsck check (planned in fsck.py) detects every SNAPSHOT missing creation_channel whose retained CREATE carries it and routes those tickets through the existing rebuild seam automatically, eliminating the need to manually enumerate affected IDs.'","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"medium"}}},{"block_threshold":null,"blocking_enabled":null,"checklist_item":"","cohort":null,"criteria":["P6"],"decision":"advisory","drop_reason":null,"evidence":["4 criterion line(s) bundle multiple deliverables with 'and' (split so each is independently verifiable)."],"finding":"Acceptance-criteria / definition-of-done quality issues.","group_criteria":null,"group_id":null,"id":"f607dd457c67f9209","impact":0.4,"is_primary":null,"location":"","norm_id":"ned06ebc801a522e3","priority":0.4,"reason":null,"scenarios":[],"severity":"minor","suggested_fix":"Split compound criteria, replace subjective terms with observable outcomes, and state how each is verified.","tier":"DET","validity":1.0,"verification":null},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add or extend a test (or update test_event_schema_forward_compat.py fixtures) to explicitly simulate old-code process_snapshot receiving a SNAPSHOT whose compiled_state contains creation_channel and creation_channel_inferred, confirming the keys survive replay intact.","cohort":["COH","E1","T4"],"criteria":["T4"],"decision":"advisory","drop_reason":null,"evidence":["'an existing new-code SNAPSHOT retains unknown compiled_state keys if replayed by old code'","AC #6: 'Prove with uv run pytest -q tests/interfaces/lifecycle/test_compact_rollback_recovery.py tests/interfaces/store/test_fsck_snapshot_checks.py tests/interfaces/contracts/test_event_schema_forward_compat.py'","ABSENCE: no new test or updated fixture is described that places creation_channel* keys in a compiled_state and replays it through old-code process_snapshot logic"],"finding":"The rollback description asserts that old-code replay of a new-code SNAPSHOT will carry forward unknown compiled_state keys harmlessly ('an existing new-code SNAPSHOT retains unknown compiled_state keys if replayed by old code'), but no new test is added to verify this for the specific new keys. AC #6 points only to pre-existing tests (test_event_schema_forward_compat.py) that predate this change and almost certainly do not include creation_channel or creation_channel_inferred in their fixture SNAPSHOTs.","group_criteria":null,"group_id":null,"id":"f5d7a318a30e4a241","impact":0.55,"is_primary":null,"location":"What section (rollback schema-state matrix) / AC #6 verify command","norm_id":"ne4af83422bf2779b","priority":0.3438,"reason":"default-advisory","scenarios":["A future old-code deployment encounters new-format SNAPSHOTs during the rollback window; if old process_snapshot strips or errors on unknown keys the recovery path described in the rollback matrix silently breaks."],"severity":"major","suggested_fix":"In tests/interfaces/contracts/test_event_schema_forward_compat.py, add a fixture SNAPSHOT whose compiled_state includes {'creation_channel': 'jira', 'creation_channel_inferred': True} and assert that the restored state retains both keys when process_snapshot runs — this directly validates the rollback-matrix claim.","tier":"LLM","validity":0.625,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"yes"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Explicitly state in AC #7 (or in the Files list) that test_schema_outputs.py and/or test_schema_coverage.py must be extended with assertions for each of the six newly-required documentation topics so the proving command cannot pass vacuously on unmodified test fixtures.","cohort":["E2","E6","F1"],"criteria":["E6","F1"],"decision":"advisory","drop_reason":null,"evidence":["Plan lists test_schema_outputs.py and test_schema_coverage.py as EXISTING files (not in the new-file list under Files)","AC states 'verify docs/event-schema.md plus docs/output-schemas.md jointly cover the enum, Jira inference, import semantics, SNAPSHOT placement, actor/environment/source_* distinctions, plus the diagnostic trust boundary' — six distinct new content requirements","VCDT issue #4 (fixture invalidity): the fixtures (existing tests) do not exercise the new claims unless explicitly updated","No plan step says 'update test_schema_outputs.py / test_schema_coverage.py to assert new doc content'"],"finding":"AC #7's proving command references existing test files (test_schema_outputs.py, test_schema_coverage.py) but the plan never specifies that those files must be updated to assert the six newly-required documentation topics (enum, Jira inference, import semantics, SNAPSHOT placement, actor/environment/source_* distinctions, diagnostic trust boundary). An executor could add the prose to the docs, run the unmodified existing tests (which know nothing of the new content), get green, and declare done — the AC is vacuously satisfiable.","group_criteria":null,"group_id":null,"id":"fb31d57252c4e7a07","impact":0.55,"is_primary":null,"location":"Acceptance Criteria — final bullet (AC #7): 'Prove with uv run pytest -q tests/interfaces/contracts/test_schema_outputs.py tests/interfaces/contracts/test_schema_coverage.py && make lint'","norm_id":"n3f6aea1968e063ed","priority":0.275,"reason":"default-advisory","scenarios":["Executor writes new doc sections, existing schema coverage tests pass because they only check pre-existing coverage anchors, executor marks AC done — new doc content is never actually machine-verified.","CI stays green on a PR that omits the Jira-inference or SNAPSHOT-placement doc sections entirely."],"severity":"major","suggested_fix":"Add to the Files list: 'tests/interfaces/contracts/test_schema_outputs.py and tests/interfaces/contracts/test_schema_coverage.py: extend coverage anchors for creation_channel enum values, Jira inference marker, import semantics, SNAPSHOT compiled_state placement, actor/env/source_* distinctions, and diagnostic trust boundary.' Then amend AC #7 to read '…after extending the coverage tests to assert each of the six new topics…'.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"yes","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Replace or supplement the `tests/integration/test_concurrency_regression.py` reference in AC-5 with `tests/scripts/reducer/test_snapshot_horizon_rebuild.py` (or a new test in that module), which actually exercises snapshot rebuild and horizon compaction paths.","cohort":["E4"],"criteria":["E4"],"decision":"advisory","drop_reason":null,"evidence":["Read tests/integration/test_concurrency_regression.py lines 1-60: module docstring covers only 'Two independent clones… concurrent transitions… reconverge… (a) union (b) deterministic (c) fork tie-break (d) no data loss'","Search for 'rebuild' in test_concurrency_regression.py: no matches","tests/scripts/reducer/test_snapshot_horizon_rebuild.py exists and its docstring confirms it covers include_retired full-log replay and rebuild path cache bypass"],"finding":"AC-5 cites `uv run pytest -q tests/integration/test_concurrency_regression.py` as proof for 'rebuild and horizon regression', but reading that file confirms it covers only WS3 concurrency invariants (union, deterministic replay, fork tie-break, no data loss under push failure) — it has no test cases for snapshot rebuild or horizon compaction. The actual horizon+rebuild reducer tests live in `tests/scripts/reducer/test_snapshot_horizon_rebuild.py`, which is not referenced anywhere in the plan's AC commands.","group_criteria":null,"group_id":null,"id":"f4a8ea932d4fb648a","impact":0.55,"is_primary":null,"location":"Acceptance Criteria, AC-5: 'uv run pytest -q tests/interfaces/lifecycle/test_creation_channel_compaction.py -k \"rebuild or horizon or rollback_recovery\" && uv run pytest -q tests/integration/test_concurrency_regression.py'","norm_id":"n36eea9c99712563b","priority":0.275,"reason":"default-advisory","scenarios":["The plan author may believe test_concurrency_regression.py covers horizon/rebuild regressions, and will not add the missing coverage, leaving those paths unguarded.","A reviewer who audits AC-5 and runs only the cited command sees green (the existing concurrency tests pass) but the horizon+rebuild regression is never actually exercised."],"severity":"major","suggested_fix":"Change AC-5's prove command to: `uv run pytest -q tests/interfaces/lifecycle/test_creation_channel_compaction.py -k \"rebuild or horizon or rollback_recovery\" && uv run pytest -q tests/scripts/reducer/test_snapshot_horizon_rebuild.py tests/integration/test_concurrency_regression.py`","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"underspecified_oracle","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add tests/interfaces/contracts/test_schema_outputs.py and tests/interfaces/contracts/test_schema_coverage.py to the Files list (with a note on what needs updating), or explicitly state in AC #7 that these tests require no modification and explain why.","cohort":["COH","E1","T4"],"criteria":["E1"],"decision":"advisory","drop_reason":null,"evidence":["AC #7: 'Prove with uv run pytest -q tests/interfaces/contracts/test_schema_outputs.py tests/interfaces/contracts/test_schema_coverage.py && make lint'","Files section lists docs/output-schemas.md as a changed file but does not list tests/interfaces/contracts/test_schema_outputs.py or tests/interfaces/contracts/test_schema_coverage.py","What section: 'Update docs/output-schemas.md to state that SNAPSHOT-only replay plus snapshot rebuild emit the same creation_channel and creation_channel_inferred values'"],"finding":"AC #7's verify command references tests/interfaces/contracts/test_schema_outputs.py and tests/interfaces/contracts/test_schema_coverage.py, but neither file appears in the Files list. Because docs/output-schemas.md is being materially updated (new parity guarantee between full-log, SNAPSHOT-only, and rebuilt-SNAPSHOT replay), at least test_schema_coverage.py likely requires a corresponding update; omitting it from Files leaves that work unscoped.","group_criteria":null,"group_id":null,"id":"f0c274b3a8909977e","impact":0.0,"is_primary":null,"location":"AC #7 verify command / Files section","norm_id":"n48ec10aa053dd493","priority":0.0,"reason":"default-advisory","scenarios":["An implementer updates docs/output-schemas.md but doesn't know whether the contract tests need updating because the Files list implies they are untouched; the AC then fails in CI."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add `tests/unit/test_identity_4e9d_heldout.py` to the Files section (or explicitly note it as a verified non-impact consumer), since it calls `rebuild_snapshot_from_full_log` and may need assertion updates once `creation_channel` appears in the rebuilt compiled_state.","cohort":["G1G2"],"criteria":["G1G2"],"decision":"advisory","drop_reason":null,"evidence":["tests/unit/test_identity_4e9d_heldout.py:116: 'compact.py's rebuild_snapshot_from_full_log path also stamps author_email.'","tests/unit/test_identity_4e9d_heldout.py:123: '_compact.rebuild_snapshot_from_full_log(tracker, tid, ticket_dir)'","File section omits tests/unit/test_identity_4e9d_heldout.py entirely"],"finding":"tests/unit/test_identity_4e9d_heldout.py calls rebuild_snapshot_from_full_log (confirmed at line 123) and asserts on the rebuilt snapshot's compiled_state, but is not listed in the Files section. Once creation_channel is included in compiled_state (via the dependency stories), the rebuilt snapshot produced by rebuild_snapshot_from_full_log will contain creation_channel, and this test's snapshot-content assertions could fail or require updating.","group_criteria":null,"group_id":null,"id":"fd787e6f08883126c","impact":0.0,"is_primary":null,"location":"Files section / src/rebar/_commands/compact.py: rebuild_snapshot_from_full_log","norm_id":"ndf80c0c423ae6e3b","priority":0.0,"reason":"default-advisory","scenarios":["After the dependency stories deliver creation_channel into compiled_state, rebuild_snapshot_from_full_log will include it in the rebuilt SNAPSHOT. test_identity_4e9d_heldout.py's assertions over the rebuilt state could start failing if it checks the full compiled_state dict or asserts on its exact keys."],"severity":"none","suggested_fix":"Add `tests/unit/test_identity_4e9d_heldout.py` to the Files section with reason 'verify no assertion regression from creation_channel appearing in rebuilt SNAPSHOT compiled_state'.","tier":"LLM","validity":0.5714,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add an ADR or AGENTS.md entry (or a clearly-marked section in docs/concurrency.md) capturing: (1) why compiled_state is the provenance home, (2) the rationale for test-only strip-key enforcement, and (3) the rollback schema-state matrix with operator preconditions — so the design intent survives beyond the plan ticket.","cohort":["T2","T5e","T7"],"criteria":["T7","T5e"],"decision":"dropped","drop_reason":null,"evidence":["Plan names docs/event-schema.md, docs/output-schemas.md, docs/concurrency.md as doc targets — none is an ADR or AGENTS.md.","'The guard is deliberately test-enforced rather than a production assertion because the strip set is static internal policy and CI is the enforcement boundary.' — this design rationale exists only in ephemeral plan prose.","'Preserving the field through that established path avoids a second provenance representation' — architectural justification present only in Approach Rationale, not in a committed artifact.","No ADR, no AGENTS.md update, no design-doc entry appears in the Files list."],"finding":"The plan introduces three durable architectural decisions — (1) compiled_state as the canonical provenance home rather than the SNAPSHOT envelope, (2) CI/test-only enforcement of the strip-key guard rather than a production assertion, and (3) the rollback schema-state matrix with its operator preconditions — but names no ADR or AGENTS.md update to preserve this rationale. The targeted doc files (event-schema.md, output-schemas.md, concurrency.md) cover consumer-facing contracts, not the internal design rationale. Future maintainers touching compact.py or _processors.py will lack a traceable record of why these choices were made.","group_criteria":null,"group_id":null,"id":"f921f79761415932c","impact":0.0,"is_primary":null,"location":"Files section / Approach Rationale / What (rollback matrix paragraph)","norm_id":"nc7a99f9614c6bd91","priority":0.0,"reason":"low-validity","scenarios":["A future engineer extending compiled_state compaction or adding a new strip key has no traceable record of the test-only enforcement rationale and may inadvertently introduce a production assertion or duplicate representation.","A rollback incident responder finds the schema-state matrix only in a closed ticket rather than in an ops runbook or concurrency ADR, slowing diagnosis."],"severity":"none","suggested_fix":"Add `docs/adr/NNN-snapshot-provenance-placement.md` to the Files list, covering the three decisions above, and reference it from the final AC documentation-integrator check. Alternatively, add a clearly delimited 'Architecture Notes' section to docs/concurrency.md (already a target file) that captures these three rationale points so they live in a committed, versioned artifact.","tier":"LLM","validity":0.1429,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"no","path_reachable":"na","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"medium","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"none","reversibility":"moderate","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify the error contract for _project_legacy_creation_channel: define whether it must never raise (log-and-continue) or whether it is allowed to propagate, and add a test case covering a malformed/unexpected compiled_state input.","cohort":["T12","T5b","T9"],"criteria":["T5b"],"decision":"dropped","drop_reason":null,"evidence":["No error-handling clause appears around the helper invocation description.","process_snapshot is presumably on the critical path for every snapshot restore operation; an unhandled exception would abort replay entirely."],"finding":"The plan does not specify what happens if _project_legacy_creation_channel raises an exception during process_snapshot restore — it is silent on whether the failure should be a hard abort or a graceful degradation that logs a warning and leaves the field absent.","group_criteria":null,"group_id":null,"id":"f0f2e1776670b6f66","impact":0.33,"is_primary":null,"location":"What section: 'At the end of process_snapshot, after compiled_state restoration ... call _project_legacy_creation_channel(state)'","norm_id":"n132eefaf07eb8eee","priority":0.1237,"reason":"low-validity","scenarios":["A snapshot with unexpected/corrupt compiled_state data causes the inference helper to throw; the entire ticket becomes unreadable rather than returning with creation_channel absent.","A dependency (e.g., ticket_id pattern matching) changes and the helper throws on upgrade — rolling back becomes harder if replays are broken."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"medium","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Add a logging (at least DEBUG/INFO level) specification for: (a) each legacy projection invocation that modifies a restored state, (b) each fsck detection of a SNAPSHOT missing creation_channel, and (c) each rebuild triggered for provenance repair.","cohort":["T12","T5b","T9"],"criteria":["T5b"],"decision":"dropped","drop_reason":null,"evidence":["No logging, metric emission, or alerting is mentioned for any of the new failure/migration paths.","The fsck --repair-snapshots seam is referenced for detection and repair but no diagnostic output spec is given.","The rollback recovery procedure requires operators to 'record affected ticket IDs' but provides no tooling or log signal to identify them."],"finding":"The plan does not address observability (logging or metrics) when the legacy projection hook fires, when fsck detects a SNAPSHOT missing creation_channel, or when rebuild_snapshot_from_full_log is invoked for provenance repair — operators have no signal that migration or repair activity is occurring.","group_criteria":null,"group_id":null,"id":"f0738b6b2f527ef69","impact":0.33,"is_primary":null,"location":"What section / src/rebar/_commands/fsck.py / src/rebar/reducer/_processors.py","norm_id":"nbb25444fb19dc75b","priority":0.1237,"reason":"low-validity","scenarios":["After a silent downgrade-window compaction, operators cannot identify which tickets were compacted without creation_channel because no log entry was emitted.","Legacy projection fires on thousands of tickets during a bulk replay; there is no metric to distinguish inferred-from-snapshot from inferred-from-live-CREATE."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"medium","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"silent","undecomposed":"none","vague_directive":"low"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Specify the ordering and idempotency contract for the SNAPSHOT-write + CREATE-retire sequence: define which operation happens first, that re-running compact on a partially-compacted ticket is safe, and add a test that simulates a crash between the two steps.","cohort":["T12","T5b","T9"],"criteria":["T5b","T9"],"decision":"dropped","drop_reason":null,"evidence":["The plan states compact 'retires the source CREATE' and writes the SNAPSHOT but gives no ordering or atomicity guarantee.","'Writes idempotent; partial state safe/durable' is a T5b requirement for write operations.","No mention of how a subsequent compact run behaves if it encounters a ticket with both a live SNAPSHOT and an un-retired CREATE."],"finding":"The plan does not specify the atomicity or idempotency of the two-phase compaction write (write SNAPSHOT + retire CREATE) under mid-operation failure — if the process crashes after writing the SNAPSHOT but before retiring the CREATE (or vice versa), the safe-restart behavior is unspecified.","group_criteria":null,"group_id":null,"id":"f29b1c37322f77d81","impact":0.0,"is_primary":null,"location":"src/rebar/_commands/compact.py / Acceptance Criteria AC5 (rebuild and horizon)","norm_id":"n9548dad55a6179cf","priority":0.0,"reason":"veto:absence-refuted","scenarios":["Process crashes after SNAPSHOT is written but CREATE is not yet retired; next compact run sees both and may double-compact or produce a duplicate SNAPSHOT.","Process crashes before SNAPSHOT is written but after CREATE is marked retired; ticket loses its CREATE permanently with no SNAPSHOT to compensate."],"severity":"none","suggested_fix":"Write SNAPSHOT first, then retire CREATE (so a crash leaves the CREATE still active and the next compact run safely overwrites the orphan SNAPSHOT); document this ordering explicitly.","tier":"LLM","validity":0.4286,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Acknowledge the all-at-once activation explicitly and either (a) add a --legacy-projection-only dry-run mode that reports what _project_legacy_creation_channel would change without writing, or (b) document a bounded blast-radius estimate (e.g., only tickets with no existing creation_channel in their last SNAPSHOT are affected) so operators can scope a targeted rebuild if needed.","cohort":["T12","T5b","T9"],"criteria":["T12"],"decision":"dropped","drop_reason":null,"evidence":["No flag, canary, or staged-activation path is described.","The rollback procedure is manual: stop compact, record IDs, re-deploy, rebuild — no automated or cheap undo.","'The MVP has no writer-only binary mode' explicitly rules out a staged approach."],"finding":"The plan specifies no feature flag or incremental opt-in mechanism — the new compiled_state fields and legacy projection hook activate for all tickets simultaneously on binary upgrade, with rollback requiring a full binary swap and manual operator steps to capture affected IDs.","group_criteria":null,"group_id":null,"id":"f1bf749f9803ed39b","impact":0.0,"is_primary":null,"location":"Rollout/rollback section in What: 'Before a full binary downgrade, operators stop every scheduled or manual rebar compact invocation'","norm_id":"nd704babbb161dc4a","priority":0.0,"reason":"veto:absence-refuted","scenarios":["A bug in _project_legacy_creation_channel causes incorrect inference for a class of tickets; all affected tickets have already been processed before the bug is detected, requiring full rebuild.","Operator misses the compact-pause window during downgrade; the recovery procedure requires identifying affected IDs from logs that may not exist (see observability finding)."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"no","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"module","debt_impact":"low","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"moderate","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.95,"blocking_enabled":false,"checklist_item":"- [ ] Confirm that _project_legacy_creation_channel is consumed by at least one other call-site beyond process_snapshot (e.g. the upstream Jira/import story's inference path) before extracting it as a named helper; if it has only one call-site, inline it as a conditional block in process_snapshot following the existing managed_refs / attestations migration pattern.","cohort":["A1"],"criteria":["A1"],"decision":"dropped","drop_reason":null,"evidence":["Plan states: 'call _project_legacy_creation_channel(state)' as a single hook at end of process_snapshot","Plan's Dependency clause: 'the shared field, inference helper, and marker semantics must exist before snapshot migration can preserve them' — implies the helper is exported for the upstream story, but that story's call-site is not named in this plan","Existing codebase pattern: managed_refs seeding is inlined directly into process_snapshot (line 764) as a one-liner; attestations fold-in (lines 772-777) is also inlined — neither extracts a named helper, because each is a simple conditional","grep of src/rebar shows zero existing hits for _project_legacy_creation_channel, creation_channel, or creation_channel_inferred — the helper does not yet exist and no second call-site is visible"],"finding":"_project_legacy_creation_channel is introduced as a 'shared helper' but the plan names only one explicit call-site (end of process_snapshot); without a second confirmed consumer the Rule-of-Three bar is not met and the extraction may be premature.","group_criteria":null,"group_id":null,"id":"fcdb081cf4327b164","impact":0.0,"is_primary":null,"location":"What section / Files: src/rebar/reducer/_processors.py — 'call _project_legacy_creation_channel(state)' hook","norm_id":"n37d81005911479d0","priority":0.0,"reason":"veto:absence-refuted","scenarios":["If the upstream Jira/import story inlines the inference logic rather than calling this helper, the extracted function has exactly one call-site and violates Rule-of-Three.","If the helper is private to _processors.py, it adds an indirection layer with no reuse benefit over inlining the three-state conditional directly (as the managed_refs and attestations migrations do)."],"severity":"none","suggested_fix":"If only one call-site exists, inline the three-state check directly in process_snapshot after the keyring migration block (as a plain `if 'creation_channel' not in compiled_state:` guard), matching the style of the managed_refs and attestations migrations already there.","tier":"LLM","validity":0.4,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.75,"blocking_enabled":true,"checklist_item":"- [ ] Explicitly name the module path and function signature of `_project_legacy_creation_channel` and confirm the `creation_channel` / `creation_channel_inferred` field names match what the Jira/import story will export — reference the dependency story's AC or a shared constants module so this plan cannot diverge from its upstream contract.","cohort":["E4"],"criteria":["E4"],"decision":"dropped","drop_reason":null,"evidence":["Grep of src/rebar for '_project_legacy_creation_channel': no matches","Grep of src/rebar for 'creation_channel': no matches","Grep of src/rebar for 'creation_channel_inferred': no matches","Plan states: 'Depends on the Jira/import story because the shared field, inference helper, and marker semantics must exist before snapshot migration can preserve them.'"],"finding":"The plan's central helper `_project_legacy_creation_channel` and both fields `creation_channel` / `creation_channel_inferred` are entirely absent from the codebase. The plan treats them as deliverables of the upstream 'Jira/import story' dependency, but a grep of the full `src/rebar` tree finds zero matches for any of these three names — so the dependency assertion ('the shared field, inference helper, and marker semantics must exist') rests on an upstream story that has not landed. If the dependency story ships late or with a different API, every piece of this plan (process_snapshot hook, compaction strip-key guard, legacy migration, AC tests) breaks at the integration seam with no fallback.","group_criteria":null,"group_id":null,"id":"fc615bdd7fda2aad6","impact":0.0,"is_primary":null,"location":"Dependencies section; Approach Rationale; What §4 ('call _project_legacy_creation_channel(state)')","norm_id":"n193bca3fa190dadb","priority":0.0,"reason":"veto:absence-refuted","scenarios":["If the Jira/import story ships with a different helper name or field name, every call site in this plan (_processors.py, compact.py test, AC tests) silently references the wrong symbol.","If the dependency story is descoped or split, this plan has no field to preserve and no helper to call, yet the AC tests will still be written expecting them."],"severity":"none","suggested_fix":"Add a 'Dependency contract' sub-section naming the exact import path (e.g., `from rebar.reducer._provenance import _project_legacy_creation_channel`), the field enum values, and the inference predicate signature. Alternatively, add a stub/protocol import here that the dependency story must satisfy, making a mismatch a CI import error rather than a silent logic hole.","tier":"LLM","validity":0.5714,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"yes","path_reachable":"yes","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"self_revealing","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.6,"blocking_enabled":true,"checklist_item":"- [ ] Specify a second distinguishing marker (e.g. a `creation_channel_recorded=true` flag parallel to `creation_channel_inferred`, or restrict `_project_legacy_creation_channel`'s re-projection guard to only trigger when `creation_channel` is absent or None — never when it is a known enum value including `unknown`) so the helper cannot overwrite a value that was explicitly written by the dependency story's write path.","cohort":["G6"],"criteria":["G6"],"decision":"dropped","drop_reason":null,"evidence":["Plan text: 'absent, None, or provisional unknown-without-marker state is re-evaluated from restored ticket_id/author/env_id'","Plan text: 'creation_channel_inferred=true' is only materialized for 'inferred historical Jira' (AC2), not for recorded-unknown","The state distinguisher between 'provisional unknown' and 'recorded unknown' is unspecified — both arrive in compiled_state with creation_channel=unknown and no inferred marker","process_create (live code) does not yet stamp creation_channel, so ALL pre-dependency-story tickets share this ambiguity, but post-dependency-story tickets that record explicit unknown will also hit it"],"finding":"The no-op guard in `_project_legacy_creation_channel` cannot distinguish a legitimately recorded `creation_channel=unknown` (written by the dependency story's writer path) from a pre-feature 'provisional unknown-without-marker' state, because the plan only materializes `creation_channel_inferred=true` for inferred-Jira outcomes, not for recorded-unknown. A post-feature ticket whose CREATE explicitly sets `creation_channel=unknown` would arrive in process_snapshot with `creation_channel=unknown` and no inferred marker — the same state as a provisional pre-feature unknown — causing the helper to incorrectly re-project it to `unknown` (a no-op in this case but fragile) or, if the three-signal Jira predicate fires, to incorrectly override a recorded `unknown` with `jira`.","group_criteria":null,"group_id":null,"id":"f0d1d395fc91961e1","impact":0.0,"is_primary":null,"location":"What section: '_project_legacy_creation_channel' helper description; 'absent, None, or provisional unknown-without-marker state is re-evaluated'","norm_id":"nb65d36c7b04ec316","priority":0.0,"reason":"veto:absence-refuted","scenarios":["A ticket created via the dependency story's writer path with explicit creation_channel=unknown is then compacted; process_snapshot calls _project_legacy_creation_channel; the helper sees creation_channel=unknown, no inferred marker, and the Jira three-signal predicate fires — the recorded unknown is silently overwritten with jira","After the dependency story ships and some tickets have recorded-unknown, any downgrade/rebuild cycle re-runs the migration and mis-classifies them"],"severity":"none","suggested_fix":"Narrow the re-projection trigger to `creation_channel is None or creation_channel not in VALID_CHANNEL_ENUM`. A recorded `unknown` is a known enum value and should be treated as concrete-recorded, bypassing re-inference. The 'provisional unknown-without-marker' concept should be dropped in favor of 'absent or None triggers migration; any enum value including unknown is concrete'.","tier":"LLM","validity":0.5,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"yes","path_reachable":"no","respects_artifact_altitude":"yes","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Add a reference to (or inline) the canonical `creation_channel` enum vocabulary (cli, mcp, python, jira, import, unknown) in the What section, and name the module/constant (e.g., in `reducer/_version.py`) where it is defined, so `_project_legacy_creation_channel`'s no-op guard can be implemented unambiguously.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Plan says '_project_legacy_creation_channel… is a no-op for concrete recorded channels or an already-inferred jira value; absent, None, or provisional unknown-without-marker state is re-evaluated' — the boundary between 'concrete recorded' and 'provisional unknown' requires a canonical enum set.","AC1 names cli, mcp, python, jira, and import as channels, AC2 names jira/inferred, AC3 names unknown — but no single authoritative vocabulary definition is given.","grep for `creation_channel` in src/rebar and docs returns zero matches — the field is entirely unimplemented and the plan defers its vocabulary to the dependency story without naming the constant or module.","ABSENCE: No enum definition, no constant reference, no module pointer in this plan."],"finding":"The `creation_channel` enum vocabulary (cli, mcp, python, jira, import, unknown) is used throughout the plan's decision rules but is never defined in this plan, nor is a pointer given to the module/constant where it lives.","group_criteria":null,"group_id":null,"id":"fc7a03146bdca2a4f","impact":0.0,"is_primary":null,"location":"What section (4th bullet: '_project_legacy_creation_channel… no-op for concrete recorded channels or an already-inferred jira value'), AC1, AC2, AC3","norm_id":"nf2dddbd93c3fdb87","priority":0.0,"reason":"veto:absence-refuted","scenarios":["Implementor of `_project_legacy_creation_channel` cannot write the no-op guard without knowing the exact set of 'concrete recorded' channel strings.","Implementor of the compaction test (AC1) cannot write assertions for all valid channels without the canonical list."],"severity":"none","suggested_fix":"In the What section, add: 'The canonical creation_channel values are defined as CREATION_CHANNEL_VALUES = frozenset({\"cli\", \"mcp\", \"python\", \"jira\", \"import\", \"unknown\"}) in reducer/_version.py (alongside KNOWN_EVENT_TYPES). Concrete recorded means the value is in this set and is not \"unknown\".'","tier":"LLM","validity":0.4,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"yes","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify the three-signal Jira inference predicate inline in the What section (or point to the shared constants by name and module), e.g., 'ticket_id matches JIRA_KEY_PATTERN AND author == LEGACY_JIRA_AUTHOR AND env_id == LEGACY_JIRA_ENV_ID', so `_project_legacy_creation_channel` is implementable without consulting the dependency story.","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Plan says 'absent, None, or provisional unknown-without-marker state is re-evaluated from restored ticket_id/author/env_id' — three signals named but matching logic omitted.","AC3 says 'for the exact three-signal predicate' — 'exact' implies a precise rule, yet the rule is not stated.","A prior review cached finding (e622/.../90287e8) notes 'LEGACY_JIRA_AUTHOR and LEGACY_JIRA_ENV_ID are proposed as shared constants' but this plan does not reference them at all.","ABSENCE: No specification of what author/env_id values match, no pointer to the constants, no formula for the predicate."],"finding":"The 'three-signal predicate' for Jira inference — referenced in AC3 and the What section — is never specified: the exact values of author and env_id that trigger `creation_channel=jira` inference are unnamed and unlocated in this plan.","group_criteria":null,"group_id":null,"id":"f739c5181b84858f3","impact":0.0,"is_primary":null,"location":"What section (4th bullet: 're-evaluated from restored ticket_id/author/env_id'), AC3 ('projects inferred Jira only for the exact three-signal predicate')","norm_id":"n82a196adcbb48c36","priority":0.0,"reason":"veto:absence-refuted","scenarios":["Implementor of `_project_legacy_creation_channel` must guess or reverse-engineer the Jira inference logic from the dependency story.","AC3 test (`-k creation_channel`) cannot be written to assert 'the exact three-signal predicate' without knowing what it is."],"severity":"none","suggested_fix":"","tier":"LLM","validity":0.4,"verification":{"binary":{"absence_confirmed_in_context":"no","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"na","no_viable_alternative_explanation":"yes","path_reachable":"na","respects_artifact_altitude":"na","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"none","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"none"}}},{"block_threshold":0.7,"blocking_enabled":true,"checklist_item":"- [ ] Specify the error-handling contract for `_project_legacy_creation_channel` failures in the What section (e.g., 'on any exception, default to creation_channel=unknown and log a warning, consistent with the existing migration hooks' silent-no-op pattern').","cohort":["T8"],"criteria":["T8"],"decision":"dropped","drop_reason":null,"evidence":["Plan says 'call _project_legacy_creation_channel(state) … a no-op for concrete recorded channels' — normal path described, exception/failure path absent.","All three existing migration hooks in process_snapshot (managed_refs, attestations, keyring) are purely conditional no-ops that cannot raise; the new hook involves inference logic with external constants and could fail on malformed state.","ABSENCE: No statement on whether failure should propagate (hard abort), be swallowed (silent unknown), or emit a warning."],"finding":"`_project_legacy_creation_channel` has no specified fallback/error-handling behavior for exceptions during `process_snapshot` restoration.","group_criteria":null,"group_id":null,"id":"fe69a7ea107ec9b48","impact":0.33,"is_primary":null,"location":"What section (4th bullet), Files section (src/rebar/reducer/_processors.py)","norm_id":"nc6c15fcd90fc2161","priority":0.1237,"reason":"low-validity","scenarios":["A malformed legacy snapshot with a non-string creation_channel value causes an unexpected exception inside process_snapshot, breaking replay for that ticket.","Silent swallowing of exceptions could leave creation_channel absent, causing downstream consumers to treat the ticket as if it had no channel."],"severity":"minor","suggested_fix":"","tier":"LLM","validity":0.375,"verification":{"binary":{"absence_confirmed_in_context":"yes","cited_reference_accurate":"na","claims_absence":"yes","committed_work_relies_on_unbacked_claim":"na","evidence_entails_finding":"no","impact_follows_necessarily":"no","is_verifiable":"yes","no_existing_mitigation":"yes","no_viable_alternative_explanation":"no","path_reachable":"yes","respects_artifact_altitude":"no","severity_claim_justified":"no"},"severity_attributes":{"ac_unverifiable":"none","blast_radius":"local","debt_impact":"none","divergent_implementation":"none","dod_uncertifiable":"none","internal_conflict":"none","irreversible_without_rationale":"none","likelihood":"low","prod_impact":"low","reversibility":"easy","silent_vs_self_revealing":"","undecomposed":"none","vague_directive":"low"}}}],"impact_model_version":"plan-v3","material_fingerprint":"aad81079482042a7","metrics":{"claim_path":"no-llm/no-network (structural; the fast claim check is a local HMAC verify)","det_ms":221.9,"llm_calls":29,"llm_ms":622801.3,"total_ms":623154.4,"verify_requests":24},"model":"claude-sonnet-4-6","regver":"efe0f612161b342c","runner":"pydantic_ai","schema":"plan_review_result_v2","ticket_id":"568c-b44b-7e2b-4d87","ticket_type":"story","verdict":"PASS","verified_at_sha":"89e59453cdde62ec41b0de08905a2b9bb4cad45f"},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"REVIEW_RESULT","timestamp":1784279809536103001,"uuid":"db0da7d6-815d-4267-b1e4-ac86e1c13f23"}