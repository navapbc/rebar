1784400793654920001-bf29f75f-ec09-4460-a60b-88e87224a9b4"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"0ba6f34efb597b37ecd1f2bf2c916fa35fe5b5590e21972a4f103ec2a79561ef","event_uuid":"6c0dc03a-39d0-410b-b50b-31f11df6c52c","position":{"commit_sha":"afd4b8e2b3a853f2eb69d1ec34c3f9cc3eea3ee3","position":"1784400793892320001-6c0dc03a-39d0-410b-b50b-31f11df6c52c"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"b5633b5b0a6aa43995a5d9422c873ced6fb02bf58b023fb5e86e3895fa322c3a","event_uuid":"8ee5146a-13be-4893-b736-f34302ef5c4b","position":{"commit_sha":"9a1b04b4d10e3efc7acce19c739bbda178e7a902","position":"1784401802766167252-8ee5146a-13be-4893-b736-f34302ef5c4b"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-214_agent","claim_remote_session":null,"claimed_session":"e1dc6410-25d7-406a-b015-01c40c9fa16a","comments":[],"created_at":1784397383396212001,"creation_channel":"cli","deps":[],"description":"## Problem\n`src/rebar/config.py` is 869 LOC — over the 800-LOC module-size soft cap — and is grandfathered in `.github/module-size-allowlist.txt` + `.github/module-size-ceilings.txt` (pinned 869), with a remedy row in `docs/architecture.md`.\n\n## arch.md remedy row is STALE / already-shipped\nThe `docs/architecture.md` offenders row for `config.py` reads \"split the dataclass/schema from the env/CLI-override + cache machinery along the existing seam\". That seam ALREADY SHIPPED: the typed dataclass/schema layer now lives in the sibling `src/rebar/_config_schema.py` (config.py already imports `_SECTIONS`, `Config`, `ConfigError`, `_as_bool`, `coerce_sparse`, `merge_sparse` from it). So the recorded remedy no longer describes an available seam — it is superseded. This ticket DELETES that stale row rather than claiming it records the seam below.\n\n## New seam (on the CURRENT code): raw-input source layer\nExtract the raw-input resolution layer — filesystem config discovery + TOML file parsing (with the mtime-keyed parse cache) + `REBAR_*` env & legacy-alias override collection — into a NEW leaf `src/rebar/_config_sources.py`. This cluster is cohesive (it turns files+env into raw sparse mappings) and sits strictly BELOW the typed-merge/cache/precedence machinery that stays in config.py (`load_config`, `_ordered_layers`, `_resolve`, the resolved-Config cache, the public writers/readers).\n\nMOVE (by name): `repo_root`, `config_file`, `tracker_dir_override`, `_TOML_CACHE`, `_parse_toml`, `_read_toml_table`, `_pyproject_rebar_state`, `_discover_project_config`, `user_config_path`, `_CANONICAL_ENV_NAMES`, `_canonical_env_name`, `_LEGACY_ENV_ALIASES`, `_map_legacy_env`, `env_overrides`, `_strict_unknown_keys`.\n\nThe leaf imports ONLY stdlib + `rebar._config_schema` + `rebar._deprecations` (no import of `rebar.config`), so it is a true leaf with no back-edge.\n\n## Back-compat (public surface preserved)\nconfig.py RE-EXPORTS the full moved set (`from rebar._config_sources import X as X`), so `rebar.config.<name>` attribute access and `from rebar.config import <name>` keep resolving unchanged (~90 importers; externally-used include `repo_root`, `tracker_dir_override`, `_canonical_env_name`, `_LEGACY_ENV_ALIASES`, `user_config_path`, `_read_toml_table`, `_discover_project_config`, `env_overrides`). Two invariants preserved:\n- `_TOML_CACHE` shared-object identity: `reset_config_cache` stays in config.py and mutates the imported dict via `.clear()` (never rebinds) — test_config_perf.py depends on this.\n- Monkeypatch seam: retained callers (`_ordered_layers` etc.) call the BARE re-exported names (`_discover_project_config(...)`), so `monkeypatch.setattr(cfg, \"_discover_project_config\", ...)` still intercepts resolution.\n\n## Scope note\nThis is a pure/mechanical refactor: NO signature or logic changes. E5 testing-plan is not-applicable — the existing config test suite (test_config_perf, test_config_loader, test_config_surface_golden, test_config_backcompat, test_config_tracker_dir, test_config_show) is the behavioral oracle.\n\n## Acceptance Criteria\n- [ ] New leaf `src/rebar/_config_sources.py` exists with a line count in [100, 800]; verify: `n=$(wc -l < src/rebar/_config_sources.py); [ \"$n\" -ge 100 ] && [ \"$n\" -le 800 ]`\n- [ ] `src/rebar/config.py` is at most 800 lines; verify: `[ \"$(wc -l < src/rebar/config.py)\" -le 800 ]`\n- [ ] config.py removed from the allowlist; verify: `grep -qv \"src/rebar/config.py\" .github/module-size-allowlist.txt && ! grep -q \"src/rebar/config.py\" .github/module-size-allowlist.txt`\n- [ ] config.py removed from the ceilings file; verify: `! grep -q \"src/rebar/config.py\" .github/module-size-ceilings.txt`\n- [ ] The stale config.py remedy row is gone from docs/architecture.md; verify: `! grep -q \"config.py.*split the dataclass/schema\" docs/architecture.md`\n- [ ] Module-size contract test passes (allowlist == over-cap set == ceilings keys); verify: `python -m pytest tests/unit/test_module_size_contract.py -q`\n- [ ] Config test suite passes; verify: `python -m pytest tests/unit -k config -q`\n- [ ] Lint clean; verify: `make lint` reports \"All checks passed!\"","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_config_sources.py","reason":"NEW leaf: raw-input resolution layer (file discovery + TOML parse cache + REBAR_* env & legacy-alias overrides)"},{"path":"src/rebar/config.py","reason":"remove moved cluster; re-export moved names for back-compat; graduates under 800 LOC"},{"path":".github/module-size-allowlist.txt","reason":"remove config.py — no longer over cap"},{"path":".github/module-size-ceilings.txt","reason":"remove config.py ceiling row + stale config.py NOTE"},{"path":"docs/architecture.md","reason":"delete stale/already-shipped config.py offenders remedy row"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","716f-b917-9fc8-41f5"]],"parent_id":"716f-b917-9fc8-41f5","parent_status_uuid":"bf29f75f-ec09-4460-a60b-88e87224a9b4","preconditions_summary":{"status":"pre-manifest"},"priority":1,"reverts":[],"status":"in_progress","tags":["module-size"],"ticket_id":"02c7-1283-afb6-4b97","ticket_type":"story","title":"Split config.py: extract raw-input source layer into _config_sources.py","verify_commands":[]},"source_event_uuids":["10772789-1609-4bb1-9f26-a3102347c7f9","a6ced86a-b7d3-459b-b8b1-3906560e3e83","1a07da1b-678d-4f37-b664-9517a1748e60","05c6f76c-adff-45ae-aefc-bf3162124f49","3a10a044-932b-47d4-a789-9b034e6f25c7","2591ad74-6b95-40e0-a32e-b80d22b5a129","bebf2cd9-000a-4018-a2c9-b64e332c8178","bf29f75f-ec09-4460-a60b-88e87224a9b4","6c0dc03a-39d0-410b-b50b-31f11df6c52c","8ee5146a-13be-4893-b736-f34302ef5c4b"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784401802766167253,"uuid":"98f2c5cc-50d3-4205-84c9-3c261f8fc0d1"}