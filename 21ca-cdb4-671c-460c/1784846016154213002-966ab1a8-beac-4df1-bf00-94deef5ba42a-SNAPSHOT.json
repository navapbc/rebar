{"author":"RebarBotNava","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","data":{"compacted_at":1784846016154213002,"compiled_state":{"alias":"inborn-atrophic-frog","assignee":"","attestations":{"plan-review":{"algorithm":"sshsig","author":"RebarBotNava","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-9dcf-5ad6-4e6d","envelope":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.opcert.v1+json\", \"signatures\": [{\"keyid\": \"ade0f2ef-51cc-45a2-bb97-c09846cd3df5\", \"sig\": \"\"}]}","head_sha":"2359176ae64a78aa44080666bff0b520b02c8f4f","key_id":null,"kind":"plan-review","manifest":["plan-review: PASS","ticket: 21ca-cdb4-671c-460c","material: 40852905bfd019d6","model: claude-sonnet-4-6","runner: pydantic_ai","blocking: 0","advisory: 6","review-phase: planning","rebar-version: 0.10.0 (2359176ae)","regver: b058e30f0de6a907","refreshed-from: ade0f2ef-51cc-45a2-bb97-c09846cd3df5 probe=PASS","dep e4c39fb58adf2766b4f13840edddfa0a032c19f66e0bd614f63574c4e9829129 src/rebar/_engine/rebar_reconciler/_backend.py","dep 0e4d0b6ca3a65eafb98b9d7493d64bc453714d1f0f72343d17a0726457496e36 src/rebar/_engine/rebar_reconciler/adapters/jira/backend.py","dep 6c3040105b66794cea42f1ecdd918b78eee69296985d02fbc6ffcd57800a1002 src/rebar/_engine/rebar_reconciler/inbound_fields.py","dep c1277434954c14f917cbe204938383bc4ae1ea7f51640260f3ef2d9340d80d5b src/rebar/_engine/rebar_reconciler/inbound_translate.py","dep 9a6873ce29a757c26d1d1cff481f1907e852cfe31594e23e872c9cd29da21bf6 src/rebar/_engine/rebar_reconciler/outbound_comments.py","dep 9e48de23307aeae9095d4de7664894b62d6d24e80b321f1965d9672b56318807 tests/unit/rebar_reconciler/test_backend_neutrality.py"],"material_fingerprint":"40852905bfd019d6","merged_log_commit":"2359176ae64a78aa44080666bff0b520b02c8f4f","principal":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","signature":null,"signed_at":1784844856997668000}},"author":"Joe Oakhart","author_email":"joeoakhart+bot@navapbc.com","author_id":"594c-