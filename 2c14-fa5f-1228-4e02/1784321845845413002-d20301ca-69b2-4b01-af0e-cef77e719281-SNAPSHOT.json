e-86e0-1302caeef5f4","position":{"commit_sha":"4589275c9779636be09275013d15a5e37543a089","position":"1784321305124666001-d67ad3fb-d539-4c3e-86e0-1302caeef5f4"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"62ec60c5fd8b25151843716822f56e2a83d3553b2aee582db4bbbb1cea9138f0","event_uuid":"7dae3d23-09f0-4df7-a4c9-6a4ec07a0a6f","position":{"commit_sha":"1bb38d2338a7380ba789d699e229811ddd1013ab","position":"1784321337767796001-7dae3d23-09f0-4df7-a4c9-6a4ec07a0a6f"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"624b0409a95dfd14d898dd911a47ba80133d03500dfca09cbf7e76775d88ab58","event_uuid":"f5ed5ec6-da58-4aed-aa3a-52c3b2fcc6ef","position":{"commit_sha":"32fb5b4ddf3438ed110b6fa0146768b2f9cb2610","position":"1784321845845413001-f5ed5ec6-da58-4aed-aa3a-52c3b2fcc6ef"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":null,"claim_remote_session":null,"claimed_session":null,"comments":[],"created_at":1784317556157853001,"creation_channel":"unknown","deps":[],"description":"## Why\n\nCriterion authors configuring project-specific code-review rules currently see a valid overlay\nmerge but no criterion execution or eval path, a silent failure that is indistinguishable from a\nrubric that found no issues.\n\nADR 0017 and `.rebar/criteria_routing.json` advertise one project-criteria extension surface across\nplan review and code review, but the current code-review runtime only executes the static workflow\nlist and consults packaged decision/eval lookups. A project can therefore configure a net-new\nLLM-backed code-review criterion that merges successfully yet never runs end to end.\n\n## What\n\nComplete the generic, project-id-agnostic code-review runtime seam. The child bug\n`8a4b-e8b6-1bf9-48d8` owns the reproduced defect and implementation details. This story owns the\ndelivered capability and compatibility contract: activated project criteria run exactly once,\ntheir repository prompt and eval assets resolve through the CLI, and deterministic Pass 3 uses\nrepository-effective routing.\n\n## Scope\n\n- Reuse plan review's runner-side dynamic fan-in pattern without adding a workflow DSL field or a\n  hard-coded project criterion id. `CodeReviewBatchRunner` uses a named\n  `PROJECT_FAN_IN_STEP_ID = \"round_a\"` constant as a stateless discriminator: activated project\n  prompts are appended only for that step, deduplicated against included static physical ids, and\n  never appended for `round_b`. No instance flag survives between reviews. A test submits both\n  requests to one reusable runner and proves one project-prompt execution per review across the\n  complete topology. This runner seam is chosen because it is the existing plan-review pattern and\n  preserves the versioned workflow schema unchanged.\n- Map a logical `project.<name>` criterion to physical prompt id\n  `code-review-project-<name-with-dots-replaced-by-dashes>`; for this epic the physical prompt/eval\n  basename is `code-review-project-review-phase-boundaries`. Routing JSON continues to use the\n  logical id as its key; translation occurs only when prompt/eval assets are dispatched.\n- Extend `criteria.ids.criterion_prompt_id(criterion_id, *, gate_key=\"plan_review\")` with\n  `CODE_REVIEW_PROMPT_PREFIX = \"code-review-\"`; the default preserves plan-review callers, while\n  `gate_key=\"code_review\"` produces the physical project id. Extend calibration as\n  `calibrate_criterion(criterion_id, *, repo_root=None, runs=1, gate_key=\"plan_review\")`; the CLI\n  passes its resolved gate key, and calibration passes it to the same mapper. Existing\n  criterion-preview/editor callers remain\n  plan-review-only and retain the default; code-review project assets are manually authored through\n  the documented `.rebar/` overlay surface in this epic.\n- Resolve project prompt/eval assets from the reviewed repository snapshot. An activated missing or\n  malformed asset is a fatal configuration failure: raise a located `LLMError` before model\n  execution rather than emitting an empty-findings coverage gap or silently skipping the criterion.\n- Extend `criteria eval` preflight to accept a logical id only when it is active in code review's\n  repository-effective criteria. Compute plan-review and code-review membership: zero matches keeps\n  the existing unknown-id error, one match selects that gate for `calibrate_criterion`, and two\n  matches fail with an explicit ambiguous-gate error rather than silently choosing a prompt.\n- Extend `_code_review_prompt_id(prompt_id, repo_root)` to recognize the sanitized physical id only\n  when its logical inverse is active, then reuse the existing `_run_code_review_case` arm. Eval\n  cases use the `diff` key and return the prompt's native `{findings: [...]}` output; they never run\n  through the plan-review `_run_criterion_case` / `pass1_chunk` path and require no new solver arm.\n- For every project prompt, retain the local physical-to-logical map built during fan-in. On each\n  emitted project finding, overwrite `criteria` with `[logical_id]` and set `reviewer_id` to the\n  physical prompt id. Pass 3 therefore consumes only logical routing keys regardless of model\n  output; built-in finding attribution remains unchanged.\n- Preserve the existing behavior and result shape for repositories without a code-review project\n  overlay.\n- In `code_review_decide`, compute `routing = registry.effective_routing(ctx.repo_root)` once. Bind\n  the kernel's threshold callback to `registry.threshold_for(criterion, routing)`—which returns\n  both `block_threshold` and `blocking_enabled`—and call\n  `registry.nit_suppressed_criteria(routing)` so both deterministic decision inputs use the same\n  repository-effective map; no YAML input or LLM step is added.\n- Update `docs/llm-framework.md` to describe code-review project-criterion runtime resolution,\n  configuration failures, and the eval entry point, completing rather than replacing ADR 0017.\n\nOut of scope: authoring `project.review-phase-boundaries`, changing four-pass decision math,\nmodifying packaged built-in criteria, or deploying a Gerrit criterion.\n\n## Sequencing and Rollback\n\nThe child bug is implemented and closed before this story closes. Downstream criterion authoring\ndepends on this story. Revert the fan-in, routing lookup, eval resolution, tests, and documentation\ntogether if overlay-absent compatibility regresses; the additive seam has no data migration.\n\n## Acceptance Criteria\n\n- [ ] Child bug `8a4b-e8b6-1bf9-48d8` is closed and its change is landed on `main`; verify with\n  `.venv/bin/rebar show 8a4b-e8b6-1bf9-48d8` and\n  `git log origin/main --oneline --grep='rebar-ticket: 8a4b-e8b6-1bf9-48d8'`.\n- [ ] A synthetic activated code-review `project.*` criterion runs exactly once in Pass 1, retains\n  its logical id in every finding's `criteria`, and resolves validator-safe repository prompt/eval\n  ids. The same reusable runner receives `round_a` and `round_b` requests for two review runs and\n  records one project execution per review; verify with\n  `.venv/bin/pytest -q tests/unit/test_code_review_project_criteria.py -k 'fan_in or eval'`.\n- [ ] Pass 3 applies repository-effective threshold, blocking posture, and nit-suppression routing\n  for the synthetic id without invoking an LLM; verify with\n  `.venv/bin/pytest -q tests/unit/test_code_review_project_criteria.py -k routing`.\n- [ ] Activated missing/malformed project assets raise a located `LLMError` before model execution,\n  while an overlay-absent repository retains its pre-change result; verify with\n  `.venv/bin/pytest -q tests/unit/test_code_review_project_criteria.py -k 'missing or parity'`.\n- [ ] `rebar criteria eval` accepts an activated logical code-review project id, maps it to the\n  sanitized physical prompt id, dispatches `diff` cases through `_run_code_review_case`, and rejects\n  unknown/inactive/dual-gate ambiguous ids; verify with\n  `.venv/bin/pytest -q tests/unit/test_code_review_project_criteria.py -k cli`.\n- [ ] `docs/llm-framework.md` contains a `Code-review project criteria` section covering Round-A\n  fan-in, logical/physical ids, fatal configuration errors, deterministic Pass-3 routing, and the\n  `criteria eval` entry point; verify with\n  `.venv/bin/python -c 'from pathlib import Path; s=Path(\"docs/llm-framework.md\").read_text(); assert\n  all(x in s for x in (\"Code-review project criteria\", \"round_a\", \"criteria eval\",\n  \"configuration error\", \"effective routing\"))'`.\n- [ ] Shared-overlay and four-pass regression suites pass; verify with\n  `.venv/bin/pytest -q tests/unit/test_unified_criteria.py tests/unit/test_code_review_evals.py\n  tests/unit/workflow/test_code_review_workflow.py && make lint`.","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/llm/criteria/ids.py","reason":"Gate-keyed project criterion id mapping"},{"path":"src/rebar/llm/code_review/batch_runner.py","reason":"Exactly-once Round-A project-criterion fan-in"},{"path":"src/rebar/llm/code_review/workflow_ops.py","reason":"Repository-effective deterministic Pass-3 routing"},{"path":"src/rebar/llm/evals/eval_solver.py","reason":"Project criterion eval solver dispatch"},{"path":"src/rebar/llm/evals/eval.py","reason":"Gate-aware criterion calibration mapping"},{"path":"src/rebar/_cli/_llm_eval_commands.py","reason":"Resolve plan-review versus code-review membership"},{"path":"tests/unit/test_code_review_project_criteria.py","reason":"End-to-end seam and compatibility coverage"},{"path":"docs/llm-framework.md","reason":"Document runtime resolution and errors"}],"keyring":[],"managed_refs":[["parent","jira-reb-1001"]],"parent_id":"jira-reb-1001","parent_status_uuid":"","preconditions_summary":{"status":"pre-manifest"},"priority":1,"reverts":[],"status":"open","tags":["review-architecture","project-criteria","integration"],"ticket_id":"2c14-fa5f-1228-4e02","ticket_type":"story","title":"Complete the generic code-review project-criterion runtime seam","verify_commands":[{"command":"rtk .venv/bin/pytest -q tests/unit/test_code_review_project_criteria.py -k \"fan_in or eval\"","dd_id":"DD-SEAM-1","dd_text":"Reusable runner executes each project prompt once per review and stamps logical criterion ids"},{"command":"rtk .venv/bin/pytest -q tests/unit/test_code_review_project_criteria.py -k routing","dd_id":"DD-SEAM-2","dd_text":"Repository-effective Pass-3 threshold, blocking posture, and nit suppression pass"},{"command":"rtk .venv/bin/pytest -q tests/unit/test_code_review_project_criteria.py -k \"missing or parity\"","dd_id":"DD-SEAM-3","dd_text":"Fatal missing-asset errors and overlay-absent parity pass"},{"command":"rtk .venv/bin/pytest -q tests/unit/test_unified_criteria.py tests/unit/test_code_review_evals.py tests/unit/workflow/test_code_review_workflow.py","dd_id":"DD-SEAM-4","dd_text":"Shared overlay and four-pass regressions remain green"},{"command":"rtk .venv/bin/pytest -q tests/unit/test_code_review_project_criteria.py -k cli","dd_id":"DD-SEAM-5","dd_text":"Criteria-eval CLI selects one gate and rejects unknown, inactive, or ambiguous ids"},{"command":"rtk .venv/bin/python -c \"from pathlib import Path; s=Path(\\\"docs/llm-framework.md\\\").read_text(); assert all(x in s for x in (\\\"Code-review project criteria\\\", \\\"round_a\\\", \\\"criteria eval\\\", \\\"configuration error\\\", \\\"effective routing\\\"))\"","dd_id":"DD-SEAM-6","dd_text":"Runtime documentation covers the stable project-criterion contract"}]},"source_event_uuids":["58403b9d-63aa-41fe-a3c5-2d7b67e898c4","130aa610-e962-4ee2-9b0b-a44a65644da5","d3e26bca-5c17-46d7-83b0-4d81040187a7","9f930534-b960-4d7c-bcf7-29ba49b0836d","21242b0e-86aa-4c7f-9afb-a8dfd483daae","8c6eaf6a-ac1a-4ed9-8337-dfc0b8b64dca","357067a4-26c6-4c0e-9a28-e49ca19d3599","e8d75def-6ed2-4b82-b38a-00bc2b628214","1a7429ef-d803-4ab3-8828-5fdfff9983b8","90944124-7326-40e9-a108-9b289b327d86","d67ad3fb-d539-4c3e-86e0-1302caeef5f4","7dae3d23-09f0-4df7-a4c9-6a4ec07a0a6f","f5ed5ec6-da58-4aed-aa3a-52c3b2fcc6ef"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784321845845413002,"uuid":"d20301ca-69b2-4b01-af0e-cef77e719281"}