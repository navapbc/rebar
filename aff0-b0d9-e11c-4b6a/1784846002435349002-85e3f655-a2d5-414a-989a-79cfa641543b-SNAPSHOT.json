{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"4291a9dbc3b2e74ac78c0f7b603bf23d5d03bd8abc5c6d9f5e1deefe3981beb1","event_uuid":"5d9303f6-cd90-43d9-bf3d-1094ff69adc4","position":{"commit_sha":"4110975ca37d9d6bb8f067d525871b591ee6d9bf","position":"1784829247879368001-5d9303f6-cd90-43d9-bf3d-1094ff69adc4"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"e1c7ccf600e5232592bae538d5bb9519fab9952d641f61bd465dcddfde57fade","event_uuid":"aee9ab92-d1b9-4ef8-a011-d288d1c864c0","position":{"commit_sha":"7448e7b8193c15b97a421bdf9b0786707a7f6b44","position":"1784829506024474843-aee9ab92-d1b9-4ef8-a011-d288d1c864c0"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"bb38942ae30f31f953c0dd907453cd47a62c293e0095f8152cb1f776fea08f52","event_uuid":"ab7d656e-a69b-46e9-a844-f69b600a0031","position":{"commit_sha":"e785dda2e76fba42a9dbb4b6c0f13e4b71ee9f3d","position":"1784843853355864001-ab7d656e-a69b-46e9-a844-f69b600a0031"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"},{"content_hash":"bd70fffb54cf5480f88bf0267f18cc40c1987814e767fb5acc85f24af8c0c4b5","event_uuid":"27411a01-5f96-455f-8b72-1c830f8024c1","position":{"commit_sha":"dbd854ce8f3bc0f7b855f9e2547eeaa79851dd41","position":"1784846002435349001-27411a01-5f96-455f-8b72-1c830f8024c1"},"signature":"{\"payload\": \"\", \"payloadType\": \"application/vnd.rebar.authorship.v1+json\", \"signatures\": [{\"keyid\": \"594c-9dcf-5ad6-4e6d\", \"sig\": \"\"}]}","signer_pubkey":"ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHe3p+OG3L79IIh99qRBEkAEXaU+VbeQcSfhIu4M2F8b rebar-bot joeoakhart+bot@navapbc.com"}],"bridge_alerts":[],"claim_harness":"claude-code_2-1-218_agent","claim_remote_session":null,"claimed_session":"cbe2d483-8609-4f4e-ba56-db538f86808d","comments":[],"created_at":1784820310147234001,"creation_channel":"cli","deps":[],"description":"## Context / Problem\n\n`inbound_probe.py` is wholly Jira-specific code living in the backend-neutral core: it builds\nthe Jira REST URL shape (`/rest/api/2/issue/{key}?fields=status,resolution`), sends a\nbasic-auth GET, resolves `JIRA_URL`/`JIRA_USER`/`JIRA_API_TOKEN` via\n`adapters.jira.acli_subprocess.resolve_jira_settings()` (`inbound_probe.py:65-77`), and\nclassifies by Jira status names (`RESOLVED_STATUS_NAMES = {\"Resolved\",\"Done\",\"Cancelled\"}`).\nIt is called from `run_differs.py:369`, and its result vocabulary is consumed *neutrally* by\n`reconcile_helpers.route_inbound_probe` (`reconcile_helpers.py:291-355`). A second backend\nwould need an entirely different probe, but there is no seam. Epic bbf1 AC3 requires zero\n`adapters.jira` imports in core.\n\n## Approach\n\nSplit vocabulary from vendor mechanics:\n\n- The neutral vocabulary — `ProbeBranch` (4 branches), `ProbeResult`, `ProbeConfigError` —\n  stays in root `inbound_probe.py`. The file must remain at the package root: it is\n  location-pinned (ADR 0035 context list) and loaded by filename at\n  `reconcile_helpers.py:317` (`_load(\"inbound_probe\", \"inbound_probe.py\")`).\n- The Jira mechanics (URL construction, basic-auth GET, GET-only invariant, status-name\n  classification, JIRA_* env resolution) move to a new `adapters/jira/probe.py`.\n- A new `@runtime_checkable` capability Protocol `SupportsAbsenceProbe` in `_backend.py` with\n  `probe_remote(remote_id: str) -> Any` (return documented as `inbound_probe.ProbeResult`;\n  `_backend.py` stays a pure stdlib+typing interface module, consistent with its existing\n  loosely-typed `dict[str, Any]` style, so it does not import the vocabulary module).\n  `JiraBackend` implements it by delegating to `adapters/jira/probe.py`.\n- `run_differs.py:369` routes through the backend: `isinstance(backend, SupportsAbsenceProbe)`\n  guarded, matching the existing capability pattern (`SupportsLinks`/`SupportsComments`/\n  `SupportsIncremental` in `_backend.py`). Wiring: today the backend is loaded at\n  `run_differs.py:234` — AFTER the probe dispatch call at `:230` — so the\n  `_load_reconcile_backend()` call (`run_differs.py:62-75`, a pure registry/config load with\n  no remote side effects) is hoisted above the probe dispatch, and the backend object is\n  passed into `_run_differs_inbound_probe_dispatch` as a new `backend` parameter, replacing\n  that function's direct `probe_mod.probe(...)` call at `:369`. The later load site reuses\n  the already-loaded instance. A backend without the capability yields\n  `ProbeResult(UNREACHABLE)` — the conservative \"do not classify, leave for retry\" branch\n  that `route_inbound_probe` already handles (`reconcile_helpers.py:351`).\n- Extend the AST neutrality gate to assert zero `adapters.jira` imports in\n  `inbound_probe.py`.\n\nRejected alternative: injecting url/user/token through scalar port accessors and keeping the\nGET + classification in core — that leaves the vendor REST URL shape and Jira status-name\nclassification in neutral code, so a second backend still could not drop in; the port must\nown the whole probe as a capability.\n\n## Scope\n\n- src/rebar/_engine/rebar_reconciler/_backend.py (SupportsAbsenceProbe capability)\n- src/rebar/_engine/rebar_reconciler/inbound_probe.py (reduced to neutral vocabulary)\n- src/rebar/_engine/rebar_reconciler/adapters/jira/probe.py (new: Jira GET + classification)\n- src/rebar/_engine/rebar_reconciler/adapters/jira/backend.py (implement probe_remote)\n- src/rebar/_engine/rebar_reconciler/run_differs.py (capability-guarded routing at the probe call site)\n- tests/unit/rebar_reconciler/fetch/test_inbound_probe.py, test_inbound_probe_dispatch.py (classification tests migrate to the adapter home)\n- tests/unit/rebar_reconciler/fetch/test_probe_capability_routing.py (new: the capability-routing tests — backend-with-capability runtime proof, capability-lacking UNREACHABLE degradation)\n- tests/unit/rebar_reconciler/test_backend_neutrality.py (AST gate extended to inbound_probe.py)\n\n## Testing\n\n- Happy path: 200 + resolved status → PRESENT_RESOLVED; 200 + other status →\n  PRESENT_FILTERED (now exercised against `adapters/jira/probe.py`).\n- Failure/edge: 404/410/403 → ARCHIVED_OR_MOVED; 5xx/401/timeout/URLError → UNREACHABLE;\n  missing JIRA_* env → ProbeConfigError naming the missing vars; GET-only invariant asserted\n  in the adapter.\n- Capability routing (new file\n  `tests/unit/rebar_reconciler/fetch/test_probe_capability_routing.py`): with a FakeBackend\n  implementing SupportsAbsenceProbe, run_differs uses the backend's probe (runtime proof);\n  with a FakeBackend lacking it, the mutation is classified UNREACHABLE and left for retry.\n\n## Acceptance Criteria\n\n- [ ] `inbound_probe.py` contains NO `adapters.jira` import and no vendor REST code (URL\n      shape, auth, status-name classification all live under `adapters/jira/probe.py`) —\n      verified by the extended AST case in\n      `tests/unit/rebar_reconciler/test_backend_neutrality.py` plus code review.\n- [ ] `run_differs` reaches the probe only through `SupportsAbsenceProbe`; a\n      capability-lacking backend degrades to UNREACHABLE — verified by the routing tests in\n      Testing.\n- [ ] Probe classification behavior is byte-identical for Jira (all branches) — verified by\n      the migrated probe tests.\n- [ ] `make lint && make typecheck && make test` green; whole test tree collects with 0 errors.\n\n## Landed\n\nImplemented and merged to `main` as Gerrit change 927 (LLM-Review +1, Verified +1).","env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","file_impact":[{"path":"src/rebar/_engine/rebar_reconciler/_backend.py","reason":"SupportsAbsenceProbe capability"},{"path":"src/rebar/_engine/rebar_reconciler/inbound_probe.py","reason":"reduced to neutral vocabulary"},{"path":"src/rebar/_engine/rebar_reconciler/adapters/jira/probe.py","reason":"new: Jira GET + classification"},{"path":"src/rebar/_engine/rebar_reconciler/adapters/jira/backend.py","reason":"implement probe_remote"},{"path":"src/rebar/_engine/rebar_reconciler/run_differs.py","reason":"capability-guarded probe routing"},{"path":"tests/unit/rebar_reconciler/fetch/test_inbound_probe.py","reason":"migrate probe tests to the adapter home"},{"path":"tests/unit/rebar_reconciler/test_backend_neutrality.py","reason":"AST gate extended to inbound_probe.py"}],"keyring":[],"last_status_env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","managed_refs":[["parent","bbf1-82e1-cf9d-494a"]],"parent_id":"bbf1-82e1-cf9d-494a","parent_status_uuid":"a088b30a-3ce2-4585-95fa-9cd8268914f0","plan_review_phase":"execution","preconditions_summary":{"status":"pre-manifest"},"priority":2,"reverts":[],"status":"in_progress","tags":[],"ticket_id":"aff0-b0d9-e11c-4b6a","ticket_type":"story","title":"Vendor absence probe behind a SupportsAbsenceProbe capability (relocate Jira REST probe into adapters/jira/)","verify_commands":[]},"source_event_uuids":["5bc41cc9-5a3b-41be-940b-cbc97b339e2a","e6306d33-8b80-4ae9-b672-f1be85aa3519","84823791-b66d-43ef-ba0a-ebb7f9919a43","1a5ccb01-aae7-4871-9aa2-bfc60cc0465a","a41459fb-0652-4657-b5ec-7329825afc70","62a7e28c-179e-49a2-bd3f-edbce4663dff","a088b30a-3ce2-4585-95fa-9cd8268914f0","5d9303f6-cd90-43d9-bf3d-1094ff69adc4","aee9ab92-d1b9-4ef8-a011-d288d1c864c0","ab7d656e-a69b-46e9-a844-f69b600a0031","27411a01-5f96-455f-8b72-1c830f8024c1"]},"env_id":"ade0f2ef-51cc-45a2-bb97-c09846cd3df5","event_type":"SNAPSHOT","timestamp":1784846002435349002,"uuid":"85e3f655-a2d5-414a-989a-79cfa641543b"}